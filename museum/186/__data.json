{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"museum":1,"inscriptions":18},{"slug":2,"type":3,"name":4,"uri":5,"description":6,"location":7,"idno":15},"186","site","Necropoli di Abakainon","http://sicily.classics.ox.ac.uk/museum/186","Partially uncovered Hellenistic necropolis",{"settlement":8,"region":9,"country":10,"address":11,"geo":12},"Tripi","Messina","","contrada Carusa",{"lat":13,"lon":14},38.06519,15.11438,{"type":16,"url":17},"Pleiades","https://pleiades.stoa.org/places/462062",[19,112,149,188,223,259,296],{"file":20,"uri":20,"title":21,"status":22,"editionAuthor":24,"type":25,"objectType":29,"material":33,"condition":10,"layoutDesc":37,"handNote":44,"date":58,"places":64,"geo":74,"country":78,"region":79,"settlement":8,"repository":80,"idno":81,"textLang":83,"facsimile":87,"provenance":66,"letterHeights":94,"publications":95,"zotero":98,"keywords":101,"html":111},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":23},"edited",null,{"_":26,"ana":27,"ref":28},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":30,"ana":31,"ref":32},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":34,"ana":35,"ref":36},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":38},{"p":39,"rs":40,"damage":10},"Single line of greek letters approximately centred on the face of the plinth",{"_":41,"ana":42,"ref":43},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":45,"dimensions":46},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[47,53],{"type":48,"l":49,"from":50,"to":50,"h":51,"unit":52},"letterHeight","Line 1","line1","30","mm",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":59,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,"archaeological-context","low",[65,70],{"_":66,"type":67,"ref":68,"corresp":69},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062","#findspot",{"_":8,"type":71,"ref":72,"offset":73},"modern","http://sws.geonames.org/2522853","near",[75],[76,77],38.05191,15.10158,"Italy","Sicily",{"_":4,"role":3,"ref":5},{"type":82},"inventory",{"_":84,"mainLang":85,"languages":86},"Ancient Greek","grc",[84],{"n":88,"url":89,"height":90,"width":91,"desc":92,"surfaceType":93},"screen","ISic004415_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[96,97],"Bacci and Coppolino, 2009, La Necropoli di Abakainon: primi dati","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[99,100],"DX8AWC9Q","JQQKI6JP",[102,103,104,26,30,34,105,106,107,108,106,109,110,85],"isic004415","epitaph for krimma, child of aunakos",{"_":23},"abacaenum","tripi","italy","sicily","necropoli di abakainon","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":113,"uri":113,"title":114,"status":115,"editionAuthor":24,"type":116,"objectType":117,"material":118,"condition":10,"layoutDesc":119,"handNote":123,"date":129,"places":130,"geo":133,"country":78,"region":79,"settlement":8,"repository":135,"idno":136,"textLang":137,"facsimile":139,"provenance":66,"letterHeights":141,"publications":142,"zotero":143,"keywords":144,"html":148},"ISic004416","Epitaph for Philon, son Aunakos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":120},{"p":121,"rs":122,"damage":10},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":41,"ana":42,"ref":43},{"lettering":124,"dimensions":125},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[126,128],{"type":48,"l":49,"from":50,"to":50,"h":127,"unit":52},"59",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":59,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},[131,132],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[134],[76,77],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":138},[84],{"n":88,"url":140,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004416_tiled.tif",[],[96,97],[99,100],[145,146,147,26,30,34,105,106,107,108,106,109,110,85],"isic004416","epitaph for philon, son aunakos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":150,"uri":150,"title":151,"status":152,"editionAuthor":24,"type":153,"objectType":154,"material":155,"condition":10,"layoutDesc":156,"handNote":160,"date":166,"places":167,"geo":170,"country":78,"region":79,"settlement":8,"repository":172,"idno":173,"textLang":174,"facsimile":176,"provenance":66,"letterHeights":178,"publications":179,"zotero":181,"keywords":183,"html":187},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":157},{"p":158,"rs":159,"damage":10},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":41,"ana":42,"ref":43},{"lettering":161,"dimensions":162},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[163,165],{"type":48,"l":164,"from":50,"to":56,"h":51,"unit":52},"Line 1-2",{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":59,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},[168,169],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[171],[76,77],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":175},[84],{"n":88,"url":177,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004417_tiled.tif",[],[96,180,97],"Sofia, 2015, Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi",[99,182,100],"9QTE4E3Z",[184,185,186,26,30,34,105,106,107,108,106,109,110,85],"isic004417","epitaph for [-?-], child of gerontios",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":189,"uri":189,"title":151,"status":190,"editionAuthor":24,"type":191,"objectType":192,"material":193,"condition":10,"layoutDesc":194,"handNote":198,"date":203,"places":205,"geo":208,"country":78,"region":79,"settlement":8,"repository":210,"idno":211,"textLang":212,"facsimile":214,"provenance":66,"letterHeights":216,"publications":217,"zotero":218,"keywords":219,"html":222},"ISic004418",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":195},{"p":196,"rs":197,"damage":10},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":41,"ana":42,"ref":43},{"lettering":199,"dimensions":200},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[201,202],{"type":48,"l":164,"from":50,"to":56,"h":127,"unit":52},{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":204,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[206,207],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[209],[76,77],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":213},[84],{"n":88,"url":215,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004418_tiled.tif",[],[96,180,97],[99,182,100],[220,185,221,26,30,34,105,106,107,108,106,109,110,85],"isic004418",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":224,"uri":224,"title":225,"status":226,"editionAuthor":24,"type":227,"objectType":228,"material":229,"condition":10,"layoutDesc":230,"handNote":234,"date":239,"places":240,"geo":243,"country":78,"region":79,"settlement":8,"repository":245,"idno":246,"textLang":247,"facsimile":249,"provenance":66,"letterHeights":251,"publications":252,"zotero":253,"keywords":254,"html":258},"ISic004419","Epitaph for Aristarchos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":231},{"p":232,"rs":233,"damage":10},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":41,"ana":42,"ref":43},{"lettering":235,"dimensions":236},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[237,238],{"type":48,"l":49,"from":50,"to":50,"h":51,"unit":52},{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":204,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},[241,242],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[244],[76,77],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":248},[84],{"n":88,"url":250,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004419_tiled.tif",[],[97],[100],[255,256,257,26,30,34,105,106,107,108,106,109,110,85],"isic004419","epitaph for aristarchos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":260,"uri":260,"title":261,"status":262,"editionAuthor":24,"type":263,"objectType":264,"material":265,"condition":10,"layoutDesc":266,"handNote":270,"date":276,"places":277,"geo":280,"country":78,"region":79,"settlement":8,"repository":282,"idno":283,"textLang":284,"facsimile":286,"provenance":66,"letterHeights":288,"publications":289,"zotero":290,"keywords":291,"html":295},"ISic004420","Epitaph for Aristokrates",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":267},{"p":268,"rs":269,"damage":10},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":41,"ana":42,"ref":43},{"lettering":271,"dimensions":272},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[273,275],{"type":48,"l":164,"from":50,"to":56,"h":274,"unit":52},"49",{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":204,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},[278,279],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[281],[76,77],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":285},[84],{"n":88,"url":287,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004420_tiled.tif",[],[97],[100],[292,293,294,26,30,34,105,106,107,108,106,109,110,85],"isic004420","epitaph for aristokrates",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":297,"uri":297,"title":298,"status":299,"editionAuthor":24,"type":300,"objectType":301,"material":302,"condition":10,"layoutDesc":303,"handNote":307,"date":313,"places":315,"geo":318,"country":78,"region":79,"settlement":8,"repository":320,"idno":321,"textLang":322,"facsimile":324,"provenance":66,"letterHeights":326,"publications":327,"zotero":328,"keywords":329,"html":333},"ISic004421","Epitaph for Athanippos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":304},{"p":305,"rs":306,"damage":10},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":41,"ana":42,"ref":43},{"lettering":308,"dimensions":309},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[310,312],{"type":48,"l":49,"from":50,"to":50,"h":311,"unit":52},"29",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":314,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[316,317],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[319],[76,77],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":323},[84],{"n":88,"url":325,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004421_tiled.tif",[],[97],[100],[330,331,332,26,30,34,105,106,107,108,106,109,110,85],"isic004421","epitaph for athanippos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>"],"uses":{"params":["slug"]}}]}
