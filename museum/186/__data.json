{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"museum":1,"inscriptions":16},{"slug":2,"type":3,"name":4,"uri":5,"description":6,"location":7,"pleiades":15},"186","site","Necropoli di Abakainon","http://sicily.classics.ox.ac.uk/museum/186","Partially uncovered Hellenistic necropolis",{"settlement":8,"region":9,"country":10,"address":11,"geo":12},"Tripi","Messina","","contrada Carusa",{"lat":13,"lon":14},38.06519,15.11438,"https://pleiades.stoa.org/places/462062",[17,110,146,184,218,253,289],{"file":18,"uri":18,"title":19,"status":20,"editionAuthor":22,"type":23,"objectType":27,"material":31,"condition":10,"layoutDesc":35,"handNote":42,"date":56,"places":62,"geo":72,"country":76,"region":77,"settlement":8,"repository":78,"idno":79,"textLang":81,"facsimile":85,"provenance":64,"letterHeights":92,"publications":93,"zotero":96,"keywords":99,"html":109},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":21},"edited",null,{"_":24,"ana":25,"ref":26},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":28,"ana":29,"ref":30},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":32,"ana":33,"ref":34},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":36},{"p":37,"rs":38,"damage":10},"Single line of greek letters approximately centred on the face of the plinth",{"_":39,"ana":40,"ref":41},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":43,"dimensions":44},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[45,51],{"type":46,"l":47,"from":48,"to":48,"h":49,"unit":50},"letterHeight","Line 1","line1","30","mm",{"type":52,"l":53,"from":48,"to":54,"h":55,"unit":50},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":57,"notBefore":58,"notAfter":59,"evidence":60,"precision":61},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,"archaeological-context","low",[63,68],{"_":64,"type":65,"ref":66,"corresp":67},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062","#findspot",{"_":8,"type":69,"ref":70,"offset":71},"modern","http://sws.geonames.org/2522853","near",[73],[74,75],38.05191,15.10158,"Italy","Sicily",{"_":4,"role":3,"ref":5},{"type":80},"inventory",{"_":82,"mainLang":83,"languages":84},"Ancient Greek","grc",[82],{"n":86,"url":87,"height":88,"width":89,"desc":90,"surfaceType":91},"screen","ISic004415_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[94,95],"Bacci and Coppolino, 2009, La Necropoli di Abakainon: primi dati","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[97,98],"DX8AWC9Q","JQQKI6JP",[100,101,102,24,28,32,103,104,105,106,104,107,108,83],"isic004415","epitaph for krimma, child of aunakos",{"_":21},"abacaenum","tripi","italy","sicily","necropoli di abakainon","ancient greek","Text encoding: Jonathan Prag",{"file":111,"uri":111,"title":112,"status":113,"editionAuthor":22,"type":114,"objectType":115,"material":116,"condition":10,"layoutDesc":117,"handNote":121,"date":127,"places":128,"geo":131,"country":76,"region":77,"settlement":8,"repository":133,"idno":134,"textLang":135,"facsimile":137,"provenance":64,"letterHeights":139,"publications":140,"zotero":141,"keywords":142,"html":109},"ISic004416","Epitaph for Philon, son Aunakos",{"_":21},{"_":24,"ana":25,"ref":26},{"_":28,"ana":29,"ref":30},{"_":32,"ana":33,"ref":34},{"layout":118},{"p":119,"rs":120,"damage":10},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":39,"ana":40,"ref":41},{"lettering":122,"dimensions":123},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[124,126],{"type":46,"l":47,"from":48,"to":48,"h":125,"unit":50},"59",{"type":52,"l":53,"from":48,"to":54,"h":55,"unit":50},{"_":57,"notBefore":58,"notAfter":59,"evidence":60,"precision":61},[129,130],{"_":64,"type":65,"ref":66,"corresp":67},{"_":8,"type":69,"ref":70,"offset":71},[132],[74,75],{"_":4,"role":3,"ref":5},{"type":80},{"_":82,"mainLang":83,"languages":136},[82],{"n":86,"url":138,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004416_tiled.tif",[],[94,95],[97,98],[143,144,145,24,28,32,103,104,105,106,104,107,108,83],"isic004416","epitaph for philon, son aunakos",{"_":21},{"file":147,"uri":147,"title":148,"status":149,"editionAuthor":22,"type":150,"objectType":151,"material":152,"condition":10,"layoutDesc":153,"handNote":157,"date":163,"places":164,"geo":167,"country":76,"region":77,"settlement":8,"repository":169,"idno":170,"textLang":171,"facsimile":173,"provenance":64,"letterHeights":175,"publications":176,"zotero":178,"keywords":180,"html":109},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":21},{"_":24,"ana":25,"ref":26},{"_":28,"ana":29,"ref":30},{"_":32,"ana":33,"ref":34},{"layout":154},{"p":155,"rs":156,"damage":10},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":39,"ana":40,"ref":41},{"lettering":158,"dimensions":159},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[160,162],{"type":46,"l":161,"from":48,"to":54,"h":49,"unit":50},"Line 1-2",{"type":52,"l":53,"from":48,"to":54,"unit":50},{"_":57,"notBefore":58,"notAfter":59,"evidence":60,"precision":61},[165,166],{"_":64,"type":65,"ref":66,"corresp":67},{"_":8,"type":69,"ref":70,"offset":71},[168],[74,75],{"_":4,"role":3,"ref":5},{"type":80},{"_":82,"mainLang":83,"languages":172},[82],{"n":86,"url":174,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004417_tiled.tif",[],[94,177,95],"Sofia, 2015, Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi",[97,179,98],"9QTE4E3Z",[181,182,183,24,28,32,103,104,105,106,104,107,108,83],"isic004417","epitaph for [-?-], child of gerontios",{"_":21},{"file":185,"uri":185,"title":148,"status":186,"editionAuthor":22,"type":187,"objectType":188,"material":189,"condition":10,"layoutDesc":190,"handNote":194,"date":199,"places":201,"geo":204,"country":76,"region":77,"settlement":8,"repository":206,"idno":207,"textLang":208,"facsimile":210,"provenance":64,"letterHeights":212,"publications":213,"zotero":214,"keywords":215,"html":109},"ISic004418",{"_":21},{"_":24,"ana":25,"ref":26},{"_":28,"ana":29,"ref":30},{"_":32,"ana":33,"ref":34},{"layout":191},{"p":192,"rs":193,"damage":10},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":39,"ana":40,"ref":41},{"lettering":195,"dimensions":196},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[197,198],{"type":46,"l":161,"from":48,"to":54,"h":125,"unit":50},{"type":52,"l":53,"from":48,"to":54,"unit":50},{"_":200,"notBefore":58,"notAfter":59,"evidence":60,"precision":61},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[202,203],{"_":64,"type":65,"ref":66,"corresp":67},{"_":8,"type":69,"ref":70,"offset":71},[205],[74,75],{"_":4,"role":3,"ref":5},{"type":80},{"_":82,"mainLang":83,"languages":209},[82],{"n":86,"url":211,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004418_tiled.tif",[],[94,177,95],[97,179,98],[216,182,217,24,28,32,103,104,105,106,104,107,108,83],"isic004418",{"_":21},{"file":219,"uri":219,"title":220,"status":221,"editionAuthor":22,"type":222,"objectType":223,"material":224,"condition":10,"layoutDesc":225,"handNote":229,"date":234,"places":235,"geo":238,"country":76,"region":77,"settlement":8,"repository":240,"idno":241,"textLang":242,"facsimile":244,"provenance":64,"letterHeights":246,"publications":247,"zotero":248,"keywords":249,"html":109},"ISic004419","Epitaph for Aristarchos",{"_":21},{"_":24,"ana":25,"ref":26},{"_":28,"ana":29,"ref":30},{"_":32,"ana":33,"ref":34},{"layout":226},{"p":227,"rs":228,"damage":10},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":39,"ana":40,"ref":41},{"lettering":230,"dimensions":231},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[232,233],{"type":46,"l":47,"from":48,"to":48,"h":49,"unit":50},{"type":52,"l":53,"from":48,"to":54,"h":55,"unit":50},{"_":200,"notBefore":58,"notAfter":59,"evidence":60,"precision":61},[236,237],{"_":64,"type":65,"ref":66,"corresp":67},{"_":8,"type":69,"ref":70,"offset":71},[239],[74,75],{"_":4,"role":3,"ref":5},{"type":80},{"_":82,"mainLang":83,"languages":243},[82],{"n":86,"url":245,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004419_tiled.tif",[],[95],[98],[250,251,252,24,28,32,103,104,105,106,104,107,108,83],"isic004419","epitaph for aristarchos",{"_":21},{"file":254,"uri":254,"title":255,"status":256,"editionAuthor":22,"type":257,"objectType":258,"material":259,"condition":10,"layoutDesc":260,"handNote":264,"date":270,"places":271,"geo":274,"country":76,"region":77,"settlement":8,"repository":276,"idno":277,"textLang":278,"facsimile":280,"provenance":64,"letterHeights":282,"publications":283,"zotero":284,"keywords":285,"html":109},"ISic004420","Epitaph for Aristokrates",{"_":21},{"_":24,"ana":25,"ref":26},{"_":28,"ana":29,"ref":30},{"_":32,"ana":33,"ref":34},{"layout":261},{"p":262,"rs":263,"damage":10},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":39,"ana":40,"ref":41},{"lettering":265,"dimensions":266},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[267,269],{"type":46,"l":161,"from":48,"to":54,"h":268,"unit":50},"49",{"type":52,"l":53,"from":48,"to":54,"unit":50},{"_":200,"notBefore":58,"notAfter":59,"evidence":60,"precision":61},[272,273],{"_":64,"type":65,"ref":66,"corresp":67},{"_":8,"type":69,"ref":70,"offset":71},[275],[74,75],{"_":4,"role":3,"ref":5},{"type":80},{"_":82,"mainLang":83,"languages":279},[82],{"n":86,"url":281,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004420_tiled.tif",[],[95],[98],[286,287,288,24,28,32,103,104,105,106,104,107,108,83],"isic004420","epitaph for aristokrates",{"_":21},{"file":290,"uri":290,"title":291,"status":292,"editionAuthor":22,"type":293,"objectType":294,"material":295,"condition":10,"layoutDesc":296,"handNote":300,"date":306,"places":308,"geo":311,"country":76,"region":77,"settlement":8,"repository":313,"idno":314,"textLang":315,"facsimile":317,"provenance":64,"letterHeights":319,"publications":320,"zotero":321,"keywords":322,"html":109},"ISic004421","Epitaph for Athanippos",{"_":21},{"_":24,"ana":25,"ref":26},{"_":28,"ana":29,"ref":30},{"_":32,"ana":33,"ref":34},{"layout":297},{"p":298,"rs":299,"damage":10},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":39,"ana":40,"ref":41},{"lettering":301,"dimensions":302},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[303,305],{"type":46,"l":47,"from":48,"to":48,"h":304,"unit":50},"29",{"type":52,"l":53,"from":48,"to":54,"h":55,"unit":50},{"_":307,"notBefore":58,"notAfter":59,"evidence":60,"precision":61},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[309,310],{"_":64,"type":65,"ref":66,"corresp":67},{"_":8,"type":69,"ref":70,"offset":71},[312],[74,75],{"_":4,"role":3,"ref":5},{"type":80},{"_":82,"mainLang":83,"languages":316},[82],{"n":86,"url":318,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004421_tiled.tif",[],[95],[98],[323,324,325,24,28,32,103,104,105,106,104,107,108,83],"isic004421","epitaph for athanippos",{"_":21}],"uses":{"params":["slug"]}}]}
