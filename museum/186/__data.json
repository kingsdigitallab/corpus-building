he end of the 3rd century BCE, offering a terminus ante quem",[216,217],{"_":67,"type":68,"ref":69,"corresp":70,"region":71},{"_":8,"type":73,"ref":74,"offset":75,"region":71},[219],[78,79],[13,14],{"_":4,"role":3,"ref":5},{"type":84},{"_":86,"mainLang":87,"languages":224},[86],{"n":90,"url":226,"height":92,"width":93,"desc":94,"surfaceType":95},"ISic004418_tiled.tif",[228],{"atLeast":149,"atMost":149},[100,190,101],[103,192,104],[232,195,233,26,30,34,109,110,111,112,110,113,114,87],"isic004418",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":236,"uri":236,"title":237,"status":238,"editionAuthor":24,"type":239,"objectType":240,"material":241,"condition":10,"layoutDesc":242,"handNote":246,"date":251,"places":252,"geo":255,"country":71,"provenance":67,"provenanceGeo":257,"region":81,"settlement":8,"repository":258,"idno":259,"textLang":260,"tmNumber":10,"facsimile":262,"letterHeights":264,"publications":266,"zotero":267,"keywords":268,"html":272,"idnoSort":116,"languageSort":86,"materialSort":34,"originSort":67,"typeSort":26},"ISic004419","Epitaph for Aristarchos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"type":36,"subtype":37,"ref":38},{"layout":243},{"p":244,"rs":245,"damage":10},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":43,"ana":44,"ref":45},{"lettering":247,"dimensions":248},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[249,250],{"type":50,"l":51,"from":52,"to":52,"h":53,"unit":54,"atLeast":53,"atMost":53},{"type":56,"l":57,"from":52,"to":58,"h":59,"unit":54},{"_":214,"notBefore":62,"notAfter":63,"evidence":64},[253,254],{"_":67,"type":68,"ref":69,"corresp":70,"region":71},{"_":8,"type":73,"ref":74,"offset":75,"region":71},[256],[78,79],[13,14],{"_":4,"role":3,"ref":5},{"type":84},{"_":86,"mainLang":87,"languages":261},[86],{"n":90,"url":263,"height":92,"width":93,"desc":94,"surfaceType":95},"ISic004419_tiled.tif",[265],{"atLeast":98,"atMost":98},[101],[104],[269,270,271,26,30,34,109,110,111,112,110,113,114,87],"isic004419","epitaph for aristarchos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":274,"uri":274,"title":275,"status":276,"editionAuthor":24,"type":277,"objectType":278,"material":279,"condition":10,"layoutDesc":280,"handNote":284,"date":290,"places":291,"geo":294,"country":71,"provenance":67,"provenanceGeo":296,"region":81,"settlement":8,"repository":297,"idno":298,"textLang":299,"tmNumber":10,"facsimile":301,"letterHeights":303,"publications":306,"zotero":307,"keywords":308,"html":312,"idnoSort":116,"languageSort":86,"materialSort":34,"originSort":67,"typeSort":26},"ISic004420","Epitaph for Aristokrates",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"type":36,"subtype":37,"ref":38},{"layout":281},{"p":282,"rs":283,"damage":10},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":43,"ana":44,"ref":45},{"lettering":285,"dimensions":286},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[287,289],{"type":50,"l":172,"from":52,"to":58,"h":288,"unit":54,"atLeast":288,"atMost":288},"49",{"type":56,"l":57,"from":52,"to":58,"unit":54},{"_":214,"notBefore":62,"notAfter":63,"evidence":64},[292,293],{"_":67,"type":68,"ref":69,"corresp":70,"region":71},{"_":8,"type":73,"ref":74,"offset":75,"region":71},[295],[78,79],[13,14],{"_":4,"role":3,"ref":5},{"type":84},{"_":86,"mainLang":87,"languages":300},[86],{"n":90,"url":302,"height":92,"width":93,"desc":94,"surfaceType":95},"ISic004420_tiled.tif",[304],{"atLeast":305,"atMost":305},49,[101],[104],[309,310,311,26,30,34,109,110,111,112,110,113,114,87],"isic004420","epitaph for aristokrates",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":314,"uri":314,"title":315,"status":316,"editionAuthor":24,"type":317,"objectType":318,"material":319,"condition":10,"layoutDesc":320,"handNote":324,"date":330,"places":332,"geo":335,"country":71,"provenance":67,"provenanceGeo":337,"region":81,"settlement":8,"repository":338,"idno":339,"textLang":340,"tmNumber":10,"facsimile":342,"letterHeights":344,"publications":347,"zotero":348,"keywords":349,"html":353,"idnoSort":116,"languageSort":86,"materialSort":34,"originSort":67,"typeSort":26},"ISic004421","Epitaph for Athanippos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"type":36,"subtype":37,"ref":38},{"layout":321},{"p":322,"rs":323,"damage":10},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":43,"ana":44,"ref":45},{"lettering":325,"dimensions":326},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[327,329],{"type":50,"l":51,"from":52,"to":52,"h":328,"unit":54,"atLeast":328,"atMost":328},"29",{"type":56,"l":57,"from":52,"to":58,"h":59,"unit":54},{"_":331,"notBefore":62,"notAfter":63,"evidence":64},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[333,334],{"_":67,"type":68,"ref":69,"corresp":70,"region":71},{"_":8,"type":73,"ref":74,"offset":75,"region":71},[336],[78,79],[13,14],{"_":4,"role":3,"ref":5},{"type":84},{"_":86,"mainLang":87,"languages":341},[86],{"n":90,"url":343,"height":92,"width":93,"desc":94,"surfaceType":95},"ISic004421_tiled.tif",[345],{"atLeast":346,"atMost":346},29,[101],[104],[350,351,352,26,30,34,109,110,111,112,110,113,114,87],"isic004421","epitaph for athanippos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>"],"uses":{"params":["slug"]}}]}
