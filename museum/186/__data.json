{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"museum":1,"inscriptions":18},{"slug":2,"type":3,"name":4,"uri":5,"description":6,"location":7,"idno":15},"186","site","Necropoli di Abakainon","http://sicily.classics.ox.ac.uk/museum/186","Partially uncovered Hellenistic necropolis",{"settlement":8,"region":9,"country":10,"address":11,"geo":12},"Tripi","Messina","","contrada Carusa",{"lat":13,"lon":14},38.06519,15.11438,{"type":16,"url":17},"Pleiades","https://pleiades.stoa.org/places/462062",[19,118,159,201,239,278,319],{"file":20,"uri":20,"title":21,"status":22,"editionAuthor":24,"type":25,"objectType":29,"material":33,"condition":10,"layoutDesc":40,"handNote":47,"date":61,"places":66,"geo":77,"country":72,"provenance":68,"provenanceGeo":81,"region":82,"settlement":8,"repository":83,"idno":84,"textLang":86,"tmNumber":10,"facsimile":90,"letterHeights":97,"publications":100,"zotero":103,"keywords":106,"html":116,"idnoSort":117,"languageSort":87,"materialSort":34,"originSort":68,"typeSort":26},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":23},"edited",null,{"_":26,"ana":27,"ref":28},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":30,"ana":31,"ref":32},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":34,"ana":35,"type":36,"subtype":37,"ref":39},"sandstone","#material.inorganic.stone","stone.unspecified",[38],"unverified","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":41},{"p":42,"rs":43,"damage":10},"Single line of greek letters approximately centred on the face of the plinth",{"_":44,"ana":45,"ref":46},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":48,"dimensions":49},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[50,56],{"type":51,"l":52,"from":53,"to":53,"h":54,"unit":55,"atLeast":54,"atMost":54},"letterHeight","Line 1","line1","30","mm",{"type":57,"l":58,"from":53,"to":59,"h":60,"unit":55},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":62,"notBefore":63,"notAfter":64,"evidence":65},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,"archaeological-context",[67,73],{"_":68,"type":69,"ref":70,"corresp":71,"region":72},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062","#findspot","Sicilia",{"_":8,"type":74,"ref":75,"offset":76,"region":72},"modern","http://sws.geonames.org/2522853","near",[78],[79,80],38.05191,15.10158,[13,14],"Sicily",{"_":4,"role":3,"ref":5},{"type":85},"inventory",{"_":87,"mainLang":88,"languages":89},"Ancient Greek","grc",[87],{"n":91,"url":92,"height":93,"width":94,"desc":95,"surfaceType":96},"screen","ISic004415_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[98],{"atLeast":99,"atMost":99},30,[101,102],"Bacci, Coppolino, 2009, La Necropoli di Abakainon: primi dati","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[104,105],"DX8AWC9Q","JQQKI6JP",[107,108,109,26,30,34,110,111,112,113,111,114,115,88],"isic004415","epitaph for krimma, child of aunakos",{"_":23},"abacaenum","tripi","sicilia","sicily","necropoli di abakainon","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",9999999999,{"file":119,"uri":119,"title":120,"status":121,"editionAuthor":24,"type":122,"objectType":123,"material":124,"condition":10,"layoutDesc":126,"handNote":130,"date":136,"places":137,"geo":140,"country":72,"provenance":68,"provenanceGeo":142,"region":82,"settlement":8,"repository":143,"idno":144,"textLang":145,"tmNumber":10,"facsimile":147,"letterHeights":149,"publications":152,"zotero":153,"keywords":154,"html":158,"idnoSort":117,"languageSort":87,"materialSort":34,"originSort":68,"typeSort":26},"ISic004416","Epitaph for Philon, son Aunakos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"type":36,"subtype":125,"ref":39},[38],{"layout":127},{"p":128,"rs":129,"damage":10},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":44,"ana":45,"ref":46},{"lettering":131,"dimensions":132},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[133,135],{"type":51,"l":52,"from":53,"to":53,"h":134,"unit":55,"atLeast":134,"atMost":134},"59",{"type":57,"l":58,"from":53,"to":59,"h":60,"unit":55},{"_":62,"notBefore":63,"notAfter":64,"evidence":65},[138,139],{"_":68,"type":69,"ref":70,"corresp":71,"region":72},{"_":8,"type":74,"ref":75,"offset":76,"region":72},[141],[79,80],[13,14],{"_":4,"role":3,"ref":5},{"type":85},{"_":87,"mainLang":88,"languages":146},[87],{"n":91,"url":148,"height":93,"width":94,"desc":95,"surfaceType":96},"ISic004416_tiled.tif",[150],{"atLeast":151,"atMost":151},59,[101,102],[104,105],[155,156,157,26,30,34,110,111,112,113,111,114,115,88],"isic004416","epitaph for philon, son aunakos",{"_":23},"\u003