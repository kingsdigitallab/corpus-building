{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"museum":1,"inscriptions":18},{"slug":2,"type":3,"name":4,"uri":5,"description":6,"location":7,"idno":15},"186","site","Necropoli di Abakainon","http://sicily.classics.ox.ac.uk/museum/186","Partially uncovered Hellenistic necropolis",{"settlement":8,"region":9,"country":10,"address":11,"geo":12},"Tripi","Messina","","contrada Carusa",{"lat":13,"lon":14},38.06519,15.11438,{"type":16,"url":17},"Pleiades","https://pleiades.stoa.org/places/462062",[19,115,155,196,233,271,311],{"file":20,"uri":20,"title":21,"status":22,"editionAuthor":24,"type":25,"objectType":29,"material":33,"condition":10,"layoutDesc":37,"handNote":44,"date":58,"places":63,"geo":73,"provenance":65,"provenanceGeo":77,"country":78,"region":79,"settlement":8,"repository":80,"idno":81,"textLang":83,"tmNumber":10,"facsimile":87,"letterHeights":94,"publications":97,"zotero":100,"keywords":103,"html":113,"idnoSort":114,"languageSort":84,"materialSort":34,"originSort":65,"typeSort":26},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":23},"edited",null,{"_":26,"ana":27,"ref":28},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":30,"ana":31,"ref":32},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":34,"ana":35,"ref":36},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":38},{"p":39,"rs":40,"damage":10},"Single line of greek letters approximately centred on the face of the plinth",{"_":41,"ana":42,"ref":43},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":45,"dimensions":46},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[47,53],{"type":48,"l":49,"from":50,"to":50,"h":51,"unit":52,"atLeast":51,"atMost":51},"letterHeight","Line 1","line1","30","mm",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":59,"notBefore":60,"notAfter":61,"evidence":62},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,"archaeological-context",[64,69],{"_":65,"type":66,"ref":67,"corresp":68},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062","#findspot",{"_":8,"type":70,"ref":71,"offset":72},"modern","http://sws.geonames.org/2522853","near",[74],[75,76],38.05191,15.10158,[13,14],"Italy","Sicily",{"_":4,"role":3,"ref":5},{"type":82},"inventory",{"_":84,"mainLang":85,"languages":86},"Ancient Greek","grc",[84],{"n":88,"url":89,"height":90,"width":91,"desc":92,"surfaceType":93},"screen","ISic004415_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[95],{"atLeast":96,"atMost":96},30,[98,99],"Bacci, Coppolino, 2009, La Necropoli di Abakainon: primi dati","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[101,102],"DX8AWC9Q","JQQKI6JP",[104,105,106,26,30,34,107,108,109,110,108,111,112,85],"isic004415","epitaph for krimma, child of aunakos",{"_":23},"abacaenum","tripi","italy","sicily","necropoli di abakainon","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",9999999999,{"file":116,"uri":116,"title":117,"status":118,"editionAuthor":24,"type":119,"objectType":120,"material":121,"condition":10,"layoutDesc":122,"handNote":126,"date":132,"places":133,"geo":136,"provenance":65,"provenanceGeo":138,"country":78,"region":79,"settlement":8,"repository":139,"idno":140,"textLang":141,"tmNumber":10,"facsimile":143,"letterHeights":145,"publications":148,"zotero":149,"keywords":150,"html":154,"idnoSort":114,"languageSort":84,"materialSort":34,"originSort":65,"typeSort":26},"ISic004416","Epitaph for Philon, son Aunakos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":123},{"p":124,"rs":125,"damage":10},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":41,"ana":42,"ref":43},{"lettering":127,"dimensions":128},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[129,131],{"type":48,"l":49,"from":50,"to":50,"h":130,"unit":52,"atLeast":130,"atMost":130},"59",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":59,"notBefore":60,"notAfter":61,"evidence":62},[134,135],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[137],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":142},[84],{"n":88,"url":144,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004416_tiled.tif",[146],{"atLeast":147,"atMost":147},59,[98,99],[101,102],[151,152,153,26,30,34,107,108,109,110,108,111,112,85],"isic004416","epitaph for philon, son aunakos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003C