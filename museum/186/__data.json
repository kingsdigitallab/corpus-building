\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":197,"uri":197,"title":157,"status":198,"editionAuthor":24,"type":199,"objectType":200,"material":201,"condition":10,"layoutDesc":202,"handNote":206,"date":211,"places":213,"geo":216,"provenance":65,"provenanceGeo":218,"country":78,"region":79,"settlement":8,"repository":219,"idno":220,"textLang":221,"tmNumber":10,"facsimile":223,"letterHeights":225,"publications":227,"zotero":228,"keywords":229,"html":232,"idnoSort":114,"languageSort":84,"materialSort":34,"originSort":65,"typeSort":26},"ISic004418",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":203},{"p":204,"rs":205,"damage":10},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":41,"ana":42,"ref":43},{"lettering":207,"dimensions":208},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[209,210],{"type":48,"l":170,"from":50,"to":56,"h":130,"unit":52,"atLeast":130,"atMost":130},{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":212,"notBefore":60,"notAfter":61,"evidence":62},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[214,215],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[217],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":222},[84],{"n":88,"url":224,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004418_tiled.tif",[226],{"atLeast":147,"atMost":147},[98,188,99],[101,190,102],[230,193,231,26,30,34,107,108,109,110,108,111,112,85],"isic004418",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":234,"uri":234,"title":235,"status":236,"editionAuthor":24,"type":237,"objectType":238,"material":239,"condition":10,"layoutDesc":240,"handNote":244,"date":249,"places":250,"geo":253,"provenance":65,"provenanceGeo":255,"country":78,"region":79,"settlement":8,"repository":256,"idno":257,"textLang":258,"tmNumber":10,"facsimile":260,"letterHeights":262,"publications":264,"zotero":265,"keywords":266,"html":270,"idnoSort":114,"languageSort":84,"materialSort":34,"originSort":65,"typeSort":26},"ISic004419","Epitaph for Aristarchos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":241},{"p":242,"rs":243,"damage":10},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":41,"ana":42,"ref":43},{"lettering":245,"dimensions":246},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[247,248],{"type":48,"l":49,"from":50,"to":50,"h":51,"unit":52,"atLeast":51,"atMost":51},{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":212,"notBefore":60,"notAfter":61,"evidence":62},[251,252],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[254],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":259},[84],{"n":88,"url":261,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004419_tiled.tif",[263],{"atLeast":96,"atMost":96},[99],[102],[267,268,269,26,30,34,107,108,109,110,108,111,112,85],"isic004419","epitaph for aristarchos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":272,"uri":272,"title":273,"status":274,"editionAuthor":24,"type":275,"objectType":276,"material":277,"condition":10,"layoutDesc":278,"handNote":282,"date":288,"places":289,"geo":292,"provenance":65,"provenanceGeo":294,"country":78,"region":79,"settlement":8,"repository":295,"idno":296,"textLang":297,"tmNumber":10,"facsimile":299,"letterHeights":301,"publications":304,"zotero":305,"keywords":306,"html":310,"idnoSort":114,"languageSort":84,"materialSort":34,"originSort":65,"typeSort":26},"ISic004420","Epitaph for Aristokrates",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":279},{"p":280,"rs":281,"damage":10},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":41,"ana":42,"ref":43},{"lettering":283,"dimensions":284},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[285,287],{"type":48,"l":170,"from":50,"to":56,"h":286,"unit":52,"atLeast":286,"atMost":286},"49",{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":212,"notBefore":60,"notAfter":61,"evidence":62},[290,291],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[293],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":298},[84],{"n":88,"url":300,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004420_tiled.tif",[302],{"atLeast":303,"atMost":303},49,[99],[102],[307,308,309,26,30,34,107,108,109,110,108,111,112,85],"isic004420","epitaph for aristokrates",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":312,"uri":312,"title":313,"status":314,"editionAuthor":24,"type":315,"objectType":316,"material":317,"condition":10,"layoutDesc":318,"handNote":322,"date":328,"places":330,"geo":333,"provenance":65,"provenanceGeo":335,"country":78,"region":79,"settlement":8,"repository":336,"idno":337,"textLang":338,"tmNumber":10,"facsimile":340,"letterHeights":342,"publications":345,"zotero":346,"keywords":347,"html":351,"idnoSort":114,"languageSort":84,"materialSort":34,"originSort":65,"typeSort":26},"ISic004421","Epitaph for Athanippos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":319},{"p":320,"rs":321,"damage":10},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":41,"ana":42,"ref":43},{"lettering":323,"dimensions":324},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[325,327],{"type":48,"l":49,"from":50,"to":50,"h":326,"unit":52,"atLeast":326,"atMost":326},"29",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":329,"notBefore":60,"notAfter":61,"evidence":62},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[331,332],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[334],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":339},[84],{"n":88,"url":341,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004421_tiled.tif",[343],{"atLeast":344,"atMost":344},29,[99],[102],[348,349,350,26,30,34,107,108,109,110,108,111,112,85],"isic004421","epitaph for athanippos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>"],"uses":{"params":["slug"]}}]}
