[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":196,"uri":196,"title":156,"status":197,"editionAuthor":24,"type":198,"objectType":199,"material":200,"condition":10,"layoutDesc":201,"handNote":205,"date":210,"places":212,"geo":215,"provenance":65,"provenanceGeo":217,"country":78,"region":79,"settlement":8,"repository":218,"idno":219,"textLang":220,"tmNumber":10,"facsimile":222,"letterHeights":224,"publications":226,"zotero":227,"keywords":228,"html":231},"ISic004418",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":202},{"p":203,"rs":204,"damage":10},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":41,"ana":42,"ref":43},{"lettering":206,"dimensions":207},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[208,209],{"type":48,"l":169,"from":50,"to":56,"h":129,"unit":52,"atLeast":129,"atMost":129},{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":211,"notBefore":60,"notAfter":61,"evidence":62},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[213,214],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[216],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":221},[84],{"n":88,"url":223,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004418_tiled.tif",[225],{"atLeast":146,"atMost":146},[98,187,99],[101,189,102],[229,192,230,26,30,34,107,108,109,110,108,111,112,85],"isic004418",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":233,"uri":233,"title":234,"status":235,"editionAuthor":24,"type":236,"objectType":237,"material":238,"condition":10,"layoutDesc":239,"handNote":243,"date":248,"places":249,"geo":252,"provenance":65,"provenanceGeo":254,"country":78,"region":79,"settlement":8,"repository":255,"idno":256,"textLang":257,"tmNumber":10,"facsimile":259,"letterHeights":261,"publications":263,"zotero":264,"keywords":265,"html":269},"ISic004419","Epitaph for Aristarchos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":240},{"p":241,"rs":242,"damage":10},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":41,"ana":42,"ref":43},{"lettering":244,"dimensions":245},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[246,247],{"type":48,"l":49,"from":50,"to":50,"h":51,"unit":52,"atLeast":51,"atMost":51},{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":211,"notBefore":60,"notAfter":61,"evidence":62},[250,251],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[253],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":258},[84],{"n":88,"url":260,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004419_tiled.tif",[262],{"atLeast":96,"atMost":96},[99],[102],[266,267,268,26,30,34,107,108,109,110,108,111,112,85],"isic004419","epitaph for aristarchos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":271,"uri":271,"title":272,"status":273,"editionAuthor":24,"type":274,"objectType":275,"material":276,"condition":10,"layoutDesc":277,"handNote":281,"date":287,"places":288,"geo":291,"provenance":65,"provenanceGeo":293,"country":78,"region":79,"settlement":8,"repository":294,"idno":295,"textLang":296,"tmNumber":10,"facsimile":298,"letterHeights":300,"publications":303,"zotero":304,"keywords":305,"html":309},"ISic004420","Epitaph for Aristokrates",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":278},{"p":279,"rs":280,"damage":10},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":41,"ana":42,"ref":43},{"lettering":282,"dimensions":283},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[284,286],{"type":48,"l":169,"from":50,"to":56,"h":285,"unit":52,"atLeast":285,"atMost":285},"49",{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":211,"notBefore":60,"notAfter":61,"evidence":62},[289,290],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[292],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":297},[84],{"n":88,"url":299,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004420_tiled.tif",[301],{"atLeast":302,"atMost":302},49,[99],[102],[306,307,308,26,30,34,107,108,109,110,108,111,112,85],"isic004420","epitaph for aristokrates",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":311,"uri":311,"title":312,"status":313,"editionAuthor":24,"type":314,"objectType":315,"material":316,"condition":10,"layoutDesc":317,"handNote":321,"date":327,"places":329,"geo":332,"provenance":65,"provenanceGeo":334,"country":78,"region":79,"settlement":8,"repository":335,"idno":336,"textLang":337,"tmNumber":10,"facsimile":339,"letterHeights":341,"publications":344,"zotero":345,"keywords":346,"html":350},"ISic004421","Epitaph for Athanippos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":318},{"p":319,"rs":320,"damage":10},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":41,"ana":42,"ref":43},{"lettering":322,"dimensions":323},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[324,326],{"type":48,"l":49,"from":50,"to":50,"h":325,"unit":52,"atLeast":325,"atMost":325},"29",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":328,"notBefore":60,"notAfter":61,"evidence":62},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[330,331],{"_":65,"type":66,"ref":67,"corresp":68},{"_":8,"type":70,"ref":71,"offset":72},[333],[75,76],[13,14],{"_":4,"role":3,"ref":5},{"type":82},{"_":84,"mainLang":85,"languages":338},[84],{"n":88,"url":340,"height":90,"width":91,"desc":92,"surfaceType":93},"ISic004421_tiled.tif",[342],{"atLeast":343,"atMost":343},29,[99],[102],[347,348,349,26,30,34,107,108,109,110,108,111,112,85],"isic004421","epitaph for athanippos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>"],"uses":{"params":["slug"]}}]}
