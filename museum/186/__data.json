ight vertical joining the diagonal above the line; omicron is small and mid-line.",[47,53],{"type":48,"l":49,"from":50,"to":50,"h":51,"unit":52},"letterHeight","Line 1","line1","30","mm",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":59,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,"archaeological-context","low",[65,70],{"_":66,"type":67,"ref":68,"corresp":69},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062","#findspot",{"_":8,"type":71,"ref":72,"offset":73},"modern","http://sws.geonames.org/2522853","near",[75],[76,77],38.05191,15.10158,[13,14],"Italy","Sicily",{"_":4,"role":3,"ref":5},{"type":83},"inventory",{"_":85,"mainLang":86,"languages":87},"Ancient Greek","grc",[85],{"n":89,"url":90,"height":91,"width":92,"desc":93,"surfaceType":94},"screen","ISic004415_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[97,98],", , 2009, La Necropoli di Abakainon: primi dati","Nuove iscrizioni funerarie dalla necropoli di Abakainon, 2018",[100,101],"DX8AWC9Q","JQQKI6JP",[103,104,105,26,30,34,106,107,108,109,107,110,111,86],"isic004415","epitaph for krimma, child of aunakos",{"_":23},"abacaenum","tripi","italy","sicily","necropoli di abakainon","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":114,"uri":114,"title":115,"status":116,"editionAuthor":24,"type":117,"objectType":118,"material":119,"condition":10,"layoutDesc":120,"handNote":124,"date":130,"places":131,"geo":134,"provenance":66,"provenanceGeo":136,"country":79,"region":80,"settlement":8,"repository":137,"idno":138,"textLang":139,"tmNumber":10,"facsimile":141,"letterHeights":143,"publications":144,"zotero":145,"keywords":146,"html":150},"ISic004416","Epitaph for Philon, son Aunakos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":121},{"p":122,"rs":123,"damage":10},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":41,"ana":42,"ref":43},{"lettering":125,"dimensions":126},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[127,129],{"type":48,"l":49,"from":50,"to":50,"h":128,"unit":52},"59",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":59,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},[132,133],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[135],[76,77],[13,14],{"_":4,"role":3,"ref":5},{"type":83},{"_":85,"mainLang":86,"languages":140},[85],{"n":89,"url":142,"height":91,"width":92,"desc":93,"surfaceType":94},"ISic004416_tiled.tif",[],[97,98],[100,101],[147,148,149,26,30,34,106,107,108,109,107,110,111,86],"isic004416","epitaph for philon, son aunakos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":152,"uri":152,"title":153,"status":154,"editionAuthor":24,"type":155,"objectType":156,"material":157,"condition":10,"layoutDesc":158,"handNote":162,"date":168,"places":169,"geo":172,"provenance":66,"provenanceGeo":174,"country":79,"region":80,"settlement":8,"repository":175,"idno":176,"textLang":177,"tmNumber":10,"facsimile":179,"letterHeights":181,"publications":182,"zotero":184,"keywords":186,"html":190},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":159},{"p":160,"rs":161,"damage":10},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":41,"ana":42,"ref":43},{"lettering":163,"dimensions":164},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[165,167],{"type":48,"l":166,"from":50,"to":56,"h":51,"unit":52},"Line 1-2",{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":59,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},[170,171],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[173],[76,77],[13,14],{"_":4,"role":3,"ref":5},{"type":83},{"_":85,"mainLang":86,"languages":178},[85],{"n":89,"url":180,"height":91,"width":92,"desc":93,"surfaceType":94},"ISic004417_tiled.tif",[],[97,183,98],"Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi, 2015",[100,185,101],"9QTE4E3Z",[187,188,189,26,30,34,106,107,108,109,107,110,111,86],"isic004417","epitaph for [-?-], child of gerontios",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":192,"uri":192,"title":153,"status":193,"editionAuthor":24,"type":194,"objectType":195,"material":196,"condition":10,"layoutDesc":197,"handNote":201,"date":206,"places":208,"geo":211,"provenance":66,"provenanceGeo":213,"country":79,"region":80,"settlement":8,"repository":214,"idno":215,"textLang":216,"tmNumber":10,"facsimile":218,"letterHeights":220,"publications":221,"zotero":222,"keywords":223,"html":226},"ISic004418",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":198},{"p":199,"rs":200,"damage":10},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":41,"ana":42,"ref":43},{"lettering":202,"dimensions":203},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[204,205],{"type":48,"l":166,"from":50,"to":56,"h":128,"unit":52},{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":207,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[209,210],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[212],[76,77],[13,14],{"_":4,"role":3,"ref":5},{"type":83},{"_":85,"mainLang":86,"languages":217},[85],{"n":89,"url":219,"height":91,"width":92,"desc":93,"surfaceType":94},"ISic004418_tiled.tif",[],[97,183,98],[100,185,101],[224,188,225,26,30,34,106,107,108,109,107,110,111,86],"isic004418",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":228,"uri":228,"title":229,"status":230,"editionAuthor":24,"type":231,"objectType":232,"material":233,"condition":10,"layoutDesc":234,"handNote":238,"date":243,"places":244,"geo":247,"provenance":66,"provenanceGeo":249,"country":79,"region":80,"settlement":8,"repository":250,"idno":251,"textLang":252,"tmNumber":10,"facsimile":254,"letterHeights":256,"publications":257,"zotero":258,"keywords":259,"html":263},"ISic004419","Epitaph for Aristarchos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":235},{"p":236,"rs":237,"damage":10},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":41,"ana":42,"ref":43},{"lettering":239,"dimensions":240},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[241,242],{"type":48,"l":49,"from":50,"to":50,"h":51,"unit":52},{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":207,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},[245,246],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[248],[76,77],[13,14],{"_":4,"role":3,"ref":5},{"type":83},{"_":85,"mainLang":86,"languages":253},[85],{"n":89,"url":255,"height":91,"width":92,"desc":93,"surfaceType":94},"ISic004419_tiled.tif",[],[98],[101],[260,261,262,26,30,34,106,107,108,109,107,110,111,86],"isic004419","epitaph for aristarchos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":265,"uri":265,"title":266,"status":267,"editionAuthor":24,"type":268,"objectType":269,"material":270,"condition":10,"layoutDesc":271,"handNote":275,"date":281,"places":282,"geo":285,"provenance":66,"provenanceGeo":287,"country":79,"region":80,"settlement":8,"repository":288,"idno":289,"textLang":290,"tmNumber":10,"facsimile":292,"letterHeights":294,"publications":295,"zotero":296,"keywords":297,"html":301},"ISic004420","Epitaph for Aristokrates",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":272},{"p":273,"rs":274,"damage":10},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":41,"ana":42,"ref":43},{"lettering":276,"dimensions":277},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[278,280],{"type":48,"l":166,"from":50,"to":56,"h":279,"unit":52},"49",{"type":54,"l":55,"from":50,"to":56,"unit":52},{"_":207,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},[283,284],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[286],[76,77],[13,14],{"_":4,"role":3,"ref":5},{"type":83},{"_":85,"mainLang":86,"languages":291},[85],{"n":89,"url":293,"height":91,"width":92,"desc":93,"surfaceType":94},"ISic004420_tiled.tif",[],[98],[101],[298,299,300,26,30,34,106,107,108,109,107,110,111,86],"isic004420","epitaph for aristokrates",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":303,"uri":303,"title":304,"status":305,"editionAuthor":24,"type":306,"objectType":307,"material":308,"condition":10,"layoutDesc":309,"handNote":313,"date":319,"places":321,"geo":324,"provenance":66,"provenanceGeo":326,"country":79,"region":80,"settlement":8,"repository":327,"idno":328,"textLang":329,"tmNumber":10,"facsimile":331,"letterHeights":333,"publications":334,"zotero":335,"keywords":336,"html":340},"ISic004421","Epitaph for Athanippos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"ref":36},{"layout":310},{"p":311,"rs":312,"damage":10},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":41,"ana":42,"ref":43},{"lettering":314,"dimensions":315},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[316,318],{"type":48,"l":49,"from":50,"to":50,"h":317,"unit":52},"29",{"type":54,"l":55,"from":50,"to":56,"h":57,"unit":52},{"_":320,"notBefore":60,"notAfter":61,"evidence":62,"precision":63},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[322,323],{"_":66,"type":67,"ref":68,"corresp":69},{"_":8,"type":71,"ref":72,"offset":73},[325],[76,77],[13,14],{"_":4,"role":3,"ref":5},{"type":83},{"_":85,"mainLang":86,"languages":330},[85],{"n":89,"url":332,"height":91,"width":92,"desc":93,"surfaceType":94},"ISic004421_tiled.tif",[],[98],[101],[337,338,339,26,30,34,106,107,108,109,107,110,111,86],"isic004421","epitaph for athanippos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>"],"uses":{"params":["slug"]}}]}
