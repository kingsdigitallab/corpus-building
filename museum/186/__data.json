 Cardusa a Tripi",[104,195,105],"9QTE4E3Z",[197,198,199,26,30,34,110,111,112,113,111,114,115,88],"isic004417","epitaph for [-?-], child of gerontios",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":202,"uri":202,"title":161,"status":203,"editionAuthor":24,"type":204,"objectType":205,"material":206,"condition":10,"layoutDesc":208,"handNote":212,"date":217,"places":219,"geo":222,"country":72,"provenance":68,"provenanceGeo":224,"region":82,"settlement":8,"repository":225,"idno":226,"textLang":227,"tmNumber":10,"facsimile":229,"letterHeights":231,"publications":233,"zotero":234,"keywords":235,"html":238,"idnoSort":117,"languageSort":87,"materialSort":34,"originSort":68,"typeSort":26},"ISic004418",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"type":36,"subtype":207,"ref":39},[38],{"layout":209},{"p":210,"rs":211,"damage":10},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":44,"ana":45,"ref":46},{"lettering":213,"dimensions":214},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[215,216],{"type":51,"l":175,"from":53,"to":59,"h":134,"unit":55,"atLeast":134,"atMost":134},{"type":57,"l":58,"from":53,"to":59,"unit":55},{"_":218,"notBefore":63,"notAfter":64,"evidence":65},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[220,221],{"_":68,"type":69,"ref":70,"corresp":71,"region":72},{"_":8,"type":74,"ref":75,"offset":76,"region":72},[223],[79,80],[13,14],{"_":4,"role":3,"ref":5},{"type":85},{"_":87,"mainLang":88,"languages":228},[87],{"n":91,"url":230,"height":93,"width":94,"desc":95,"surfaceType":96},"ISic004418_tiled.tif",[232],{"atLeast":151,"atMost":151},[101,193,102],[104,195,105],[236,198,237,26,30,34,110,111,112,113,111,114,115,88],"isic004418",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":240,"uri":240,"title":241,"status":242,"editionAuthor":24,"type":243,"objectType":244,"material":245,"condition":10,"layoutDesc":247,"handNote":251,"date":256,"places":257,"geo":260,"country":72,"provenance":68,"provenanceGeo":262,"region":82,"settlement":8,"repository":263,"idno":264,"textLang":265,"tmNumber":10,"facsimile":267,"letterHeights":269,"publications":271,"zotero":272,"keywords":273,"html":277,"idnoSort":117,"languageSort":87,"materialSort":34,"originSort":68,"typeSort":26},"ISic004419","Epitaph for Aristarchos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"type":36,"subtype":246,"ref":39},[38],{"layout":248},{"p":249,"rs":250,"damage":10},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":44,"ana":45,"ref":46},{"lettering":252,"dimensions":253},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[254,255],{"type":51,"l":52,"from":53,"to":53,"h":54,"unit":55,"atLeast":54,"atMost":54},{"type":57,"l":58,"from":53,"to":59,"h":60,"unit":55},{"_":218,"notBefore":63,"notAfter":64,"evidence":65},[258,259],{"_":68,"type":69,"ref":70,"corresp":71,"region":72},{"_":8,"type":74,"ref":75,"offset":76,"region":72},[261],[79,80],[13,14],{"_":4,"role":3,"ref":5},{"type":85},{"_":87,"mainLang":88,"languages":266},[87],{"n":91,"url":268,"height":93,"width":94,"desc":95,"surfaceType":96},"ISic004419_tiled.tif",[270],{"atLeast":99,"atMost":99},[102],[105],[274,275,276,26,30,34,110,111,112,113,111,114,115,88],"isic004419","epitaph for aristarchos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":279,"uri":279,"title":280,"status":281,"editionAuthor":24,"type":282,"objectType":283,"material":284,"condition":10,"layoutDesc":286,"handNote":290,"date":296,"places":297,"geo":300,"country":72,"provenance":68,"provenanceGeo":302,"region":82,"settlement":8,"repository":303,"idno":304,"textLang":305,"tmNumber":10,"facsimile":307,"letterHeights":309,"publications":312,"zotero":313,"keywords":314,"html":318,"idnoSort":117,"languageSort":87,"materialSort":34,"originSort":68,"typeSort":26},"ISic004420","Epitaph for Aristokrates",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"type":36,"subtype":285,"ref":39},[38],{"layout":287},{"p":288,"rs":289,"damage":10},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":44,"ana":45,"ref":46},{"lettering":291,"dimensions":292},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[293,295],{"type":51,"l":175,"from":53,"to":59,"h":294,"unit":55,"atLeast":294,"atMost":294},"49",{"type":57,"l":58,"from":53,"to":59,"unit":55},{"_":218,"notBefore":63,"notAfter":64,"evidence":65},[298,299],{"_":68,"type":69,"ref":70,"corresp":71,"region":72},{"_":8,"type":74,"ref":75,"offset":76,"region":72},[301],[79,80],[13,14],{"_":4,"role":3,"ref":5},{"type":85},{"_":87,"mainLang":88,"languages":306},[87],{"n":91,"url":308,"height":93,"width":94,"desc":95,"surfaceType":96},"ISic004420_tiled.tif",[310],{"atLeast":311,"atMost":311},49,[102],[105],[315,316,317,26,30,34,110,111,112,113,111,114,115,88],"isic004420","epitaph for aristokrates",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":320,"uri":320,"title":321,"status":322,"editionAuthor":24,"type":323,"objectType":324,"material":325,"condition":10,"layoutDesc":327,"handNote":331,"date":337,"places":339,"geo":342,"country":72,"provenance":68,"provenanceGeo":344,"region":82,"settlement":8,"repository":345,"idno":346,"textLang":347,"tmNumber":10,"facsimile":349,"letterHeights":351,"publications":354,"zotero":355,"keywords":356,"html":360,"idnoSort":117,"languageSort":87,"materialSort":34,"originSort":68,"typeSort":26},"ISic004421","Epitaph for Athanippos",{"_":23},{"_":26,"ana":27,"ref":28},{"_":30,"ana":31,"ref":32},{"_":34,"ana":35,"type":36,"subtype":326,"ref":39},[38],{"layout":328},{"p":329,"rs":330,"damage":10},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":44,"ana":45,"ref":46},{"lettering":332,"dimensions":333},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[334,336],{"type":51,"l":52,"from":53,"to":53,"h":335,"unit":55,"atLeast":335,"atMost":335},"29",{"type":57,"l":58,"from":53,"to":59,"h":60,"unit":55},{"_":338,"notBefore":63,"notAfter":64,"evidence":65},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[340,341],{"_":68,"type":69,"ref":70,"corresp":71,"region":72},{"_":8,"type":74,"ref":75,"offset":76,"region":72},[343],[79,80],[13,14],{"_":4,"role":3,"ref":5},{"type":85},{"_":87,"mainLang":88,"languages":348},[87],{"n":91,"url":350,"height":93,"width":94,"desc":95,"surfaceType":96},"ISic004421_tiled.tif",[352],{"atLeast":353,"atMost":353},29,[102],[105],[357,358,359,26,30,34,110,111,112,113,111,114,115,88],"isic004421","epitaph for athanippos",{"_":23},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>"],"uses":{"params":["slug"]}}]}
