od/66.html",{"ana":40},"#condition.fragment",{"layout":42},{"p":43,"rs":44,"damage":48},"Remains of two columns of text, with a space between of 1-2.5 cm. The right margin of the left column (A) is uneven, with a vacat equivalent to two line ends above the end of the first visibile line of text; the left margin of the right column is consistent.",{"_":45,"ana":46,"ref":47},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":49},"#text_condition.incomplete",{"lettering":51,"dimensions":52},"Arena notes that the quadrangular module of the individual letters is somewhat irregular, with the combined module of omicron-nu (used as a control across multiple similar fragments) being 10mm from centre to centre. Letters with neat terminal serifs, elegantly cut.",[53,60],{"type":54,"l":55,"from":56,"to":57,"h":58,"unit":59,"atLeast":58,"atMost":58},"letterHeight","Line 1-5","line1","line5","8","mm",{"type":61,"l":62,"from":56,"to":57,"h":63,"unit":59,"atLeast":63,"atMost":63},"interlinear","Interlineation","6",{"_":65,"notBefore":66,"notAfter":67,"evidence":68},"Later 2nd century BCE or early C1 BCE",-150,-51,"lettering",[70,74],{"_":71,"type":72,"ref":73},"Halaesa","ancient","http://pleiades.stoa.org/places/462225",{"_":75,"type":76,"ref":77,"offset":78},"Castel di Tusa","modern","http://sws.geonames.org/2525099","near",[80],[81,82],37.99907,14.26197,[],"Sicily",{"_":4,"role":3,"ref":5},{"_":87,"type":88},"ME30906","inventory",{"_":90,"mainLang":91,"languages":92},"Ancient Greek","grc",[90],"",[95,97],{"atLeast":96,"atMost":96},8,{"atLeast":98,"atMost":98},6,[100],"Arena, 2020, Nuove epigrafi greche da Halaesa Archonidea. Dati inediti sulle Tabulae Halaesinae e su una città della Sicilia tardo-ellenistica",[102],"KAIR5ZLR",[104,105,106,28,32,36,107,108,109,110,111,112,113,91],"isic001694","fragment of a public inscription",{"_":19},"halaesa","castel di tusa","italy","sicily","messina","soprintendenza beni culturali e ambientali di messina