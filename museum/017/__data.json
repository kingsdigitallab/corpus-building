,"geo":287,"country":66,"provenance":63,"provenanceGeo":289,"region":75,"settlement":8,"repository":290,"textLang":291,"tmNumber":293,"facsimile":294,"letterHeights":296,"publications":303,"zotero":305,"keywords":307,"html":312,"idnoSort":173,"languageSort":81,"materialSort":257,"originSort":63,"typeSort":179},"ISic003420","Fragment of an imperial honorific",{"_":19},{"_":179,"ana":180,"ref":254},"https://www.eagle-network.eu/voc/objtyp/lod/69.html",{"_":121,"ana":122,"ref":123},{"_":257,"ana":258,"type":32,"subtype":259,"resp":130,"ref":35},"Coarse-grained, homogeneous, white marble, likely Aphrodisian, Parian-2, Parian-3, Parian-4, Proconnesian, Thasian-3 (identification based on digital microscopy)","#material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Aphrodisian #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-2 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-3 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-4 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Proconnesian #material.inorganic.stone.metamorphic_rock.marble.dolomitic_marble.Thasian-3",[260,261,262,263,264,265],"Aphrodisian","Parian-2","Parian-3","Parian-4","Proconnesian","Thasian-3",{"ana":132},{"layout":268},{"p":269,"rs":270,"damage":271},"The beginning of two lines of monumental letters are preserved on the stone. A substantial left margin is preserved at the start of each line. Unless the lines below were substantially further indented, there was no text below; the preserved vacat above line 1 (90mm)  is significantly greater than that between lines 1 and 2 (57mm), so it is unclear if another line originally stood above (the top of the stone appears intact) - if it did, it was either significantly above the preserved first line and/or indented several letters to the right.",{"_":40,"ana":41,"ref":42},{"ana":138},{"lettering":273,"dimensions":274},"Deep, very regular, v-cut letters, with a broad v-cut, hair-line extensions to wedge serifs, and a quite wide square module. The I in line one is extended.",[275,278,281],{"type":46,"l":47,"from":48,"to":48,"h":276,"unit":50,"atLeast":277,"atMost":277},"68 (I = 87)","68",{"type":46,"l":279,"from":54,"to":54,"h":280,"unit":50,"atLeast":280,"atMost":280},"Line 2","58",{"type":52,"l":53,"from":48,"to":54,"h":282,"unit":50,"atLeast":282,"atMost":282},"57",{"_":146,"notBefore":147,"notAfter":148,"evidence":60},[285,286],{"_":63,"type":64,"ref":65,"corresp":151,"region":66},{"_":8,"type":68,"ref":69,"region":66},[288],[72,73],[],{"_":4,"role":3,"ref":5},{"_":81,"mainLang":82,"languages":292},[81],"644815",{"n":86,"url":295,"height":162,"width":161,"desc":163,"surfaceType":91},"ISic003420_tiled.tif",[297,299,301],{"atLeast":298,"atMost":298},68,{"atLeast":300,"atMost":300},58,{"atLeast":302,"atMost":302},57,[304,230],"Korhonen, 2004, La cultura epigrafica della colonia di Catina nell'alto impero",[306,238],"NMS48IZF",[308,309,310,179,121,311,106,107,108,109,107,110,111,82],"isic003420","fragment of an imperial honorific",{"_":19},"coarse-grained, homogeneous, white marble, likely aphrodisian, parian-2, parian-3, parian-4, proconnesian, thasian-3 (identification based on digital microscopy)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>div[o \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>tri[bunicia potestate \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>"],"uses":{"params":["slug"]}}]}
