\u003Cp class=\"miniapp\">\u003C/p>",{"file":401,"uri":401,"title":402,"status":403,"editionAuthor":21,"type":405,"objectType":406,"material":410,"condition":137,"layoutDesc":416,"handNote":420,"date":436,"places":439,"geo":442,"country":62,"provenance":59,"provenanceGeo":444,"region":72,"settlement":59,"repository":445,"textLang":446,"tmNumber":137,"facsimile":448,"letterHeights":450,"publications":459,"zotero":462,"keywords":465,"html":470,"idnoSort":118,"languageSort":75,"materialSort":411,"originSort":59,"typeSort":124},"ISic004390","Fragmentary early Christian funerary inscription",{"_":404},"edited",{"_":124,"ana":125,"ref":126},{"_":407,"ana":408,"ref":409},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":411,"ana":412,"type":413,"subtype":414,"ref":415},"marble\n                                    ","#material.inorganic.stone.metamorphic_rock.marble","stone.marble",[30],"http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":417},{"p":418,"rs":419,"damage":137},"Remains of three lines of Greek letters, with small space to the margin at top, and vacat to the right and a roughly consistent right margin, suggesting line ends are preserved. The letters on the fourth fragment are smaller, and preserve vacat to the left suggesting line beginning. A further line is partially preserved on the fourth fragment.",{"_":37,"ana":38,"ref":39},{"lettering":421,"dimensions":422},"The letters are fairly regularly cut, with almost no serifs/terminations to the strokes, excpt for the slight extension of the apex of alpha and delta. Alpha has broken bar; omicron is slightly ovoid and full size; pi has equal length verticals; epsilon is lunate; phi is rhomboid.",[423,425,429,431],{"type":45,"l":46,"from":47,"to":47,"h":424,"unit":48,"atLeast":424,"atMost":424},"12",{"type":45,"l":426,"from":52,"to":52,"h":427,"unit":48,"atLeast":424,"atMost":428},"Line 2","12-14","14",{"type":50,"l":51,"from":47,"to":52,"h":430,"unit":48,"atLeast":430,"atMost":430},"2",{"type":50,"l":432,"from":52,"to":433,"h":434,"unit":48,"atLeast":435,"atMost":430},"Interlineation line 2 to 3","line3","1-2","1",{"_":437,"notBefore":374,"notAfter":438,"evidence":149},"4th century CE",400,[440,441],{"_":59,"type":60,"ref":61,"region":62},{"_":64,"type":65,"ref":66,"region":62},[443],[69,70],[],{"_":4,"role":3,"ref":5},{"_":75,"mainLang":76,"languages":447},[75],{"n":80,"url":449,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004390_tiled.tif",[451,453,455,457],{"atLeast":452,"atMost":452},12,{"atLeast":452,"atMost":454},14,{"atLeast":456,"atMost":456},2,{"atLeast":458,"atMost":456},1,[460,461],"Tréziny, 2011, À propos d’une inscription funéraire paléochrétienne de Mégara Hyblaea","Tréziny, 2018, Mégara Hyblaea. 7, La ville classique, hellénistique et romaine",[463,464],"DFXDQ8GT","5UHWUE4K",[466,467,468,124,407,469,111,112,113,114,111,115,116,76],"isic004390","fragmentary early christian funerary inscription",{"_":404},"marble","\u003Cspan class=\"textpartnumber\" id=\"aba\">fragment (physical) a\u003C/span>  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"diva--interpretive\">  \u003Ca id=\"aa-l1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>τ]ό παιδὶον \u003Cbr id=\"aa-l2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[ὃς ἀπὲθανε] τῇ πρό \u003Cspan class=\"supraline\" title=\"line above\">ε\u003C/span>  \u003Cbr id=\"aa-l3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[εἰδῶν Σεπτε]μβρὶων \u003Cbr id=\"aa-l4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[ζῆσας ἔτη\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cspan class=\"textpartnumber\" id=\"abb\">fragment (physical) b\u003C/span>  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"divb--interpretive\">  \u003Ca id=\"ab-l1-interpretive\">\u003C!--0-->\u003C/a