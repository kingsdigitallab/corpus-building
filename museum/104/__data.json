12,96],"CV66J2Z8",[314,315,316,118,199,27,106,107,108,109,106,110,111,72],"isic003697","i.sicily inscription 003697",{"_":20},{"file":318,"uri":318,"title":319,"status":320,"editionAuthor":21,"type":321,"objectType":325,"material":326,"condition":30,"layoutDesc":327,"handNote":333,"date":339,"places":343,"geo":346,"country":10,"region":68,"settlement":57,"repository":348,"textLang":349,"facsimile":351,"provenance":57,"letterHeights":353,"publications":354,"zotero":355,"keywords":356,"html":360},"ISic003698","I.Sicily inscription 003698",{"_":20},{"_":322,"ana":323,"ref":324},"terminus","#function.terminus","http://www.eagle-network.eu/voc/typeins/lod/96.html",{"_":122,"ana":123,"ref":124},{"_":27,"ana":28,"ref":29},{"layout":328},{"p":329,"rs":330,"damage":331},"unclear whether the original text covered the entire upper face or not, being very weathered.",{"_":34,"ana":35,"ref":36},{"ana":332},"#text_condition.incomplete",{"dimensions":334},[335,338],{"type":42,"l":336,"from":44,"to":49,"h":337,"unit":45},"Line 1-2","75",{"type":47,"l":48,"from":44,"to":49,"unit":45},{"_":340,"notBefore":341,"notAfter":342,"precision":54},"4th-7th century CE",301,700,[344,345],{"_":57,"type":58,"ref":59},{"_":61,"type":62,"ref":63},[347],[66,67],{"_":4,"role":3,"ref":5},{"_":71,"mainLang":72,"languages":350},[71],{"n":75,"url":352,"height":77,"width":78,"desc":79,"surfaceType":80},"ISic003698_tiled.tif",[],[83,86],[93,96],[357,358,359,322,122,27,106,107,108,109,106,110,111,72],"isic003698","i.sicily inscription 003698",{"_":20},"Text encoding: Valentina Mignosa; Jonathan Prag, edition source:",{"file":362,"uri":362,"title":363,"status":364,"editionAuthor":21,"type":366,"objectType":367,"material":371,"condition":30,"layoutDesc":375,"handNote":379,"date":393,"places":396,"geo":399,"country":10,"region":68,"settlement":57,"repository":401,"textLang":402,"facsimile":404,"provenance":57,"letterHeights":406,"publications":407,"zotero":410,"keywords":413,"html":418},"ISic004390","Fragmentary early Christian funerary inscription",{"_":365},"edited",{"_":118,"ana":119,"ref":120},{"_":368,"ana":369,"ref":370},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":372,"ana":373,"ref":374},"marble\n                                    ","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":376},{"p":377,"rs":378,"damage":30},"Remains of three lines of Greek letters, with small space to the margin at top, and vacat to the right and a roughly consistent right margin, suggesting line ends are preserved. The letters on the fourth fragment are smaller, and preserve vacat to the left suggesting line beginning. A further line is partially preserved on the fourth fragment.",{"_":34,"ana":35,"ref":36},{"lettering":380,"dimensions":381},"The letters are fairly regularly cut, with almost no serifs/terminations to the strokes, excpt for the slight extension of the apex of alpha and delta. Alpha has broken bar; omicron is slightly ovoid and full size; pi has equal length verticals; epsilon is lunate; phi is rhomboid.",[382,384,387,389],{"type":42,"l":43,"from":44,"to":44,"h":383,"unit":45},"12",{"type":42,"l":385,"from":49,"to":49,"h":386,"unit":45},"Line 2","12-14",{"type":47,"l":48,"from":44,"to":49,"h":388,"unit":45},"2",{"type":47,"l":390,"from":49,"to":391,"h":392,"unit":45},"Interlineation line 2 to 3","line3","1-2",{"_":394,"notBefore":341,"notAfter":395,"evidence":140,"precision":54},"4th century CE",400,[397,398],{"_":57,"type":58,"ref":59},{"_":61,"type":62,"ref":63},[400],[66,67],{"_":4,"role":3,"ref":5},{"_":71,"mainLang":72,"languages":403},[71],{"n":75,"url":405,"height":77,"width":78,"desc":79,"surfaceType":80},"ISic004390_tiled.tif",[],[408,409],"Tréziny, 2011, À propos d’une inscription funéraire paléochrétienne de Mégara Hyblaea","Tréziny, 2018, Mégara Hyblaea. 7, La ville classique, hellénistique et romaine",[411,412],"DFXDQ8GT","5UHWUE4K",[414,415,416,118,368,417,106,107,108,109,106,110,111,72],"isic004390","fragmentary early christian funerary inscription",{"_":365},"marble","Text encoding: Jonathan Prag, edition source:",{"file":420,"uri":420,"title":421,"status":422,"editionAuthor":21,"type":423,"objectType":427,"material":431,"condition":30,"layoutDesc":432,"handNote":436,"date":446,"places":450,"geo":453,"country":10,"region":68,"settlement":57,"repository":455,"idno":456,"textLang":459,"facsimile":461,"provenance":57,"letterHeights":463,"publications":464,"zotero":465,"keywords":466,"html":418},"ISic004405","Small altar dedicated to Aphrodite",{"_":20},{"_":424,"ana":425,"ref":426},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":428,"ana":429,"ref":430},"altar","#object.altar","http://www.eagle-network.eu/voc/objtyp/lod/29.html",{"_":27,"ana":28,"ref":29},{"layout":433},{"p":434,"rs":435,"damage":30},"Three lines of Greek letters are incised into the front face, occupying most of the space between the mouldings, with a more or less consistent left margin and an uneven right margin",{"_":34,"ana":35,"ref":36},{"lettering":437,"dimensions":438},"The letters are somewhat unevenly incised. Horizontals on alpha and eta often slope down to the left; epsilon is lunate; theta is roughly circulate with a detached horizontal bar in the centre; mu is unevenly incised, with a middle stroke which does not descend all the way.",[439,442,444],{"type":42,"l":440,"from":44,"to":391,"h":441,"unit":45},"Line 1-3","3-7",{"type":47,"l":48,"from":44,"to":49,"h":443,"unit":45},"2-4",{"type":47,"l":390,"from":49,"to":391,"h":445,"unit":45},"0-2",{"_":447,"notBefore":448,"notAfter":449,"evidence":140,"precision":54},"2nd — 1st century BCE",-200,-1,[451,452],{"_":57,"type":58,"ref":59},{"_":61,"type":62,"ref":63},[454],[66,67],{"_":4,"role":3,"ref":5},{"_":457,"type":458},"MH C22","inventory",{"_":71,"mainLang":72,"languages":460},[71],{"n":75,"url":462,"height":77,"width":78,"desc":79,"surfaceType":80},"ISic004405_ti