ntry":60,"provenance":57,"provenanceGeo":431,"region":70,"settlement":57,"repository":432,"textLang":433,"tmNumber":133,"facsimile":435,"letterHeights":437,"publications":446,"zotero":449,"keywords":452,"html":457,"idnoSort":116,"languageSort":73,"materialSort":400,"originSort":57,"typeSort":122},"ISic004390","Fragmentary early Christian funerary inscription",{"_":393},"edited",{"_":122,"ana":123,"ref":124},{"_":396,"ana":397,"ref":398},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":400,"ana":401,"ref":402},"marble\n                                    ","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":404},{"p":405,"rs":406,"damage":133},"Remains of three lines of Greek letters, with small space to the margin at top, and vacat to the right and a roughly consistent right margin, suggesting line ends are preserved. The letters on the fourth fragment are smaller, and preserve vacat to the left suggesting line beginning. A further line is partially preserved on the fourth fragment.",{"_":35,"ana":36,"ref":37},{"lettering":408,"dimensions":409},"The letters are fairly regularly cut, with almost no serifs/terminations to the strokes, excpt for the slight extension of the apex of alpha and delta. Alpha has broken bar; omicron is slightly ovoid and full size; pi has equal length verticals; epsilon is lunate; phi is rhomboid.",[410,412,416,418],{"type":43,"l":44,"from":45,"to":45,"h":411,"unit":46,"atLeast":411,"atMost":411},"12",{"type":43,"l":413,"from":50,"to":50,"h":414,"unit":46,"atLeast":411,"atMost":415},"Line 2","12-14","14",{"type":48,"l":49,"from":45,"to":50,"h":417,"unit":46,"atLeast":417,"atMost":417},"2",{"type":48,"l":419,"from":50,"to":420,"h":421,"unit":46,"atLeast":422,"atMost":417},"Interlineation line 2 to 3","line3","1-2","1",{"_":424,"notBefore":363,"notAfter":425,"evidence":145},"4th century CE",400,[427,428],{"_":57,"type":58,"ref":59,"region":60},{"_":62,"type":63,"ref":64,