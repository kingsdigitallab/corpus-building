h fragment.",{"_":35,"ana":36,"ref":37},{"lettering":407,"dimensions":408},"The letters are fairly regularly cut, with almost no serifs/terminations to the strokes, excpt for the slight extension of the apex of alpha and delta. Alpha has broken bar; omicron is slightly ovoid and full size; pi has equal length verticals; epsilon is lunate; phi is rhomboid.",[409,411,415,417],{"type":43,"l":44,"from":45,"to":45,"h":410,"unit":46,"atLeast":410,"atMost":410},"12",{"type":43,"l":412,"from":50,"to":50,"h":413,"unit":46,"atLeast":410,"atMost":414},"Line 2","12-14","14",{"type":48,"l":49,"from":45,"to":50,"h":416,"unit":46,"atLeast":416,"atMost":416},"2",{"type":48,"l":418,"from":50,"to":419,"h":420,"unit":46,"atLeast":421,"atMost":416},"Interlineation line 2 to 3","line3","1-2","1",{"_":423,"notBefore":362,"notAfter":424,"evidence":144},"4th century CE",400,[426,427],{"_":57,"type":58,"ref":59},{"_":61,"type":62,"ref":63},[429],[66,67],[],{"_":4,"role":3,"ref":5},{"_":72,"mainLang":73,"languages":433},[72],{"n":77,"url":435,"height":79,"width":80,"desc":81,"surfaceType":82},"ISic004390_tiled.tif",[437,439,441,443],{"atLeast":438,"atMost":438},12,{"atLeast":438,"atMost":440},14,{"atLeast":442,"atMost":442},2,{"atLeast":444,"atMost":442},1,[446,447],"Tréziny, 2011, À propos d’une inscription funéraire paléochrétienne de Mégara Hyblaea","Tréziny, 2018, Mégara Hyblaea. 7, La ville classique, hellénistique et romaine",[449,450],"DFXDQ8GT","5UHWUE4K",[452,453,454,121,395,455,108,109,110,111,108,112,113,73],"isic004390","fragmentary early christian funerary inscription",{"_":392},"marble","\u003Cspan class=\"textpartnumber\" id=\"aba\">fragment (physical) a\u003C/span>  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"diva--interpretive\">  \u003Ca id=\"aa-l1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>τ]ό παιδὶον \u003Cbr id=\"aa-l2-interpretive\">\u003Cspan class=\"l