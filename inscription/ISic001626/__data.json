{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":100,"html":258,"xml":315},"ISic001626",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":19,"type":20,"support":24,"objectType":25,"material":29,"condition":37,"dimensions":39,"layoutDesc":50,"handNote":57,"date":74,"places":78,"geo":88,"country":83,"provenance":80,"provenanceFound":92,"provenanceGeo":96,"provenanceObserved":97,"provenanceLost":19,"graphics":100,"region":108,"settlement":85,"repository":109,"idno":122,"textLang":125,"bibliographyEdition":129,"bibliographyDiscussion":186,"citation":189,"tmNumber":8,"facsimile":230,"letterHeights":231,"publications":235,"zotero":241,"keywords":247,"lettering_types":257},"Epitaph for Sokrates",{"_":5},"draft",[7,10,12,14,16],{"_":8,"type":9},"645078","TM",{"type":11},"EDR",{"type":13},"EDH",{"type":15},"EDCS",{"_":17,"type":18},"316276","PHI",null,{"_":21,"ana":22,"ref":23},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","Marble plaque damaged on the left upper corner (restored with plaster).",{"_":26,"ana":27,"ref":28},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":30,"ana":31,"type":32,"subtype":33,"resp":35,"ref":36},"marble","#material.inorganic.stone","stone.unspecified",[34],"unspecified","#Coccato","http://www.eagle-network.eu/voc/material/lod/48.html",{"ana":38},"#condition.damaged",[40,44,47],{"_":41,"unit":42,"dimension":43},"36","cm","height",{"_":45,"unit":42,"dimension":46},"50","width",{"_":48,"unit":42,"dimension":49},"3.5","depth",{"layout":51},{"rs":52,"damage":56},{"_":53,"ana":54,"ref":55},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1","",{"lettering":58,"dimensions":59},"Regular letters with apices, lunate Ε and Σ, cursive Ω, A, Δ and Λ with extended serifs. Two Christograms at l. 2.",[60,69],{"type":61,"l":62,"from":63,"to":64,"h":65,"unit":6