hità, 1876-","Wessel, 1989, IGCVO","Ferrua, 1989, Note e giunte alle iscrizioni cristiane antiche della Sicilia",[242,243,244,245,246],"2EUC82DH","D9BZFDDR","4MCP2PVV","9CT5ZWIK","759ZXHKQ",[248,249,250,21,26,30,251,252,253,254,252,255,256,127],"isic001626","epitaph for sokrates",{"_":5},"catina","catania","sicilia","sicily","museo civico di catania","ancient greek",[],{"title":259,"body":260,"divs":261,"editions":288,"images":307,"handnote":313},"ISic001626. Epitaph for Sokrates","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σωκράτης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Σωκράτης\">\u003Cspan data-text=\"Σωκράτης\" data-n=\"5\" data-lemma=\"Σωκράτης\">Σωκράτης\u003C/span>\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>☧ \u003Cspan data-text=\"πάντων\" data-n=\"15\" data-lemma=\"πᾶς\">πάντων\u003C/span>  \u003Cspan data-text=\"ὁ\" data-n=\"20\" data-lemma=\"ὁ\">ὁ\u003C/span> ☧ \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"φίλος\" data-n=\"30\" data-lemma=\"φίλος\">φίλος\u003C/span>  \u003Cspan data-text=\"ἐνθά\n                    δε\" data-n=\"35\" data-lemma=\"ἐνθάδε\">ἐνθά-\u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>δε\u003C/span>  \u003Cspan data-text=\"κεῖται\" data-n=\"40\" data-lemma=\"κεῖμαι\">κεῖται\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Victoria Fendel, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-interpretive-simple-lemmatized\">  \u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Cspan data-text=\"Σωκράτης\" data-n=\"5\" data-lemma=\"Σωκράτης\">Σωκράτης\u003C/span>  \u003Cspan data-text=\"πάντων\" data-n=\"15\" data-lemma=\"πᾶς\">πάντων\u003C/span>  \u003Cspan data-text=\"ὁ\" data-n=\"20\" data-lemma=\"ὁ\">ὁ\u003C/span>  \u003Cspan data-text=\"φίλος\" data-n=\"30\" data-lemma=\"φίλος\">φίλος\u003C/span>  \u003Cspan data-text=\"ἐνθάδε\" data-n=\"35\" data-lemma=\"ἐνθάδε\">ἐνθάδε\u003C/span>  \u003Cspan data-text=\"κεῖται\" data-n=\"40\" data-lemma=\"κεῖμαι\">κεῖται\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σωκράτης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Σωκράτης\">\u003Cspan data-text=\"Σωκράτης\" data-n=\"5\" data-lemma=\"Σωκράτης\">ΣΩΚΡΑΤΗΣ\u003C/span>\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>☧\u003Cspan data-text=\"πάντων\" data-n=\"15\" data-lemma=\"πᾶς\">ΠΑΝΤΩΝ\u003C/span>\u003Cspan data-text=\"ὁ\" data-n=\"20\" data-lemma=\"ὁ\">Ο\u003C/span>☧\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"φίλος\" data-n=\"30\" data-lemma=\"φίλος\">ΦΙΛΟΣ\u003C/span>\u003Cspan data-text=\"ἐνθά\n                    δε\" data-n=\"35\" data-lemma=\"ἐνθάδε\">ΕΝΘΑ\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>ΔΕ\u003C/span>\u003Cspan data-text=\"κεῖται\" data-n=\"40\" data-lemma=\"κεῖμαι\">ΚΕΙΤΑΙ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Victoria Fendel, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-diplomatic-simple-lemmatized\">\u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Cspan data-text=\"Σωκράτης\" data-n=\"5\" data-lemma=\"Σωκράτης\">ΣΩΚΡΑΤΗΣ\u003C/span>\u003Cspan data-text=\"πάντων\" data-n=\"15\" data-lemma=\"πᾶς\">ΠΑΝΤΩΝ\u003C/span>\u003Cspan data-text=\"ὁ\" data-n=\"20\" data-lemma=\"ὁ\">Ο\u003C/span>\u003Cspan data-text=\"φίλος\" data-n=\"30\" data-lemma=\"φίλος\">ΦΙΛΟΣ\u003C/span>\u003Cspan data-text=\"ἐνθάδε\" data-n=\"35\" data-lemma=\"ἐνθάδε\">ΕΝΘΑΔΕ\u003C/span>\u003Cspan data-text=\"κεῖται\" data-n=\"40\" data-lemma=\"κεῖμαι\">ΚΕΙΤΑΙ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001626_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001626_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001626.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001626-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>  \u003Cspan>Text based on photograph\u003C/span>  \u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Orsi, Agnello, Wessel: πάντων ὁ | φίλος; Ferrua, Korhonen: πάντων | φίλος (Ο is part of the Christogram)\u003C/span>  \u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>Sokrates, the friend of all, lies here.\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Sokrates, l’amico di tutti, giace qui.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>This epitaph has a formula very similar to pagan epitaphs, although the presence of the two Christograms denotes it as Christian. Ferrua and Korhonen read \u003Cspan class=\"lang\" lang=\"grc\">πάντων φίλος\u003C/span> with the interpretation of \u003Cspan class=\"lang\" lang=\"grc\">Ο\u003C/span> as part of the Christogram, which in this case should be interpreted as \u003Cspan class=\"lang\" lang=\"grc\">ὁ Χ(ριστό)ς\u003C/span> (the same hight of the letter \u003Cspan class=\"lang\" lang=\"grc\">O\u003C/span> compared to the other letters of the text is probably a misinterpretation of the stonecutter). However, there is no need to eliminate the article since other parallels of similar epithets denoting friendship and affection in Christian inscriptions, such as IMusCatania 178 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001359\" target=\"_blank\">ISic001359\u003C/a> and SEG 65. 791 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001633\" target=\"_blank\">ISic001633\u003C/a> present the names of the deceased followed by adjectives preceded by the article (\u003Cspan class=\"lang\" lang=\"grc\">Κάλλιστος καὶ | Εὐκαρπία οἱ φιλόστορ|γοι\u003C/span> and \u003Cspan class=\"lang\" lang=\"grc\">ὁ πανφίλ|ητος ... Εὐδέμων\u003C/span> respectively).\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 1022 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000394\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000394\u003C/a>  \u003C/li>\u003Cli> Orsi NSA 1918 62 no.3 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001392\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001392\u003C/a>  \u003C/li>\u003Cli> Agnello 1953 no.58) \u003Ca href=\"https://biblio.inscriptiones.org/epig10002211\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002211\u003C/a>  \u003C/li>\u003Cli> Ferrua 1989 110 no.416 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001995\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001995\u003C/a>  \u003C/li>\u003Cli> Korhonen 2004 196 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>  \u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\"> \u003Cp>Regular letters with apices, lunate Ε and Σ, cursive Ω, A, Δ and Λ with extended serifs. Two Christograms at l. 2.\u003C/p> Lines 1-4  33-45  Interlineation line 1 to 2  not recorded  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[262,265,268,271,274,276,279,282,285],{"id":263,"html":264},"editions","\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σωκράτης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Σωκράτης\">\u003Cspan data-text=\"Σωκράτης\" data-n=\"5\" data-lemma=\"Σωκράτης\">Σωκράτης\u003C/span>\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>☧ \u003Cspan data-text=\"πάντων\" data-n=\"15\" data-lemma=\"πᾶς\">πάντων\u003C/span>  \u003Cspan data-text=\"ὁ\" data-n=\"20\" data-lemma=\"ὁ\">ὁ\u003C/span> ☧ \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"φίλος\" data-n=\"30\" data-lemma=\"φίλος\">φίλος\u003C/span>  \u003Cspan data-text=\"ἐνθά\n                    δε\" data-n=\"35\" data-lemma=\"ἐνθάδε\">ἐνθά-\u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>δε\u003C/span>  \u003Cspan data-text=\"κεῖται\" data-n=\"40\" data-lemma=\"κεῖμαι\">κεῖται\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Victoria Fendel, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-interpretive-simple-lemmatized\">  \u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Cspan data-text=\"Σωκράτης\" data-n=\"5\" data-lemma=\"Σωκράτης\">Σωκράτης\u003C/span>  \u003Cspan data-text=\"πάντων\" data-n=\"15\" data-lemma=\"πᾶς\">πάντων\u003C/span>  \u003Cspan data-text=\"ὁ\" data-n=\"20\" data-lemma=\"ὁ\">ὁ\u003C/span>  \u003Cspan data-text=\"φίλος\" data-n=\"30\" data-lemma=\"φίλος\">φίλος\u003C/span>  \u003Cspan data-text=\"ἐνθάδε\" data-n=\"35\" data-lemma=\"ἐνθάδε\">ἐνθάδε\u003C/span>  \u003Cspan data-text=\"κεῖται\" data-n=\"40\" data-lemma=\"κεῖμαι\">κεῖται\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σωκράτης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Σωκράτης\">\u003Cspan data-text=\"Σωκράτης\" data-n=\"5\" data-lemma=\"Σωκράτης\">ΣΩΚΡΑΤΗΣ\u003C/span>\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>☧\u003Cspan data-text=\"πάντων\" data-n=\"15\" data-lemma=\"πᾶς\">ΠΑΝΤΩΝ\u003C/span>\u003Cspan data-text=\"ὁ\" data-n=\"20