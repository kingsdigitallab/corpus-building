187_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001187.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Φιλοκλῆ\u003Csupplied reason=\"lost\">ς\u003C/supplied>\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"10\">χαῖρε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Φιλοκλῆς\">Φιλοκλῆς\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"χαίρω\">χαῖρε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003Cp>Text of IGPalermo\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Philokles, chaire; following Ferrua, it's pagan. This seems a daft comment given the date! I have a slide of this, which is on display in the epig. gallery of Palermo Museum. Wilson notes that if really on white marble, then must be imperial in date.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">364a\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGMusPalermo\">\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1973\u003C/date>\n                        \u003CcitedRange>39\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F66S4X3M\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000531\">https://biblio.inscriptiones.org/epig10000531\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2004\u003C/date>\n                        \u003CcitedRange>4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Salinas\u003C/author>