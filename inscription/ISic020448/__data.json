csimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020448_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020448.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>τᾶς \u003CpersName type=\"attested\">\u003Cname>\u003Cchoice>\u003Creg>Καλλικράτεος\u003C/reg>\u003Corig>Καλικράτεος\u003C/orig>\u003C/choice>\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronymic\">Μεννάδος\u003C/name>\u003C/persName>\u003C/persName> ε̄̓μί\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Arena 1989 (IGASM I)\u003C/note>\n                    \u003C/app>\n                    \u003Capp>\n                        \u003Cnote>Tusa: Καλικράτεος Μένναρός ε̄̓μι.\u003C/note>\n                    \u003C/app>\n                    \u003Capp>\n                        \u003Cnote>Villa: Μενναδο͂ς.\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#VM\">\n                \u003Cp>I am (the krater) of Mennados (son) of Kallikratos.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#VM\">\n                \u003Cp>Sono (il cratere) di Mennados (figlio) di Kallikratos.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>The first mu (initial of the name Μεννάδος) seems to have a very different \n                    ductus from the second one (in ε̄̓μί): the difference could be explained, according to Arena, \n                    by assuming an intervention by the writer who would have written a pi at first \n                    and then amended it to mu. The name Μεννάδος is not elsewhere attested.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IGASM1\">\n                        \u003Cauthor>Arena\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>74, fig. 12\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VC9IHZAR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000638\">https://biblio.inscriptiones.org/epig10000638\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Villa\u003C/author>\n                        \u003Cdate>1979\u003C/date>\n                        \u003CcitedRange>64ff., fig. 1, pl. 12, figs. 1-2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/BUZEARMI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001461\">https://biblio.inscriptiones.org/epig10001461\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Tusa\u003C/author>\n                        \u003Cdate>1971\u003C/date>\n                        \u003CcitedRange>27, pl. 6d\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/V74EPNKB\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001534\">https://biblio.inscriptiones.org/epig10001534\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
