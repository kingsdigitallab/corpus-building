/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#DD\">Dmitry Dundua's lemmatizations were added from source CoNLL-U files\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc using PyEpiDoc and associated scripts\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001493_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001493.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw n=\"5\">Εὔσκις\u003C/w> \u003Cw n=\"10\">ἔζη\n                    \u003Clb n=\"2\" break=\"no\"/>σεν\u003C/w> \u003Cw n=\"15\">ἔτη\u003C/w> \u003Cnum value=\"28\">\u003Cw n=\"20\">κη\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"25\">·\u003C/g> \u003Cname>\u003Cw n=\"30\">Ἀσ\n                    \u003Clb n=\"3\" break=\"no\"/>τομάχις\u003C/w>\u003C/name>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"35\">ἔζησεν\u003C/w>\n                    \u003Clb n=\"5\"/>\u003Cw n=\"40\">ἔτη\u003C/w> \u003Cg ref=\"#interpunct\" n=\"45\">·\u003C/g> \u003Cnum value=\"12\">\u003Cw n=\"50\">ιβ\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"55\">·\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Εὔσκις\">Εὔσκις\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"ζῶ\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"κη\">κη\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"Ἀστομάχις\">Ἀστομάχις\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"ζῶ\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ιβ\">ιβ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based upon Bitto 2001 with Photograph\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>Euskis lived for 28 years. Astomaxis lived for 12 years.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Double memorial, name plus age in years in each case; Euskis, that is Euskios, masc. form of Euskia known from another tomb (Orsi, Rom. Quart. (1895), 300), and also IG 14.246 where the name should read Euskios, not Eusebios. The other deceased is Astomachis.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IMusMessina\">\n                        \u003Cauthor>Bitto\u003C/author>\n                        \u003Cdate>2001\u003C/date>\n                        \u003CcitedRange>43\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/M9HMEP2R\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000029\">https://biblio.inscriptiones.org/epig10000029\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1941\u003C/date>\n                        \u003CcitedRange>253 no.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/P7QQ9SB6\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002655\">https://biblio.inscriptiones.org/epig10002655\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
