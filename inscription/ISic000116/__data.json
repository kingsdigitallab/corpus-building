\" xml:lang=\"la\" resp=\"#TA #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\" xml:id=\"ALΙAK\"/>\u003CpersName type=\"attested\" xml:id=\"ALΙAU\">\u003Cname xml:id=\"ALΙAe\">Musice\u003C/name>\n                    \u003Clb n=\"2\" xml:id=\"ALΙAo\"/>\u003CplaceName type=\"ethnic\" xml:id=\"ALΙAy\">\u003Cw xml:id=\"ALΙAΙ\" n=\"5\">\u003Cchoice xml:id=\"ALΙAΤ\">\u003Corig xml:id=\"ALΙAε\" n=\"10\">Viboniensis\u003C/orig>\u003Creg xml:id=\"ALΙAο\">Vibonensis\u003C/reg>\u003C/choice>\u003C/w>\u003C/placeName>\u003C/persName>\n                    \u003Clb n=\"3\" xml:id=\"ALΙBA\"/>\u003Cw xml:id=\"ALΙBK\" n=\"15\">\u003Cexpan xml:id=\"ALΙBU\">\u003Cabbr xml:id=\"ALΙBe\">ann\u003C/abbr>\u003Cex xml:id=\"ALΙBo\">orum\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" xml:id=\"ALΙBy\" n=\"20\">·\u003C/g> \u003Cnum value=\"26\" xml:id=\"ALΙBΙ\">XXVI\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of ILTermini\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#TA\">\n                \u003Cp>Musice, from Vibo (Valentia), aged 26\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The name is assumed to be a female Greek name, with the Greek nominative ending in -e (Manganaro however considered the name to be masculine).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624\u003C/date>\n                        \u003CcitedRange>93\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GIN6NANU\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002388\">https://biblio.inscriptiones.org/epig10002388\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>256\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1769\u003C/date>\n                        \u003CcitedRange>cl.6 no.7\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SPTB56H3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002084\">https://biblio.inscriptiones.org/epig10002084\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1784\u003C/date>\n                        \u003CcitedRange>cl.6 no.10\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/7PSFHSUH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002083\">https://biblio.inscriptiones.org/epig10002083\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arach