            \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462153\">Centuripae\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525032\">Centuripe\u003C/placeName>\n                            \t\u003Cgeo>37.62336, 14.74049\u003C/geo>\n\t\t\u003C/origPlace> \n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0200\" notAfter-custom=\"0200\" evidence=\"textual-context\">The use of Greek suggests a later Hellenistic date; the name 'Cornelius' suggests a very late Republican or more likely early Imperial date. A period in the second half of the first century BCE is perhaps most likely.\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1851\">Reported by Ansaldi as among material found in the area of the ancient bath building by the Aqua Amara spring in contrada Difesa, Centuripe\u003Cgeo>37.6233651,14.7405903\u003C/geo>\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cprovenance type=\"not-observed\" subtype=\"lost\">Lost.\u003C/provenance>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.honorific #function.dedication\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/69.html\" cert=\"low\">honorific; dedication\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-01-30\" who=\"#JP\">Jonathan Prag made initial edit from publications\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002950_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002950.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n         \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" xml:lang=\"grc\">\n                \u003Cab>\n                    \u003Cnote>Ansaldi reports that the text recorded a gymnasiarch by the name of Cornelius, and indicated in some fashion that it had been set up in front of the gymnasium\u003C/note>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>No copy of the text is preserved\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>A Greek inscription recording a gymnasiarch with the name Cornelius. It was seemingly lost even when Ansaldi reported it in 1851. It was apparentliy written in Greek, and the text indicated that it was erected in front of the gymnasium, and tha tthe gymnasiarch responsible was a Cornelius. Ansaldi laments its loss. Other texts record the existence of a gymnasium (ISic002945 and ISic004370), while a Latin text found elsewhere in the town (ISic000004) records the building of a sphaeristerium (part of a baths or gymnasium) by two Cornelii in the Imperial period. It is tempting to link the name Cornelius, at least to the same family, but there is no formal basis for doing so. The date of this text is clearly problematic, since the use of Greek suggests a pre-imperial date, while the name Cornelius encourages a date in the Imperial period (by comparison with other material). A date at the very end of the Republican period / beginning of the Augustan period is perhaps most likely.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Ansaldi\u003C/author>\n                        \u003Cdate>1851\u003C/date>\n                        \u003CcitedRange>\u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/724712\">15-16\u003C/ref>\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9BF3BJJI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002182\">https://biblio.inscriptiones.org/epig10002182\u003C/ref>\u003C/bibl>\n                    \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\n\t       \u003Cbibl type=\"corpus\" n=\"ILMusPalermo\">\n                         \u003Cauthor>Bivona\u003C/author>\n                         \u003Cdate>1970\u003C/date> \n\t           \u003CcitedRange>cf. 004\u003C/citedRange>\n\t           \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10002142\">https://biblio.inscriptiones.org/epig10002142\u003C/ref>\u003C/bibl>\n\t       \u003Cbibl>\n\t           \u003Cauthor>Wilson\u003C/author>\n\t           \u003Cdate>1990\u003C/date>\n\t           \u003CcitedRange>152 fig.130\u003C/citedRange>\n\t           \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VF9MMBI9\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10001509\">https://biblio.inscriptiones.org/epig10001509\u003C/ref>\u003C/bibl>\n\t       \u003Cbibl>\n\t           \u003Cauthor>Bivona\u003C/author>\n\t           \u003Cdate>1970\u003C/date>\n\t           \u003CcitedRange>22\u003C/citedRange>\n\t           \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10002142\">https://biblio.inscriptiones.org/epig10002142\u003C/ref>\u003C/bibl>\n\t       \u003Cbibl>\n\t           \u003Cauthor>Libertini\u003C/author>\n\t           \u003Cdate>1926\u003C/date>\n\t           \u003CcitedRange>75-76\u003C/citedRange>\n\t           \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VJZRAI26\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10001874\">https://biblio.inscriptiones.org/epig10001874\u003C/ref>\u003C/bibl>\n\t       \u003Cbibl>\n\t           \u003Cauthor>Libertini\u003C/author>\n\t           \u003Cdate>1949\u003C/date>\n\t           \u003CcitedRange>93-94\u003C/citedRange>\n\t           \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VQURX85J\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10001865\">https://biblio.inscriptiones.org/epig10001865\u003C/ref>\u003C/bibl>\n\t   \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
