30004_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic030004.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/isicily/items/SEW88NC7\">\n                \u003Cdiv type=\"textpart\" subtype=\"face\" n=\"a\">\n                \u003Cab>\n                    \u003Clb n=\"1\" style=\"text-direction:l-to-r\"/>τὰν Ε\u003Csupplied reason=\"explanation\">ὐ\u003C/supplied>κλέος γλο͂σαν κ\n                    \u003Clb n=\"2\" break=\"no\" style=\"text-direction:r-to-l\"/>αὶ τὰν Ἀριστοφάνιος\n                    \u003Clb n=\"3\" style=\"text-direction:l-to-r\"/>καὶ τ\u003Cunclear>ὰ\u003C/unclear>ν Ἀνγείλιος κα\n                    \u003Clb n=\"4\" break=\"no\" style=\"text-direction:r-to-l\"/>ὶ τ\u003Csupplied reason=\"lost\">ὰν\u003C/supplied> Ἀλκ\u003Csupplied reason=\"lost\">ί\u003C/supplied>φρ\u003Cunclear>ο\u003C/unclear>νο\u003Csupplied reason=\"lost\">ς\u003C/supplied> κ\n                    \u003Clb n=\"5\" break=\"no\" style=\"text-direction:l-to-r\"/>αὶ τὰν Ͱαγεστράτο̄ \u003Cunclear>τ\u003C/unclear>ο͂\n                    \u003Clb n=\"6\" break=\"no\" style=\"text-direction:r-to-l\"/>ν συνδίϙο̄ν \u003Cunclear>τ\u003C/unclear>ο͂\u003Cunclear>ν\u003C/unclear> \u003Csupplied reason=\"lost\">Ε\u003C/supplied>ὐ\u003Csupplied reason=\"lost\">κ\u003C/supplied>λί\n                    \u003Clb n=\"7\" break=\"no\" style=\"text-direction:l-to-r\"/>ος κα\u003Csupplied reason=\"lost\">ὶ\u003C/supplied> \u003Csupplied reason=\"lost\">τ\u003C/supplied>ο͂\u003Cunclear>ν\u003C/unclear> Ἀριστοφάνε\n                    \u003Clb n=\"8\" break=\"no\" style=\"text-direction:r-to-l\"/>ος \u003Csupplied reason=\"lost\">τὰς\u003C/supplied> \u003Csupplied reason=\"lost\">γ\u003C/supplied>λό̄\u003Csupplied reason=\"lost\">σ\u003C/supplied>ας κα\u003Csupplied reason=\"lost\">ὶ\u003C/supplied> \u003Csupplied reason=\"lost\">τ\u003C/supplied>ὰν\n                    \u003Clb n=\"9\" style=\"text-direction:l-to-r\"/>\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"4\"/>λ\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"1\"/>ονος \u003Csupplied reason=\"lost\">γλο͂σαν\u003C/supplied>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"textpart\" subtype=\"face\" n=\"b\">\n                \u003Cab>\n                    \u003Clb n=\"1\" style=\"text-direction:l-to-r\"/>καὶ τὰν Ο\u003Csupplied reason=\"lost\">ἰ\u003C/supplied>ν\u003Cunclear>ο\u003C/unclear>\u003Csupplied reason=\"lost\">θ\u003C/supplied>\u003Cunclear>έ\u003C/unclear>ο̄ καὶ τ\n                    \u003Clb n=\"2\" break=\"no\" style=\"text-direction:r-to-l\"/>ὰν \u003Cunclear>Α\u003C/unclear>\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"3\"/>\u003Csupplied reason=\"lost\">γ\u003C/supplied>\u003Cunclear>λ\u003C/unclear>ο͂\u003Csupplied reason=\"lost\">σ\u003C/supplied>αν\n                \u003C/ab>\n            \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Bettarini 2005\u003C/note>\n                    \u003C/app>\n                  \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp/>\n    