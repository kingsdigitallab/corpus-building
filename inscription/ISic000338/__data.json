"40\">Caepario\u003C/w>\u003C/name>\n                    \u003Clb n=\"3\"/>\u003Cname>\u003Cw n=\"45\">Sotericho\u003C/w>\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\" n=\"50\">·\u003C/g> \u003Cw n=\"55\">et\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"60\">filiae\u003C/w> \u003Cg ref=\"#interpunct\" n=\"65\">·\u003C/g> \u003Cw n=\"70\">eius\u003C/w>\n                    \u003Clb n=\"5\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"75\">\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>arcus\u003C/ex>\u003C/expan>\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"80\">·\u003C/g> \u003Cname>\u003Cw n=\"85\">Capillianus\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"6\"/>\u003Cw n=\"90\">fecit\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"dis\">Dis\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"manes\">Manibus\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"sacrum\">sacrum\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"Marcus\">Marco\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"Caeparius\">Caepario\u003C/w>\n                    \u003Cw n=\"45\" lemma=\"Soterichus\">Sotericho\u003C/w>\n                    \u003Cw n=\"55\" lemma=\"et\">et\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"filia\">filiae\u003C/w>\n                    \u003Cw n=\"70\" lemma=\"is\">eius\u003C/w>\n                    \u003Cw n=\"75\" lemma=\"Marcus\">Marcus\u003C/w>\n                    \u003Cw n=\"85\" lemma=\"Capillianus\">Capillianus\u003C/w>\n                    \u003Cw n=\"90\" lemma=\"facio\">fecit\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>CIL\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#TNS #MH\">\n                \u003Cp>Sacred to the gods of the underworld. Marcus Capillianus made this for Marcus Caeparius Soterichus and his daughter.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Inscription lost since Gualtherus\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>59\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7054\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],