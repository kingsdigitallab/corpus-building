onale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020435.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"xly-Grek\" resp=\"#VM\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003Cgap cert=\"low\" reason=\"lost\" extent=\"unknown\" unit=\"character\"/>τιαιεμ\u003Cgap cert=\"low\" reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cunclear>μ\u003C/unclear>ι\n                    \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" subtype=\"transliteration\" xml:lang=\"xly-Latn\">\n                \u003Cab/>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Agostiniani 2021 (IAS I, App.).\u003C/note>\n                    \u003C/app>\n                    \u003Capp>\n                        \u003Cnote>Calascibetta: τιαιεμ\u003C/note>\n                    \u003C/app>\n                    \u003Capp>\n                        \u003Cnote>Falsone: [---]τιαιεμ[---]\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp>\u003C!--No translation currently agreed-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp>\u003C!--No translation currently agreed-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>The editor, L. Agostiniani, rightly invites a comparison with the inscription \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020368\">ISic020368\u003C/ref> ]κυτιαιεμ[, from Grotta Vanella,\n                    which makes this text very problematic. The editor suggests that it may be an epigraphic forgery.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IAS I, App.\">\n                        \u003Cauthor>Agostiniani\u003C/author>\n                        \u003Cdate>2021\u003C/date>\n                        \u003CcitedRange>435\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VQEP8IPT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002320\">https://biblio.inscriptiones.org/epig10002320\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Agostiniani\u003C/author>\n                        \u003Cdate>1992\u003C/date>\n                        \u003CcitedRange>1, note 7\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/WJ94BXFS\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002312\">https://biblio.inscriptiones.org/epig10002312\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Calascibetta\u003C/author>\n                        \u003Cdate>1990\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/C834XVST\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001408\">https://biblio.inscriptiones.org/epig10001408\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Agostiniani\u003C/author>\n                        \u003Cdate>1988-1989\u003C/date>\n                        \u003CcitedRange>345, note 1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EJ2TIVJP\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002311\">https://biblio.inscriptiones.org/epig10002311\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Falsone\u003C/author>\n                        \u003Cdate>1988-1989\u003C/date>\n                        \u003CcitedRange>311\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SVZ8GPGQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002310\">https://biblio.inscriptiones.org/epig10002310\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n                    \u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
