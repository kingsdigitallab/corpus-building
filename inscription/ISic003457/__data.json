\"3884px\" width=\"5826px\">\n            \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; Photo R.J.A. Wilson\u003C/desc>\n        \u003C/graphic>\n        \u003Cgraphic n=\"print\" url=\"ISic003457.jpg\" height=\"3884px\" width=\"5826px\">\n            \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; Photo R.J.A. Wilson\u003C/desc>\n        \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\n                    \u003CpersName type=\"attested\">\n                        \u003Csupplied reason=\"lost\" cert=\"low\">\n                            \u003Cname>\n                                \u003Cexpan>\n                                    \u003Cabbr>L\u003C/abbr>\n                                    \u003Cex>ucius\u003C/ex>\n                                \u003C/expan>\n                            \u003C/name>\n                        \u003C/supplied>\n                        \u003Csupplied reason=\"lost\" cert=\"low\">\n                            \u003Cname>Plinius\u003C/name>\u003C/supplied>\n                        \u003Csupplied reason=\"lost\" cert=\"low\">    \n                        \u003Cname>\n                                \u003Cexpan>\n                                    \u003Cabbr>L\u003C/abbr>\n                                    \u003Cex>uci\u003C/ex>\n                                \u003C/expan>\n                            \u003C/name>\n                        \u003C/supplied>\n                        \u003Csupplied reason=\"lost\" cert=\"low\">\n                            \u003Cexpan>\n                                \u003Cabbr>f\u003C/abbr>\n                                \u003Cex>ilius\u003C/ex>\n                            \u003C/expan>\n                        \u003C/supplied>\n                        \u003Cname>\u003Csupplied reason=\"lost\" cert=\"low\">Ruf\u003C/supplied>us\n                        \u003C/name>\n                    \u003C/persName>\n                    \u003CroleName type=\"supracivic\" subtype=\"legatus.pro.praetore\">\u003Cexpan>\n                        \u003Cabbr>leg\u003C/abbr>\n                        \u003Cex>atus\u003C/ex>\n                    \u003C/expan>\n                    pro\n                    \u003Cexpan>\n                        \u003Cabbr>pr\u003C/abbr>\n                        \u003Cex>aetore\u003C/ex>\n                    \u003C/expan>\u003C/roleName>\n                   \u003CroleName type=\"supracivic\" subtype=\"praetor.designatus\"> \u003Cexpan>\n                        \u003Cabbr>pr\u003C/abbr>\n                        \u003Cex>aetor\u003C/ex>\n                    \u003C/expan>\n                    \u003Cexpan>\n                        \u003Cabbr>desig\u003C/abbr>\n                        \u003Cex>natus\u003C/ex>\n                    \u003C/expan>\u003C/roleName>\n                    \u003CpersName type=\"divine\">\u003Cname>Veneri\u003C/name> \u003Cname type=\"epithet\">Eque\n                    \u003Csupplied reason=\"lost\">stri\u003C/supplied>\u003C/name>\u003C/persName>\n                    \u003Csupplied reason=\"lost\" cert=\"low\">\n                        \u003Cexpan>\n                            \u003Cabbr>don\u003C/abbr>\n                            \u003Cex>um\u003C/ex>\n                        \u003C/expan>\n                    \u003C/supplied>\n                    \u003Csupplied reason=\"lost\" cert=\"low\">\n                        \u003Cexpan>\n                            \u003Cabbr>ded\u003C/abbr>\n                            \u003Cex>it\u003C/ex>\n                        \u003C/expan>\n                    \u003C/supplied>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Silvestrini 2014\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>[Lucius Plinius Rufus, son of Lucius] propraetorian legate, praetor designate, [gave this as a gift] to Venus Equestris\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Silvestrini 2014 plausibly suggests that this is a dedication set up by L. Plinius L.f. Rufus, legatus pro praetore of Sextus Pompeius and praetor designate for 33 BC, already attested at Lilybaeum in ILLRP 426 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic000007\">ISic000007\u003C/ref>. The inscription is referenced within AE 2007.678-679, although neither lemma there concerns this text.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>2014.537\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Silvestrini\u003C/author>\n                        \u003Cdate>2014\u003C/date>\n                        \u003CcitedRange>211-215 no.2 fig.5-6\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9JUZPUIJ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001581\">https://biblio.inscriptiones.org/epig10001581\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Silvestrini\u003C/author>\n                        \u003Cdate>2024\u003C/date>\n                        \u003CcitedRange>424-425, figs. 438-439\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/H5GJ8WQW\"/>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
