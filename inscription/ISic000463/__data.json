n=\"lost\">me\u003C/supplied>\u003Cunclear>m\u003C/unclear>oria Ma\u003Cunclear>u\u003C/unclear>\u003Csupplied reason=\"lost\" cert=\"low\">ri\u003C/supplied>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/>\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\"/> \u003Cg>((branch))\u003C/g>\n                    \u003Clb n=\"3\"/>\u003Csupplied reason=\"lost\">c\u003C/supplied>aprinar\u003Csupplied reason=\"lost\">ii\u003C/supplied>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text from autopsy\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Schubring: IORIAMA+; Mommsen: IORIAMAL\u003C/note>\u003C/app>\n                    \u003Capp loc=\"2\">\u003Cnote>Vertical stroke at start of line, but impossible to know if letter or decoration.\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Memorial of Maurus, seller of goat meat\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Transcribed by Schubring in materials sent to the Berlin academy in October 1865 (his no.219; now in the CIL archives), but no details of provenance are recorded. Ferrua proposed reading 'caprinarius' in the final line, accepted by both Rizzo and Chioffi.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseit