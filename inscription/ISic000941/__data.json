entità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Cmilestone unit=\"section\" n=\"a\"/>\n                        \u003Clb n=\"1\"/>Εὐμοίρει\n                        \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Θεοκτίστην\u003C/name>\u003C/persName>\n                    \u003Cmilestone unit=\"section\" n=\"b\"/>\n                        \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Οὐλπία\u003C/name>\u003C/persName> δέξε\n                        \u003Clb n=\"2\"/>τεκοῦσα \u003CpersName type=\"attested\">\u003Cname>Θεοκτίστην\u003C/name>\u003C/persName>\n                        \u003Clb n=\"3\"/>λαγόνεσ\u003Csupplied reason=\"lost\">σι\u003C/supplied>ν\n                    \u003Cmilestone unit=\"section\" n=\"c\"/>\n                        \u003Clb n=\"1\"/>Εὐμοίρει \u003CpersName type=\"attested\">\u003Cname>\u003Csupplied reason=\"lost\">Οὐλπία\u003C/supplied> \u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after IG, with slight changes\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Ferrua re-edits, scathing of past attempts and provides a ?definitive text of the main epitaph, a single hexameter, flanked by acclamations. Appeal to Ulpia to accept Theoktiste in her tomb.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>102\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">124\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>45.1419.5\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Kirchhoff\u003C/author>\n                        \u003Cdate>1877\u003C/date>\n                        \u003CcitedRange>9454\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/533T