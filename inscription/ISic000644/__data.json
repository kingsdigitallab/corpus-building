003C/abbr>\u003Cex>νες\u003C/ex>\u003C/expan>\u003C/w> \u003Cnum value=\"3\">γ\u003C/num> \u003Cw>\u003Cexpan>\u003Cabbr>ἡμέρ\u003C/abbr>\u003Cex>ας\u003C/ex>\u003C/expan>\u003C/w>\n                    \u003Clb n=\"6\"/>\u003Cnum value=\"15\">ιε\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of Manganaro, checked against photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>Rizzone: ἄμεμπτο-|ς\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Seberos, chrestos kai amenptos. Age in years, months, days. Name and lunate letters sugg. date for Mang. Republished with photograph by V.G. Rizzone in the small catalogue for Camarina antiquarium, with correction of provenance (Comiso, not Castiglione as in Manganaro)-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>2012.0630\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1994.0767\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003