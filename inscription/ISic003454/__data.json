ww.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-10-06\" who=\"#MB\">encoded text\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#DD\">Dmitry Dundua's lemmatizations were added from source CoNLL-U files\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc using PyEpiDoc and associated scripts\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003454_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003454.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#MB\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#cross_latin\" n=\"5\">†\u003C/g> \u003Cw n=\"10\">Ένθάδε\u003C/w>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"15\">\u003Cchoice>\u003Corig>κὲτε\u003C/orig>\u003Creg>κεῖται\u003C/reg>\u003C/choice>\u003C/w> \u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"25\">Ἰωά\n                    \u003Clb n=\"3\" break=\"no\"/>\u003Csupplied reason=\"lost\">νν\u003C/supplied>ης\u003C/w>\u003C/name> \u003Cw n=\"30\">μον\n                    \u003Clb n=\"4\" break=\"no\"/>\u003Csupplied reason=\"lost\">αχὸ\u003C/supplied>ς\u003C/w> \u003Cw n=\"35\">ὁ\u003C/w> \u003Cname>\u003Cw n=\"40\">Με\n                    \u003Clb n=\"5\" break=\"no\"/>\u003Csupplied reason=\"lost\">νου\u003C/supplied>θ\u003C/w>\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"10\" lemma=\"ἐνθάδε\">Ένθάδε\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"κεῖμαι\">κὲτε\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"Ἰωάννης\">Ἰωάννης\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"μοναχός\">μοναχὸς\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"ὁ\">ὁ\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"Μενουθ\">Μενουθ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Rizzone 2009\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n                \u003Capp loc=\"5\">\n                    \u003Crdg>\n                        μαν\u003Cnote>Rizzone 2009 suggests as alternative\u003C/note>\n                    \u003C/rdg>\n                \u003C/app>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#MB\">\n                \u003Cp>Qui giace Iohannes monaco, Menouth (o Mamanth).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#MB\">\n                \u003Cp>Here lies Iohannes Menouth (or Mamanth), the monk.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The text of Cordano 2005 / 2014 is misleading (and the suggestion that the text is in a mixture of Greek and Latin is clearly incorrect), and the edition of Rizzone is to be preferred.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>2009.0439\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>59.1110\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzone\u003C/author>\n                        \u003Cdate>2009\u003C/date>\n                        \u003CcitedRange>431-434 no.2 fig.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/P44QBETH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001634\">https://biblio.inscriptiones.org/epig10001634\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Cordano\u003C/author>\n                        \u003Cdate>2014\u003C/date>\n                        \u003CcitedRange>109 no.11\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/A3NF7B7J\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001366\">https://biblio.inscriptiones.org/epig10001366\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Cordano\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003CcitedRange>125\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/WECDMWG9\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002668\">https://biblio.inscriptiones.org/epig10002668\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
