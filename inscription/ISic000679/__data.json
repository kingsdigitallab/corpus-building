{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":115,"html":241,"xml":287},"ISic000679",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":45,"dimensions":47,"layoutDesc":58,"handNote":67,"date":87,"places":91,"geo":101,"country":96,"provenance":93,"provenanceFound":105,"provenanceGeo":109,"provenanceObserved":110,"provenanceLost":20,"graphics":115,"region":123,"settlement":98,"repository":124,"idno":138,"textLang":141,"bibliographyEdition":145,"bibliographyDiscussion":184,"citation":187,"tmNumber":8,"facsimile":214,"letterHeights":215,"publications":221,"zotero":225,"keywords":229,"lettering_types":240},"Honours for Publius Septimius Geta",{"_":5},"edited",[7,10,13,15,18],{"_":8,"type":9},"175745","TM",{"_":11,"type":12},"081488","EDR",{"type":14},"EDH",{"_":16,"type":17},"6100253","EDCS",{"type":19},"PHI",null,{"_":22,"ana":23,"ref":24},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html","Fragment of a thick grey marble plaque, intact along the lower edge, but broken on the other three sides. The lower edge is chipped, and the edge itself only roughly finished. The rear is finished smooth.",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":31,"ana":32,"type":33,"subtype":34,"resp":36,"ref":37,"placeName":38},"Fine to medium-grained, homogeneous, grey, calcitic marble, likely Proconnesian. Optical microscopy: heteroblastic to homeoblastic fabric. Digital microscopy: heteroblastic to homeoblastic fabric (identification based on pXRF, digital microscopy, XRD, optical microscopy)\n","#material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Proconnesian","stone.marble",[35],"Proconnesian","#Coccato","http://www.eagle-network.eu/voc/material/lod/48.html",{"type":39,"ref":40,"location":43},"provenance",{"_":41,"target":42},"Marmara District","https://www.geonames.org/741729/marmara-adasi.html",{"geo":44},"40.61972,27.61694",{"ana":46},"#condition.fragment",[48,52,55],{"_":49,"unit":50,"dimension":51},"19.8","cm","height",{"_":53,"unit":50,"dimension":54},"22.5","width",{"_":56,"unit":50,"dimension":57},"2.8-3.6 (right to left)","depth",{"layout":59},{"p":60,"rs":61,"damage":65},"Traces of four lines of Latin letters, guidelines are visible top and bottom of line 3; line four is much smaller.",{"_":62,"ana":63,"ref":64},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":66},"#text_condition.incomplete",{"lettering":68,"dimensions":69},"Deeply v-cut letters with serifs. Letters generally tend to the taller, thinner and slighly curved form. Upper horizontals curve up and away, P is sometimes open, L has a downward trailing foot, G has a very curved hook; Y in line 3 is much taller (58mm). Small triangular interpuncts.",[70,79,83],{"type":71,"l":72,"from":73,"to":74,"h":75,"unit":76,"atLeast":77,"atMost":78},"letterHeight","Line 2-3","line2","line3","46-51","mm","46","51",{"type":71,"l":80,"from":81,"to":81,"h":82,"unit":76,"atLeast":82,"atMost":82},"Line 4","line4","25",{"type":84,"l":85,"from":86,"to":73,"unit":76},"interlinear","Interlineation line 1 to 2","line1",{"_":88,"notBefore":89,"notAfter":90},"Presumably to fall within the period of Geta as either Caesar (from 198) or Augustus (209) and his death in late 211.",198,211,[92,97],{"_":93,"type":94,"ref":95,"region":96},"Tyndaris","ancient","http://pleiades.stoa.org/places/462527","Sicilia",{"_":98,"type":99,"ref":100,"region":96},"Tindari","modern","http://sws.geonames.org/10282151",[102],[103,104],38.14227,15.04385,{"_":106,"type":107,"subtype":108,"geo":20},"From the site of Tindari, but details of provenance not recorded.","found","discovered",[],{"_":111,"type":112,"subtype":113,"resp":114,"geo":20},"Prag, 2022-07-12, in the antiquarium","observed","autopsied","#JP",