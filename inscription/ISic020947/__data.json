\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.identification\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Identification\">identification\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"edited\">\n            \u003ClistChange>\n                \u003Cchange when=\"2025-12-01\" who=\"#JP\">Jonathan Prag created file based upon scheda provided by Rossana De Simone\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020947_tiled.tif\" height=\"620px\" width=\"726px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020947.jpg\" height=\"620px\" width=\"726px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"transliteration-primary\" xml:space=\"preserve\" xml:lang=\"xpu-Latn\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/EGNUE9CZ\">\n                \u003Cab>\n                    \u003Clb n=\"1\" style=\"text-direction:r-to-l\"/>ʾl\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after De Simone 2013\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#RDS\">\n                \u003Cp> ʾl\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#RDS\">\n                \u003Cp>ʾl\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#RDS\">\n                \u003Cp>The first letter (Aleph) is written upright, and before writing the second letter (Lamed), the scribe rotated the vessel counterclockwise. It could be interpreted as an abbreviation (of a name) or a commercial sigla. The text appears to be complete.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Spagnoli\u003C/author>\n                        \u003Cdate>2012\u003C/date>\n                        \u003CcitedRange>53 fig.35\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SYUJJPT8\"/>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Simone\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>26 MO.5 fig.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EGNUE9CZ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002545\">https://biblio.inscriptiones.org/epig10002545\u003C/ref>\n                    \u003C/bibl>\n                  \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
