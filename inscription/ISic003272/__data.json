ial.stone.marble\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/257\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--measurements from Korhonen-->\n                                        \u003Cheight unit=\"cm\">12.5\u003C/height>\n                                        \u003Cwidth unit=\"cm\">14.5\u003C/width>\n                                        \u003Cdepth unit=\"cm\">2\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                    \u003Cdamage/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>A with straight bar, lunate Σ, Ο at l. 2 has a mark inside.\u003C/p>\u003C!--measurements from Korhonen-->\n                                \u003Clocus from=\"line1\" to=\"line3\">Lines 1-3\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"20\" atMost=\"25\">20-25\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\">not recorded\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462270\">Catina\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525068\">Catania\u003C/placeName>\n                                \u003Cgeo>37.49223, 15.07041\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0151\" notAfter-custom=\"0300\">End 2nd — end 3rd century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\">Original discovery not recorded, but probably from Catania.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\">Observed by Korhonen in Magazzino superiore, Museo Civico.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-08-26\" who=\"#AA\">Alex Antoniou Epidoc editing\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-12-22\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#VF\">Victoria Fendel's lemmatizations were added from source CoNLL-U files using PyEpiDoc and associated scripts\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003272_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003272.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" n=\"5\"/>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"10\"/>\u003Corig n=\"15\">ΙΣΙ\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"20\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"25\"/>\u003Corig n=\"30\">\u003Cunclear>Σ\u003C/unclear>\u003C/orig> \u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\" n=\"35\"/>\u003Corig n=\"40\">Ι\u003C/orig> \u003Cw n=\"45\">οὐ\n                    \u003Clb n=\"3\" break=\"no\"/>\u003Csupplied reason=\"lost\">δεὶς\u003C/supplied>\u003C/w> \u003Cw n=\"50\">\u003Csupplied reason=\"lost\">ἀθ\u003C/supplied>άνατος\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" n=\"5\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"10\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Corig n=\"15\">ΙΣΙ\u003C/orig>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"20\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"25\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Corig n=\"30\">Σ\u003C/orig>\n                    \u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\" n=\"35\">\u003Cdesc>[.]\u003C/desc>\u003C/gap>\n\t\t\t\t\t\u003Corig n=\"40\">Ι\u003C/orig>\n                    \u003Cw n=\"45\" lemma=\"οὐδείς\">οὐδεὶς\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ἀθάνατος\">ἀθάνατος\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based on photograph\u003C/note>\n                    \u003C/app>\n                    \u003Capp>\n                        \u003Cnote>Korhonen restores οὐ[δεὶς] at l. 2, but it seems there is a space after υ and that the restoration should continue at l. 3\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>… Nobody is immortal.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>… Nessuno è immortale.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>The fragment is part of an epitaph: Korhonen restores a formula found in Greek pagan and Christian inscriptions and in Latin funerary inscriptions (in which it occurs in Greek), \u003Cforeign xml:lang=\"grc\">οὐδεὶς ἀθάνατος\u003C/foreign>. The formula is found in another Latin inscription from Catania, CIL 10.7111 = IG 14.513 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic000393\">ISic000393\u003C/ref>: on the formula, see Marcel Simon, ‘Θάρσει Οὐδεὶς Ἀθάνατος: Étude de Vocabulaire Religieux', Revue de l'histoire des religions 113 (1936): 188–206. The traces at l. 2 are not compatible with \u003Cforeign xml:lang=\"grc\">εὐψύχ(ε)ι\u003C/foreign>, which usually accompanies the expression. It is not possible to say whether this is a pagan or a Christian epitaph.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>54.0908\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2004\u003C/date>\n                        \u003CcitedRange>159\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n\t       \u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
