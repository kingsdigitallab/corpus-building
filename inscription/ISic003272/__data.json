profileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-08-26\" who=\"#AA\">Alex Antoniou Epidoc editing\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-12-22\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#VF\">Victoria Fendel's lemmatizations were added from source CoNLL-U files using PyEpiDoc and associated scripts\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003272_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003272.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" n=\"5\"/>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"10\"/>\u003Corig n=\"15\">ΙΣΙ\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"20\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"25\"/>\u003Corig n=\"30\">\u003Cunclear>Σ\u003C/unclear>\u003C/orig> \u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\" n=\"35\"/>\u003Corig n=\"40\">Ι\u003C/orig> \u003Cw n=\"45\">οὐ\n                    \u003Clb n=\"3\" break=\"no\"/>\u003Csupplied reason=\"lost\">δεὶς\u003C/supplied>\u003C/w> \u003Cw n=\"50\">\u003Csupplied reason=\"lost\">ἀθ\u003C/supplied>άνατος\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" n=\"5\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"10\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Corig n=\"15\">ΙΣΙ\u003C/orig>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"20\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"25\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Corig n=\"30\">Σ\u003C/orig>\n                    \u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\" n=\"35\">\u003Cdesc>[.]\u003C/desc>\u003C/gap>\n\t\t\t\t\t\u003Corig n=\"40\">Ι\u003C/orig>\n                    \u003Cw n=\"45\" lemma=\"οὐδείς\">οὐδεὶς\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ἀθάνατος\">ἀθάνατος\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based on photograph\u003C/note>\n                    \u003C/app>\n                    \u003Capp>\n                        \u003Cnote>Korhonen restores οὐ[δεὶς] at l. 2, but it seems there is a space after υ and that the restoration should continue at l. 3\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>… Nobody is immortal.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>… Nessuno è immortale.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>The fragment is part of an epitaph: Korhonen restores a formula found in Greek pagan and Christian inscriptions and in Latin funerary inscriptions (in which it occurs in Greek), \u003Cforeign xml:lang=\"grc\">οὐδεὶς ἀθάνατος\u003C/foreign>. The formula is found in another Latin inscription from Catania, CIL 10.7111 = IG 14.513 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic000393\">ISic000393\u003C/ref>: on the formula, see Marcel Simon, ‘Θάρσει Οὐδεὶς Ἀθάνατος: Étude de Vocabulaire Religieux', Revue de l'histoire des religions 113 (1936): 188–206. The traces at l. 2 are not compatible with \u003Cforeign xml:lang=\"grc\">εὐψύχ(ε)ι\u003C/foreign>, which usually accompanies the expression. It is not possible to say whether this is a pagan or a Christian epitaph.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>54.0908\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2004\u003C/date>\n                        \u003CcitedRange>159\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n\t       \u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
