han Prag","#JP",{"_":214,"ref":215},[218,221,225,229,233,237],{"_":214,"xml:id":219,"ref":220},"JP","http://orcid.org/0000-0003-3819-8537",{"_":222,"xml:id":223,"ref":224},"Marta Fogagnolo","martaf","https://orcid.org/0000-0001-5187-5163",{"_":226,"xml:id":227,"ref":228},"James Cummings","JCu","http://orcid.org/0000-0002-6686-3728",{"_":230,"xml:id":231,"ref":232},"Alex Antoniou","AA","http://orcid.org/0000-0001-7077-0703",{"_":234,"xml:id":235,"ref":236},"Simona Stoyanova","SS","https://orcid.org/0000-0003-3914-9569",{"_":238,"xml:id":239,"ref":240},"Alessia Coccato","Coccato","https://orcid.org/0000-0002-6641-2820",{"_":242,"when":243,"who":244},"Marta Fogagnolo revised the text encoding, added dimensions, italian translation and commentary","2022-10-31","#martaf",{"n":108,"url":109,"height":110,"width":111,"desc":112,"surfaceType":113},[247],{"atLeast":248,"atMost":249},15,22,[251,252,253,254,255,256],"Amico, 1741, Catana Ilustrata","Kaibel, 1890, IG","Korhonen, 2004, IMusCatania","Curtius, Kirchhoff, Roehl, 1877, CIG","Wessel, 1989, IGCVO","Ferrua, 1941, Epigrafica sicula pagana e cristiana",[258,259,260,261,262,263],"F5INCW3T","Q2SBPG9F","2EUC82DH","533T8HNS","9CT5ZWIK","4HR4GXBX",[265,266,267,24,29,33,268,269,270,271,269,272,273,133],"isic001352","epitaph for euploutos",{"_":5},"catina","catania","sicilia","sicily","museo civico di catania","ancient greek",[],{"title":276,"body":277,"divs":278,"editions":305,"images":315,"handnote":321},"ISic001352. Epitaph for Euploutos","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"Ἐνθάδε\">Ἐνθάδε\u003C/span>\u003Cspan data-text=\" κεῖται\"> κ[εῖται]\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὔπλουτος\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὔπλουτος\">Εὔπλουτ[ος\u003C/span>\u003C/span> ζήσας] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> δεκ[α´ \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"Ἐνθάδε\">ΕΝΘΑΔΕ\u003C/span>\u003Cspan data-text=\" κεῖται\">Κ[.....]\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὔπλουτος\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὔπλουτος\">ΕΥΠΛΟΥΤ[..\u003C/span>\u003C/span>.....]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">ΕΤΗ\u003C/span>ΔΕΚ[.\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001352_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001352_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001352.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001352-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photographs; note that modern repainting is misleading / erroneous in some letters.\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 1\">line.1: \u003Cspan>κ[ῖτε Wessel\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Amico, Kaibel: ΕΥΠΑΘΥΤ; Kirchhof: Εὐπάθτ[ος; Ferrua: Εὔπλους; Wessel: Εὐπᾶ θυάτηρ ζήσασα; Korhonen: Εὔπλουτ[ος\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 3\">line.3: \u003Cspan>Ferrua: δεκ[απέντε\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0001-7077-0703\">Alex Antoniou\u003C/a>\u003C/p>  \u003Cp>Here lies Euploutos, having lived for ten(?) years.\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Qui giace Euploutos, avendo vissuto dieci(?) anni.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>This short Christian epitaph has the traditional formula \u003Cspan class=\"lang\" lang=\"grc\">ἔνθαδε κεῖται\u003C/span> followed by the name of the deceased and his age (see Korhonen 2004: 105-107). The name has been restored in different ways: from Kirchhof’s reading \u003Cspan class=\"lang\" lang=\"grc\">Εὐπάθητος\u003C/span> (palaeographically implausible and not otherwise attested, and based upon the misleading overpainting) to Wessel’s reading \u003Cspan class=\"lang\" lang=\"grc\">Εὐπᾶ θυγάτηρ ζήσασα\u003C/span> (palaeographically implausible), from Ferrua’s reading \u003Cspan class=\"lang\" lang=\"grc\">Εὔπλους\u003C/span> to Korhonen’s reading \u003Cspan class=\"lang\" lang=\"grc\">Εὔπλουτος\u003C/span>. Even if \u003Cspan class=\"lang\" lang=\"grc\">Εὔπλους\u003C/span> is better attested (perhaps also in another inscription from Catania, IG 14.452), \u003Cspan class=\"lang\" lang=\"grc\">Εὔπλουτος\u003C/span> seems more probable considering the shape of the last letter at l. 2 (see NSA 1895, p. 235 Euploutus, Capri, 1st cent. CE).\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 1357 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000394\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000394\u003C/a>\u003C/li>\u003Cli> Amico 1741 275 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002186\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002186\u003C/a>\u003C/li>\u003Cli> Kirchhoff 1877 9502 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001249\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001249\u003C/a>\u003C/li>\u003Cli> Kaibel 1890 \u003Ca href=\"https://clio.columbia.edu/catalog/6873760\" target=\"_blank\">533\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10001072\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001072\u003C/a>\u003C/li>\u003Cli> Ferrua 1941 222 no.108 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001456\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001456\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 184 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli> Korhonen 2004 105-107 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>Irregular letters, Α and Δ with serifs; quadrate Ε; nearly rhomboid O at l. 2.\u003C/p>  Lines 1-3  15-22  Interlineation line 1 to 2  not recorded  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[279,282,285,288,291,293,296,299,302],{"id":280,"html":281},"editions","\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"Ἐνθάδε\">Ἐνθάδε\u003C/span>\u003Cspan data-text=\" κεῖται\"> κ[εῖται]\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὔπλουτος\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὔπλουτος\">Εὔπλουτ[ος\u003C/span>\u003C/span> ζήσας] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> δεκ[α´ \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"Ἐνθάδε\">ΕΝΘΑΔΕ\u003C/span>\u003Cspan data-text=\" κεῖται\">Κ[.....]\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὔπλουτος\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὔπλουτος\">ΕΥΠΛΟΥΤ[..\u003C/span>\u003C/span>.....]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">ΕΤΗ\u003C/span>ΔΕΚ[.\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":283,"html":284},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001352_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001352_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001352.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001352-thumb.jpg\">\u003C/a>",{"id":286,"html":287},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photographs; note that modern repainting is misleading / erroneous in some letters.\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 1\">line.1: \u003Cspan>κ[ῖτε Wessel\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Amico, Kaibel: ΕΥΠΑΘΥΤ; Kirchhof: Εὐπάθτ[ος; Ferrua: Εὔπλους; Wessel: Εὐπᾶ θυάτηρ ζήσασα; Korhonen: Εὔπλουτ[ος\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 3\">line.3: \u003Cspan>Ferrua: δεκ[απέντε\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":289,"html":290},"translation","\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0001-7077-0703\">Alex Antoniou\u003C/a>\u003C/p>  \u003Cp>Here lies Euploutos, having lived for ten(?) years.\u003C/p>  ",{"id":289,"html":292},"\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Qui giace Euploutos, avendo vissuto dieci(?) anni.\u003C/p>  ",{"id":294,"html":295},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>This short Christian epitaph has the traditional formula \u003Cspan class=\"lang\" lang=\"grc\">ἔνθαδε κεῖται\u003C/span> followed by the name of the deceased and his age (see Korhonen 2004: 105-107). The name has been restored in different ways: from Kirchhof’s reading \u003Cspan class=\"lang\" lang=\"grc\">Εὐπάθητος\u003C/span> (palaeographically implausible and not otherwise attested, and based upon the misleading overpainting) to Wessel’s reading \u003Cspan class=\"lang\" lang=\"grc\">Εὐπᾶ θυγάτηρ ζήσασα\u003C/span> (palaeographically implausible), from Ferrua’s reading \u003Cspan class=\"lang\" lang=\"grc\">Εὔπλους\u003C/span> to Korhonen’s reading \u003Cspan class=\"lang\" lang=\"grc\">Εὔπλουτος\u003C/span>. Even if \u003Cspan class=\"lang\" lang=\"grc\">Εὔπλους\u003C/span> is better attested (perhaps also in another inscription from Catania, IG 14.452), \u003Cspan class=\"lang\" lang=\"grc\">Εὔπλουτος\u003C/span> seems more probable considering the shape of the last letter at l. 2 (see NSA 1895, p. 235 Euploutus, Capri, 1st cent. CE).\u003C/p>  ",{"id":297,"html":298},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 1357 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000394\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000394\u003C/a>\u003C/li>\u003Cli> Amico 1741 275 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002186\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002186\u003C/a>\u003C/li>\u003Cli> Kirchhoff 1877 9502 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001249\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001249\u003C/a>\u003C/li>\u003Cli> Kaibel 1890 \u003Ca href=\"https://clio.columbia.edu/catalog/6873760\" target=\"_blank\">533\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10001072\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001072\u003C/a>\u003C/li>\u003Cli> Ferrua 1941 222 no.108 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001456\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001456\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 184 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli> Korhonen 2004 105-107 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  ",{"id":300,"html":301},"handnote","\u003Cp>Irregular letters, Α and Δ with serifs; quadrate Ε; nearly rhomboid O at l. 2.\u003C/p>  Lines 1-3  15-22  Interlineation line 1 to 2  not recorded  ",{"id":303,"html":304},"license"," Licensed under a Creative Commons-Attribution 4.0 licence. ",[306,308,311,312],{"html":307},"Text encoding: Marta Fogagnolo",{"id":309,"lang":133,"html":310},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"Ἐνθάδε\">Ἐνθάδε\u003C/span>\u003Cspan data-text=\" κεῖται\"> κ[εῖται]\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὔπλουτος\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὔπλουτος\">Εὔπλουτ[ος\u003C/span>\u003C/span> ζήσας] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> δεκ[α´ \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":307},{"id":313,"lang":133,"html":314},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"Ἐνθάδε\">ΕΝΘΑΔΕ\u003C/span>\u003Cspan data-