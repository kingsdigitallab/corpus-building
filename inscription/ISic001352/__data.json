    \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Funerary\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-07-15\" who=\"#AA\">Alex Antoniou Epidoc editing and English translation\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-10-31\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, italian translation and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001352_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001352.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw>Ἐνθάδε\u003C/w>\u003Cw> κ\u003Csupplied reason=\"lost\">εῖται\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Εὔπλουτ\u003Csupplied reason=\"lost\">ος\u003C/supplied>\u003C/name>\u003C/persName> \u003Csupplied reason=\"lost\">ζήσας\u003C/supplied>\n                    \u003Clb n=\"3\"/>\u003Cw>ἔτη\u003C/w> \u003Cnum value=\"10\">δεκ\u003Csupplied reason=\"lost\">α\u003C/supplied>\u003C/num> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photographs; note that modern repainting is misleading / erroneous in some letters.\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 1\">\u003Cnote>κ[ῖτε Wessel\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 2\">\u003Cnote>Amico, Kaibel: ΕΥΠΑΘΥΤ; Kirchhof: Εὐπάθ\u003Ccorr>η\u003C/corr>τ[ος; Ferrua: Εὔπλους; Wessel: Εὐπᾶ θυ\u003Ccorr>γ\u003C/corr>άτηρ ζήσασα; Korhonen: Εὔπλουτ[ος\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 3\">\u003Cnote>Ferrua: δεκ[απέντε\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>Here lies Euploutos, having lived for ten(?) years.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>Qui giace Euploutos, avendo vissuto dieci(?) anni.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>This short Christian epitaph has the traditional formula \u003Cforeign xml:lang=\"grc\">ἔνθαδε κεῖται\u003C/foreign> followed by the name of the deceased and his age (see Korhonen 2004: 105-107). The name has been restored in different ways: from Kirchhof’s reading \u003Cforeign xml:lang=\"grc\">Εὐπάθητος\u003C/foreign> (palaeographically implausible and not otherwise attested, and based upon the misleading overpainting) to Wessel’s reading \u003Cforeign xml:lang=\"grc\">Εὐπᾶ θυγάτηρ ζήσασα\u003C/foreign> (palaeographically implausible), from Ferrua’s reading \u003Cforeign xml:lang=\"grc\">Εὔπλους\u003C/foreign> to Korhonen’s reading \u003Cforeign xml:lang=\"grc\">Εὔπλουτος\u003C/foreign>. Even if \u003Cforeign xml:lang=\"grc\">Εὔπλους\u003C/foreign> is better attested (perhaps also in another inscription from Catania, IG 14.452), \u003Cforeign xml:lang=\"grc\">Εὔπλουτος\u003C/foreign> seems more probable considering the shape of the last letter at l. 2 (see NSA 1895, p. 235 Euploutus, Capri, 1st cent. CE).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Amico\u003C/author>\n                        \u003Cdate>1741\u003C/date>\n                        \u003CcitedRange>275\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F5INCW3T\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002186\">https://biblio.inscriptiones.org/epig10002186\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">533\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>184\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Kirchhoff\u003C/author>\n                        \u003Cdate>1877\u003C/date>\n                        \u003CcitedRange>9502\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/533T8HNS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001249\">https://biblio.inscriptiones.org/epig10001249\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGCVO\">\n                        \u003CcitedRange>1357\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9CT5ZWIK\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000394\">https://biblio.inscriptiones.org/epig10000394\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1941\u003C/date>\n                        \u003CcitedRange>222 no.108\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4HR4GXBX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001456\">https://biblio.inscriptiones.org/epig10001456\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\n\t       \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n\t           \u003CcitedRange>105-107\u003C/citedRange>\n\t           \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n\t   \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
