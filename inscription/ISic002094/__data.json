5620px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana;  photo R.J.A. Wilson 2022-06-04\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/TLANX4H9\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#cross_greek\">&#x1F7A3;\u003C/g> \u003CpersName type=\"attested\">\u003Cname>\u003Chi rend=\"reversed\">S\u003C/hi>oter\u003C/name>\u003C/persName> \u003Cchoice>\u003Corig>defuc\n                    \u003Clb n=\"2\" break=\"no\"/>tu\u003Chi rend=\"reversed\">s\u003C/hi>\u003C/orig>\u003Creg>defunctus\u003C/reg>\u003C/choice> e\u003Chi rend=\"reversed\">s\u003C/hi>t pridi\n                    \u003Clb n=\"3\" break=\"no\"/>e idu\u003Chi rend=\"reversed\">s\u003C/hi> \u003Chi rend=\"reversed\">S\u003C/hi>epte\u003Chi rend=\"reversed\">n\u003C/hi>\n                   \u003Clb n=\"4\" break=\"no\"/>bre\u003Chi rend=\"reversed\">s\u003C/hi> indictio\n                    \u003Clb n=\"5\" break=\"no\"/>ne octaba\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Terranova, checked against photograph\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>((cross)) Soter died the day before the Ides of September, in the eighth indiction.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"Terranova\">\n                \u003Cp>Soter è morto il giorno prima delle Idi di settembre nel corso della indizione ottava\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Terranova\u003C/author>\n                        \u003Cdate>2014\u003C/date>\n                        \u003CcitedRange>81 no.87\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TLANX4H9\"/>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzone\u003C/author>\n                        \u003Cdate>2014-2015\u003C/date>\n                        \u003CcitedRange>75 no.5 fig.5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/S3G73QA2\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001626\">https://biblio.inscriptiones.org/epig10001626\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
