rary context (as Muscolino also notes, most likely to be in re-use, not funerary).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Muscolino\u003C/author>\n                        \u003Cdate>2011-2012\u003C/date>\n                        \u003CcitedRange>239 G/L1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GJKY97S8\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002215\">https://biblio.inscriptiones.org/epig10002215\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
