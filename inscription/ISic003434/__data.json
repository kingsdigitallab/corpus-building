href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-11-28\" who=\"#JP\">Jonathan Prag revised from publication\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003434_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003434.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan>\u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"2\"/>Cassia \u003Cg ref=\"#interpunct\">·\u003C/g> Galene\n                    \u003Clb n=\"3\"/>vixit \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>ann\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cnum value=\"40\">XXXX\u003C/num>\n                    \u003Clb n=\"4\" />\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>aius\u003C/ex>\u003C/expan> Iulius \u003Cg ref=\"#interpunct\">·\u003C/g> Macedo\n                    \u003Clb n=\"5\"/>uxori \u003Cg ref=\"#interpunct\">·\u003C/g> pissiimae\n                    \u003Clb n=\"6\"/>\u003Cg ref=\"#interpunct\">·\u003C/g> fecit \u003Cg ref=\"#interpunct\">·\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Bivona and Ferrua (but with interpuncts formally recorded)\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Sacred to the shades of the underworld. Cassia Galene lived 40 years. Caius Iulius Macedo made (this) for his most dutiful wife\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The piece's provenance is uncertain. Ferrua suggested that it should be from Palermo, but it is one of three which he so attributed without much evidence, as one of the three is from Taormina and one from Rome; there appears however to be no documentation regarding the origin of this piece, which Bivona therefore lists among the 'ignota'.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1975.0453\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1941\u003C/date>\n                        \u003CcitedRange>267 no.37\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/P7QQ9SB6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002655\">https://biblio.inscriptiones.org/epig10002655\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILMusPalermo\">\n                        \u003Cauthor>Bivona\u003C/author>\n                        \u003Cdate>1970\u003C/date>\n                        \u003CcitedRange>88\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002142\">https://biblio.inscriptiones.org/epig10002142\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
