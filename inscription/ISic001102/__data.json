oconsul\">ἀνθύπατον\u003C/roleName>\n                    \u003Clb n=\"7\"/>\u003CplaceName>Ἀσίας\u003C/placeName>\n                    \u003Clb n=\"8\"/>δικαιώτατον\n                    \u003Clb n=\"9\"/>\u003CpersName type=\"attested\">\u003Cname type=\"nomen\">Ἀσίννιος\u003C/name>\n                    \u003Clb n=\"10\"/>\u003Cname type=\"cognomen\">Ἀμίαντος\u003C/name>\u003C/persName>\n                    \u003Clb n=\"11\"/>\u003CroleName type=\"supracivic\" subtype=\"procurator\">ἐπίτροπος\u003C/roleName>\n                    \u003Clb n=\"12\"/>τὸν \u003CroleName type=\"supracivic\" subtype=\"dominus\">δεσπότη\u003Csupplied reason=\"lost\">ν\u003C/supplied>\u003C/roleName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp loc=\"line 1\">\u003Cnote>Brugnone 1982-83 suggests a line preceding: [Γ Ἀσίννιον]; Manganaro argues that the top of the stone is partially preserved\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--to ?C. Asinius Nicomachus Iulianus, by Asinius Amiantos, procurator. Cos. suff. in unknown year of the C3 AD); cf. IG 14.284, same man; SEG has Rufus Nikomachos Iulianus.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">283\u003C/ref>\n                        \u0