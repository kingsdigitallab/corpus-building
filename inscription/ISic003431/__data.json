      \u003Cgraphic n=\"print\" url=\"ISic003431.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>λη χρησ\n                    \u003Clb n=\"2\" break=\"no\"/>\u003Csupplied reason=\"lost\">τὴ\u003C/supplied> \u003Csupplied reason=\"lost\">χαῖ\u003C/supplied>ρε \u003Cchoice>\u003Corig>ἔσζω\n                    \u003Clb n=\"3\" break=\"no\"/>\u003Csupplied reason=\"lost\">σε\u003C/supplied>\u003C/orig>\u003Creg>ἔσζω\u003Csupplied reason=\"lost\">σε\u003C/supplied>\u003C/reg>\u003C/choice> \u003Csupplied reason=\"lost\">ἔτι\u003C/supplied>α \u003Cnum value=\"20\">εἴκοσι\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Orsi\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Orsi consulted Guarducci for advice on the non-standard forms in the text. Parallels can be found in \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001313\">ISic001313\u003C/ref> from Catania. The text is unusual in being carved into the brick slab after firing. The implication of the restorations conjectured for lines 2-3 is that not more than c.4 letters are missing from the personal name in line 1.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1931\u003C/date>\n                        \u003CcitedRange>391-392 fig.17\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n                   \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
