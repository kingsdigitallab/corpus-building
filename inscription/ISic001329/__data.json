60,"ref":61},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1","",{"lettering":64,"dimensions":65},"Cursive Μ, Ο in smaller size; lunate epsilon according to Kaibel. The second line is indented.",[66,75],{"type":67,"l":68,"from":69,"to":70,"h":71,"unit":72,"atLeast":73,"atMost":74},"letterHeight","Lines 1-3","line1","line3","15-22","mm","15","22",{"type":76,"l":77,"from":69,"to":78,"h":79,"unit":72},"interlinear","Interlineation line 1 to 2","line2","not recorded",{"_":81,"notBefore":82,"notAfter":83},"Second half of 3rd century CE or 4th century CE",251,400,[85,90],{"_":86,"type":87,"ref":88,"region":89},"Catina","ancient","http://pleiades.stoa.org/places/462270","Sicilia",{"_":91,"type":92,"ref":93,"region":89},"Catania","modern","http://sws.geonames.org/2525068",[95],[96,97],37.49223,15.07041,{"_":99,"type":100,"geo":26},"Original discovery not recorded, but probably Catania.","found",[],{"_":103,"type":104,"geo":26},"Observed by Amico in Museo Biscari and by Kaibel (who saw more of it than is now preserved); later by Korhonen in magazzino superiore, Collezione Biscari.","observed",[106],{"n":107,"url":108,"height":109,"width":110,"desc":111,"surfaceType":112},"screen","ISic001329_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":115,"role":116,"ref":117,"museum":118},"Museo Civico di Catania","museum","http://sicily.classics.ox.ac.uk/museum/018",{"slug":119,"type":116,"name":115,"uri":117,"description":120,"location":121},"018","Antiquarian collection, comprehensive in scope",{"settlement":91,"region":91,"country":122,"address":123,"geo":124},"Italy","Castello Ursino, Piazza Federico II di Svevia, 95121 Catania (CT)",{"lat":125,"lon":126},37.498991,15.084607,{"_":128,"mainLang":129,"languages":130},"Ancient Greek","grc",[128],{"type":132,"bibl":133},"edition",[134,14