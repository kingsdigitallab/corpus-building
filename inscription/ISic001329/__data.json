                  \u003Cmaterial ana=\"#material.stone.marble\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/259.html\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--measurements from Korhonen-->\n                                        \u003Cheight unit=\"cm\">10\u003C/height>\n                                        \u003Cwidth unit=\"cm\">10.5\u003C/width>\n                                        \u003Cdepth unit=\"cm\">1.7\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragments.contiguous\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Cursive Μ, Ο in smaller size; lunate epsilon according to Kaibel. The second line is indented.\u003C/p>\u003C!--measurements from Korhonen-->\n                                \u003Clocus from=\"line1\" to=\"line3\">Lines 1-3\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"15\" atMost=\"22\">15-22\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\">not recorded\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462270\">Catina\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525068\">Catania\u003C/placeName>\n                            \t\u003Cgeo>37.49223, 15.07041\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0251\" notAfter-custom=\"0400\">Second half of 3rd century CE or 4th century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\">Original discovery not recorded, but probably Catania.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\">Observed by Amico in Museo Biscari and by Kaibel (who saw more of it than is now preserved); later by Korhonen in magazzino superiore, Collezione Biscari.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-07-11\" who=\"#AA\">Alex Antoniou Epidoc editing\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-10-31\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translation and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001329_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001329.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Τίμη\u003C/name>\u003C/persName> \u003Csupplied reason=\"lost\">καὶ\u003C/supplied>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Ποιμ\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003Cw>\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">ἑα\u003C/supplied>υτ\u003Csupplied reason=\"lost\">οῖς\u003C/supplied>\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">καὶ\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw>\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">το\u003C/supplied>\u003Csupplied reason=\"lost\">ῖς\u003C/supplied>\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">ἰδίοις\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"5\"/>\u003Cw>\u003Csupplied reason=\"lost\" cert=\"low\">ἐποίησαν\u003C/supplied>\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photographs\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 1\">\u003Cnote>Kaibel: Τίμη; Ferrua: Τιμη[σίθεος; Korhonen: Τιμή\u003C/note>\u003C/app> \n                    \u003Capp loc=\"lines 1-2\">\u003Cnote>Kirchhoff read ΠΟΙΩ which Ferrua (1941) corrected in ΠΟΙΗ (ἐ|ποίη[σε) but a Μ is clearly legible. Later, Ferrua (1989) suggested the supplement Ποιμ[ένιος]\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 3\">\u003Cnote>Ferrua: ἑαυτ[ῷ]; Kaibel, Korhonen ἑαυτ[οῖς]\u003C/note>\u003C/app>\n                    \u003Capp loc=\"lines 4-5\">\u003Cnote>Kaibel: τὸ[ν τόπον] (scil. ἠγόρασαν)]; Ferrua: το[ῖς ἰδίο]|[ις πᾶσιν]; Korhonen: το[ῖς ἰδίοις]|[ἐποίησαν?]\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>Time and Poim--- made (this) for themselves and their relatives.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>Time e Poim--- realizzarono (questo) per loro stessi e per i loro familiari.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The structure of the epitaph is influenced by  Latin epigraphy (\u003Cforeign xml:lang=\"la\">fecit sibi et suis\u003C/foreign>) and recurs often (but not exclusively) in Christian epitaphs: for this reason, Ferrua believed that the epitaph was Christian. The formula is used to indicate the dedicant, who is not yet dead, but the verb \u003Cforeign xml:lang=\"grc\">ζάω\u003C/foreign> is often omitted (see Korhonen 2004: 88-89). According to Kaibel, followed by LGPN 3A: 429, \u003Cforeign xml:lang=\"grc\">Τίμη\u003C/foreign>, attested in the imperial age also in SEG 31.1327A, is the name of the first deceased, whereas \u003Cforeign xml:lang=\"grc\">Τιμησίθεος\u003C/foreign> suggested by Ferrua is not attested in that age. The second deceased could have been a \u003Cforeign xml:lang=\"grc\">Ποιμήν\u003C/foreign> or a \u003Cforeign xml:lang=\"grc\">Ποιμένιος\u003C/foreign> (as Ferrua suggested): the latter is attested in Christian age by literary sources. On the names, see Solin 1982: 1030 and 1256.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">508\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>199\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Kirchhoff\u003C/author>\n                        \u003Cdate>1877\u003C/date>\n                        \u003CcitedRange>9512\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/533T8HNS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001249\">https://biblio.inscriptiones.org/epig10001249\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1941\u003C/date>\n                        \u003CcitedRange>243 no.141\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4HR4GXBX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001456\">https://biblio.inscriptiones.org/epig10001456\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>no.443\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/759ZXHKQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001995\">https://biblio.inscriptiones.org/epig10001995\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
