Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2018-05-03\" who=\"#TA\">Tuuli Ahlholm cleaned up the autogenerated EpiDoc and added an apparatus\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-17\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000034_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000034.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan>\u003C/supplied> \u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"2\"/>\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">Iuniae\u003C/supplied> \u003Cg ref=\"#interpunct\">·\u003C/g> Festivae\n                    \u003Clb n=\"3\"/>\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">patronae\u003C/supplied> \u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">e\u003C/supplied>t \u003Cg ref=\"#interpunct\">·\u003C/g> uxori \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>rariss\u003C/abbr>\u003Cex>imae\u003C/ex>\u003C/expan> \n                    \u003Clb n=\"4\"/>\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>aius\u003C/ex>\u003C/expan>\u003C/supplied> \u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">Iunius\u003C/supplied> Mercurius\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of Mommsen\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Omitted by Gualtherus\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>Bivona: [---]Mercu\u003Cunclear>r\u003C/unclear>[iu]\u003Cunclear>s\u003C/unclear>\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Bivona essentially dismisses the earlier tradition (which, as per her practice throughout the catalogue, she does not report or reference), seemingly on the sole basis that she read F, not E, as the first surviving letter of line 2. Gualtherus saw the piece entire, and Mommsen the surviving right half, and there is no obvious reason to doubt Gualtherus' report of the original entire text.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624\u003C/date>\n                        \u003CcitedRange>76\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GIN6NANU\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002388\">https://biblio.inscriptiones.org/epig10002388\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>235\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/650793\">7311\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILMusPalermo\">\n                         \u003Cauthor>Bivona\u003C/author>\n                         \u003Cdate>1970\u003C/date> \n                        \u003CcitedRange>34\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002142\">https://biblio.inscriptiones.org/epig10002142\u003C/ref>\u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
