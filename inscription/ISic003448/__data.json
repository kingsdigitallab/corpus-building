0\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Dmitry Dundua, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-interpretive-simple-lemmatized\">  \u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Cspan data-text=\"Ἀσκληπιάδη\" data-n=\"5\" data-lemma=\"Ἀσκληπιάδης\">Ἀσκληπιάδη\u003C/span>  \u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Sinja Küppers\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἀσκλη\n                    πιάδη\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἀσκλη\n                    πιάδη\">\u003Cspan data-text=\"Ἀσκλη\n                    πιάδη\" data-n=\"5\" data-lemma=\"Ἀσκληπιάδης\">ΑΣΚΛΗ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>ΠΙΑΔΗ\u003C/span>\u003C/span>\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">ΧΑΙΡΕ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Dmitry Dundua, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-diplomatic-simple-lemmatized\">\u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Cspan data-text=\"Ἀσκληπιάδη\" data-n=\"5\" data-lemma=\"Ἀσκληπιάδης\">ΑΣΚΛΗΠΙΑΔΗ\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">ΧΑΙΡΕ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">