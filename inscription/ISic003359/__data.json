                  \u003Cmaterial ana=\"#material.stone.limestone\" ref=\"http://www.eagle-network.eu/voc/material/lod/66.html\">limestone\u003C/material>\n                                    \u003CobjectType ana=\"#object.ash_chest\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/79.html\">ash chest\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">25.5\u003C/height>\n                                        \u003Cwidth unit=\"cm\">43.5\u003C/width>\n                                        \u003Cdepth unit=\"cm\">37.5\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                    \u003Cdamage/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>Somewhat irregular sized letters, not strictly following the horizontal. Pronounced but simple heavy serifs on deep v-cut letters. Alpha has extended top stroke, with cross-bar sloping down to the left; epsilon is lunate; kappa has short equal length arms; mu has four equal slopint strokes; rho has a large just closed eye; phi has ovoid body with standard height vertical; omega is cursive.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line3\">Lines 1-3\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"35\" atMost=\"60\">35-60\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\">not measured\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462503\">Syracusae\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2523083\">Siracusa\u003C/placeName>\n                                \u003Cgeo>37.08415, 15.27628\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0001\" notAfter-custom=\"0300\" cert=\"low\">1st — 3rd century CE (?)\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"1902-07-04\">Hypogeum in Grotticelli, excavated 4 July 1902\u003C/provenance>\n                        \u003Cprovenance type=\"observed\">Display Sector D\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" resp=\"#JP\">2006.07.25; 2013.09.30\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2018-05-28\" who=\"#JP\">Jonathan Prag checked EpiDoc, added images\u003C/change>\n                \u003Cchange when=\"2018-05-31\" who=\"#JP\">Jonathan Prag added text, translation, metadata\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#VF\">Victoria Fendel's lemmatizations were added from source CoNLL-U files using PyEpiDoc and associated scripts\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003359_tiled.tif\" height=\"2501px\" width=\"4142px\">\n                \u003Cdesc>Photo J. Prag, Aut. Assessorato Beni Culturali Regione Siciliana n.10681 del 06/05/2014\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003359.jpg\" height=\"2501px\" width=\"4142px\">\n                \u003Cdesc>Photo J. Prag, Aut. Assessorato Beni Culturali Regione Siciliana n.10681 del 06/05/2014\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n        \u003Csurface type=\"threequarter\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003359_threequarter_tiled.tif\" height=\"3835px\" width=\"4945px\">\n                \u003Cdesc>Photo J. Prag, Aut. Assessorato Beni Culturali Regione Siciliana n.10681 del 06/05/2014\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003359_threequarter.jpg\" height=\"3835px\" width=\"4945px\">\n                \u003Cdesc>Photo J. Prag, Aut. Assessorato Beni Culturali Regione Siciliana n.10681 del 06/05/2014\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw n=\"5\">\u003Cexpan>\u003Cabbr>Γ\u003C/abbr>\u003Cex>αι\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"10\">·\u003C/g> \u003Cname>\u003Cw n=\"15\">Ματρίνι\u003C/w>\u003C/name>\n                    \u003Clb n=\"2\"/>\u003Cname>\u003Cw n=\"20\">Φηλικίων\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"25\">·\u003C/g>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"30\">\u003Cexpan>\u003Cabbr>χρη\u003C/abbr>\u003Cex>στὲ\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"35\">·\u003C/g> \u003Cw n=\"40\">καὶ\u003C/w> \u003Cg ref=\"#interpunct\" n=\"45\">·\u003C/g> \u003Cw n=\"50\">\u003Cexpan>\u003Cabbr>ἄμε\u003C/abbr>\u003Cex>μπτε\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"55\">·\u003C/g> \u003Cw n=\"60\">χαῖρε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Γαίους\">Γαι\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"Ματρίνιος\">Ματρίνι\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"Φηλικίων\">Φηλικίων\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"χρηστός\">χρηστὲ\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"καί\">καὶ\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ἄμεμπτος\">ἄμεμπτε\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"χαίρω\">χαῖρε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text from autopsy\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Gaius Matrinius Felicio, worthy and blameless, farewell!\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>Φηλικίων presumably renders the Latin Felicio. Although the inscription is in Greek, it is noteworthy that it employs a Latin vocative form for Matrinius (implicit therefore also for Gaius), as well as abbreviating the formulaic words χρηστὲ and ἄμεμπτε, according to the more normal practices of Latin inscriptions; the use of interpuncts throughout is also distinctively Latin in practice. Ferrua suggests that the letters are of the end of the third century AD, but an earlier date also seems possible, and indeed likely.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1941\u003C/date>\n                        \u003CcitedRange>217 no.97\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4HR4GXBX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001456\">https://biblio.inscriptiones.org/epig10001456\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
