C/name>\n                    \u003Clb n=\"3\"/>\u003Cname>\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>arci\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilii\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CorgName>\u003Cexpan>\u003Cabbr>Ouf\u003C/abbr>\u003Cex>entina\u003C/ex>\u003C/expan>\u003C/orgName>\n                    \u003Clb n=\"4\"/>\u003Cname>Pollionis\u003C/name>\n                    \u003Clb n=\"5\"/>\u003Cexpan>\u003Cabbr>oper\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Domiti\u003C/name>\n                    \u003Clb n=\"6\"/>\u003Cname>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilii\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>Vot\u003C/abbr>\u003Cex>uria\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Rufi\u003C/name>\n                    \u003Clb n=\"7\"/>\u003Corig>ALYPUS\u003C/orig> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Corig>SIMBUL\u003C/orig>\n                    \u003Clb n=\"8\"/>Mercurio\n                    \u003Clb n=\"9\"/>Augusto\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text: CIL\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 5\">\u003Cnote>Mommsen oper(a) vel oper(is) opinor\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>[By the order of?] Marcus Albus Pollio, son of Marcus, of [tribe] Oufentina, f