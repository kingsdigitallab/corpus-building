 visibly smaller.",{"_":50,"ana":51,"ref":52},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"dimensions":54},[55,62,66],{"type":56,"l":57,"from":58,"to":59,"h":60,"unit":61,"atLeast":60,"atMost":60},"letterHeight","Lines 1-4","line1","line4","25","mm",{"type":56,"l":63,"from":64,"to":64,"h":65,"unit":61,"atLeast":65,"atMost":65},"Line 5","line5","15",{"type":67,"l":68,"from":58,"to":69,"unit":61},"interlinear","Interlineation line 1 to 2","line2",{"_":71,"notBefore":72,"notAfter":73},"1st — 3rd century CE",1,300,[75,79],{"_":76,"type":77,"ref":78},"Messana","ancient","http://pleiades.stoa.org/places/462538",{"_":80,"type":81,"ref":82},"Messina","modern","http://sws.geonames.org/2524170",[84],[85,86],38.19394,15.55256,{"_":88,"type":89,"subtype":90,"geo":20},"Via S. Marta, fondo Martines","found","discovered",[],{"_":93,"type":94,"subtype":95,"geo":20},"None","observed","autopsied",[97],{"n":98,"url":99,"height":100,"width":101,"desc":102,"surfaceType":103},"screen","ISic001492_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Italy","Sicily",{"_":107,"role":108,"ref":109,"museum":110},"Museo regionale interdisciplinare di Messina","museum","http://sicily.classics.ox.ac.uk/museum/147",{"slug":111,"type":108,"name":107,"uri":109,"description":112,"location":113},"147","The collection is focused on finds made within the city of Messina itself (the warship ram from Acqualadroni being one of the only notable exceptions). Beginning with the prehistoric periods (a single case) it progresses through the different areas and periods of the city, focusing at the end on the sculpture and inscriptions. The accompanying boards set the objects into a clear historical context. One of the highlights of the collection is the aforementioned warship ram. Two other objects given prominence are two of the four Oscan inscriptions in the collection, from the time of Mamertine domination. The principle display cases focus on the cemeteries and religious areas of the city. The grounds of the museum contain a number of monuments and architectural pieces (many from the post-medieval city that was destroyed in the 1908 earthquake) but some earlier as well, principally Roman in date",{"settlement":80,"region":80,"country":104,"address":114,"geo":115},"Viale della Liberta 465, Messina",{"lat":116,"lon":117},38.2166927,15.5639472,{"_":119,"type":120},"A3572","inventory",{"_":122,"mainLang":123,"languages":124},"Ancient Greek","grc",[122],{"type":126,"bibl":127},"edition",[128,141],{"type":129,"n":130,"author":131,"date":132,"citedRange":133,"ptr":134,"ref":136,"inscriptionDate":132,"title":138,"citation":139,"uri":140},"corpus","IMusMessina","Bitto","2001","41",{"target":135},"https://www.zotero.org/groups/382445/items/M9HMEP2R",{"_":137,"target":137},"https://biblio.inscriptiones.org/epig10000029","Le iscrizioni greche e latine di Messina","\u003Cspan>Irma Bitto, \u003Ci>Le iscrizioni greche e latine di Messina\u003C/i>, vol. 1, Pelorias 7 (Messina: Dipartimento di Scienze dell’Antichità dell’Università degli Studi di Messina, 2001)\u003C/span>","https://www.zotero.org/groups/isicily/items/M9HMEP2R",{"author":142,"date":143,"citedRange":144,"ptr":145,"ref":147,"inscriptionDate":143,"title":149,"citation":150,"uri":151},"Ferrua","1941","252-253 no.1",{"target":146},"https://www.zotero.org/groups/382445/items/P7QQ9SB6",{"_":148,"target":148},"https://biblio.inscriptiones.org/epig10002655","Analecta sicula","\u003Cspan>Antonio Ferrua, «Analecta sicula», \u003Ci>Epigraphica\u003C/i> 3 (1941): 252–70\u003C/span>","https://www.zotero.org/groups/isicily/items/P7QQ9SB6",{"type":153,"bibl":154},"discussion",[20],{"editor":156,"principal":159,"contributors":160,"change":188},{"_":157,"ref":158},"Jonathan Prag","#JP",{"_":157,"ref":158},[161,164,168,172,176,180,184],{"_":157,"xml: