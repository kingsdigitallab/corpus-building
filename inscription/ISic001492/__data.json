 of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw n=\"5\">\u003Cexpan>\u003Cabbr>Θ\u003C/abbr>\u003Cex>εοῖς\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"10\">·\u003C/g> \u003Cw n=\"15\">\u003Cexpan>\u003Cabbr>Κ\u003C/abbr>\u003Cex>αταχθονίοις\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"20\">·\u003C/g>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"nomen\">\u003Cw n=\"25\">Αἴσαρις\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"30\">·\u003C/g> \u003Cname type=\"cognomen\">\u003Cw n=\"35\">Σατ\n                    \u003Clb n=\"3\" break=\"no\"/>τάρας\u003C/w>\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\" n=\"40\">·\u003C/g> \u003Cw n=\"45\">ἔζη\n                    \u003Clb n=\"4\" break=\"no\"/>σεν\u003C/w> \u003Cg ref=\"#interpunct\" n=\"50\">·\u003C/g> \u003Cw n=\"55\">ἔτη\u003C/w>\n                    \u003Clb n=\"5\"/>\u003Cg ref=\"#interpunct\" n=\"60\">·\u003C/g> \u003Cnum value=\"52\">\u003Cw n=\"65\">ν\u003Cg ref=\"#interpunct\" n=\"68\">·\u003C/g>β\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"70\">·\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"θεός\">Θεοῖς\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"καταχθόνιος\">Καταχθονίοις\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"Αἴσαρις\">Αἴσαρις\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"Σαττάρας\">Σαττάρας\u003C/w>\n                    \u003Cw n=\"45\" lemma=\"ζῶ\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"55\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"65\" lemma=\"νβ\">νβ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003Cp>\u003ClistApp>\u003Capp>\u003Cnote>Text based upon Bitto 2001 no.41 with photograph\u003C/note>\u003C/app>\u003C/listApp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>To the underworld deities, Aisaris Sataras lived for 52 years\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Th.K. heading. Of Aisaris Sataras, a freedman of eastern origin, of someone with a gentilicium taken from the Esarus of Calabria?, viz. Esarius, etc. - or so suggests Ferrua. Age in years given.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IMusMessina\">\n                        \u003Cauthor>Bitto\u003C/author>\n                        \u003Cdate>2001\u003C/date>\n                        \u003CcitedRange>41\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/M9HMEP2R\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000029\">https://biblio.inscriptiones.org/epig10000029\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1941\u003C/date>\n                        \u003CcitedRange>252-253 no.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/P7QQ9SB6\"/>\n                  