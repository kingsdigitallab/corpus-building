red bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-01-28\" who=\"#JP\">Jonathan Prag made preliminary edit of file from editions\u003C/change>\n                \u003Cchange when=\"2022-02-09\" who=\"#JP\">Jonathan Prag added bibl ref\u003C/change>\n                \u003Cchange when=\"2025-12-18\" who=\"#ZG\">Zoe Greblunas tagged names and persons\u003C/change> \n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001393_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001393.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Csupplied reason=\"lost\">ἐ\u003C/supplied>πὶ \u003CpersName type=\"attested\">\u003Cname>Ἡρακλείου\u003C/name> τοῦ \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw part=\"I\">Α\u003C/w>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>ο\u003Cunclear>υ\u003C/unclear> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Ἀριστονίκου\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003CpersName type=\"divine\">\u003Cname>Διὶ\u003C/name> \u003Cname type=\"epithet\">Ὠρίῳ\u003C/name>\u003C/persName> ἀνφιπολεύσας\n                    \u003Clb n=\"4\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Csupplied reason=\"lost\">Ἀρ\u003C/supplied>\u003Cunclear>τ\u003C/unclear>εμίσκος\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Νύμ\u003Cunclear>φ\u003C/unclear>ωνος\u003C/name>\u003C/persName>\n                    \u003Clb n=\"5\"/>\u003Cname>Κάβαλλος\u003C/name>\u003C/persName> ἐκ τῶν αὑτοῦ\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after IG and Manganaro, from antiquarian edition\u003C/note>\u003C/app>\n                    \u003Capp loc=\"2\">\u003Cnote>apographs read: [---]ΟΓ at line beginning.\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>apographs read: [---]ΙΕΜ at line beginning; apographs read: ΝΥΜΡΩΝΟΣ \u003C/note>\u003C/app>\n                    \u003Capp loc=\"5\">\u003Cnote>apographs read: ΚΑΒΑΜΟΣ (correction goes back to Kaibel)\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Dedication made in the epnomyous mag (type uncertain) of Herakleios and another, by Artemiskos Kabamos, son of Nymphon, from his own money, having served as amphipolis of Zeus Orios; Tusa discusses the priesthood. Manganaro replaces the name 'kabamos' with 'kaballos', which is a Greek name (nothing to do with Latin caballus). M. notes that the amphipolis is not therefore the eponymous mag in Centuripae; also observes the cult is largely eastern, p'haps esp. Egyptian, and implies maritime links, citing the Centuripae naval service in support of an inland town having such. Goes on to cite IG 14.576 as possible support also of an Isis cult in the town.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">574\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1964.0615\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                         \u003Cauthor>Dubois\u003C/author>\n                         \u003Cdate>1989\u003C/date> \n                        \u003CcitedRange>\n                            \u003Cref target=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\">188\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RWXNUFEX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"SGDI\">\n                        \u003Cauthor>Hoffmann\u003C/author>\n                        \u003Cdate>1904\u003C/date>\n                        \u003CcitedRange>5248\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DQDPC573\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000817\">https://biblio.inscriptiones.org/epig10000817\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ansaldi\u003C/author>\n                        \u003Cdate>1851\u003C/date>\n                        \u003CcitedRange>\u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/724747\">50 no. 5\u003C/ref>\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9BF3BJJI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002182\">https://biblio.inscriptiones.org/epig10002182\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1963\u003C/date>\n                        \u003CcitedRange>51\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/M3UEW68D\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001850\">https://biblio.inscriptiones.org/epig10001850\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Cappelletti\u003C/author>\n                        \u003Cdate>2020\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/5VBVFAQC\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002340\">https://biblio.inscriptiones.org/epig10002340\u003C/ref>\u003C/bibl>\n                  \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\n\t       \u003Cbibl>\n\t           \u003Cauthor>Tusa\u003C/author>\n\t           \u003Cdate>1963\u003C/date>\n\t           \u003CcitedRange>189 no. 2\u003C/citedRange>\n\t           \u003Cptr target=\"https://www.zotero.org/groups/382445/items/UB6D4JA9\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10001540\">https://biblio.inscriptiones.org/epig10001540\u003C/ref>\u003C/bibl>\n\t   \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
