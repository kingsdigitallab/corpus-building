ly with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JH\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"2\"/>\u003Cname>Valeria\u003C/name> \u003Cname>Thermitana\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> vixit\n                    \u003Clb n=\"3\"/>annos \u003Cnum value=\"3\">III\u003C/num> \u003Cexpan>\u003Cabbr>mens\u003C/abbr>\u003Cex>es\u003C/ex>\u003C/expan> \u003Cnum value=\"4\">IIII\u003C/num> dies \u003Cnum value=\"6\">VI\u003C/num>\n                    \u003Clb n=\"4\"/>\u003Cname>Valerius\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Eutyches\u003C/name> et \u003Cname>Lysidia\u003C/name>\n                    \u003Clb n=\"5\"/>Thaumasie parentes \u003Cexpan>\u003Cabbr>fecerun\u003C/abbr>\u003Cex>t\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"6\"/>filiae \u003Cg ref=\"#interpunct\">·\u003C/g> piissimae\n                    \u003Clb n=\"7\"/>et sibi et suis\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of CIL\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JH\">\n                \u003Cp>To the gods of the underworld, Valeria Thermitana lived for three years, four months, and six days. Valerius Eutyches and Lysidia Thaumasie, her parents, made this (tomb?) for their most dutiful daughter, and for themselves and their family.\n                \u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--D M S Valeria Thermitana, erected by Valerius Eutyches and Lysidia Thaumasie, parents-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7099\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
