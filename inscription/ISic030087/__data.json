glish\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.defixio\" ref=\"https://www.eagle-network.eu/voc/typeins/lod/76.html\">defixio\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2021-06-09\" who=\"#VM\">Valentina Mignosa added basic metadata\u003C/change>\n                \u003Cchange when=\"2021-08-21\" who=\"#SN\">Savannah Neibart encoded inscription using data from ISicDef, supplemented by Bettarini\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic030087_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic030087.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#SN\">\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"a\">\n                \u003Cab>\n                    \u003Cmilestone unit=\"face\" n=\"a\"/>\n                    \u003Clb n=\"1\"/>θεά\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Κ\u003Cunclear>λ\u003C/unclear>εοννο̄́\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003Cunclear>ͱ\u003C/unclear>ότι κα λ\n                    \u003Clb n=\"4\" break=\"no\"/>\u003Cunclear>ο͂\u003C/unclear>ν\u003Cunclear>τ\u003C/unclear>\u003Csupplied reason=\"lost\">ι\u003C/supplied>\n                \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"b\">\n                 \u003Cab>\n                     \u003Cmilestone unit=\"face\" n=\"b\"/>\n                  \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Ἀθο̄́νυμος\u003C/name>\u003C/persName>\n                  \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Συλιν\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Σίμο̄\u003C/name>\u003C/persName>\u003C/persName>\n                \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Bettarini.\u003C/note>\u003C!-- ISicDef no. 43 -->\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"it\">\n                \u003Cp>Tra gli aspetti più interessanti del recto c'è l'intestazione θεά: che si tratti di un'intestazione è confermato dal fatto che la parola è stata incisa nella prima riga di scrittura in posizione centrale, mentre le righe successive cominciano tutte vicino al margine sinistro della lamina. L'identificazione di questa dea è scontata: si tratta ovviamente di Persefone, associata nel culto a Demetra Malophoros, dal cui santuario in località Gaggera provengono molte defixiones. Non è comune intestare le defixiones (sebbene vi sia l'esemplare geloo che inizia con tyka). La presenza di un'intestazione è solo uno di quegli artifici (come il ricorso a liste incolonnate e ad abbreviazioni) che aveva lo scopo di conferire ufficialità alla pratica privata e segreta della magia nera. (Bettarini)\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"ISelinunteDef\"> \n                        \u003Cauthor>Bettarini\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003CcitedRange>1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SEW88NC7\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001388\">https://biblio.inscriptiones.org/epig10001388\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>55.1020\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
