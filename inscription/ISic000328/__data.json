"character\"/>\n                    \u003Clb n=\"3\"/>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>aius\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> Iulius \u003Cg ref=\"#interpunct\">·\u003C/g> Dio\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"4\"/>\u003Cexpan>\u003Cabbr>Ti\u003C/abbr>\u003Cex>berius\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> Claudius \u003Cg ref=\"#interpunct\">·\u003C/g> Ce\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"5\"/>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>aius\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> Iulius \u003Cg ref=\"#interpunct\">·\u003C/g> Pr\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"6\"/>\u003Corig>PAISV\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n                \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of Mommsen (from autopsy)\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>Amico:  DIOP...\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>Amico: CEI...\u003C/note>\u003C/app>\n                    \u003Capp loc=\"6\">\u003Cnote>Amico: CRASSVS...\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Manganaro and Korhonen suggest that this might be a list of officials; Amico assumed it to be a list of those buried in a tomb and so funerary, since the area of its discovery is more broadly that of the necropolis.\u003C/p>\n            \