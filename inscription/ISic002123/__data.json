/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002156\">https://biblio.inscriptiones.org/epig10002156\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
