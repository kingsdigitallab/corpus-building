term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2024-07-10\" who=\"#JP\">Jonathan Prag revised from publication\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#VF\">Victoria Fendel's lemmatizations were added from source CoNLL-U files using PyEpiDoc and associated scripts\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001377_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001377.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw n=\"5\">ἐνθάδ\u003Csupplied reason=\"lost\">ε\u003C/supplied>\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"10\"/>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"15\">ζησασ\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"20\"/>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"25\">ἔτη\u003C/w> \u003Cnum value=\"50\">\u003Cw n=\"30\">\u003Chi rend=\"supraline\">ν\u003C/hi>\u003C/w>\u003C/num> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"35\"/>\n                    \u003Clb n=\"4\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"40\"/> \u003Corig n=\"45\">ΥΤΟ\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"50\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"ἐνθάδε\">ἐνθάδε\u003C/w>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"10\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cw n=\"15\" lemma=\"ζάω\">ζησασ\u003C/w>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"20\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cw n=\"25\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"ν\">ν\u003C/w>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"35\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"40\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Corig n=\"45\">ΥΤΟ\u003C/orig>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"50\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Amico and Kaibel\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"1\">\n                        \u003Cnote>Amico 1741: 274: ΕΝΘΑΚ\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"3\">\n                        \u003Cnote>Amico 1741: 274: ΕΤΗΝ; Amico 1741: 277: ΕΤΕΝ̅\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"4\">\n                        \u003Cnote>Amico 1741: 274: ΚΤΩ....; Kirchoff: [τελευτᾷ τῇ πρὸ -- Ὀ]κτω[βρίων]; Ferrua:  [ὑπατίᾳ — —ο]υ τὸ[\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Amico presents the text in two different variants, without seemingly recognising that it is the same text. Ferrua suggests that the traces in line 4 would be compatible with a consular dating, such as for an imperial consul, as with Honorius in 404 CE, but obviously the actual date is speculative. Kirchoff in CIG offered a possible restoration of line 3-4 on the basic of Amico's alternative reading.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Amico\u003C/author>\n                        \u003Cdate>1741\u003C/date>\n                        \u003CcitedRange>274, 277\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F5INCW3T\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002186\">https://biblio.inscriptiones.org/epig10002186\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">558\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>36.0844\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Kirchhoff\u003C/author>\n                        \u003Cdate>1877\u003C/date>\n                        \u003CcitedRange>9500\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/533T8HNS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001249\">https://biblio.inscriptiones.org/epig10001249\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1982-1983\u003C/date>\n                        \u003CcitedRange>27 no.91\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q7DDNWD6\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001996\">https://biblio.inscriptiones.org/epig10001996\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
