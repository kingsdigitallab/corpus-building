                   \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>original data collection and editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JCu\" ref=\"http://orcid.org/0000-0002-6686-3728\">James Cummings\u003C/name>\n                    \u003Cresp>conversion to EpiDoc\u003C/resp>\n                \u003C/respStmt>\n\t    \u003CrespStmt>\n     \t       \u003Cname xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n     \t       \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n \t   \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"GC\" ref=\" https://orcid.org/0000-0003-1030-5679\">Giorgia Capra\u003C/name>\n                    \u003Cresp>epidoc editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"ZL\" ref=\"https://orcid.org/0009-0007-0586-7956\">Zoé Lienard\u003C/name>\n                    \u003Cresp>named entity annotation\u003C/resp>\n                \u003C/respStmt>\n            \u003CrespStmt>\u003Cname xml:id=\"Coccato\" ref=\"https://orcid.org/0000-0002-6641-2820\">Alessia Coccato\u003C/name>\u003Cresp>Petrographic observation and analysis\u003C/resp>\u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic003390\u003C/idno>\n                \u003Cidno type=\"TM\">645661\u003C/idno>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\"/>\n                \u003Cidno type=\"PHI\"/>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic003390\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-23\">10.5281/zenodo.4388492\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Siracusa\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/097\">Museo Archeologico Regionale Paolo Orsi\u003C/repository>\n                        \u003Cidno type=\"inventory\">5\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>A large block of off-white marble. The under side has a concentric worked area, and a circular hole at the centre, implying that the block was fixed onto another block underneath. The upper face has a cavity scooped out of the rear centre. The block is intact on all sides, and finished smooth on the front, left and right faces. Minor abrasion to the edges of the front face, and a crack runs horizontally across the middle of the face, left to right.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Hymettan\" type=\"stone.marble\" subtype=\"Hymettan\" resp=\"#Coccato\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">Very fine-grained, banded, grey, calcitic marble, likely Hymettan. Optical microscopy: heteroblastic fabric with mosaic microstructure, lineated, fine-grained areas. Digital microscopy: homeoblastic fabric (identification based on pXRF, digital microscopy, XRD, optical microscopy, stable isotopes analysis, EPR, LA-ICP-MS)\n\u003CplaceName type=\"provenance\">\n \u003Cref target=\"https://www.geonames.org/261786/ymittos-oros.html\">Mt. Hymettos\u003C/ref>\n \u003Clocation>\n  \u003Cgeo>37.93508,23.80974\u003C/geo>\n \u003C/location>\n\u003C/placeName>\u003C/material>\n                                    \u003CobjectType ana=\"#object.block\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/189.html\">block\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">27\u003C/height>\n                                        \u003Cwidth unit=\"cm\">50.5\u003C/width>\n                                        \u003Cdepth unit=\"cm\">48.5\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003Cp>Lines 1-3 are arranged continuously along the upper part of the face; below are two wreaths, with words inside each wreath.\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Clocus from=\"line1\" to=\"line3\">Line 1-3\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"10\" atMost=\"15\">10-15\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line4\" to=\"line4\">Line 4\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"5\" atMost=\"6\">5-6\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                        \u003CdecoDesc>\u003CdecoNote>Two crowns enclosing elements of line 4\u003C/decoNote>\u003C/decoDesc> \n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Grecia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/579885\">Athenae\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/264371\">Athens\u003C/placeName>\n                            \t\u003Cgeo>37.970793, 23.719536\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0300\" notAfter-custom=\"-0001\">Hellenistic\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">The inscription - from Athens - appears already in the museum inventory of 1885, described as 'prov. incerta', and was previously observed in the preceding museum by Julius Schubring in the 1860s. There is no record of how it came to be in Sicily, and as Manganaro observes, it most likely arrived as ballast stone in a ship (at some date prior to c.1860). Now in storage in the Museum.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" xml:id=\"autopsy\">Prag 2014-09, Magazzino B\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.dedication\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Dedication\">dedication\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-05-21\" who=\"#GC\">edited text and added english and italian translation\u003C/change>\n                \u003Cchange when=\"2026-02-11\" who=\"#ZL\">tagged names and persons\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003390_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-12\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003390.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-12\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"screen\" url=\"ISic003390_detail1_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-12\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003390_detail1.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-12\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"screen\" url=\"ISic003390_detail2_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-12\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003390_detail2.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-12\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#GC #JP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Δεινίας\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Κηφ\u003Csupplied reason=\"lost\">ισο\u003C/supplied>δότου\u003C/name>\u003C/persName> \u003CorgName type=\"demotic\">Βου\u003Cunclear>τ\u003C/unclear>άδη\u003Csupplied reason=\"lost\">ς\u003C/supplied>\u003C/orgName>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003CroleName type=\"civic\" subtype=\"thesmothete\">θεσμοθετήσα\u003Csupplied reason=\"lost\">ς\u003C/supplied>\u003C/roleName> \u003Csupplied reason=\"lost\">ἐπὶ\u003C/supplied> \u003CpersName type=\"attested\">\u003Cname>Φειδοστράτο\u003Csupplied reason=\"lost\">υ\u003C/supplied>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003CroleName type=\"civic\" subtype=\"archon\">ἄ\u003Csupplied reason=\"lost\">ρ\u003C/supplied>χον\u003Csupplied reason=\"lost\">τ\u003C/supplied>ο\u003Csupplied reason=\"lost\">ς\u003C/supplied>\u003C/roleName> \u003Csupplied reason=\"lost\">ἀ\u003C/supplied>νέθηκεν\n                    \u003Clb n=\"4\"/>\u003Csupplied reason=\"lost\">ἡ\u003C/supplied> \u003Csupplied reason=\"lost\">βουλή\u003C/supplied> ὁ δῆμος\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text from autopsy\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#GC\">\n               \u003Cp>Deinias son of Kephisodotos of Boutadai, who was thesmothete when Pheidostratos was archon, dedicated this. (In crown, on the left) The Council. (In crown, on the right) The People.\u003C/p> \n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#GC\">\n                \u003Cp>Deinias figlio di Kephisodotos di Boutadai, che era tesmoteta durante l'arcontato di Pheidostratos, dedicò questo. (In corona, a sinistra) Il consiglio. (In corona, a destra) Il popolo.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003CcitedRange>02/03(2).3.1.2855\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/KVYN6RR3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000420\">https://biblio.inscriptiones.org/epig10000420\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003CcitedRange>02/03(3).4.1.99\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/AXP6R9HE\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000413\">https://biblio.inscriptiones.org/epig10000413\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Schubring\u003C/author>\n                        \u003Cdate>1861-1867\u003C/date>\n                        \u003CcitedRange>672 no. 7, tab. no.7\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TBDXRINA\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001601\">https://biblio.inscriptiones.org/epig10001601\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1929\u003C/date>\n                        \u003CcitedRange>121\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/AHZ3TB5P\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001872\">https://biblio.inscriptiones.org/epig10001872\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1965\u003C/date>\n                        \u003CcitedRange>205 tav. LXXV.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RGTHAFKT\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001841\">https://biblio.inscriptiones.org/epig10001841\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
