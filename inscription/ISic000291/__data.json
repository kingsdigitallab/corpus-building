007\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ansaldi\u003C/author>\n                        \u003Cdate>1851\u003C/date>\n                        \u003CcitedRange>\u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/724745\">48 no. 2\u003C/ref>\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9BF3BJJI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002182\">https://biblio.inscriptiones.org/epig10002182\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
