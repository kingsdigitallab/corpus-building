     \u003Clb n=\"2\"/>χρηστὰ \u003Cg ref=\"#interpunct\">·\u003C/g> καὶ\n                    \u003Clb n=\"3\"/>ἄμεμπτε\n                    \u003Clb n=\"4\"/>χαῖρε\n                    \u003Clb n=\"5\"/>\u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Γάμε\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">·\u003C/g> χρηστὲ\n                    \u003Clb n=\"6\"/>καὶ \u003Cg ref=\"#interpunct\">·\u003C/g> ἄμεμ\n                    \u003Clb n=\"7\" break=\"no\"/>πτε \u003Cg ref=\"#interpunct\">·\u003C/g> χαῖρε\n                    \u003Clb n=\"8\"/>\u003CpersName type=\"attested\">\u003Cname type=\"nomen\">Οὐρβανίων\u003C/name>\n                    \u003Clb n=\"9\"/>\u003Cname type=\"cognomen\">Γόνγε\u003C/name>\u003C/persName>\n                    \u003Clb n=\"10\"/>χρηστὲ \u003Cg ref=\"#interpunct\">·\u003C/g> καὶ\n                    \u003Clb n=\"11\"/>ἄμεμπτε\n                    \u003Clb n=\"12\"/>χαῖρε\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>text according to IG\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--contains three individuals; Oraia; Gamos; Ourbanion Gongos (Urbanius?); all three each get chrestos kai amemptos and chaire; re. Gamos, note CIL 10.7050 for a C. Aulus Gamus in Catania; re. Gongos, the name is unknown; poss. error for Longos?-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibe