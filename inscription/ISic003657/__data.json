>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/6541860\">Agrigento\u003C/placeName>\n                            \t\u003Cgeo>37.32084, 13.58876\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0480\" notAfter-custom=\"-0470\">c. 480—470 BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"1926\">Observed on the various blocks of the sima of the Temple of Demeter\u003Cgeo>37.299559,13.602667\u003C/geo>\u003C/provenance>\u003C!-- location of the temple -->\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"function.quarry_mark\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/390.html\">masons' marks\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-12-09\" who=\"#JP\">Jonathan Prag revised from publication\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003657_tiled.tif\" height=\"512px\" width=\"831px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; Marconi 1926, fig.27\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003657.jpg\" height=\"512px\" width=\"831px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; Marconi 1926, fig.27\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\">\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"a\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Δ\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"b\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Ε\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"c\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Ν\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"d\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Γ\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"e\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#hourglass\">⧖\u003C/g>\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"f\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Σ\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"g\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Ι\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"h\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Τ\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"i\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#sign_uninterpreted\"/>\n                    \u003C/ab>\n                    \u003C/div>\n                \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based upon the apograph in Marconi 1926; Marconi presents several of the letters 'reversed', but given that the orientation of a mason's mark need not follow the final orientation of the stone, this does not seem significant\u003C/note>\u003C/app>\n                    \u003Capp loc=\"e.1\">\u003Cnote>The symbol has the form of an hourglass\u003C/note>\u003C/app>\n                    \u003Capp loc=\"i.1\">\u003Cnote>The symbol has the form of an incomplete (upper left) and open (at the waist) hourglass\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Mason's marks, individual letters D, E , N G, E ,T, I, S\n                    J.WC.Akrag.61.p01-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl n=\"LSAG[2]\">\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003Cauthor>Johnston\u003C/author>\n                        \u003Cdate>1990\u003C/date>\n                        \u003CcitedRange>278 no.61\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/QUWGZA84\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000678\">https://biblio.inscriptiones.org/epig10000678\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003Cdate>1961\u003C/date>\n                        \u003CcitedRange>278 no.61\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/V6CGSWPS\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000677\">https://biblio.inscriptiones.org/epig10000677\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Marconi\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1926\u003C/date>\n                        \u003CcitedRange>134-135 fig.27\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
