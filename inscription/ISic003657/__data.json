sion of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; Marconi 1926, fig.27\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003657.jpg\" height=\"512px\" width=\"831px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; Marconi 1926, fig.27\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"http://zotero.org/groups/382445/items/4MCP2PVV\">\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"a\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Δ\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"b\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Ε\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"c\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Ν\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"d\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Γ\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"e\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#hourglass\">⧖\u003C/g>\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"f\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Σ\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"g\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Ι\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"h\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Τ\n                    \u003C/ab>\n                    \u003C/div>\n                 \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"i\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#sign_uninterpreted\"/>\n                    \u003C/ab>\n                    \u003C/div>\n                \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based upon the apograph in Marconi 1926; Marconi presents several of the letters 'reversed', but given that the orientation of a mason's mark need not follow the final orientation of the stone, this does not seem significant\u003C/note>\u003C/app>\n                    \u003Capp loc=\"e.1\">\u003Cnote>The symbol has the form of an hourglass\u003C/note>\u003C/app>\n                    \u003Capp loc=\"i.1\">\u003Cnote>The symbol has the form of an incomplete (upper left) and open (at the waist) hourglass\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Mason's marks, individual letters D, E , N G, E ,T, I, S\n                    J.WC.Akrag.61.p01-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl n=\"LSAG[2]\">\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003Cauthor>Johnston\u003C/author>\n                        \u003Cdate>1990\u003C/date>\n                        \u003CcitedRange>278 no.61\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/QUWGZA84\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000678\">https://biblio.inscriptiones.org/epig10000678\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003Cdate>1961\u003C/date>\n                        \u003CcitedRange>278 no.61\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/V6CGSWPS\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000677\">https://biblio.inscriptiones.org/epig10000677\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Marconi\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1926\u003C/date>\n                        \u003CcitedRange>134-135 fig.27\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
