n=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-30\" who=\"#VM\">Valentina Mignosa added metadata, text\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020009_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020009.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" xml:lang=\"xly-Grek\">\n                \u003Cab>    \n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#cross_uninterpreted\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Agostiniani 1977 (IAS I)\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp>\u003C!--No translation currently agreed-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp>\u003C!--No translation currently agreed-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>Cross-shaped sign recurrent as a mark throughout the ancient world. Cf. Agostiniani 1977, p.11, which reports some parallels with Attic ceramic: Graef, Langlotz 1933, p.128, no.1523, N 456; Milne 1936, fig. 34, no.14; F.Xanthos IV, p.174, nos. 400-401.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IAS1\">\n                        \u003Cauthor>Agostiniani\u003C/author>\n                        \u003Cdate>1977\u003C/date>\n                        \u003CcitedRange>9\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/QR2S9AJ9\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002201\">https://biblio.inscriptiones.org/epig10002201\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Lejeune\u003C/author>\n                        \u003Cdate>1970\u003C/date>\n                        \u003CcitedRange>144\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/2H7NP37F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001880\">https://biblio.inscriptiones.org/epig10001880\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Tusa\u003C/author>\n                        \u003Cdate>1967\u003C/date>\n                        \u003CcitedRange>no.53\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/VKGKCTWE\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001538\">https://biblio.inscriptiones.org/epig10001538\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n                        \u003Cauthor>Metzger\u003C/author>\n                        \u003Cdate>1972\u003C/date>\n                        \u003CcitedRange>p.174, nos. 400-401\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/KG5M5D44\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001748\">https://biblio.inscriptiones.org/epig10001748\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Milne\u003C/author>\n                        \u003Cdate>1936\u003C/date>\n                        \u003CcitedRange>fig. 34, no.14\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/FW7W6HTJ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002564\">https://biblio.inscriptiones.org/epig10002564\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Graef, Langlotz\u003C/author>\n                        \u003Cdate>1933\u003C/date>\n                        \u003CcitedRange>p.128, no.1523, N 456\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/MAEBB7ZT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002563\">https://biblio.inscriptiones.org/epig10002563\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
