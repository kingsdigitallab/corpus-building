\">Museo Archeologico Regionale di Adrano\u003C/repository>\n                        \u003Cidno type=\"inventory\"/>\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"scx\">Sikel\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>Two contiguous fragments of tile.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.clay.fired\" ref=\"https://www.eagle-network.eu/voc/material/lod/130.html\">clay, fired\u003C/material>\n                                    \u003CobjectType ana=\"#object.tile\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/951.html\">tile\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragments.contiguous\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs type=\"graffito\" ref=\"https://www.eagle-network.eu/voc/writing/lod/9\">scratched (before firing)\u003C/rs>\n                                    \u003Cp>The inscription runs on the two contiguous fragme