ate>\n                        \u003CcitedRange>459 no.15b\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/V6CGSWPS\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000677\">https://biblio.inscriptiones.org/epig10000677\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                         \u003Cauthor>Dubois\u003C/author>\n                         \u003Cdate>1989\u003C/date> \n                        \u003CcitedRange>\n                            \u003Cref target=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\">104\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RWXNUFEX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1965\u003C/date>\n                        \u003CcitedRange>193-194 tav.68.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RGTHAFKT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001841\">https://biblio.inscriptiones.org/epig10001841\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Curbera\u003C/author>\n                        \u003Cdate>1993\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Z7SMXPNX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001490\">https://biblio.inscriptiones.org/epig10001490\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1996\u003C/date>\