{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":97,"html":213,"xml":268},"ISic001159",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"material":30,"condition":34,"dimensions":35,"layoutDesc":46,"handNote":53,"date":68,"places":72,"geo":82,"country":77,"provenance":74,"provenanceFound":86,"provenanceGeo":90,"provenanceObserved":91,"provenanceLost":20,"graphics":97,"region":105,"settlement":79,"repository":106,"idno":120,"textLang":123,"bibliographyEdition":127,"bibliographyDiscussion":156,"citation":159,"tmNumber":8,"facsimile":192,"letterHeights":193,"publications":196,"zotero":199,"keywords":202,"lettering_types":212},"Funerary epitaph for Phaino",{"_":5},"edited",[7,10,12,14,17],{"_":8,"type":9},"492771","TM",{"type":11},"EDR",{"type":13},"EDH",{"_":15,"type":16},"39102315","EDCS",{"_":18,"type":19},"140644","PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":26,"ref":27},"Large slab of grey/brown stone. Forms a pair with , as they are similar in size, material, and the form and shape of the letters. All sides are almost square, but for the broken top left corner. The back is almost flat, but there is a slight taper on the sides towards the back",{"_":28,"target":29},"ISic001160","http://sicily.classics.ox.ac.uk/inscription/ISic001160",{"_":31,"ana":32,"ref":33},"stone (grey)","#material.stone","http://www.eagle-network.eu/voc/material/lod/2.html","",[36,40,43],{"_":37,"unit":38,"dimension":39},"22.8","cm","height",{"_":41,"unit":38,"dimension":42},"32.5","width",{"_":44,"unit":38,"dimension":45},"9.5","depth",{"layout":47},{"p":48,"rs":49,"damage":34},"Three lines of Greek text, roughly centred on stone. Clear use of inscribed guidelines on top and bottom of each line.",{"_":50,"ana":51,"ref":52},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":54,"dimensions":55},"Letters are extremely regular and neat, with letter heights all identical (except for phi in line 1, which extends above the guideline). Letters are thin, tall and evenly spaced. Terminal dots carved on all letters. Use of the classic zeta in line 2.",[56,64],{"type":57,"l":58,"from":59,"to":60,"h":61,"unit":62,"atLeast":63,"atMost":63},"letterHeight","Lines 1-3","line1","line3","39 (phi in line 1: 49mm)","mm","39",{"type":65,"l":66,"from":59,"to":67,"unit":62},"interlinear","Interlineation line 1 to 2","line2",{"_":69,"notBefore":70,"notAfter":71},"2nd century CE (?)",101,200,[73,78],{"_":74,"type":75,"ref":76,"region":77},"Thermae Himeraeae","ancient","http://pleiades.stoa.org/places/462513","Sicilia",{"_":79,"type":80,"ref":81,"region":77},"Termini Imerese","modern","http://sws.geonames.org/6539140",[83],[84,85],37.98365,13.69555,{"_":87,"type":88,"subtype":89,"geo":20},"The place, date, and circumstances of the discovery are unknown, but the inscription is assumed to come from Termini Imerese","found","discovered",[],{"_":92,"type":93,"subtype":94,"when":95,"resp":96,"geo":20},"Antoniou, 2023-07-06. In the Depositi of Museo Civico Baldassare Romano, room 1, scaffold 12, shelf 3","observed","autopsied","2023-07-06","#AA",[98],{"n":99,"url":100,"height":101,"width":102,"desc":103,"surfaceType":104},"screen","ISic001159_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":107,"role":108,"ref":109,"museum":110},"Museo Civico Baldassare Romano","museum","http://sicily.classics.ox.ac.uk/museum/066",{"slug":111,"type":108,"name":107,"uri":109,"description":112,"location":113},"066","A large and well-displayed collection. It begins with three ante-rooms, in the first of which is a rich display of lithics (mainly Neolithic) from the surrounding area. A display of material from Himera (lion-head spouts from the Temple of Victory and red-figure craters being the principle pieces) and a numismatic gallery then follow before the main room which contains Hellenistic and Roman material from Termini Imerese itself. Small finds, sculpture and inscriptions predominate. The museum collection continues upstairs with non-archaeological material (and a single inscription). The courtyard of the building holds a large collection of architectural pieces and inscriptions",{"settlement":79,"region":114,"country":115,"address":116,"geo":117},"Palermo","Italy","Via Marco Tullio Cicerone, 90018 - Termini Imerese (PA)",{"lat":118,"lon":119},37.98655109,13.69587845,{"_":121,"type":122},"147","inventory",{"_":124,"mainLang":125,"languages":126},"Ancient Greek","grc",[124],{"type":128,"bibl":129},"edition",[130,144,20],{"type":131,"n":132,"citedRange":133,"ptr":137,"ref":138,"title":139,"author":140,"date":141,"citation":142,"uri":143,"year":141},"corpus","IG",{"ref":134},{"_":135,"target":136},"340.1","https://clio.columbia.edu/catalog/6873760",{"target":138},"https://www.zotero.org/groups/382445/items/Q2SBPG9F","Inscriptiones Graecae Siciliae et Italiae, additis graecis Galliae Hispaniae, Britanniae, Germaniae inscriptionibus","Kaibel","1890","\u003Cspan>G. Kaibel, \u003Ci>Inscriptiones Graecae Siciliae et Italiae, additis graecis Galliae Hispaniae, Britanniae, Germaniae inscriptionibus\u003C/i>, Inscriptiones Graecae consilio et auctoritate Academiae Litterarum Regiae Borussicae Editae. Volumen XIV., XIV (Berlin: Georgius Reimerus, 1890)\u003C/span>","https://www.zotero.org/groups/isicily/items/Q2SBPG9F",{"type":131,"n":145,"author":146,"date":147,"citedRange":148,"ptr":149,"ref":151,"inscriptionDate":147,"title":153,"citation":154,"uri":155,"year":147},"IGMusTermini","Brugnone","1974","11",{"target":150},"https://www.zotero.org/groups/382445/items/9WZ7KU5C",{"_":152,"target":152},"https://biblio.inscriptiones.org/epig10001397","Iscrizione g