 type=\"EDCS\"/>\n                \u003Cidno type=\"PHI\"/>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic020131\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Palermo\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/064\">Museo Archeologico Regionale Antonino Salinas\u003C/repository>\n                        \u003Cidno type=\"inventory\">54425\u003C/idno>\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003Ccertainty locus=\"value\" match=\"../@mainLang\" assertedValue=\"xly\">\u003Cdesc>Elymian\u003C/desc>\u003C/certainty>\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>Base, foot and fragment of wall of a black-glaze oinochoe or skyphos.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.clay.fired\" ref=\"https://www.eagle-network.eu/voc/material/lod/131.html\">ceramic\u003C/material>\n                                    \u003CobjectType ana=\"#object.vessel.oinochoe\" cert=\"low\" ref=\"http://kerameikos.org/id/oinochoe\">oinochoe\n                                        \u003Ccertainty locus=\"value\" match=\"../@key\" assertedValue=\"skyphos\" target=\"http://kerameikos.org/id/skyphos\">\u003Cdesc>skyphos\u003C/desc>\u003C/certainty>\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">2.5\u003C/height>\n                                        \u003Cdim type=\"diameter\" unit=\"cm\">5\u003C/dim>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.scratched\" ref=\"https://www.eagle-network.eu/voc/writing/lod/9\">scratched\u003C/rs>\n                                    \u003Cp>The text is placed on the underside of the vessel. The letters have been highlighted with white painting in modern times to make them more legible.\u003C/p>\n                                    \u003Cdamage ana=\"#text_condition.incomplete text_condition.legible\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003C!--  Based on Glyph table: epsilon17; lambda15. To the left of the digram there is a sign that could be a notation of value (id: val03). -->\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"5\" atMost=\"6\">5-6\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"https://pleiades.stoa.org/places/462487\">Segesta\u003C/placeName>\n                                \u003CplaceName type=\"modern\"/>\n                                \u003Cgeo>37.94171, 12.83649\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" evidence=\"archaeological-context material-context lettering\" notBefore-custom=\"-0500\" notAfter-custom=\"-0480\">500—480 BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" from=\"1957\" to=\"1977\">Found during the excavations (from 1957 to 1977) by the Soprintendenza alle Antichità della Sicilia Occidentale in the area of Grotta Vanella, on the north-east slope of Monte Barbaro\u003Cgeo>37.94240, 12.84509\u003C/geo>, 1.9km east of temple of Segesta.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" resp=\"#VM\" when=\"2021-12-15\">Mignosa 2021-12-15\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"..