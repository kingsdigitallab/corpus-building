003Cname type=\"nomen\">\u003Cw n=\"5\">Κορνήλιος\u003C/w>\u003C/name>\n                    \u003Clb n=\"2\"/>\u003Cname type=\"cognomen\">\u003Cw n=\"10\">Μάγνος\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"15\">·\u003C/g> \u003CplaceName type=\"ethnic\">\u003Cw n=\"20\">Ἀ\n                    \u003Clb n=\"3\" break=\"no\"/>παμεὺς\u003C/w>\u003C/placeName>\u003C/persName> \u003Cg ref=\"#interpunct\" n=\"25\">·\u003C/g> \u003Cw n=\"30\">ἰδί\n                    \u003Clb n=\"4\" break=\"no\"/>ῳ\u003C/w> \u003Cg ref=\"#interpunct\" n=\"35\">·\u003C/g> \u003Cw n=\"40\">θρεπτῷ\u003C/w>\n                    \u003Clb n=\"5\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"45\">Ἐπαφρύδι\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"6\"/>\u003Cw n=\"50\">\u003Cexpan>\u003Cabbr>μ\u003C/abbr>\u003Cex>νήμης\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"55\">·\u003C/g> \u003Cw n=\"60\">\u003Cexpan>\u003Cabbr>χ\u003C/abbr>\u003Cex>άριν\u003C/ex>\u003C/expan>\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Κορνήλιος\">Κορνήλιος\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Μάγνος\">Μάγνος\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"Ἀπαμεύς\">Ἀπαμεὺς\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"ἴδιος\">ἰδίῳ\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"θρεπτός\">θρεπτῷ\u003C/w>\n                    \u003Cw n=\"45\" lemma=\"Ἐπαφρῦς\">Ἐπαφρύδι\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"μνήμη\">μνήμης\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"χάρις\">χάριν\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based upon Bitto 2001\u003C/n