{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":91,"html":205,"xml":246},"ISic001126",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":31,"condition":35,"dimensions":36,"layoutDesc":44,"handNote":50,"date":62,"places":67,"geo":76,"country":69,"provenance":69,"provenanceFound":77,"provenanceGeo":82,"provenanceObserved":83,"provenanceLost":87,"graphics":91,"region":73,"settlement":92,"repository":92,"textLang":93,"bibliographyEdition":97,"bibliographyDiscussion":156,"citation":159,"tmNumber":8,"letterHeights":184,"publications":185,"zotero":191,"keywords":197,"lettering_types":204},"I.Sicily inscription 001126",{"_":5},"draft",[7,10,12,14,17],{"_":8,"type":9},"492739","TM",{"type":11},"EDR",{"type":13},"EDH",{"_":15,"type":16},"39102283","EDCS",{"_":18,"type":19},"140611","PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","Torremuzza describes simply as a Greek funerary inscription, broken in its two extremities, meaning the left and right sides (almost certainly therefore a plaque). As Kaibel observes, the loss is not large on each side, potentially less (especially on the right) than suggested by Torremuzza, only a few letters in each case. No measurements or other details are recorded.",{"_":27,"ana":28,"ref":29,"cert":30},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259","low",{"_":32,"ana":33,"ref":34},"stone","#material.stone","http://www.eagle-network.eu/voc/material/lod/2.html","",[37,40,42],{"unit":38,"dimension":39},"cm","height",{"unit":38,"dimension":41},"width",{"unit":38,"dimension":43},"depth",{"layout":45},{"rs":46,"damage":35},{"_":47,"ana":48,"ref":49},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":51,"dimensions":52},"Torremuzza is explicit that the tex