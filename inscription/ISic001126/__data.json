0009-0006-5165-8381\">Oliver Clarke\u003C/name>\n                    \u003Cresp>named entity annotation\u003C/resp>\n                \u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic001126\u003C/idno>\n                \u003Cidno type=\"TM\">492739\u003C/idno>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\">39102283\u003C/idno>\n                \u003Cidno type=\"PHI\">140611\u003C/idno>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic001126\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-22\">10.5281/zenodo.4385518\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>unknown\u003C/settlement>\n                        \u003Crepository>unknown\u003C/repository>\n                        \u003C!--No inventory number found-->\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>Torremuzza describes simply as a Greek funerary inscription, broken in its two extremities, meaning the left and right sides (almost certainly therefore a plaque). As Kaibel observes, the loss is not large on each side, potentially less (especially on the right) than suggested by Torremuzza, only a few letters in each case. No measurements or other details are recorded.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone\" ref=\"http://www.eagle-network.eu/voc/material/lod/2.html\">stone\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/259\" cert=\"low\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Torremuzza is explicit that the text includes a quadrate lunate sigma and square omicron.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462492\">Sicilia\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2523119\">Sicily\u003C/placeName>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0001\" notAfter-custom=\"0400\" evidence=\"textual-context\">Appears to have the distinctive Sicilian formula of 'chrestos kai amemptos', age in years and a family dedicant, indicating Roman imperial period.\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1762\">Recorded by Torremuzza 1762 in the museum of the Collegio di Studi of the Jesuits, Palermo.\u003C/provenance>\n                        \u003Cprovenance type=\"not-observed\" subtype=\"lost\">Lost.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2024-04-22\" who=\"#JP\">Jonathan Prag revised from publications\u003C/change>\n                \u003Cchange when=\"2026-02-03\" who=\"#OC\">tagged names and persons\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001126_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001126.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\" cert=\"low\">\u003Cname>\u003Csupplied reason=\"lost\" cert=\"low\">Διό\u003C/supplied>γενε\u003Csupplied reason=\"lost\">ς\u003C/supplied>\u003C/name>\u003C/persName> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>ΛΙ\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Csupplied reason=\"lost\">χρησ\u003C/supplied>τὲ καὶ \u003Cunclear>ἄ\u003C/unclear>\n                    \u003Clb n=\"3\"/>\u003Csupplied reason=\"lost\">μεμ\u003C/supplied>πτε χαῖ\u003Csupplied reason=\"lost\">ρ\u003C/supplied>\u003Cunclear>ε\u003C/unclear>\n                    \u003Clb n=\"4\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/>ἔζησ\u003Cunclear>ε\u003C/unclear> \u003Cunclear>ἔ\u003C/unclear>τ\u003Cunclear>η\u003C/unclear> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"5\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/> \u003Corig>ΑΚΓΑΜΠϹ\u003C/orig> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/>\n                    \u003Clb n=\"6\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/> \u003Corig>ΛΙΝ\u003C/orig> μήτηρ \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/>\n                    \u003Clb n=\"7\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/> ἐποί\u003Csupplied reason=\"omitted\">η\u003C/supplied>σε \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/>\n                    \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text based upon Torremuzza, with considerable uncertainty about the extent of the lacunae; similar restoration in Kaibel\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" resp=\"#JP\" xml:lang=\"en\">\n                \u003Cp>Diogenes(?) [...] worthy and blameless, lived [...] years [...] his mother set this up [...]\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>A funerary inscription with probably a Greek name such as Diogenes (plus filiation?) in the first line, the typical Sicilian formula 'chrestos kai amemptos' in lines 2-3, age at death in years, and then reference to erection of the inscription by the deceased's mother. As Kaibel notes, the gaps would appear to be small, and the implication is that the gaps at the start of the line are of variable length, as well as at line end. The 'chrestos kai amemptos' formula is distinctively Sicilian, but primarily attested in Syracusae and Catina (from Palermo, compare \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001119\">ISic001119\u003C/ref>, which however, like this text, is not explicitly attested as being found in Palermo. In both cases therefore, an eastern Sicilian provenance cannot be ruled out.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1762\u003C/date>\n                        \u003CcitedRange>53 no.103 and p.374\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/4JP8QJ5H\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002085\">https://biblio.inscriptiones.org/epig10002085\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1769\u003C/date>\n                        \u003CcitedRange>cl.18 no.30\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SPTB56H3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002084\">https://biblio.inscriptiones.org/epig10002084\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1784\u003C/date>\n                        \u003CcitedRange>cl. 18 no.30\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/7PSFHSUH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002083\">https://biblio.inscriptiones.org/epig10002083\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">307\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5575\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
