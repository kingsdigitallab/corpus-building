000019_tiled.tif\" height=\"3000px\" width=\"4496px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo R. Henzel, 2016-11-07\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000019.jpg\" height=\"3000px\" width=\"4496px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo R. Henzel, 2016-11-07\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#TA #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"imperial\">\u003CroleName type=\"supracivic\" subtype=\"imperator\">\u003Cw n=\"5\">\u003Cexpan>\u003Cabbr>Imp\u003C/abbr>\u003Cex cert=\"low\">eratori\u003C/ex>\u003C/expan>\u003C/w>\u003C/roleName> \u003Cg ref=\"#interpunct\" n=\"10\">·\u003C/g> \u003Cname>\u003Cw n=\"15\">\u003Cexpan>\u003Cabbr>Caes\u003C/abbr>\u003Cex cert=\"low\">ari\u003C/ex>\u003C/expan>\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"20\">·\u003C/g> \u003Cname>\u003Cw n=\"25\">\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex cert=\"low\">arco\u003C/ex>\u003C/expan>\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"30\">·\u003C/g> \u003Cname>\u003Cw n=\"35\">\u003Chi rend=\"ligature\">Au\u003C/hi>\u003Cunclear>re\u003C/unclear>\u003Csupplied reason=\"lost\" cert=\"low\">lio\u003C/supplied>\u003C/w>\u003C/name>\u003C/persName> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"40\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"imperator\">Imperatori\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"Caesar\">Caesari\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"Marcus\">Marco\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"Aurelius\">Aurelio\u003C/w>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"40\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of ILPalermo (Bivona) checked against the photograph\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"1\">\n                        \u003Cnote>\n                            Bivona: Au\u003Cunclear>re\u003C/unclear>; Mommsen: AV̂R\n                        \u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>As Bivona notes, Mommsen in CIL chose to unify this fragment with one recorded by Gualtherus and Fazello (ISic001896, on a piece of an architrave, re-used as a church step, and which read: IMP. M. AVRELIO . ANTONINO . AVG...). However. Torremuzza described that piece separately from this one, which he placed in the courtyard of the Palazzo Senatorio, and there seems no obvious reason to conflate them.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1762\u003C/date>\n                        \u003CcitedRange>13 no.xxiv\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4JP8QJ5H\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002085\">https://biblio.inscriptiones.org/epig10002085\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/650789\">7277\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILMusPalermo\">\n                         \u003Cauthor>Bivona\u003C/author>\n                         \u003Cdate>1970\u003C/date> \n                        \u003CcitedRange>19\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002142\">https://biblio.inscriptiones.org/epig10002142\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>78\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
