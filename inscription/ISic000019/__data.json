 \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"la\">Latin\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>A fragment of compact limestone, seemingly cut down or damaged on all sides.\u003C/p>\n                                    \u003Cmaterial type=\"inorganic.stone\" subtype=\"unverified\" ref=\"http://www.eagle-network.eu/voc/material/lod/66.html\">limestone\u003C/material>\n                                    \u003CobjectType ana=\"#object.unknown\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Unable_to_determine\">unknown\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--ILPalermo-->\n                                        \u003Cheight unit=\"cm\">22\u003C/height>\n                                        \u003Cwidth unit=\"cm\">48\u003C/width>\n                                        \u003Cdepth unit=\"cm\">6\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                    \u003Cdamage ana=\"#text_condition.incomplete\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>Tall and very narrow letters, fairly crudely carved, with AV in ligature.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"105\" atMost=\"105\">105\u003C/height>\u003C!-- ILPalermo -->\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462410\">Panhormus\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2523920\">Palermo\u003C/placeName>\n                                \u003Cgeo>38.13205, 13.33561\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0161\" notAfter-custom=\"0300\" evidence=\"lettering prosopography\">The reference could be to one of several emperors from Marcus Aurelius (161 CE) onwards, although a third century date is more likely given the form of the letters.\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1762\">First recorded in Torremuzza 1762, said to be in the courtyard of the Palazzo Senatorio.\u003C/provenance>\