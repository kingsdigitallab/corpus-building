          \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462410\">Panhormus\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2523920\">Palermo\u003C/placeName>\n                                \u003Cgeo>38.13205, 13.33561\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0161\" notAfter-custom=\"0300\" evidence=\"lettering prosopography\">The reference could be to one of several emperors from Marcus Aurelius (161 CE) onwards, although a third century date is more likely given the form of the letters.\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1762\">First recorded in Torremuzza 1762, said to be in the courtyard of the Palazzo Senatorio.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.honorific\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/69.html\">honorific\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2018-03-06\" who=\"#TA\">Tuuli Ahlholm cleaned up the autogenerated EpiDoc and added an apparatus\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-17\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-02-08\" who=\"#JP\">Jonathan Prag revised from published data\u003C/change>\n                \u003Cchange when=\"2025-05-21\" who=\"#RC\">Robert Crellin added ids and lemmatizations\u003C/change>\n                \u003Cchange when=\"2025-07-03\" who=\"#RC\">Robert Crellin added local ids to new elements\u003C/change>\n                \u003Cchange when=\"2025-07-03\" who=\"#RC\">Robert Crellin added new elements to the lemmatized edition\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000019_tiled.tif\" height=\"3000px\" width=\"4496px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo R. Henzel, 2016-11-07\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000019.jpg\" height=\"3000px\" width=\"4496px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo R. Henzel, 2016-11-07\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#TA #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"imperial\">\u003CroleName type=\"supracivic\" subtype=\"imperator\">\u003Cw n=\"5\">\u003Cexpan>\u003Cabbr>Imp\u003C/abbr>\u003Cex cert=\"low\">eratori\u003C/ex>\u003C/expan>\u003C/w>\u003C/roleName> \u003Cg ref=\"#interpunct\" n=\"10\">·\u003C/g> \u003Cname>\u003Cw n=\"15\">\u003Cexpan>\u003Cabbr>Caes\u003C/abbr>\u003Cex cert=\"low\">ari\u003C/ex>\u003C/expan>\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"20\">·\u003C/g> \u003Cname>\u003Cw n=\"25\">\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex cert=\"low\">arco\u003C/ex>\u003C/expan>\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"30\">·\u003C/g> \u003Cname>\u003Cw n=\"35\">\u003Chi rend=\"ligature\">Au\u003C/hi>\u003Cunclear>re\u003C/unclear>\u003Csupplied reason=\"lost\" cert=\"low\">lio\u003C/supplied>\u003C/w>\u003C/name>\u003C/persName> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"40\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"imperator\">Imperatori\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"Caesar\">Caesari\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"Marcus\">Marco\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"Aurelius\">Aurelio\u003C/w>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"40\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of ILPalermo (Bivona) checked against the photograph\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"1\">\n                        \u003Cnote>\n                            Bivona: Au\u003Cunclear>re\u003C/unclear>; Mommsen: AV̂R\n                        \u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>As Bivona notes, Mommsen in CIL chose to unify this fragment with one recorded by Gualtherus and Fazello (ISic001896, on a piece of an architrave, re-used as a church step, and which read: IMP. M. AVRELIO . ANTONINO . AVG...). However. Torremuzza described that piece separately from this one, which he placed in the courtyard of the Palazzo Senatorio, and there seems no obvious reason to conflate them.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1762\u003C/date>\n                        \u003CcitedRange>13 no.xxiv\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4JP8QJ5H\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002085\">https://biblio.inscriptiones.org/epig10002085\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/650789\">7277\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILMusPalermo\">\n                         \u003Cauthor>Bivona\u003C/author>\n                         \u003Cdate>1970\u003C/date> \n                        \u003CcitedRange>19\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002142\">https://biblio.inscriptiones.org/epig10002142\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
