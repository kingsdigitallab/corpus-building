work.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.dedication\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/88.html\">dedication\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                            \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t   \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t  \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t               \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t   \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n\t               \u003Cchange when=\"2021-03-01\" who=\"#VM\">Valentina Mignosa encoded text division, cleaned up the autogenerated text and checked the edition\u003C/change>\n                \u003Cchange when=\"2025-12-09\" who=\"#RG\">tagged names and persons\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001024_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001024.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>ἐπὶ \u003CpersName type=\"attested\">\u003Cname>Ἀριστοδάμου\u003C/name>\n                    \u003Clb n=\"2\"/>τοῦ \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Σωσιβίου\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003CpersName type=\"attested\">\u003Cname>Νυμφ\u003Csupplied reason=\"omitted\">ὼ\u003C/supplied>ι\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Ἱέρωνος\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"4\"/>μναμονεύσασ\u003Cunclear>α\u003C/unclear>\n                    \u003Clb n=\"5\"/>ἁγναῖς θεαῖς\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Pugliese Carratelli 1956\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--?in the magistracy of Aristodamos son of Sosibios, Nymphon the son of Hieron, fulfilling his view to the holy goddesses (i.e. Ceres and Prosepina? or better, after Pugliese Carratelli, PdP 6 (1951), 68-75, to Anna and the Paides. Small limestone base with high ornate plinth with 'horns'. BE observes that the form NUMPHOI (with omicron) is fine, pace P-C. ( cf. ASNP 1981, p.1069ff for 2 oracle inscrs. from Akrai region with mentions of Nymphs and Paides.)-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">204\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1959. 0546\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5431\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Pugliese Carratelli\u003C/author>\n        