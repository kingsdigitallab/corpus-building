idth=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003512.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName>\u003Cname type=\"nomen\">\u003Cw n=\"5\">Κλωδία\u003C/w>\u003C/name> \u003Cname type=\"cognomen\">\u003Cw n=\"10\">Σε\n                    \u003Clb n=\"2\" break=\"no\"/>βῆρα\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"15\">\u003Cchoice>\u003Corig>ἔζησ\n                    \u003Clb n=\"3\" break=\"no\"/>σεν\u003C/orig>\u003Creg>ἔζησεν\u003C/reg>\u003C/choice>\u003C/w> \u003Cw n=\"25\">ἔτη\u003C/w> \u003Cg ref=\"#interpunct\" n=\"30\">·\u003C/g> \u003Cnum value=\"7\">\u003Cw n=\"35\">Ι\u003Chi rend=\"ligature\">ΙΠ\u003C/hi>\u003C/w>\u003C/num>\n                    \u003Clb n=\"4\"/>\u003Cg ref=\"#ivy-leaf\" n=\"40\">❦\u003C/g> \u003Cspace unit=\"character\" quantity=\"6\" n=\"45\"/> \u003Cg ref=\"#ivy-leaf\" n=\"50\">❦\u003C/g> \u003Cg ref=\"#ivy-leaf\" n=\"55\">❦\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Κλωδία\">Κλωδία\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Σεβῆρα\">Σεβῆρα\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ζῶ\">ἔζησσεν\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"ζ\">ΙΙΠ\u003C/w>\n                    \u003Cspace unit=\"character\" quantity=\"6\" n=\"45\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Bitto\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Klodia Sebera, lived 7 years\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The numeral is here interpreted (following Bitto) as acrophonic and ascending, i.e. two verticals, the second in ligature with a Π for πέντε. The hederae in the final line include a third hedera of different from.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IMusMessina\">\n                        \u003Cauthor>Bitto\u003C/author>\n                        \u003Cdate>2001\u003C/date>\n                        \u003CcitedRange>5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/M9HMEP2R\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000029\">https://biblio.inscriptiones.org/epig10000029\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1916\u003C/date>\n                        \u003CcitedRange>134\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/P49V3TMD\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001701\">https://biblio.inscriptiones.org/epig10001701\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
