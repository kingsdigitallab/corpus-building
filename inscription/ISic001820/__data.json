"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2023-08-12\" who=\"#JP\">Created draft file\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#VF\">Victoria Fendel's lemmatizations were added from source CoNLL-U files using PyEpiDoc and associated scripts\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001820_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001820.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw n=\"5\">\u003Csupplied reason=\"lost\">ἐτ\u003C/supplied>ελεύτησε\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"10\">\u003Csupplied reason=\"lost\">Ἀ\u003C/supplied>\u003Cunclear>ρ\u003C/unclear>έτη\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"15\">ἐν\u003C/w> \u003Cw n=\"20\">\u003Cexpan>\u003Cabbr>\u003Cam>\u003Cg ref=\"#christogram\" n=\"25\">☧\u003C/g>\u003C/am>\u003C/abbr>\u003Cex>Χριστο\u003C/ex>\u003Cabbr>ς\u003C/abbr>\u003C/expan>\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"30\">\u003Csupplied reason=\"lost\">π\u003C/supplied>ρὀ\u003C/w> \u003Cnum value=\"8\">\u003Cw n=\"35\">η\u003C/w>\u003C/num> \u003Cw n=\"40\">ἰδῶν\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"45\">Ἰουλίων\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"τελευτάω\">ἐτελεύτησε\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Ἀρέτη\">Ἀρέτη\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἐν\">ἐν\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"Χριστός\">Χριστος\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"πρὀ\">πρὀ\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"η\">η\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"εἰδοί\">ἰδῶν\u003C/w>\n                    \u003Cw n=\"45\" lemma=\"Iulius\">Ἰουλίων\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Orsi 1895\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Arete passed away in Christ 8 days before the ides of July\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The smaller lower left fragment was found during the 1893 excavation campaign, the main fragment in the 1895 campaign; the smaller fragment was first published in 1893, the two together in 1895, with a single inventory entry for both.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1893\u003C/date>\n                        \u003CcitedRange>282 no. 17\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/V7HNHTAG\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001715\">https://biblio.inscriptiones.org/epig10001715\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1895\u003C/date>\n                        \u003CcitedRange>505 no. 226\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/3T2DS245\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001711\">https://biblio.inscriptiones.org/epig10001711\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Wessel\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>184 no. 781\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9CT5ZWIK\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000394\">https://biblio.inscriptiones.org/epig10000394\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
