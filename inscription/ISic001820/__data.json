/lod/1",{"ana":54},"#text_condition.incomplete",{"dimensions":56},[57,63],{"type":58,"l":59,"from":60,"to":61,"unit":62},"letterHeight","Line 1-4","line1","line4","mm",{"type":64,"l":65,"from":60,"to":66,"unit":62},"interlinear","Interlineation line 1 to 2","line2",{"_":68,"notBefore":69,"notAfter":70},"Late C3 AD - C4 AD",275,400,[72,77],{"_":73,"type":74,"ref":75,"region":76},"Syracusae","ancient","http://pleiades.stoa.org/places/462503","Sicilia",{"_":78,"type":79,"ref":80,"region":76},"Siracusa","modern","http://sws.geonames.org/2523083",[82],[83,84],37.08415,15.27628,{"_":86,"type":87,"subtype":88,"geo":17},"Catacomb of San Giovanni","found","discovered",[],{"_":91,"type":92,"subtype":93,"geo":17},"Gradante, 2022-02-16","observed","autopsied",[95],{"n":96,"url":97,"height":98,"width":99,"desc":100,"surfaceType":101},"screen","ISic001820_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":104,"role":105,"ref":106,"museum":107},"Museo Archeologico Regionale Paolo Orsi","museum","http://sicily.classics.ox.ac.uk/museum/097",{"slug":108,"type":105,"name":104,"uri":106,"description":109,"location":110},"097","An outstanding collection of archaeological material. The collection ranges from Siracusa and the surrounding territory (Megara Hyblaia, Akrai, Kasmenai etc) to encompass all of eastern Sicily, reaching as far as Gela and Agrigento. The ground floor covers prehistory through to the end of the Classical period. Upstairs includes Hellenistic and Roman Syracuse and a display of material from the catacombs. A gallery displaying material from Hellenistic eastern Sicily is in preparation.",{"settlement":78,"region":78,"country":111,"address":112,"geo":113},"Italy","Viale Teocrito 66, 96100 - Siracusa",{"lat":114,"lon":115},37.07636989,15.2866213,{"_":117,"type":118},"14463","inventory",{"_":120,"mainLang":1