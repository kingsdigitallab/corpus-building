fier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>The text is only known through two antiquarian apographs of the late 19th / early 20th century.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.inorganic.stone\" type=\"stone.unspecified\" subtype=\"unverified\" ref=\"http://www.eagle-network.eu/voc/material/lod/2.html\">stone\u003C/material>\n                                    \u003CobjectType ana=\"#object.unknown\" ref=\"https://www.eagle-network.eu/voc/objtyp/lod/2.html\">unknown\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Savasta's apograph shows regular Hellenistic letters, with broken-bar alpha.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/465922\" cert=\"low\">Inessa-Aetna\u003C/placeName>\n                                \u003CplaceName type=\"modern\">contrada Civita\u003C/placeName>\t\t\n                            \t\u003Cgeo>37.60182, 14.90788\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0200\" notAfter-custom=\"-0001\" evidence=\"textual-context lettering\">Later Hellenistic\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Observed 'nel casino dei Signori Ardizzone', and assumed to come from the area of the settlement and necropolis at cda Civita, often identified with ancient Aetna/Inessa \u003Cgeo>37.60182, 14.90788\u003C/geo>\u003C!-- Casino Ardizzone is at 37.587167, 14.924129 -->\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cprovenance type=\"not-observed\" subtype=\"lost\">Lost.\u003C/provenance>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.dedication\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/88.html\">dedication\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-11-22\" who=\"#JP\">Jonathan Prag encoded text, made initial revisions to metadata\u003C/change>\u003C!-- Soraci 1958 still needs checking -->\n                \u003Cchange when=\"2026-01-07\" who=\"#ZL\">tagged names and persons\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002994_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002994.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>ὁ χαλκοτύπος\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Μένας\u003C/name>\u003C/persName> μ’ἀ\n                    \u003Clb n=\"3\" break=\"no\"/>νέθηκεν\n                    \u003Clb n=\"4\"/>εὐχάν\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Rizzone\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>S.Mazzarino (ap. Soraci) conjectured a name was missing at the start; no lacuna is indicated in the original apograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"2\">\u003Cnote>apograph: ΜΕΝΑΜΑ; Dubois: μνᾶμα\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>apograph: ΝΕΟΗΚΕ; Dubois: [ἀ]νέθηκεν\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Menas the bronzeworker dedicated me, as a votive offering\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>The text is likely to be of late classical or hellenistic date, given the nature of the text and its Doric form, but little more can be said given the lack of further information. The formula εὐχὴν ἀνέθηκεν is widespread. Rizzone, on the basis of a second apograph, by the local scholar Savasta, is more inclined to read the text as essentially complete, as presented here, in contrast to other attempts to amend it (Dubois) or consider it lacunose (Soraci, Mazzarino).\n                    \u003C!--Soraci convinced it's genuine; the transcription in the MS reads: O XALKOTYPOS | MENAMA | NEOHKE | EYXAN. S. Mazzarino has suggested: [ho deina] ho chalkotupos mnama anetheken euchan. There is no basis for determining date. For the location (A.M. Merendino per litt.): 'Civita' è effettivamente ne territorio fra S.Maria di Licodia e Paternò per individuare l'area su google devi cercare S. Maria di Licodia contrade Montalto e/o Cicero.  L'area dell'abitato e della necropoli fu scavata da G. Rizza negli anni '50 (G. Rizza, Paternò. Città siculo-greca in contrada 'Civita'. Scoperte fortuite nella necropoli meridionale , in Not. Scavi 1954, pp 131-145 e G. Rizza, Scavi e ricerche nel territorio di Paternò, in Bollettino d'Arte XLI, 1954, pp. 73-75). Un'altra campagna di scavi fu effettuata nel 1995 da G. Lamgna (G. Lamagna, S. Maria di Licodia- Paternò (CT), contrada Montalto - Cicero e Civita. La ripresa degli scavi nell'antico insediamento di Civita, in Boll. Arch., 28-29-30, pp. 185-194) ed e è uno dei siti, senza tuttavia prove concrete, con cui viene identificata Etna-Inessa.'-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>58.1035\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS2\">\n                         \u003Cauthor>Dubois\u003C/author>\n                         \u003Cdate>2008\u003C/date> \n                        \u003CcitedRange>114\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SM2KDHZC\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000160\">https://biblio.inscriptiones.org/epig10000160\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Soraci\u003C/author>\n                        \u003Cdate>1958\u003C/date>\n                        \u003CcitedRange>254\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZXGG3V8Z\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001571\">https://biblio.inscriptiones.org/epig10001571\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzo\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>92 no.78\u003C/citedRange>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzone\u003C/author>\n                        \u003Cdate>2014-2015\u003C/date>\n                        \u003CcitedRange>95-96 no.13 fig.29 \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/S3G73QA2\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001626\">https://biblio.inscriptiones.org/epig10001626\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
