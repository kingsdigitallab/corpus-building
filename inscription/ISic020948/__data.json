         \u003Cab>\n                    \u003Clb n=\"1\" style=\"text-direction:r-to-l\"/>ʾnpt\n                    \u003Clb n=\"2\" style=\"text-direction:r-to-l\"/>\u003Csupplied reason=\"lost\">ʾn\u003C/supplied>k ʾbk\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after Garbini 2015\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#RDS\">\n                \u003Cp> The honey, I stir\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#RDS\">\n                \u003Cp>Il miele, io agito\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#RDS\">\n                \u003Cp>The inscription seems to refer to practices of ritual libation\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Garbini\u003C/author>\n                        \u003Cdate>2015\u003C/date>\n                        \u003CcitedRange>103-105\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/A7KHWDI8\"/>\n                    \u003C/bibl>\n                   \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
