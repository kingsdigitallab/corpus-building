03C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Crescentiae\u003C/name>\u003C/persName> bene m\u003Csupplied reason=\"lost\">e\u003C/supplied>renti\n                    \u003Clb n=\"2\"/>in pace \u003Cchoice>\u003Csic>que\u003C/sic>\u003Ccorr>quae\u003C/corr>\u003C/choice> vixit \u003Cexpan>\u003Cabbr>ann\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"3\"/>\u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex>lus\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>i\u003C/ex>\u003Cabbr>n\u003C/abbr>\u003Cex>us\u003C/ex>\u003C/expan> \u003Cnum value=\"50\">L\u003C/num> \u003Cexpan>\u003Cabbr>deposit\u003C/abbr>\u003Cex>a\u003C/ex>\u003C/expan> \u003Cnum value=\"3\">III\u003C/num> \u003Cexpan>\u003Cabbr>Kal\u003C/abbr>\u003Cex>endas\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"4\"/>\u003Cexpan>\u003Cabbr>Decemb\u003C/abbr>\u003Cex>res\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>\u003Cunclear>Fl\u003C/unclear>\u003C/abbr>\u003Cex>avio\u003C/ex>\u003C/expan> \u003Cunclear>Stilico\u003C/unclear>\n                    \u003Clb n=\"5\" break=\"no\"/>ne \u003CroleName type=\"supracivic\" subtype=\"consul\">\u003Cexpan>\u003Cabbr>cons\u003C/abbr>\u003Cex>ule\u003C/ex>\u003C/expan>\u003C/roleName> se vivi conpa\u003Csupplied reason=\"lost\">ra\u003C/supplied>\n                    \u003Clb n=\"6\" break=\"no\"/>\u003Csupplied reason=\"lost\">v\u003C/supplied>er\u003Csupplied reason=\"lost\">u\u003C/supplied>n\u003Csupplied reason=\"lost\">t\u003C/supplied>\n                  \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n              \u003ClistApp>\n                  \u003Capp>\u003Cnote>Text of CIL, amended by Ferrua\u003C/note>\u003C/app>\n                  \u003Capp loc=\"4\">\u003Cnote>Amico read a confused sequence of letters after DECEMB, and conjectured FL.STILICO, and Ferrua concurs; Mommsen instead proposed FL.OPILIO\u003C/note>\u003C/app>\n                  \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>If Mommsen's reading of line 4 is accepted, the date is either 453 or 521 CE. Ferrua notes that Stilicho was also consul II in 405, but the absence of indication of iteration leads him to prefer 400 CE.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Amico\u003C/author>\n                        \u003Cdate>1741\u003C/date>\n                        \u003CcitedRange>232\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F5INCW3T\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002186\">https://biblio.inscriptiones.org/epig10002186\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1769\u003C/date>\n                        \u003CcitedRange>cl.17, no.21\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/SPTB56H3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002084\">https://biblio.inscriptiones.org/epig10002084\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1784\u003C/date>\n                        \u003CcitedRange>cl.17, no.24\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/7PSFHSUH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002083\">https://biblio.inscriptiones.org/epig10002083\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7115\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILCV\">\n                        \u003CcitedRange>3735\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/IPPB7CUI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000357\">https://biblio.inscriptiones.org/epig10000357\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1982-1983\u003C/date>\n                        \u003CcitedRange>10 no.23\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q7DDNWD6\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001996\">https://biblio.inscriptiones.org/epig10001996\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u