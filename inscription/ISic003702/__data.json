ionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-28\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" subtype=\"primary\" xml:lang=\"grc\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/IBA4JMAN\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>Σ\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>δ\u003Cunclear>ω\u003C/unclear>\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"2\"/>εβ\u003Cunclear>ο\u003C/unclear>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Noy, based upon photograph\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The inscription, on the cover of a tomb that forms part of what appears to be a Jewish hypogeum, is only alluded to in Meligunis Lipara VII, but illustrated/published in the 1988 monograph by Bernabò Brea, and republished by Noy in his corpus of Jewish inscription.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Bernabò Brea\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>99 fig.59\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GP8EAVNI\"/>\n                    \u003C/bibl>                    \n                    \u003Cbibl>\n                        \u003Cauthor>Noy\u003C/author>\n                        \u003Cdate>1993\u003C/date>\n                        \u003CcitedRange>no.162\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/IBA4JMAN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000166\">https://biblio.inscriptiones.org/epig10000166\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Bernabò Brea and Cavalier\u003C/author>\n                        \u003Cdate>1994\u003C/date>\n                        \u003CcitedRange>14\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/93BBRA2N\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002156\">https://biblio.inscriptiones.org/epig10002156\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
