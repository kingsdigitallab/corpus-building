//www.eagle-network.eu/voc/objtyp/lod/305.html\">vessel\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cdim type=\"diameter\" unit=\"cm\">13.2\u003C/dim>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.incised\" ref=\"https://www.eagle-network.eu/voc/writing/lod/14.html\">incised\u003C/rs>\n                                    \u003Cp>The text is placed on the underside of the vessel arranged in a spiral.\u003C/p>\n                                    \u003Cdamage ana=\"#text_condition.complete\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003C!-- Based on Glyph table: lambda05; csi01. -->\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"5\" atMost=\"15\">5-15\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"https://pleiades.stoa.org/places/462244\">Himera\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2524519/\">Imera\u003C/placeName>\n                                \u003Cgeo>37.97364, 13.82398\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" evidence=\"lettering archaeological-context\" notBefore-custom=\"-0520\" notAfter-custom=\"-0501\">520—500 BCE (so Arena on letters)\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Found in Imera, at the Temple D\u003Cgeo>37.97364, 13.82398\u003C/geo>.\u003C/provenance>\u003C!-- these are the general coordinates for Himera -->\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">No Autopsy\u003C/provenance>\n                        \u003Cacquisition>Imera, Parco Archeologico di Himera e Antiquarium\u003C/acquisition>\u003C!-- check this information -->\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>             \n            \u003Cxi:include href=\"../alists/charDecl.xml\">                 \n                \u003Cxi:fallback>                     \n                    \u003Cp>ISicily glyphs authority list\u003C/p>                 \n                \u003C/xi:fallback>             \n            \u003C/xi:include>         \n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.dedication\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Dedication\">dedication\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2021-06-03\" who=\"#VM\">Valentina Mignosa added metadata, text\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020587_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020587.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003CpersName type=\"divine\">\u003Cname>Ζε̄νὸς\u003C/name>\u003C/persName> ἐριγδού\u003Cunclear>π\u003C/unclear>οιο \u003Cunclear>κ\u003C/unclear>όρε̄ι γλαυκο̄́πῑ \u003CpersName type=\"divine\">\u003Cname>\u003Chi rend=\"ligature\">Ἀθ\u003C/hi>ε̄́νε̄ι\u003C/name>\u003C/persName>\n                        \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Θ\u003Chi rend=\"subscript\">ρί\u003C/hi>πυλος\u003C/name>\u003C/persName> εὐξάμε\u003Cunclear>ν\u003C/unclear>ος τε̄́νδ’ ἀνέθε̄κ\u003Cunclear>ε\u003C/unclear> θεᾶι\n                    \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Arena (IGASM 3)\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp>To the bright-eyed Athena daughter of loud-thundering Zeus, Thripylos invoking dedicated this (kylix?) to the goddess.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#VM\">\n                \u003Cp>Per Atena dagli occhi lucenti figlia di Zeus altitonante, Thripylos invocante ha dedicato questa (kylix?) alla dea.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\" resp=\"#VM\">\n                \u003Cp>Inscription incised in neat characters before firing on a base of a medium-sized vase. The inscription is a couplet of poetic \n                    inspiration whose first hemistich is the same as the beginning of v. 3 of the Homeric Hymn to Hera (Ζε̄νὸς ἐριγδούποιο). \n                    It is followed by another Homeric formula (γλαυκο̄́πῑ Ἀθε̄́νε̄ι) with a shortened form γλαυκο̄́πῑ rather than the recurring γλαυκῶπιν. \n                    The form κόρε̄ι has a vocalism that is attested in Euboea (cf. \u003Cref target=\"https://zenon.dainst.org/Record/000747552\">Bechtel 1921-1924\u003C/ref>, 74). \n                    τε̄́νδ(ε) could refer to κύλικα but could also indicate something else. It is interesting to note that a clay and headless figurine of Athena \n                    was found near the vase (Manni Piraino 1974, p. 266).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IGASM3\">\n                        \u003Cauthor>Arena\u003C/author>\n                        \u003Cdate>1994\u003C/date>\n                        \u003CcitedRange>45, pl. XIV.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/KK5FQVHF\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000282\">https://biblio.inscriptiones.org/epig10000282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                         \u003Cauthor>Dubois\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>                            \n                            \u003Cref target=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\">8\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RWXNUFEX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Hansen\u003C/author>\n                        \u003Cdate>1983\u003C/date>\n                        \u003CcitedRange>392\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/PCVG9ND6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002468\">https://biblio.inscriptiones.org/epig10002468\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1974\u003C/date>\n                        \u003CcitedRange>266, pl. XLII.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/6J3XUS7X\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001469\">https://biblio.inscriptiones.org/epig10001469\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
