ing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Letters with apices, A with sloping bar, lunate Ε and Σ, cursive Ω. Μ and Η in ligature at l. 2.\u003C/p>\u003C!--measurements from Korhonen-->\n                                \u003Clocus from=\"line1\" to=\"line2\">Lines 1-2\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"30\" atMost=\"32\">30-32\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\">not recorded\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462270\">Catina\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525068\">Catania\u003C/placeName>\n                            \t\u003Cgeo>37.49223, 15.07041\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0401\" notAfter-custom=\"0800\">5th — 8th century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\">Original discovery not recorded, probably from Catania (or another city of Eastern Sicily).\u003C/provenance>\n                        \u003Cprovenance type=\"observed\">Observed by Libertini in Museo Biscari, later by Korhonen in Magazzino superiore, Collezione Biscari.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-09-17\" who=\"#AA\">Alex Antoniou Epidoc editing\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-12-22\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003296_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003296.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Csupplied reason=\"lost\">δ\u003C/supplied>ώρα\u003C/name>\u003C/persName> \u003Cw>ἡ\u003C/w> \u003Cw>σεμ\u003Clb n=\"2\" break=\"no\"/>\u003Csupplied reason=\"lost\" cert=\"low\">νοτάτη\u003C/supplied>\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Cw>\u003Csupplied reason=\"lost\" cert=\"low\">μ\u003C/supplied>άμμη\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photograph\u003C/note>\u003C/app>\n                    \u003Capp>\u003Cnote>Apparently there is no text before l. 1\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 1\">\u003Cnote>Korhonen: [---δ]ώρα (possibly Ἰσιδώρα or Θεοδώρα)\u003C/note>\u003C/app>\n                    \u003Capp loc=\"lines 1-2\">\u003Cnote>Korhonen: σεμ|[νοτάτη]\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 2\">\u003Cnote>Korhonen: [μ]άμμη (or ἀμμή)\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>… -dora, the noblest … mother.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>… -dora, la nobilissima … madre.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>The inscription is very fragmentary. Korhonen recognised at ll. 1-2 a traditional epithet characterising women in Christian epitaphs, \u003Cforeign xml:lang=\"grc\">σεμνοτάτη\u003C/foreign> (other epithets are \u003Cforeign xml:lang=\"grc\">ἀγνοτάτη\u003C/foreign>, \u003Cforeign xml:lang=\"grc\">πιστοτάτη\u003C/foreign>, or \u003Cforeign xml:lang=\"grc\">εὐλαβεστάτη\u003C/foreign>, on which see F. Grossi Gondi, \"Trattato di epigrafia cristiana latina e greca del mondo romano occidentale\" (Roma, 1920), 171-177; Korhonen 2004: 111). The name of the deceased was supposed to be either \u003Cforeign xml:lang=\"grc\">Ἰσιδώρα\u003C/foreign> or \u003Cforeign xml:lang=\"grc\">Θεοδώρα\u003C/foreign>, names that recur in Christian Sicilian funerary inscriptions (the former appears in an inscription from Catania of the Byzantine period, IMusCatania 191 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic003289\">ISic003289\u003C/ref>, the latter in an inscription from Syracuse of the V-VI cent. CE, SEG 4.2 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic003178\">ISic003178\u003C/ref>). The term \u003Cforeign xml:lang=\"grc\">μάμμη\u003C/foreign> (or \u003Cforeign xml:lang=\"grc\">ἀμμή\u003C/foreign>) is affective and recurs in another inscription from Catania of IV-V cent. CE, Libertini (1931), 44 no.7 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001629\">ISic001629\u003C/ref>.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>204\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1930\u003C/date>\n                        \u003CcitedRange>317 no.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SKUU2R8X\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001871\">https://biblio.inscriptiones.org/epig10001871\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\n\t       \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n\t           \u003CcitedRange>p. 111\u003C/citedRange>\n\t           \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n\t   \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
