ca","Ferrua, 1989, Note e giunte alle iscrizioni cristiane antiche della Sicilia","Mercurelli, 1938, Scoperta di un sepolcreto cristiano a Catania",[234,235,236,237,238],"2EUC82DH","4MCP2PVV","ZJ65DX74","759ZXHKQ","PHQV78NC",[240,241,242,21,26,30,243,244,245,246,244,247,248,124],"isic003283","epitaph for klaudia rosskia",{"_":5},"catina","catania","sicilia","sicily","museo civico di catania","ancient greek",[],{"title":251,"body":252,"divs":253,"editions":280,"images":290,"handnote":296},"ISic003283. Epitaph for Klaudia Rosskia","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κλαυδία Ῥωσσκία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κλαυδία\">Κλαυδία\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ῥωσσκία\">Ῥωσσκ&lt;ί&gt;-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>α\u003C/span>\u003C/span>  \u003Cspan data-text=\"ζῶσα\">ζῶσα\u003C/span>  \u003Cspan data-text=\"ἐποίησα\">ἐποίησα\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"αὐτῇ\">α&lt;ὐ&gt;τῇ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"τοῖς\">τοῖς\u003C/span>  \u003Cspan data-text=\"εἰδίοις\">εἰ-\u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\">(vac.2)\u003C/span>δίοις\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"μετὰ\">μετὰ\u003C/span>  \u003Cspan data-text=\"εἰρήνης\">εἰρ[ήνης]\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>☧ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κλαυδία Ῥωσσκία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κλαυδία\">ΚΛΑΥΔΙΑ\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ῥωσσκία\">ΡΩΣΣΚ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>Α\u003C/span>\u003C/span>\u003Cspan data-text=\"ζῶσα\">ΖΩΣΑ\u003C/span>\u003Cspan data-text=\"ἐποίησα\">ΕΠΟΙΗΣΑ\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"αὐτῇ\">ΑΤΗ\u003C/span>\u003Cspan data-text=\"καὶ\">ΚΑΙ\u003C/span>\u003Cspan data-text=\"τοῖς\">ΤΟΙΣ\u003C/span>\u003Cspan data-text=\"εἰδίοις\">ΕΙ\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span> &nbsp;&nbsp;&nbsp;&nbsp;ΔΙΟΙΣ\u003C/span>\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"μετὰ\">ΜΕΤΑ\u003C/span>\u003Cspan data-text=\"εἰρήνης\">ΕΙΡ[....]\u003C/span>\u003Cbr id=\"al6-diplomatic\">\u003Cspan class=\"linenumber\">6\u003C/span>☧\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003283_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003283_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003283.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003283-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"lines 1-2\">lines.1-2: \u003Cspan>Libertini: Ῥωσσί|α; Mercurelli, Ferrua, Korhonen: Ῥωσσκ&lt;ί&gt;|α\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Libertini: Ζώηλ(ε); Ferrua, Korhonen: ζῶσα\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 2\">\u003Cspan>Libertini: ἐποίησε; Ferrua, Korhonen: ἐποίησα\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 3\">line.3: \u003Cspan>Libertini, Ferrua: αὐτῇ; Korhonen: α&lt;ὐ&gt;τῇ (i.e. ἐμαυτῇ)\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 5\">line.5: \u003Cspan>Libertini: μετ’ εἰρ[ένῃ] (sic); Ferrua, Korhonen: μετὰ εἰρ[ήνης]\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>Klaudia Rosskia while alive made (this) for herself and her relatives. In peace.\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Klaudia Rosskia mentre era viva realizzò (questo) per lei e per i suoi parenti. In pace.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>This Christian epitaph presents the structure with the name of the deceased and the verb \u003Cspan class=\"lang\" lang=\"grc\">ποιέω\u003C/span> indicating that the deceased, while still alive (participle of \u003Cspan class=\"lang\" lang=\"grc\">ζάω\u003C/span>), built the monument (or composed the epigram on the monument) for herself and his relatives (on the same structure in Catania see IG 14.489 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001312\" target=\"_blank\">ISic001312\u003C/a> and Korhonen 2004: 88-89). The clause \u003Cspan class=\"lang\" lang=\"grc\">μετὰ εἰρήνης\u003C/span> is not frequent, more frequently attested is \u003Cspan class=\"lang\" lang=\"grc\">ἐν εἰρήνῃ\u003C/span> (see IG 14.556 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001375\" target=\"_blank\">ISic001375\u003C/a>). The gentilicium \u003Cspan class=\"lang\" lang=\"grc\">Ῥωσκία\u003C/span> reveals the Roman citizenship of the deceased (for other evidence of the gentilicium in inscriptions from Catania, see IG 14.486 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001309\" target=\"_blank\">ISic001309\u003C/a>, IG 14.500 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001321\" target=\"_blank\">ISic001321\u003C/a>, IG 14.1981 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic003252\" target=\"_blank\">ISic003252\u003C/a>).\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Libertini NSA 1937 78.i \u003Ca href=\"https://biblio.inscriptiones.org/epig10001392\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001392\u003C/a>\u003C/li>\u003Cli> Mercurelli 1938 52-53 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002228\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002228\u003C/a>\u003C/li>\u003Cli> Libertini 1981 125 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001863\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001863\u003C/a>\u003C/li>\u003Cli> Ferrua 1989 111-112 no.424 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001995\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001995\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 179 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli> Korhonen 2004 pp. 88-89 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>Letters with apices, squared Ε and Σ, rhomboid Ο, cursive Ω at l. 1 (but as a reversed M at l. 2), ligature between Ε and Σ at l. 2. Chi-Rho at the end of the text.\u003C/p> Lines 1-6  15-29  Interlineation line 1 to 2  not recorded  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[254,257,260,263,266,268,271,274,277],{"id":255,"html":256},"editions","\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κλαυδία Ῥωσσκία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κλαυδία\">Κλαυδία\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ῥωσσκία\">Ῥωσσκ&lt;ί&gt;-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>α\u003C/span>\u003C/span>  \u003Cspan data-text=\"ζῶσα\">ζῶσα\u003C/span>  \u003Cspan data-text=\"ἐποίησα\">ἐποίησα\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"αὐτῇ\">α&lt;ὐ&gt;τῇ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"τοῖς\">τοῖς\u003C/span>  \u003Cspan data-text=\"εἰδίοις\">εἰ-\u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\">(vac.2)\u003C/span>δίοις\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"μετὰ\">μετὰ\u003C/span>  \u003Cspan data-text=\"εἰρήνης\">εἰρ[ήνης]\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>☧ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κλαυδία Ῥωσσκία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κλαυδία\">ΚΛΑΥΔΙΑ\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ῥωσσκία\">ΡΩΣΣΚ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>Α\u003C/span>\u003C/span>\u003Cspan data-text=\"ζῶσα\">ΖΩΣΑ\u003C/span>\u003Cspan data-text=\"ἐποίησα\">ΕΠΟΙΗΣΑ\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"αὐτῇ\">ΑΤΗ\u003C/span>\u003Cspan data-text=\"καὶ\">ΚΑΙ\u003C/span>\u003Cspan data-text=\"τοῖς\">ΤΟΙΣ\u003C/span>\u003Cspan data-text=\"εἰδίοις\">ΕΙ\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span> &nbsp;&nbsp;&nbsp;&nbsp;ΔΙΟΙΣ\u003C/span>\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"μετὰ\">ΜΕΤΑ\u003C/span>\u003Cspan data-text=\"εἰρήνης\">ΕΙΡ[....]\u003C/span>\u003Cbr id=\"al6-diplomatic\">\u003Cspan class=\"linenumber\">6\u003C/span>☧\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":258,"html":259},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003283_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003283_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003283.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003283-thumb.jpg\">\u003C/a>",{"id":261,"html":262},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"lines 1-2\">lines.1-2: \u003Cspan>Libertini: Ῥωσσί|α; Mercurelli, Ferrua, Korhonen: Ῥωσσκ&lt;ί&gt;|α\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Libertini: Ζώηλ(ε); Ferrua, Korhonen: ζῶσα\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 2\">\u003Cspan>Libertini: ἐποίησε; Ferrua, Korhonen: ἐποίησα\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 3\">line.3: \u003Cspan>Libertini, Ferrua: αὐτῇ; Korhonen: α&lt;ὐ&gt;τῇ (i.e. ἐμαυτῇ)\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 5\">line.5: \u003Cspan>Libertini: μετ’ εἰρ[ένῃ] (sic); Ferrua, Korhonen: μετὰ εἰρ[ήνης]\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":264,"html":265},"translation","\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>Klaudia Rosskia while alive made (this) for herself and her relatives. In peace.\u003C/p>  ",{"id":264,"html":267},"\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Klaudia Rosskia mentre era viva realizzò (questo) per lei e per i suoi parenti. In pace.\u003C/p>  ",{"id":269,"html":270},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>This Christian epitaph presents the structure with the name of the deceased and the verb \u003Cspan class=\"lang\" lang=\"grc\">ποιέω\u003C/span> indicating that the deceased, while still alive (participle of \u003Cspan class=\"lang\" lang=\"grc\">ζάω\u003C/span>), built the monument (or composed the epigram on the monument) for herself and his relatives (on the same structure in Catania see IG 14.489 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001312\" target=\"_blank\">ISic001312\u003C/a> and Korhonen 2004: 88-89). The clause \u003Cspan class=\"lang\" lang=\"grc\">μετὰ εἰρήνης\u003C/span> is not frequent, more frequently attested is \u003Cspan class=\"lang\" lang=\"grc\">ἐν εἰρήνῃ\u003C/span> (see IG 14.556 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001375\" target=\"_blank\">ISic001375\u003C/a>). The gentilicium \u003Cspan class=\"lang\" lang=\"grc\">Ῥωσκία\u003C/span> reveals the Roman citizenship of the deceased (for other evidence of the gentilicium in inscriptions from Catania, see IG 14.486 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001309\" target=\"_blank\">ISic001309\u003C/a>, IG 14.500 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001321\" target=\"_blank\">ISic001321\u003C/a>, IG 14.1981 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic003252\" target=\"_blank\">ISic003252\u003C/a>).\u003C/p>  ",{"id":272,"html":273},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Libertini NSA 1937 78.i \u003Ca href=\"https://biblio.inscriptiones.org/epig10001392\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001392\u003C/a>\u003C/li>\u003Cli> Mercurelli 1938 52-53 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002228\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002228\u003C/a>\u003C/li>\u003Cli> Libertini 1981 125 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001863\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001863\u003C/a>\u003C/li>\u003Cli> Ferrua 1989 111-112 no.424 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001995\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001995\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 179 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli> Korhonen 2004 pp. 88-89 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  ",{"id":275,"html":276},"handnote","\u003Cp>Letters with apices, squared Ε and Σ, rhomboid Ο, cursive Ω at l. 1 (but as a reversed M at l. 2), ligature between Ε and Σ at l. 2. Chi-Rho at the end of the text.\u003C/p> Lines 1-6  15-29  Interlineation line 1 to 2  not recorded  ",{"id":278,"html":279},"license"," Licensed under a Creative Commons-Attribution 4.0 licence. ",[281,283,286,287],{"html":282},"Text encoding: Marta Fogagnolo, Alex Antoniou",{"id":284,"lang":124,"html":285},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κλαυδία Ῥωσσκία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κλαυδία\">Κλαυδία\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ῥωσσκία\">Ῥωσσκ&lt;ί&gt;-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>α\u003C/span>\u003C/span>  \u003Cspan data-text=\"ζῶσα\">ζῶσα\u003C/span>  \u003Cspan data-text=\"ἐποίησα\">ἐποίησα\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"αὐτῇ\">α&lt;ὐ&gt;τῇ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"τοῖς\">τοῖς\u003C/span>  \u003Cspan data-text=\"εἰδίοις\">εἰ-\u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\">(vac.2)\u003C/span>δίοις\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"μετὰ\">μετὰ\u003C/span>  \u003Cspan data-text=\"εἰρήνης\">εἰρ[ήνης]\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>☧ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":282},{"id":288,"lang":124,"html":289},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κλαυδία Ῥωσσκία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κλαυδία\">ΚΛΑΥΔΙΑ\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ῥωσσκία\">ΡΩΣΣΚ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>Α\u003C/span>\u003C/span>\u003Cspan data-text=\"ζῶσα\">ΖΩΣΑ\u003C/span>\u003Cspan data-text=\"ἐποίησα\">ΕΠΟΙΗΣΑ\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"αὐτῇ\">ΑΤΗ\u003C/span>\u003Cspan data-text=\"καὶ\">ΚΑΙ\u003C/span>\u003Cspan data-text=\"τοῖς\">ΤΟΙΣ\u003C/span>\u003Cspan data-text=\"εἰδίοις\">ΕΙ\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span> &nbsp;&nbsp;&nbsp;&nbsp;ΔΙΟΙΣ\u003C/span>\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"μετὰ\">ΜΕΤΑ\u003C/span>\u003Cspan data-text=\"εἰρήνης\">ΕΙΡ[....]\u003C/span>\u003Cbr id=\"al6-diplomatic\">\u003Cspan class=\"linenumber\">6\u003C/span>☧\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",[291,293],{"image":103,"thumb":292,"title":106},"ISic003283_tiled-thumb.tif",{"image":294,"thumb":295,"title":106},"ISi