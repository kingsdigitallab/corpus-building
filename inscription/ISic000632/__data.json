{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":132,"html":317,"xml":363},"ISic000632",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":34,"dimensions":36,"layoutDesc":47,"handNote":56,"date":97,"places":102,"geo":112,"country":107,"provenance":104,"provenanceFound":116,"provenanceGeo":125,"provenanceObserved":126,"provenanceLost":20,"graphics":132,"region":140,"settlement":109,"repository":141,"idno":154,"textLang":157,"bibliographyEdition":161,"bibliographyDiscussion":247,"citation":250,"tmNumber":8,"facsimile":269,"letterHeights":270,"publications":290,"zotero":298,"keywords":306,"lettering_types":316},"I.Sicily inscription 000632",{"_":5},"draft",[7,10,13,15,18],{"_":8,"type":9},"175845","TM",{"_":11,"type":12},"073621","EDR",{"type":14},"EDH",{"_":16,"type":17},"15100066","EDCS",{"type":19},"PHI",null,{"_":22,"ana":23,"ref":24},"building","#function.building","http://www.eagle-network.eu/voc/typeins/lod/86.html","Large limestone block. Intact front, left, and partly on top and at resar. The right side is lost and the upper surface is uneven, very worn, and clearly missing some material. A piece is missing rear right.",{"_":27,"ana":28,"ref":29},"block","#object.block","http://www.eagle-network.eu/voc/objtyp/lod/189.html",{"_":31,"ana":32,"ref":33},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":35},"#condition.damaged",[37,41,44],{"_":38,"unit":39,"dimension":40},"36","cm","height",{"_":42,"unit":39,"dimension":43},"90","width",{"_":45,"unit":39,"dimension":46},"60","depth",{"layout":48},{"p":49,"rs":50,"damage":54},"The front face preserves four lines of Latin text, with a clear margin on the left, loss to the upper right of line 1, and from the right end of all four lines. A deep circular hole has been drilled into the middle of line 4, which however the letters appear to be engraved around.",{"_":51,"ana":52,"ref":53},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":55},"#text_condition.incomplete",{"lettering":57,"dimensions":58},"Broken bar A, D tending to square, lunate E, G with trailing tail, closed P and R. Use of a sinusoid form interpunct after FL in line 2.",[59,65,70,75,81,87,92],{"type":60,"l":61,"from":62,"to":62,"h":63,"unit":64,"atLeast":63,"atMost":63},"letterHeight","Line 1","line1","62","mm",{"type":60,"l":66,"from":67,"to":67,"h":68,"unit":64,"atLeast":45,"atMost":69},"Line 2","line2","60-78","78",{"type":60,"l":71,"from":72,"to":72,"h":73,"unit":64,"atLeast":74,"atMost":63},"Line 3","line3","51-62","51",{"type":60,"l":76,"from":77,"to":77,"h":78,"unit":64,"atLeast":79,"atMost":80},"Line 4","line4","45-48","45","48",{"type":82,"l":83,"from":62,"to":67,"h":84,"unit":64,"atLeast":85,"atMost":86},"interlinear","Interlineation line 1 to 2","15-25","15","25",{"type":82,"l":88,"from":67,"to":72,"h":89,"unit":64,"atLeast":90,"atMost":91},"Interlineation line 2 to 3","22-30","22","30",{"type":82,"l":93,"from":72,"to":77,"h":94,"unit":64,"atLeast":95,"atMost":96},"Interlineation line 3 to 4","32-40","32","40",{"_":98,"notBefore":99,"notAfter":100,"evidence":101},"5th or early 6th century CE",401,550,"lettering, titulature",[103,108],{"_":104,"type":105,"ref":106,"region":107},"Syracusae","ancient","http://pleiades.stoa.org/places/462503","Sicilia",{"_":109,"type":110,"ref":111,"region":107},"Siracusa","modern","http://sws.geonames.org/2523083",[113],[114,115],37.08415,15.27628,{"_":117,"type":118,"subtype":119,"notBefore":120,"notAfter":121,"geo":122},"Found during works to open Via del Littorio on Ortygia, between 1934 and 1936; one of a number of unstratified finds (apparently in secondary deposition, reused as building material) in the area of Largo Antonello Gagini, formerly Largo XXVIII Ottobre. Now in storage in the Museo Archeologico Regionale di Siracusa.","found","discovered","1934","1936",[123,124],37.0629811,15.2921563,[123,124],{"_":127,"type":128,"subtype":129,"resp":130,"xml:id":131,"geo":20},"Prag 2018-03-15","observed","autopsied","#JP","autopsy",[133],{"n":134,"url":135,"height":136,"width":137,"desc":138,"surfaceType":139},"screen","ISic000632_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2018-03-15","front","Sicily",{"_":142,"role":143,"ref":144,"museum":145},"Museo Archeologico Regionale Paolo Orsi","museum","http://sicily.classics.ox.ac.uk/museum/097",{"slug":146,"type":143,"name":142,"uri":144,"description":147,"location":148},"097","An outstanding collection of archaeological material. The collection ranges from Siracusa and the surrounding territory (Megara Hyblaia, Akrai, Kasmenai etc) to encompass all of eastern Sicily, reaching as far as Gela and Agrigento. The ground floor covers prehistory through to the end of the Classical period. Upstairs includes Hellenistic and Roman Syracuse and a display of material from the catacombs. A gallery displaying material from Hellenistic eastern Sicily is in preparation.",{"settlement":109,"region":109,"country":149,"address":150,"geo":151},"Italy","Viale Teocrito 66, 96100 - Siracusa",{"lat":152,"lon":153},37.07636989,15.2866213,{"_":155,"type":156},"50739","inventory",{"_":158,"mainLang":159,"languages":160},"Latin","la",[158],{"type":162,"bibl":163},"edition",[164,177,181,193,203,214,225,236,20],{"type":165,"n":166,"citedRange":167,"ptr":168,"ref":170,"title":172,"author":173,"date":174,"citation":175,"uri":176},"bulletin","AE","1980.0512",{"target":169},"https://www.zotero.org/groups/382445/items/R46KDTZX",{"_":171,"target":171},"https://biblio.inscriptiones.org/epig10001283","L'année épigraphique: revue des publications épigraphiques relatives a l'antiquité romaine.","","1888-","\u003