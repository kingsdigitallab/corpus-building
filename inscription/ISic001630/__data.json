             \u003Clb n=\"5\" break=\"no\"/>\u003Csupplied reason=\"lost\">σα\u003C/supplied>ς τὸν βίον ἐπ\u003Csupplied reason=\"lost\">λ\u003C/supplied>\n                    \u003Clb n=\"6\" break=\"no\"/>\u003Csupplied reason=\"lost\">ή\u003C/supplied>ρωσεν τῇ π\u003Csupplied reason=\"lost\">ρὸ\u003C/supplied>\n                    \u003Clb n=\"7\"/>\u003Cnum value=\"5\">ε\u003C/num> καλανδ\u003Csupplied reason=\"lost\">ῶν\u003C/supplied> \u003Cgap reason=\"illegible\" unit=\"character\" extent=\"unknown\">\u003Cdesc>name of month\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of Agnello\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Libertini: ἐνθάδε κῆτε\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>Libertini: ἔτη εἴκοσει τρία\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>ἀμέμπτως ζή\u003C/note>\u003C/app>\n                    \u003Capp loc=\"7\">\u003Cnote>Libertini: ε καλανδῶν. ; Agnello comments that the month name is written in very small letters at the end, but is not legible\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Here lies Kyriakos, having lived 23 years. Having lived blamelessly, he fulfilled his life on the 5th day before the Kalends of [---]\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Agnello\u003C/author>\n                        \u003Cdate>1953\u003C/date>\n                        \u003CcitedRange>no.62\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/D9BZFDDR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002211\">https://biblio.inscriptiones.org/epig10002211\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1931\u003C/date>\n                        \u003CcitedRange>44 no.8\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/T67M4XMU\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001870\">https://biblio.inscriptiones.org/epig10001870\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
