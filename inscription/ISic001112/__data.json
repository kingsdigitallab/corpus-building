data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἀρτεμιδώρου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Ἀρτεμιδώρου\">Ἀρτεμιδώρο[υ]\u003C/span>\u003C/span>\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>τὰν ἐπιμέλειαν ἐποιήσα[το] \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>τῶν ἔργων τοῦ ἀνδρεῶνο[ς] \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>[κ]αὶ τᾶς προέδρας μετὰ τ[ῶν] \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>ἱεροφυλάκων \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Giorgia Capra\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>ΙΕΡΟΜΝΑΜΟΝΕΩΝ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Τίττελος Ἀρτεμιδώρου\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Τίττελος\">ΤΙΤΤΕΛΟΣ\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἀρτεμιδώρου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Ἀρτεμιδώρου\">ΑΡΤΕΜΙΔΩΡΟ[.]\u003C/span>\u003C/span>\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>ΤΑΝΕΠΙΜΕΛΕΙΑΝΕΠΟΙΗΣΑ[..]\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>ΤΩΝΕΡΓΩΝΤΟΥΑΝΔΡΕΩΝΟ[.]\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>[.]ΑΙΤΑΣΠΡΟΕΔΡΑΣΜΕΤΑΤ[..]\u003Cbr id=\"al6-diplomatic\">\u003Cspan class=\"linenumber\">6\u003C/span>ΙΕΡΟΦΥΛΑΚΩΝ\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u0