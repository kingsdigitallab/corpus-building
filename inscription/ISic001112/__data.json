chaeological-context\" source=\"https://www.zotero.org/groups/382445/items/3PK3JKXR\">On palaeographic grounds, datable to the C3 or C2 BCE; but this inscription, together with several others almost certainly belongs in the context of the monumental stoa of the later second century BCE.\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"1810\">Found c.1810 in the ruins of ancient Segesta (precise findspot not documented).\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.honorific\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/69.html\">honorific\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-09-23\" who=\"#JP\">Jonathan Prag added ISegesta ref\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-06-11\" who=\"#GC\">edited text and added english translation\u003C/change>\n                \u003Cchange when=\"2022-05-09\" who=\"#JP\">Jonathan Prag edited metadata\u003C/change>\n                \u003Cchange when=\"2022-09-12\" who=\"#JP\">Jonathan Prag added Italian translation\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001112_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001112.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#GC\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CroleName type=\"civic.religious\" subtype=\"hieromnemon\">ἱερομναμονέων\u003C/roleName>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Τίττελος\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Ἀρτεμιδώρο\u003Csupplied reason=\"lost\">υ\u003C/supplied>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"3\"/>τὰν ἐπιμέλειαν ἐποιήσα\u003Csupplied reason=\"lost\">το\u003C/supplied>\n                    \u003Clb n=\"4\"/>τῶν ἔργων τοῦ ἀνδρεῶνο\u003Csupplied reason=\"lost\">ς\u003C/supplied>\n                    \u003Clb n=\"5\"/>\u003Csupplied reason=\"lost\">κ\u003C/supplied>αὶ τᾶς προέδρας μετὰ τ\u003Csupplied reason=\"lost\">ῶν\u003C/supplied>\n                    \u003Clb n=\"6\"/>\u003CroleName type=\"civic.religious\" subtype=\"hierophylax\">ἱεροφυλάκων\u003C/roleName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of I.Segesta\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#GC\">\n                \u003Cp>When he was hieromnamon, Tittelos son of Artemidoros took care of the works for the andreon and the proedra, together with the hierophylakes.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" source=\"https://www.zotero.org/groups/382445/items/3PK3JKXR\">\n                \u003Cp>Mentre era hieromnamon, Tittelos figlio di Artemidoros ha completato la cura dei lavori dell'andreon e della proedra insieme con gli hierophylakes.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--lists Hieromnamon under whom work undertaken; building work is of Andreon and proedra, perhaps related to gymnasion? cf. Nenci 1991 for context / discussion, offering it as the most recent (p.925) of a series of such inscr., all poss. of a single family - although if so, then C2 seems more likely!; cf. SEG 41.825.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">291\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                         \u003Cauthor>Dubois\u003C/author>\n                         \u003Cdate>1989\u003C/date> \n                        \u003CcitedRange>\n                            \u003Cref target=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\">216\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RWXNUFEX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5545 and p.1249\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"SGDI\">\n                        \u003Cauthor>Hoffmann\u003C/author>\n                        \u003Cdate>1904\u003C/date>\n                        \u003CcitedRange>5190\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DQDPC573\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000817\">https://biblio.inscriptiones.org/epig10000817\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Nenci\u003C/author>\n                        \u003Cdate>1991\u003C/date>\n                        \u003CcitedRange>923 tav.298\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ERHMXBDJ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001413\">https://biblio.inscriptiones.org/epig10001413\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Vido\u003C/author>\n                        \u003Cdate>1991\u003C/date>\n                        \u003CcitedRange>973\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/KMKJH2E8\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001409\">https://biblio.inscriptiones.org/epig10001409\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Guarducci\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1937\u003C/date>\n                        \u003CcitedRange>399\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>cf. SEG 41.825\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Vido\u003C/author>\n                        \u003Cdate>2003\u003C/date>\n                        \u003CcitedRange>398 no.5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/33HPA43I\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002041\">https://biblio.inscriptiones.org/epig10002041\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ampolo and Erdas\u003C/author>\n                        \u003Cdate>2019\u003C/date>\n                        \