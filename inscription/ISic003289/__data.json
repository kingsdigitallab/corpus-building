f":182},"Simona Stoyanova","SS","https://orcid.org/0000-0003-3914-9569",{"_":184,"xml:id":185,"ref":186},"Alessia Coccato","Coccato","https://orcid.org/0000-0002-6641-2820",{"_":188,"when":189,"who":190},"Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary","2022-12-22","#martaf",{"n":103,"url":104,"height":105,"width":106,"desc":107,"surfaceType":108},[193],{"atLeast":194,"atMost":195},33,37,[197,198],"Korhonen, 2004, IMusCatania","Libertini, 1930, Il Museo Biscari",[200,201],"2EUC82DH","SKUU2R8X",[203,204,205,21,26,206,207,208,209,210,208,211,212,128],"isic003289","fragment of an epitaph",{"_":5},"strongly altered marble, likely unspecified (identification based on pxrf)","catina","catania","sicilia","sicily","museo civico di catania","ancient greek",[],{"title":215,"body":216,"divs":217,"editions":244,"images":254,"handnote":260},"ISic003289. Fragment of an Epitaph","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al0-interpretive\">\u003C!--0-->\u003C/a>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al1-interpretive\">\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΖΙΕΙΑΔỌṂẠ\u003Cspan dir=\"ltr\" class=\"gap\">...\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cspan data-text=\"ἐτῶν\">ἐτ(ῶν?)\u003C/span> μ´ \u003Cspan data-text=\"υἱὸς\">υἱὸς\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδώρας\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδώρας\">Ἰσιδώρα(ς)\u003C/span>\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>  \u003Cspan data-text=\"κατετέθει\">κατ]ε̣τέθει\u003C/span>  \u003Cspan data-text=\"δὲ\">δὲ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδωρ \">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδωρ \">\u003Cspan data-text=\"Ἰσιδωρ\">Ἰσιδω[ρ\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]Υ̣ΤΗ \u003Cspan data-text=\"τῶν\">τ(ῶν)\u003C/span> Καταν(ῶν) ΠΟΖΗΛ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">l.4 superscript | superscript\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al0-diplomatic\">\u003C!--0-->\u003C/a>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al1-diplomatic\">\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΖΙΕΙΑΔ...\u003Cspan dir=\"ltr\" class=\"gap\">···\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan data-text=\"ἐτῶν\">ΕΤ\u003C/span>Μ\u003Cspan data-text=\"υἱὸς\">ΥΙΟΣ\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδώρας\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδώρας\">ΙΣΙΔΩΡΑ\u003C/span>\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>\u003Cspan data-text=\"κατετέθει\">...].ΤΕΘΕΙ\u003C/span>\u003Cspan data-text=\"δὲ\">ΔΕ\u003C/span>\u003Cspan data-text=\"καὶ\">ΚΑΙ\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδωρ \">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδωρ \">\u003Cspan data-text=\"Ἰσιδωρ\">ΙΣΙΔΩ[.\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>].ΤΗ\u003Cspan data-text=\"τῶν\">Τ\u003C/span>ΚΑΤΑΝΠΟΖΗ.[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">l.4 superscript | superscript\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003289_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003289_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003289.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003289-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 1\">line.1: \u003Cspan>Korhonen: [---]ZIEIAΔΣIIΛIII[---]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Libertini: υἱὸς Ἰσιδώρ(ας); Korhonen ET(---) M υἱός, Ἰσιδώρα +[---]. The small curved sign at the upper right of Τ could be an abbreviation for ων (see l. 4): ἐτ(ῶν) and the small sign above the Μ could indicate the numeral\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 3\">line.3: \u003Cspan>Libertini: ἐτέθει δὲ καὶ Ἰσιδώρα; Korhonen: [κατ]ε̣τέθει (i.e. κατετέθη) δὲ καὶ Ἰσιδώ[ρ-]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 4\">line.4: \u003Cspan>According to Korhonen the first letter could also be a Κ. The small curved sign above the T and the N could be an abbreviation for ων (τ(ῶν) Καταν(ῶν), i.e. τῶν Καταν(αίων), see also Korhonen)\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>… at the age of 40. The son of Isidora … were lied down and Isidor- … of the inhabitants of Catania…\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>… all’età di 40 anni. Il figlio di Isidora … sono stati sepolti e Isidor- … degli abitanti di Catania…\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>The epitaph is very fragmentary and the several abbreviations make it difficult to read. Palaeography suggests a date to the first Byzantine era. The text must have been an epitaph as suggested by the verb \u003Cspan class=\"lang\" lang=\"grc\">[---κατ]ετέθει\u003C/span> (i.e. \u003Cspan class=\"lang\" lang=\"grc\">κατετέθη\u003C/span>) at l. 3, which is used to indicate the act of burial. At l. 2 and l. 3 the female name \u003Cspan class=\"lang\" lang=\"grc\">Ἰσιδώρα\u003C/span> can be read (but, as Korhonen points out, the second mention could also have been the masculine name \u003Cspan class=\"lang\" lang=\"grc\">Ἰσιδώρος\u003C/span>), while at l. 4 the reading \u003Cspan class=\"lang\" lang=\"grc\">τ(ῶν) Καταν(ῶν)\u003C/span> (i.e. \u003Cspan class=\"lang\" lang=\"grc\">τῶν Καταναίων\u003C/span>) is likely and connects this inscription the city of Catania.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Libertini 1930 318 no.10 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001871\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001871\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 191 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>A with broken bar, squared E (except at l. 3 where it is lunate), lunate Σ, cursive Ω. At ll. 2 and 4, Π and Τ are crossed by slanting bars, which could indicate an abbreviation. Small H and Ο above Τ and Π at l. 4, small curved signs at the upper right of T at l. 2, T and Ν at l. 4. Small curved signs below Υ and inside Ω and Α at l. 2, which could be now decoration marks, now abbreviation marks.\u003C/p> Lines 1-4  33-37  Interlineation line 1 to 2  not recorded  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[218,221,224,227,230,232,235,238,241],{"id":219,"html":220},"editions","\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al0-interpretive\">\u003C!--0-->\u003C/a>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al1-interpretive\">\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΖΙΕΙΑΔỌṂẠ\u003Cspan dir=\"ltr\" class=\"gap\">...\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cspan data-text=\"ἐτῶν\">ἐτ(ῶν?)\u003C/span> μ´ \u003Cspan data-text=\"υἱὸς\">υἱὸς\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδώρας\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδώρας\">Ἰσιδώρα(ς)\u003C/span>\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>  \u003Cspan data-text=\"κατετέθει\">κατ]ε̣τέθει\u003C/span>  \u003Cspan data-text=\"δὲ\">δὲ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδωρ \">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδωρ \">\u003Cspan data-text=\"Ἰσιδωρ\">Ἰσιδω[ρ\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]Υ̣ΤΗ \u003Cspan data-text=\"τῶν\">τ(ῶν)\u003C/span> Καταν(ῶν) ΠΟΖΗΛ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">l.4 superscript | superscript\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al0-diplomatic\">\u003C!--0-->\u003C/a>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al1-diplomatic\">\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΖΙΕΙΑΔ...\u003Cspan dir=\"ltr\" class=\"gap\">···\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan data-text=\"ἐτῶν\">ΕΤ\u003C/span>Μ\u003Cspan data-text=\"υἱὸς\">ΥΙΟΣ\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδώρας\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδώρας\">ΙΣΙΔΩΡΑ\u003C/span>\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>\u003Cspan data-text=\"κατετέθει\">...].ΤΕΘΕΙ\u003C/span>\u003Cspan data-text=\"δὲ\">ΔΕ\u003C/span>\u003Cspan data-text=\"καὶ\">ΚΑΙ\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδωρ \">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδωρ \">\u003Cspan data-text=\"Ἰσιδωρ\">ΙΣΙΔΩ[.\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>].ΤΗ\u003Cspan data-text=\"τῶν\">Τ\u003C/span>ΚΑΤΑΝΠΟΖΗ.[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">l.4 superscript | superscript\u003C/p>\u003C/div>",{"id":222,"html":223},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003289_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003289_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003289.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003289-thumb.jpg\">\u003C/a>",{"id":225,"html":226},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 1\">line.1: \u003Cspan>Korhonen: [---]ZIEIAΔΣIIΛIII[---]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Libertini: υἱὸς Ἰσιδώρ(ας); Korhonen ET(---) M υἱός, Ἰσιδώρα +[---]. The small curved sign at the upper right of Τ could be an abbreviation for ων (see l. 4): ἐτ(ῶν) and the small sign above the Μ could indicate the numeral\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 3\">line.3: \u003Cspan>Libertini: ἐτέθει δὲ καὶ Ἰσιδώρα; Korhonen: [κατ]ε̣τέθει (i.e. κατετέθη) δὲ καὶ Ἰσιδώ[ρ-]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 4\">line.4: \u003Cspan>According to Korhonen the first letter could also be a Κ. The small curved sign above the T and the N could be an abbreviation for ων (τ(ῶν) Καταν(ῶν), i.e. τῶν Καταν(αίων), see also Korhonen)\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":228,"html":229},"translation","\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>… at the age of 40. The son of Isidora … were lied down and Isidor- … of the inhabitants of Catania…\u003C/p>  ",{"id":228,"html":231},"\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>… all’età di 40 anni. Il figlio di Isidora … sono stati sepolti e Isidor- … degli abitanti di Catania…\u003C/p>  ",{"id":233,"html":234},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>The epitaph is very fragmentary and the several abbreviations make it difficult to read. Palaeography suggests a date to the first Byzantine era. The text must have been an epitaph as suggested by the verb \u003Cspan class=\"lang\" lang=\"grc\">[---κατ]ετέθει\u003C/span> (i.e. \u003Cspan class=\"lang\" lang=\"grc\">κατετέθη\u003C/span>) at l. 3, which is used to indicate the act of burial. At l. 2 and l. 3 the female name \u003Cspan class=\"lang\" lang=\"grc\">Ἰσιδώρα\u003C/span> can be read (but, as Korhonen points out, the second mention could also have been the masculine name \u003Cspan class=\"lang\" lang=\"grc\">Ἰσιδώρος\u003C/span>), while at l. 4 the reading \u003Cspan class=\"lang\" lang=\"grc\">τ(ῶν) Καταν(ῶν)\u003C/span> (i.e. \u003Cspan class=\"lang\" lang=\"grc\">τῶν Καταναίων\u003C/span>) is likely and connects this inscription the city of Catania.\u003C/p>  ",{"id":236,"html":237},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Libertini 1930 318 no.10 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001871\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001871\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 191 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  ",{"id":239,"html":240},"handnote","\u003Cp>A with broken bar, squared E (except at l. 3 where it is lunate), lunate Σ, cursive Ω. At ll. 2 and 4, Π and Τ are crossed by slanting bars, which could indicate an abbreviation. Small H and Ο above Τ and Π at l. 4, small curved signs at the upper right of T at l. 2, T and Ν at l. 4. Small curved signs below Υ and inside Ω and Α at l. 2, which could be now decoration marks, now abbreviation marks.\u003C/p> Lines 1-4  33-37  Interlineation line 1 to 2  not recorded  ",{"id":242,"html":243},"license"," Licensed under a Creative Commons-Attribution 4.0 licence. ",[245,247,250,251],{"html":246},"Text encoding: Marta Fogagnolo, Alex Antoniou",{"id":248,"lang":128,"html":249},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al0-interpretive\">\u003C!--0-->\u003C/a>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al1-interpretive\">\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΖΙΕΙΑΔỌṂẠ\u003Cspan dir=\"ltr\" class=\"gap\">...\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cspan data-text=\"ἐτῶν\">ἐτ(ῶν?)\u003C/span> μ´ \u003Cspan data-text=\"υἱὸς\">υἱὸς\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδώρας\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδώρας\">Ἰσιδώρα(ς)\u003C/span>\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>  \u003Cspan data-text=\"κατετέθει\">κατ]ε̣τέθει\u003C/span>  \u003Cspan data-text=\"δὲ\">δὲ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδωρ \">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδωρ \">\u003Cspan data-text=\"Ἰσιδωρ\">Ἰσιδω[ρ\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]Υ̣ΤΗ \u003Cspan data-text=\"τῶν\">τ(ῶν)\u003C/span> Καταν(ῶν) ΠΟΖΗΛ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">l.4 superscript | superscript\u003C/p>",{"html":246},{"id":252,"lang":128,"html":253},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al0-diplomatic\">\u003C!--0-->\u003C/a>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al1-diplomatic\">\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΖΙΕΙΑΔ...\u003Cspan dir=\"ltr\" class=\"gap\">···\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan data-text=\"ἐτῶν\">ΕΤ\u003C/span>Μ\u003Cspan data-text=\"υἱὸς\">ΥΙΟΣ\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδώρας\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδώρας\">ΙΣΙΔΩΡΑ\u003C/span>\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>\u003Cspan data-text=\"κατετέθει\">...].ΤΕΘΕΙ\u003C/span>\u003Cspan data-text=\"δὲ\">ΔΕ\u003C/span>\u003Cspan data-text=\"καὶ\">ΚΑΙ\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἰσιδωρ \">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἰσιδωρ \">\u003Cspan data-text=\"Ἰσιδωρ\">ΙΣΙΔΩ[.\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>].ΤΗ\u003Cspan data-text=\"τῶν\">Τ\u003C/span>ΚΑΤΑΝΠΟΖΗ.[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">l.4 superscript | superscript\u003C/p>",[255,257],{"image":104,"thumb":256,"title":107},"ISic003289_tiled-thumb.tif",{"image":258,"thumb":259,"title":107},"ISic003289.jpg","ISic003289-thumb.jpg",[261],{"html":58},"\u003C?xml version='1.0' encoding='UTF-8'?>\n\u003C?xml-model href=\"https://epidoc.stoa.org/schema/latest/tei-epidoc.rng\" type=\"application/xml\" schematypens=\"http://relaxng.org/ns/structure/1.0\"?>\n\u003C?xml-model href=\"../schematron/ircyr-checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XInclude\" xml:lang=\"en\">\n    \u003CteiHeader>\n        \u003CfileDesc>\n            \u003CtitleStmt>\n                \u003Ctitle>Fragment of an Epitaph\u003C/title>\n                \u003Ceditor ref=\"#JP\">Jonathan Prag\u003C/editor>\n                \u003Cprincipal ref=\"#JP\">Jonathan Prag\u003C/principal>\n                \u003Cfunder>John Fell OUP Research Fund\u003C/funder>\n\t   \u003Cfunder>\u003Cref target=\"https://cordis.europa.eu/project/id/885040\">ERC Advanced Grant no.885040\u003C/ref>\u003C/funder>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>original data collection and editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"martaf\" ref=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/name>\n                    \u003Cresp>editing, translation and commentary\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JCu\" ref=\"http://orcid.org/0000-0002-6686-3728\">James Cummings\u003C/name>\n                    \u003Cresp>conversion to EpiDoc\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"AA\" ref=\"http://orcid.org/0000-0001-7077-0703\">Alex Antoniou\u003C/name>\n                    \u003Cresp>EpiDoc editing\u003C/resp>\n                \u003C/respStmt>\n\t    \u003CrespStmt>\n     \t       \u003Cname xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n     \t       \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n \t   \u003C/respStmt>\n            \u003CrespStmt>\u003Cname xml:id=\"Coccato\" ref=\"https://orcid.org/0000-0002-6641-2820\">Alessia Coccato\u003C/name>\u003Cresp>Petrographic observation and analysis\u003C/resp>\u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic003289\u003C/idno>\n                \u003Cidno type=\"TM\">645556\u003C/idno>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\"/>\n                \u003Cidno type=\"PHI\">316272\u003C/idno>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic003289\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-18\">10.5281/zenodo.4358063\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Catania\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/018\">Museo Civico di Catania\u003C/repository>\n                        \u003Cidno type=\"inventory\">644\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>Two joining fragments of marble plaque damaged on all sides.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.inorganic.stone.metamorphic_rock.marble\" type=\"stone.marble\" subtype=\"unspecified\" resp=\"#Coccato\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">Strongly altered marble, likely unspecified (identification based on pXRF)\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/257\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--measurements from Korhonen-->\n                                        \u003Cheight unit=\"cm\">19\u003C/height>\n                                        \u003Cwidth unit=\"cm\">31\u003C/width>\n                                        \u003Cdepth unit=\"cm\">4.3\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragments.contiguous\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>A with broken bar, squared E (except at l. 3 where it is lunate), lunate Σ, cursive Ω. At ll. 2 and 4, Π and Τ are crossed by slanting bars, which could indicate an abbreviation. Small H and Ο above Τ and Π at l. 4, small curved signs at the upper right of T at l. 2, T and Ν at l. 4. Small curved signs below Υ and inside Ω and Α at l. 2, which could be now decoration marks, now abbreviation marks.\u003C/p>\u003C!--measurements from Korhonen-->\n                                \u003Clocus from=\"line1\" to=\"line4\">Lines 1-4\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"33\" atMost=\"37\">33-37\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\">not recorded\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462270\">Catina\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525068\">Catania\u003C/placeName> \n                            \t\u003Cgeo>37.49223, 15.07041\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0501\" notAfter-custom=\"0900\">6th — 9 century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1766-11-21\">Original discovery not recorded, but probably from Catania; Tardìa, Cod. Bibl. Comunale Palermo Qq C 17 a, f. 136r mentions the inscription as coming from Catania, communicated to him by Torremuzza 21 November 1766.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\">Observed by Libertini in Museo Biscari, later by Korhonen in Magazzino superiore, Collezione Biscari (formerly sala VII 288).\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Funerary\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-09-29\" who=\"#AA\">Alex Antoniou Epidoc editing\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-12-22\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003289_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003289.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\"/>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>ΖΙΕΙΑΔ\u003Cunclear>OMA\u003C/unclear>\u003C/orig>\u003Cgap reason=\"illegible\" quantity=\"3\" unit=\"character\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Cw>\u003Cexpan>\u003Cabbr>ἐτ\u003C/abbr>\u003Cex cert=\"low\">ῶν\u003C/ex>\u003C/expan>\u003C/w> \u003Cnum value=\"40\">μ\u003C/num> \u003Cw>υἱὸς\u003C/w> \u003CpersName type=\"attested\">\u003Cname>\u003Cexpan>\u003Cabbr>Ἰσιδώρα\u003C/abbr>\u003Cex>ς\u003C/ex>\u003C/expan>\u003C/name>\u003C/persName> \u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Cw>\u003Csupplied reason=\"lost\">κατ\u003C/supplied>\u003Cunclear>ε\u003C/unclear>τέθει\u003C/w> \u003Cw>δὲ\u003C/w> \u003Cw>καὶ\u003C/w> \u003CpersName type=\"attested\">\u003Cname>\u003Cw part=\"I\">Ἰσιδω\u003Csupplied reason=\"lost\">ρ\u003C/supplied>\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"4\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cunclear>Υ\u003C/unclear>Τ\u003Chi rend=\"superscript\">Η\u003C/hi> \u003Cw>\u003Cexpan>\u003Cabbr>τ\u003C/abbr>\u003Cex>ῶν\u003C/ex>\u003C/expan>\u003C/w> \u003CplaceName type=\"ethnic\">\u003Cexpan>\u003Cabbr>Καταν\u003C/abbr>\u003Cex>ῶν\u003C/ex>\u003C/expan>\u003C/placeName> Π\u003Chi rend=\"superscript\">Ο\u003C/hi>ΖΗ\u003Cunclear>Λ\u003C/unclear>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"5\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 1\">\u003Cnote>Korhonen: [---]ZIEIAΔΣIIΛIII[---]\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 2\">\u003Cnote>Libertini: υἱὸς Ἰσιδώρ(ας); Korhonen ET(---) M υἱός, Ἰσιδώρα +[---]. The small curved sign at the upper right of Τ could be an abbreviation for ων (see l. 4): ἐτ(ῶν) and the small sign above the Μ could indicate the numeral\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 3\">\u003Cnote>Libertini: ἐτέθει δὲ καὶ Ἰσιδώρα; Korhonen: [κατ]\u003Cunclear>ε\u003C/unclear>τέθει (i.e. κατετέθη) δὲ καὶ Ἰσιδώ[ρ-]\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 4\">\u003Cnote>According to Korhonen the first letter could also be a Κ. The small curved sign above the T and the N could be an abbreviation for ων (τ(ῶν) Καταν(ῶν), i.e. τῶν Καταν(αίων), see also Korhonen)\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>… at the age of 40. The son of Isidora … were lied down and Isidor- … of the inhabitants of Catania…\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>… all’età di 40 anni. Il figlio di Isidora … sono stati sepolti e Isidor- … degli abitanti di Catania…\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>The epitaph is very fragmentary and the several abbreviations make it difficult to read. Palaeography suggests a date to the first Byzantine era. The text must have been an epitaph as suggested by the verb \u003Cforeign xml:lang=\"grc\">[---κατ]ετέθει\u003C/foreign> (i.e. \u003Cforeign xml:lang=\"grc\">κατετέθη\u003C/foreign>) at l. 3, which is used to indicate the act of burial. At l. 2 and l. 3 the female name \u003Cforeign xml:lang=\"grc\">Ἰσιδώρα\u003C/foreign> can be read (but, as Korhonen points out, the second mention could also have been the masculine name \u003Cforeign xml:lang=\"grc\">Ἰσιδώρος\u003C/foreign>), while at l. 4 the reading \u003Cforeign xml:lang=\"grc\">τ(ῶν) Καταν(ῶν)\u003C/foreign> (i.e. \u003Cforeign xml:lang=\"grc\">τῶν Καταναίων\u003C/foreign>) is likely and connects this inscription the city of Catania.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>191\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1930\u003C/date>\n                        \u003CcitedRange>318 no.10\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SKUU2R8X\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001871\">https://biblio.inscriptiones.org/epig10001871\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
