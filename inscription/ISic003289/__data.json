{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":101,"html":214,"xml":262},"ISic003289",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":19,"type":20,"support":24,"objectType":25,"material":29,"condition":37,"dimensions":39,"layoutDesc":50,"handNote":57,"date":74,"places":78,"geo":88,"country":83,"provenance":80,"provenanceFound":92,"provenanceGeo":97,"provenanceObserved":98,"provenanceLost":19,"graphics":101,"region":109,"settlement":85,"repository":110,"idno":123,"textLang":126,"bibliographyEdition":130,"bibliographyDiscussion":155,"citation":158,"tmNumber":8,"facsimile":191,"letterHeights":192,"publications":196,"zotero":199,"keywords":202,"lettering_types":213},"Fragment of an Epitaph",{"_":5},"draft",[7,10,12,14,16],{"_":8,"type":9},"645556","TM",{"type":11},"EDR",{"type":13},"EDH",{"type":15},"EDCS",{"_":17,"type":18},"316272","PHI",null,{"_":21,"ana":22,"ref":23},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","Two joining fragments of marble plaque damaged on all sides.",{"_":26,"ana":27,"ref":28},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/257",{"_":30,"ana":31,"type":32,"subtype":33,"resp":35,"ref":36},"Strongly altered marble, likely unspecified (identification based on pXRF)","#material.inorganic.stone.metamorphic_rock.marble","stone.marble",[34],"unspecified","#Coccato","http://www.eagle-network.eu/voc/material/lod/48.html",{"ana":38},"#condition.fragments.contiguous",[40,44,47],{"_":41,"unit":42,"dimension":43},"19","cm","height",{"_":45,"unit":42,"dimension":46},"31","width",{"_":48,"unit":42,"dimension":49},"4.3","depth",{"layout":51},{"rs":52,"damage":56},{"_":53,"ana":54,"ref":55},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1","",{"lettering":58,"dimensions":59},"A with broken bar, squared E (except at l. 3 where it is lunate), lunate Σ, cursive Ω. At ll. 2 and 4, Π and Τ are crossed by slanting bars, which could indicate an abbreviation. Small H and Ο above Τ and Π at l. 4, small curved signs at the upper right of T at l. 2, T and Ν at l. 4. Small curved signs below Υ and inside Ω and Α at l. 2, which could be now decoration marks, now abbreviation marks.",[60,69],{"type":61,"l":62,"from":63,"to":64,"h":65,"unit":66,"atLeast":67,"atMost":68},"letterHeight","Lines 1-4","line1","line4","33-37","mm","33","37",{"type":70,"l":71,"from":63,"to":72,"h":73,"unit":66},"interlinear","Interlineation line 1 to 2","line2","not recorded",{"_":75,"notBefore":76,"notAfter":77},"6th — 9 century CE",501,900,[79,84],{"_":80,"type":81,"ref":82,"region":83},"Catina","ancient","http://pleiades.stoa.org/places/462270","Sicilia",{"_":85,"type":86,"ref":87,"region":83},"Catania","modern","http://sws.geonames.org/2525068",[89],[90,91],37.49223,15.07041,{"_":93,"type":94,"subtype":95,"notAfter":96,"geo":19},"Original discovery not recorded, but probably from Catania; Tardìa, Cod. Bibl. Comunale Palermo Qq C 17 a, f. 136r mentions the inscription as coming from Catania, communicated to him by Torremuzza 21 November 1766.","found","discovered","1766-11-21",[],{"_":99,"type":100,"geo":19},"Observed by Libertini in Museo Biscari, later by Korhonen in Magazzino superiore, Collezione Biscari (formerly sala VII 288).","observed",[102],{"n":103,"url":104,"height":105,"width":106,"desc":107,"surfaceType":108},"screen","ISic003289_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":111,"role":112,"ref":113,"museum":114},"Museo Civico di Catania","museum","http://sicily.classics.ox.ac.uk/museum/018",{"slug":115,"type":112,"name":111,"uri":113,"description":116,"location":117},"018","Antiquarian collection, comprehensive in scope",{"settlement":85,"region":85,"country":118,"address":119,"