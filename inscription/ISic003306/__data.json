i Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\"/>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\"/>\u003Corig>\u003Cunclear>A\u003C/unclear>\u003C/orig>\u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Cw>πρὸ\u003C/w> \u003Cw>\u003Cexpan>\u003Cabbr>Κ\u003C/abbr>\u003Cex>αλανδῶν\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cw>Ν\u003Csupplied reason=\"lost\" cert=\"low\">οεμβρίων\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cgap reason=\"illegible\" quantity=\"2\" unit=\"character\"/>\u003Corig>Ε\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" cert=\"low\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photograph\u003C/note>\u003C/app>\n                    \u003Capp>\u003Cnote>After K is perhaps an abbreviation mark\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" re