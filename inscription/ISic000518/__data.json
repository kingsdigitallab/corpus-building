e\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"1\"/>ex aere conlato patrono\n                    \u003Clb n=\"2\"/>bene de se merito curante\n                    \u003Clb n=\"3\"/>et de suo quod defuerat\n                    \u003Clb n=\"4\"/>supplente\n                    \u003Clb n=\"5\"/>\u003CpersName type=\"attested\">\u003Cname>Paconio\u003C/name> \u003Cname>Clodiano\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text from Gualtherus; Mommsen adds interpuncts throughout, but these are not recorded by Gualtherus and so have no basis in fact.\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Mommsen notes the smiilarity to CIL 10.7294 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic000551\">ISic000551\u003C/ref> and so speculates that this might be a doublet in the antiquarian tradition.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624\u003C/date>\n                        \u003CcitedRange>249\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GIN6NANU\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002388\">https://biblio.inscriptiones.org/epig10002388\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n       