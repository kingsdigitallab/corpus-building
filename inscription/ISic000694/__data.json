 \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Chi rend=\"supraline\">\u003Cnum value=\"7\">VII\u003C/num>\u003C/hi> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"5\"/>\u003Cname>\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>arcus\u003C/ex>\u003C/expan>\u003C/name> \u003Cname>Allianus\u003C/name>\n                    \u003Clb n=\"6\"/>\u003Cexpan>\u003Cabbr>fil\u003C/abbr>\u003Cex>ius\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>fec\u003C/abbr>\u003Cex>it\u003C/ex>\u003C/expan>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text: Manganaro 1989, with comparison to Fasolo 2013, fig 59 photo\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>To the shades of the underworld, Asinia Charmosyne lived for 65 years and 7 months. Marcus Allianus, her son, built this.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Asinia Charmosyne, erected by son Mallianus (not M. Allianus as Manganaro); photograph from antiquarium visit 2006-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1991.0901\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1989.0338n\u003C/citedRange>\n                        \u003Cptr target=\"http://zoter