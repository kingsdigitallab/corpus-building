Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-07-14\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#AA #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>d\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Asinia\u003C/name> \u003Cname>Char\n                    \u003Clb n=\"3\" break=\"no\"/>mosyne\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>v\u003C/abbr>\u003Cex>ixit\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>a\u003C/abbr>\u003Cex>nnis\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"4\"/>\u003Cnum value=\"65\">LXV\u003C/num> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>mens\u003C/abbr>\u003Cex>ibus\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Chi rend=\"supraline\">\u003Cnum value=\"7\">VII\u003C/num>\u003C/hi> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"5\"/>\u003CpersName type=\"attested\">\u003Cname>Mallianus\u003C/name>\u003C/persName>\n                    \u003Clb n=\"6\"/>\u003Cexpan>\u003Cabbr>fil\u003C/abbr>\u003Cex>ius\u003C/ex>\u003C/expan> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g> \u003Cexpan>\u003Cabbr>fec\u003C/abbr>\u003Cex>it\u003C/ex>\u003C/expan>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text from autopsy (earlier editions did not note interpuncts, hedera, or supraline)\u003C/note>\u003C/app>\n                    \u003Capp loc=\"5\">\u003Cnote>Manganaro: M.Allianus\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>To the shades of the underworld, Asinia Charmosyne lived for 65 years and 7 months. Mallianus, her son, set this up.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Solin rejects Manganaro's reading of MALLIENUS in line 5 as M(arcus) Allienus, partly because the absence of a gentilicium would be odd and partly because of the absence of an interpunct after the M (which autopsy confirms to be absent). Fasolo repeats Manganaro's text.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1991.0901\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1989.0338n\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>165 no.22 fig.22\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EZMBJ6GN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001831\">https://biblio.inscriptiones.org/epig10001831\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Solin\u003C/author>\n                        \u003Cdate>1990\u003C/date>\n                        \u003CcitedRange>134 no.139\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/CQUAVV2K\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001422\">https://biblio.inscriptiones.org/epig10001422\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fasolo\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>85 no.33 fig.59\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/X2SEXMRX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002011\">https://biblio.inscriptiones.org/epig10002011\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
