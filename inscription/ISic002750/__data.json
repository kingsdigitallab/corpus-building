ine1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462153\">Centuripae\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525032\">Centuripe\u003C/placeName>\n                                \u003Cgeo>37.62336, 14.74049\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0001\" notAfter-custom=\"0200\">1st — 2nd century CE (Manganaro; Libertini suggests 2nd — 3rd century CE)\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"1930\">Described by Libertini as a chance find in Vallata Difesa, during roadworks some 80 m from the Chiesa del Crocifisso, on the road descending towards teh sulpher works in localita Marmora. Currently on display in the Centuripe museum.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" xml:id=\"autopsy\">Prag 2006-04\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-06-30\" who=\"#FP\">Francesca Prado edited the text\u003C/change>\n                \u003Cchange when=\"2021-07-14\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2022-02-03\" who=\"#JP\">Jonathan Prag edited file from autopsy notes and publication, added translation\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002750_tiled.tif\" height=\"3412px\" width=\"3408px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002750.jpg\" height=\"3412px\" width=\"3408px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#FP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw>Ἐνθάδε\u003C/w> \u003Cw>\u003Cunclear>κ\u003C/unclear>\u003Csupplied reason=\"lost\">εῖται\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"nomen\">Νώνιος\u003C/name> \u003Cname type=\"cognomen\">\u003Cseg part=\"I\">Π\u003Cunclear>ι\u003C/unclear>\u003C/seg>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/name>\n                    \u003Clb n=\"3\"/>\u003Cw>τέκτων\u003C/w>\u003C/persName> \u003Cw>κά\u003Cunclear>λ\u003C/unclear>\u003Csupplied reason=\"lost\">λιστόν\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw>ποτε\u003C/w> \u003Cw>τοῦτον\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">ἀ\u003C/supplied>νεῖ\n                    \u003Clb n=\"5\" break=\"no\"/>λε\u003C/w> \u003Cw>κίων\u003C/w> \u003Cw>καὶ\u003C/w> \u003CpersName type=\"divine\">\u003Cname>Μοῖρα\u003C/name>\u003C/persName>\n                    \u003Clb n=\"6\"/>\u003Cw>ὃς\u003C/w> \u003Cw>κατέλειψε\u003C/w> \u003Cw>πατρὶ\u003C/w>\n                    \u003Clb n=\"7\"/>\u003Cw>λύπην\u003C/w> \u003Cw>δεινοτάτην\u003C/w>\n                    \u003Clb n=\"8\"/>\u003Cw>ἔζησε\u003C/w> \u003Cw>ἔτη\u003C/w> \u003Cnum value=\"22\">\u003Cunclear>κ\u003C/unclear>β\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after Manganaro 1994 but controlled with autopsy/photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"8\">\u003Cnote>Manganaro: ιβ’\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Here lies Nonios Pi[--], a carpenter. A column and Fate snatched away this once most handsome man, who left behind the most wretched grief for his father. He lived 22 years.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>A verse distych begins midway through line 3.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>44.0748\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                   \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1953.0279\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1994\u003C/date>\n                        \u003CcitedRange>102 no. 17 fig. 22\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/532NF7SV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001825\">https://biblio.inscriptiones.org/epig10001825\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1949\u003C/date>\n                        \u003CcitedRange>94 no. 2 fig. 2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VQURX85J\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001865\">https://biblio.inscriptiones.org/epig10001865\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>44.0738\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
