tml\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-06-30\" who=\"#FP\">Francesca Prado edited the text\u003C/change>\n                \u003Cchange when=\"2021-07-14\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2022-02-03\" who=\"#JP\">Jonathan Prag edited file from autopsy notes and publication, added translation\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002750_tiled.tif\" height=\"3412px\" width=\"3408px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002750.jpg\" height=\"3412px\" width=\"3408px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#FP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw>Ἐνθάδε\u003C/w> \u003Cw>\u003Cunclear>κ\u003C/unclear>\u003Csupplied reason=\"lost\">εῖται\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"nomen\">Νώνιος\u003C/name> \u003Cname type=\"cognomen\">\u003Cseg part=\"I\">Π\u003Cunclear>ι\u003C/unclear>\u003C/seg>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/name>\n                    \u003Clb n=\"3\"/>\u003Cw>τέκτων\u003C/w>\u003C/persName> \u003Cw>κά\u003Cunclear>λ\u003C/unclear>\u003Csupplied reason=\"lost\">λιστόν\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw>ποτε\u003C/w> \u003Cw>τοῦτον\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">ἀ\u003C/supplied>νεῖ\n                    \u003Clb n=\"5\" break=\"no\"/>λε\u003C/w> \u003Cw>κίων\u003C/w> \u003Cw>καὶ\u003C/w> \u003CpersName type=\"divine\">\u003Cname>Μοῖρα\u003C/name>\u003C/persName>\n                    \u003Clb n=\"6\"/>\u003Cw>ὃς\u003C/w> \u003Cw>κατέλειψε\u003C/w> \u003Cw>πατρὶ\u003C/w>\n                    \u003Clb n=\"7\"/>\u003Cw>λύπην\u003C/w> \u003Cw>δεινοτάτην\u003C/w>\n                    \u003Clb n=\"8\"/>\u003Cw>ἔζησε\u003C/w> \u003Cw>ἔτη\u003C/w> \u003Cnum value=\"22\">\u003Cunclear>κ\u003C/unclear>β\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after Manganaro 1994 but controlled with autopsy/photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"8\">\u003Cnote>Manganaro: ιβ’\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Here lies Nonios Pi[--], a carpenter. A column and Fate snatched away this once most handsome man, who left behind the most wretched grief for his father. He lived 22 years.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>A verse distych begins midway through line 3.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>44.0748\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                   \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1953.0279\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1994\u003C/date>\n                        \u003CcitedRange>102 no. 17 fig. 22\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/532NF7SV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001825\">https://biblio.inscriptiones.org/epig10001825\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1949\u003C/date>\n                        \u003CcitedRange>94 no. 2 fig. 2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VQURX85J\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001865\">https://biblio.inscriptiones.org/epig10001865\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>44.0738\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
