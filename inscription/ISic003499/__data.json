g/0000-0003-3914-9569",{"_":182,"xml:id":183,"ref":184},"Valentina Mignosa","VM","https://orcid.org/0000-0002-7122-2511",{"_":186,"xml:id":187},"Flavio Santini","FS",{"_":189,"xml:id":190,"ref":191},"Romeo Gessaga","RG","https://orcid.org/0009-0003-5190-1722",{"_":193,"xml:id":194,"ref":195},"Alessia Coccato","Coccato","https://orcid.org/0000-0002-6641-2820",{"_":197,"when":198,"who":167},"Jonathan Prag revised from photograph and Santini's autopsy notes ","2026-02-17",{"n":110,"url":111,"height":112,"width":113,"desc":114,"surfaceType":115},[201,204],{"atLeast":202,"atMost":203},27,30,{"atLeast":205,"atMost":206},6,8,[208,209],"Supplementum epigraphicum graecum, 1923-","Manganaro, 1999, Sikelika: studi di antichità e di epigrafia della Sicilia greca",[211,212],"F2GG87EQ","GRB3IPD5",[214,215,216,21,26,30,217,218,219,220,218,221,222,135],"isic003499","fragmentary greek inscription",{"_":5},"syracusae","siracusa","sicilia","sicily","museo archeologico regionale paolo orsi","ancient greek",[],{"title":225,"body":226,"divs":227,"editions":252,"images":262,"handnote":273},"ISic003499. Fragmentary Greek inscription","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa, Jonathan Prag; edition source: autopsy 2018-09-18 (Santini), Magazzino B, cassa 52\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>ΕΙ\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὐτύχης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὐτύχης\">Εὐτύ[χης?\u003C/span>\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>Λ̣Ι̣Α̣Σ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa, Jonathan Prag; edition source: autopsy 2018-09-18 (Santini), Magazzino B, cassa 52\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>ΕΙ\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὐτύχης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὐτύχης\">ΕΥΤΥ[...\u003C/span>\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>....[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003499_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2019-10-01\" src=\"ISic003499_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003499.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2019-10-01\" src=\"ISic003499-thumb.jpg\">\u003C/a>\u003Ca href=\"ISic003499_rear_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2019-10-01\" src=\"ISic003499_rear_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003499_rear.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2019-10-01\" src=\"ISic003499_rear-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text from autopsy notes and photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"1\">1: \u003Cspan>Possible letter trace; not recorded by Manganaro\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"2\">2: \u003Cspan>Lapis: Σ or Δ; Manganaro; Εἰσ[---]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"4\">4: \u003Cspan>Manganaro: Αἰδο[---]\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2> translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>  \u003C/p>\u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>Manganaro presents this, on the basis of a photograph, as being part of a list of Greek names, implicitly of hellenistic date. However, the size and form of the letters (notably the V-shaped upsilon) strongly suggest that this is more likely to be a fragment of a later, Roman period, funerary inscription. The final letter of line 1 is either a four-bar sigma, or, perhaps more likely, a delta; the traces in line 4 are not easily compatible with Manganaro's reading, particularly the fourth letter, which is not an omicron, and is only really compatible with a lunate sigma (which would in turn imply delta in line 1), while the extension of the oblique hasta on the third letter suggests an alpha, in contrast to the initial lamda.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 49.1331.5 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000796\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000796\u003C/a>\u003C/li>\u003Cli> Manganaro 1999 68 no.61 fig.143 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001813\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001813\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>Simpy cut letters with terminal serifs. Epsilon with uneven middle length bar; upsilon as V not Y.\u003C/p> Line 2-3  27-30  Interlineation line 1 to 4  6-8  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[228,231,234,237,240,243,246,249],{"id":229,"html":230},"editions","\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa, Jonathan Prag; edition source: autopsy 2018-09-18 (Santini), Magazzino B, cassa 52\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>ΕΙ\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὐτύχης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὐτύχης\">Εὐτύ[χης?\u003C/span>\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>Λ̣Ι̣Α̣Σ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa, Jonathan Prag; edition source: autopsy 2018-09-18 (Santini), Magazzino B, cassa 52\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>ΕΙ\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὐτύχης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὐτύχης\">ΕΥΤΥ[...\u003C/span>\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>....[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":232,"html":233},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003499_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2019-10-01\" src=\"ISic003499_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003499.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2019-10-01\" src=\"ISic003499-thumb.jpg\">\u003C/a>\u003Ca href=\"ISic003499_rear_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2019-10-01\" src=\"ISic003499_rear_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003499_rear.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2019-10-01\" src=\"ISic003499_rear-thumb.jpg\">\u003C/a>",{"id":235,"html":236},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text from autopsy notes and photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"1\">1: \u003Cspan>Possible letter trace; not recorded by Manganaro\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"2\">2: \u003Cspan>Lapis: Σ or Δ; Manganaro; Εἰσ[---]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"4\">4: \u003Cspan>Manganaro: Αἰδο[---]\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":238,"html":239},"translation","\u003Ch2> translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>  \u003C/p>",{"id":241,"html":242},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>Manganaro presents this, on the basis of a photograph, as being part of a list of Greek names, implicitly of hellenistic date. However, the size and form of the letters (notably the V-shaped upsilon) strongly suggest that this is more likely to be a fragment of a later, Roman period, funerary inscription. The final letter of line 1 is either a four-bar sigma, or, perhaps more likely, a delta; the traces in line 4 are not easily compatible with Manganaro's reading, particularly the fourth letter, which is not an omicron, and is only really compatible with a lunate sigma (which would in turn imply delta in line 1), while the extension of the oblique hasta on the third letter suggests an alpha, in contrast to the initial lamda.\u003C/p>  ",{"id":244,"html":245},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 49.1331.5 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000796\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000796\u003C/a>\u003C/li>\u003Cli> Manganaro 1999 68 no.61 fig.143 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001813\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001813\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  ",{"id":247,"html":248},"handnote","\u003Cp>Simpy cut letters with terminal serifs. Epsilon with uneven middle length bar; upsilon as V not Y.\u003C/p> Line 2-3  27-30  Interlineation line 1 to 4  6-8  ",{"id":250,"html":251},"license"," Licensed under a Creative Commons-Attribution 4.0 licence. ",[253,255,258,259],{"html":254},"Text encoding: Valentina Mignosa, Jonathan Prag; edition source: autopsy 2018-09-18 (Santini), Magazzino B, cassa 52",{"id":256,"lang":135,"html":257},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>ΕΙ\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὐτύχης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὐτύχης\">Εὐτύ[χης?\u003C/span>\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>Λ̣Ι̣Α̣Σ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":254},{"id":260,"lang":135,"html":261},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>ΕΙ\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Εὐτύχης\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Εὐτύχης\">ΕΥΤΥ[...\u003C/span>\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>....[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",[263,265,268,270],{"image":111,"thumb":264,"title":114},"ISic003499_tiled-thumb.tif",{"image":266,"thumb":267,"title":114},"ISic003499.jpg","ISic003499-thumb.jpg",{"image":117,"thumb":269,"title":114},"ISic003499_rear_tiled-thumb.tif",{"image":271,"thumb":272,"title":114},"ISic003499_rear.jpg","ISic003499_rear-thumb.jpg",[274],{"html":60},"\u003C?xml version='1.0' encoding='UTF-8'?>\n\u003C?xml-model href=\"https://epidoc.stoa.org/schema/latest/tei-epidoc.rng\" type=\"application/xml\" schematypens=\"http://relaxng.org/ns/structure/1.0\"?>\n