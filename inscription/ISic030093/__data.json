bserved\" subtype=\"autopsied\">No Autopsy\u003C/provenance>\n                        \u003Cacquisition/> \n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>             \n            \u003Cxi:include href=\"../alists/charDecl.xml\">                 \n                \u003Cxi:fallback>                     \n                    \u003Cp>ISicily glyphs authority list\u003C/p>                 \n                \u003C/xi:fallback>             \n            \u003C/xi:include>         \n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.defixio\" ref=\"https://www.eagle-network.eu/voc/typeins/lod/76.html\">defixio\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2021-06-09\" who=\"#VM\">Valentina Mignosa added basic metadata\u003C/change>\n                \u003Cchange when=\"2021-09-21\" who=\"#SN\">Savannah Neibart encoded inscription using data from ISicDef, supplemented by Bettarini\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic030093_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic030093.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#SN\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Corig>ΡΕΕΡΥΧΘ\u003C/orig>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Bettarini.\u003C/note>\u003C!-- ISicDef no. 49 -->\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp xml:lang=\"en\">ΡΕΕΡΥΧΘ (cf. also the preceding lemma): previously unattested vox magica; the first four letters are a palindrome; -ΧΘ is a frequent sequence in magical documents; the term may have been associated with the verb ἐρύκω, ed.pr.; the occurence of vox magica may point to a (much?) later date than the 3rd cent. B.C., G.Bevilacqua, ArchClass 56 (2005) 606. (SEG)\u003C/p>\n                \u003Cp xml:lang=\"it\">La presenza di una stessa sequenza alfabetica priva di senso evidente in due distinti documenti (ISic030093 and ISic030094) non può che indurre a ipotizzare che si tratti di una vox magica. Sopravvivono pochi esemplari di età classica o ellenistica (sia perchè c'era in età imperiale una maggiore diffusione della parola scritta rispetto a età precedenti, età in cui la stesura di testi magici, strutturalmente pi semplice e scarna, sarà stata accompagnata da invocazioni, incantesimi, e preghiere recitate oralmente) perché molti erano iscritti su amuleti o poco durevoli o molto preziosi che sono andati perduti, distrutti o sono stati riutilizzati, mentre le defixiones su piombo venivano interrate in tombe o santuari. Vi sono però casi di documenti magici apotropaici di IV sec. incise su piombo, nelle quali le lettere efesie si accompagnano a voces magicae e a versi in esametri: il caso più famoso è quello della tavolette plumbea cretese di Phalasarna, una tavoletta di Selinunte che giace inedita (?) nel Getty Museum, e la terracotta fittile di area palermitana (Monte Cavalli) del III sec. Sono tutti probabilmente amleti (la vox magica da sola potrebbe funzionare da generico amuleto).\u003C/p>\n                \u003Cp xml:lang=\"it\">Non vi è nulla di simile nelle voces magicae già note, ma almeno due elementi permettono di collocarla facilmente tra le espressioni magiche: l'inizio palindromo (PEEP), e la presenza di due aspirate consecutive (ΧΘ) poiché i nessi di aspirate sembrano particolarmente prediletti in questo genere di parole. Viene naturale associarlo per assonanza con il termine greco ερυκω, il cui significato si addice perfettamente a un contesto apotropaico. (Bettarini)\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"ISelinunteDef\">\n                        \u003Cauthor>Bettarini\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003CcitedRange>7\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SEW88NC7\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001388\">https://biblio.inscriptiones.org/epig10001388\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>55.1027\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
