-->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#AA #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Ὁ δᾶ\u003Csupplied reason=\"lost\">μος\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text from photograph\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>The people (of Tyndaris ...)\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Gentili speculatively read this as a reference to an individual called Aristodamos or Kleodamos, but as Robert already observed, this must, surely, as in ISic003348, be a reference to the damos (and was so restored by Manganaro). As with ISic003348 it was found in re-use in a late antique element of the fortification walls.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1953.0277\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gentili\u003C/author>\n                        \u003Cdate>1952\u003C/date>\n                        \u003CcitedRange>164 no.1821\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/J7X6KWXI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001959\">https://biblio.inscriptiones.org/epig10001959\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1965\u003C/date>\n                        \u003CcitedRange>203 no.1 tav.72.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RGTHAFKT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001841\">https://biblio.inscriptiones.org/epig10001841\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fasolo\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>58 no.4 fig.22\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/X2SEXMRX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002011\">https://biblio.inscriptiones.org/epig10002011\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
