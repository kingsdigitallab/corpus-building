03C/change>\n\t        \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000285_tiled.tif\" height=\"3456px\" width=\"4608px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo Liceo Lazzaro 2017-11-18\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000285.jpg\" height=\"3456px\" width=\"4608px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo Liceo Lazzaro 2017-11-18\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#AA #RC\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/> Cura\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">tores\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Cexpan>\u003Cabbr>Q\u003C/abbr>\u003Cex>uintus\u003C/ex>\u003C/expan> Mac\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">ulnius\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"3\"/>\u003Cexpan>\u003Cabbr>\u003Cunclear>T\u003C/unclear>\u003C/abbr>\u003Cex>itus\u003C/ex>\u003C/expan> Tr\u003Cunclear>u\u003C/unclear>t\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">tedi\u003C/supplied>\u003Csupplied reason=\"lost\">us\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"4\"/>\u003Cexpan>\u003Cabbr>A\u003C/abbr>\u003Cex>ulus\u003C/ex>\u003C/expan> Turiu\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">s\u003C/supplied> \u003Cexpan>\u003Cabbr>\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">A\u003C/supplied>\u003C/abbr>\u003Cex>uli\u003C/ex>\u003C/expan> \u003Csupplied reason=\"undefined\" evidence=\"previouseditor\" cert=\"low\">OCHAC\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Korhonen 2004\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>Curators Quintus Maculnius, Titus Truttedius, Aulus Turius, son of Aulus\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Only the left half of the text is preserved, compared to the earlier antiquarian records. The reading is extremely difficult, due to the  nature of the volcanic stone, as noted already by Gualtherus. Modern repainting of the letters, seemingly following the reading of Gualtherus' second edition, only confuses the issue, rather than providing certainty (e.g. the painting of an A in line 3 appears to be without foundation on the stone). The text would appear to be of early (i.e. Augustan) date, reflecting construction of the aqueduct around the foundation of the Roman colonia.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624\u003C/date>\n                        \u003CcitedRange>273\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GIN6NANU\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002388\">https://biblio.inscriptiones.org/epig10002388\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>\u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/310975\">335\u003C/ref>\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/650753\">6999\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>25\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Lagona\u003C/author>\n                        \u003Cdate>1964\u003C/date>\n                        \u003CcitedRange>84-85 tav.25.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/W2SKMZD3\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001437\">https://biblio.inscriptiones.org/epig10001437\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>44 n.216 tav.14\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Belvedere\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>378\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/8QJAZISW\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001429\">https://biblio.inscriptiones.org/epig10001429\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Wilson\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>125\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/CR529RQD\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001430\">https://biblio.inscriptiones.org/epig10001430\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Wilson\u003C/author>\n                        \u003Cdate>1990\u003C/date>\n                        \u003CcitedRange>98, 370 n.256\u003C/citedRange>