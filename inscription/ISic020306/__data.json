 \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>Fragment of foot of a black-glaze kylix.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.clay.fired\" ref=\"https://www.eagle-network.eu/voc/material/lod/131.html\">ceramic\u003C/material>\n                                    \u003CobjectType ana=\"#object.vessel.kylix\" ref=\"http://kerameikos.org/id/kylix\">kylix\u003C/objectType> \u003C!-- ref=\"https://www.eagle-network.eu/voc/objtyp/lod/305.html\" -->\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.scratched\" ref=\"https://www.eagle-network.eu/voc/writing/lod/9\">scratched\u003C/rs>\n                                    \u003Cp>The text is placed on the underside of the foot. The letters have been highlighted with white painting in modern times to make them more legible.\u003C/p>\n                                    \u003Cdamage ana=\"#text_condition.incomplete text_condition.legible\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003C!--  Based on Glyph table: alpha05 (first) or symbol?; alpha03 (second); epsilon19 (first); epsilon15 (second); iota01; lambda08; mu02; nu1