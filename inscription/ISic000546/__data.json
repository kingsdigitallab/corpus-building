 dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000546.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#NCash\">\n                \u003Cab>\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" cert=\"low\"/>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cunclear>et\u003C/unclear> \u003Cexpan>\u003Cabbr>Q\u003C/abbr>\u003Cex>uinti\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> Fabi \u003Cg ref=\"#interpunct\">·\u003C/g> Caesili \u003Cg ref=\"#interpunct\">·\u003C/g> Titiani\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>avo \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>Q\u003C/abbr>\u003Cex>uinto\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> Aquilio \u003Cg ref=\"#interpunct\">·\u003C/g> Nigro\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003CroleName type=\"supracivic\" subtype=\"proconsul\">\u003Csupplied reason=\"lost\">p\u003C/supplied>ro \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>c\u003Chi rend=\"supraline\">o\u003C/hi>\u003C/abbr>\u003Cex>n\u003C/ex>\u003Cabbr>s\u003C/abbr>\u003Cex>uli\u003C/ex>\u003C/expan>\u003C/roleName>\n                    \u003Clb n=\"4\"/>Si\u003Csupplied reason=\"lost\">cili\u003C/supplied>ae\n                \u003C/ab>\