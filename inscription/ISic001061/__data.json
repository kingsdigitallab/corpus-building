ge when=\"2025-12-10\" who=\"#ZL\">tagged names and persons\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001061_tiled.tif\" height=\"1908px\" width=\"3280px\">\n                \u003Cdesc>Museo Archeologico Regionale Antonino Salinas, reproduced with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001061.jpg\" height=\"1908px\" width=\"3280px\">\n                \u003Cdesc>Museo Archeologico Regionale Antonino Salinas, reproduced with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Εὐβουλίδας\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Ἀγαθάρχου\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003CplaceName type=\"ethnic\">Κεντορρειπεῖνος\u003C/placeName>\u003C/persName> κατεσσκέ\n                    \u003Clb n=\"3\" break=\"no\"/>ωσε κράναν ἐλευ\n                    \u003Clb n=\"4\" break=\"no\"/>θέ\u003Csupplied reason=\"lost\">ρ\u003C/supplied>αν\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003Cp>Text of IGPalermo corrected against photograph\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Euboulides, son of Agatharchos, Kentorreipeinos (of Centuripe); either 'liberated' a fountain, or built one to 'Eleuthera'; On the spelling of Centuripe, with double rho, cf. a) theorodokoi list of Delphi, v.97; Thucid.XI.94, after cod.Vat.B (?)).-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">241\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGMusPalermo\">\n                         \u003Cauthor>Manni Piraino\u003C/author>\n                         \u003Cdate>1973\u003C/date> \n                        \u003CcitedRange>29\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F66S4X3M\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000531\">https://biblio.inscriptiones.org/epig10000531\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5467\u003C/citedRange>\n                        \u