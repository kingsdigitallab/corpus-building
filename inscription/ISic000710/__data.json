2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-06-04\" who=\"#TNS\">Epidoc editing\u003C/change>\n                \u003Cchange when=\"2025-01-23\" who=\"#JP\">Jonathan Prag revised from published edition and photograph\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000710_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000710.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#TNS #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Grattia\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilia\u003C/ex>\u003C/expan>\u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"2\"/>\u003Cname>Paulla\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>uxor \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CpersName type=\"attested\">\u003Cname>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Ofill\u003Chi rend=\"apex\">i\u003C/hi>\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">·\u003C/g> ma\u003Chi rend=\"tall\">t\u003C/hi>er \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CpersName type=\"attested\">\u003Cname>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Ofill\u003Csupplied reason=\"lost\">\u003Chi rend=\"apex\">i\u003C/hi>\u003C/supplied>\u003C/name>\n                    \u003Clb n=\"4\"/>\u003Cname>V\u003Chi rend=\"apex\">e\u003C/hi>ri\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CroleName type=\"civic\" subtype=\"duumvir\">d\u003Chi rend=\"apex\">u\u003C/hi>mviralium\u003C/roleName>\n                    \u003Clb n=\"5\"/>\u003Chi rend=\"tall\">f\u003C/hi>unere \u003Cg ref=\"#interpunct\">·\u003C/g> publico \u003Cg ref=\"#interpunct\">·\u003C/g> elata \u003Cg ref=\"#interpunct\">·\u003C/g> e\u003Chi rend=\"tall\">t\u003C/hi> \u003Cg ref=\"#interpunct\">·\u003C/g> l\u003Cunclear>o\u003C/unclear>\u003Csupplied reason=\"lost\">co\u003C/supplied>\n                    \u003Clb n=\"6\"/>publico \u003Cg ref=\"#interpunct\">·\u003C/g> sepulta \u003Cg ref=\"#interpunct\">·\u003C/g> e\u003Chi rend=\"tall\">t\u003C/hi> \u003Cg ref=\"#interpunct\">·\u003C/g> st\u003Cunclear>a\u003C/unclear>\u003Csupplied reason=\"lost\">tua\u003C/supplied>\n                    \u003Clb n=\"7\"/>data \u003Cg ref=\"#interpunct\">·\u003C/g> in \u003Cg ref=\"#interpunct\">·\u003C/g> foro \u003Cspace unit=\"character\" quantity=\"2\"/> \u003CroleName type=\"civic\" subtype=\"decurio\">\u003Cexpan>\u003Cabbr>d\u003C/abbr>\u003Cex>ecurionum\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>\u003Cunclear>d\u003C/unclear>\u003C/abbr>\u003Cex>ecreto\u003C/ex>\u003C/expan>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Manganaro 1989 controlled against photograph\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Grattia Paulla, daughter of Caius, wife of Caius Ofillius, mother of Caius Ofillius Verus, both holders of the duumvirate, laid out in a public funeral and buried in a public lot, and granted a statue in the forum - by decree of the decurions.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1989.0341m\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl/>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>44\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>172 no.43 fig.47\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EZMBJ6GN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001831\">https://biblio.inscriptiones.org/epig10001831\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
