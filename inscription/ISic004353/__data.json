\">ιβ\u003C/num> \u003Cg ref=\"#interpunct\" n=\"35\">·\u003C/g> κ\u003Cunclear>αὶ\u003C/unclear> \u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\" n=\"40\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"45\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text from autopsy\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"1\">\n                        \u003Cnote>Biondi: πρὸ ι καλ\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"2\">\n                        \u003Cnote>The character after final Κ is either Α or Λ, followed by the tops of two further letters.\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Rizzone and Ferrua identify a consular date in line 2, Theodosius for the 12 time and Valentinian\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1982-1983\u003C/date>\n                        \u003CcitedRange>17 no.55 (14 fig.2a)\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q7DDNWD6\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001996\">https://biblio.inscriptiones.org/epig10001996\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Biondi and Buscemi Felici\u003C/author>\n                        \u003Cdate>2014\u003C/date>\n                        \u003CcitedRange>171 no. 242 fig. 42\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/8CH847SJ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002149\">https://biblio.inscriptiones.org/epig10002149\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzone\u003C/author>\n                        \u003Cdate>2014-2015\u003C/date>\n                        \u003CcitedRange>97 no.14 fig.30\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/S3G73QA2\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001626\">https://biblio.inscriptiones.org/epig10001626\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
