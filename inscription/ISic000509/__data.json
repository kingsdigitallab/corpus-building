istChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2018-06-08\" who=\"#JP\">Jonathan Prag revised EpiDoc added text and translation via LSA and bibl elements\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-17\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000509_tiled.tif\" height=\"4608px\" width=\"3072px\">\n                \u003Cdesc>Photo M. Metcalfe\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000509.jpg\" height=\"4608px\" width=\"3072px\">\n                \u003Cdesc>Photo M. Metcalfe\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CroleName type=\"supracivic\" subtype=\"imperator\">\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>Imp\u003C/abbr>\u003Cex>eratori\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/roleName> \u003Csupplied reason=\"lost\">Caesari\u003C/supplied>\n                    \u003Clb n=\"2\"/>\u003CroleName type=\"supracivic\" subtype=\"dominus\">\u003Cexpan>\u003Cabbr>d\u003C/abbr>\u003Cex>omino\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cexpan>\u003Cabbr>n\u003C/abbr>\u003Cex>ostro\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>F\u003C/abbr>\u003Csupplied reason=\"lost\">\u003Cabbr>l\u003C/abbr>\u003Cex>avio\u003C/ex>\u003C/supplied>\u003C/expan> \u003Csupplied reason=\"lost\">Valentini\u003C/supplied>\n                    \u003Clb n=\"3\" break=\"no\"/>ano pio \u003Csupplied reason=\"lost\">felici\u003C/supplied>\n                    \u003Clb n=\"4\"/>semper Aug\u003Csupplied reason=\"lost\">usto\u003C/supplied>\n                    \u003Clb n=\"5\"/>\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>arcus\u003C/ex>\u003C/expan> Valerius\n                    \u003Clb n=\"6\"/>Quintianus\n                    \u003Clb n=\"7\"/>\u003Cexpan>\u003Cabbr>v\u003C/abbr>\u003Cex>ir\u003C/ex>\u003C/expan> \u003CroleName type=\"supracivic\" subtype=\"clarissimus\">\u003Cexpan>\u003Cabbr>c\u003C/abbr>\u003Cex>larissimus\u003C/ex>\u003C/expan>\u003C/roleName> \u003CroleName type=\"supracivic\" subtype=\"consularis\">\u003Cexpan>\u003Cabbr>cons\u003C/abbr>\u003Cex>ularis\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex>rovinciae\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>S\u003C/abbr>\u003Cex>iciliae\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"8\"/>clementiae\n                    \u003Clb n=\"9\"/>pietatique eius\n                    \u003Clb n=\"10\"/>semper dicatis\n                    \u003Clb n=\"11\" break=\"no\"/>simus\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Marino 1978\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp>To the emperor Caesar, our lord Flavius Valentinianus, pious, fortunate, forever Augustus; Marcus Valerius Quintianus, of clarissimus rank, governor (consularis) of the province of Sicilia, most dedicated to his clemency and piety (set this up) [translation of Gehn and Machado, LSA 2063]\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Traces of a probably C3 AD inscription are visible between the final lines\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7229\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Marino\u003C/author>\n                        \u003Cdate>1978\u003C/date>\n                        \u003CcitedRange>106-110 no.4\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/NBA3MBAP\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001760\">https://biblio.inscriptiones.org/epig10001760\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Machado and Gehn\u003C/author>\n                        \u003Cdate>2014\u003C/date>\n                        \u003CcitedRange>\u003Cref target=\"http://laststatues.classics.ox.ac.uk/database/detail-base.php?record=LSA-2063\">LSA-2063\u003C/ref>\u003C/citedRange>\n                        \u003Cptr target=\"http://laststatues.classics.ox.ac.uk/\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002692\">https://biblio.inscriptiones.org/epig10002692\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
