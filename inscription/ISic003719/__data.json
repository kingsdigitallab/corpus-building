 e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>-->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Cmilestone unit=\"face\" n=\"a\"/>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Μ \u003Cg>((plough))\u003C/g>\n                    \u003Cmilestone unit=\"face\" n=\"b\"/>\n                    \u003Clb n=\"2\"/>η\n                    \u003Clb n=\"3\"/>\u003Cg>((jug))\u003C/g>\n                    \u003Clb n=\"4\" style=\"text-direction:r-to-l\"/>νία\u003C/name>\u003C/persName>\n                    \u003Cmilestone unit=\"face\" n=\"d\"/>\n                    \u003Clb n=\"5\"/> εὖ\n                    \u003Clb n=\"6\"/>\u003Cg>((amphora))\u003C/g>\n                    \u003Cmilestone unit=\"face\" n=\"d\"/>\n                    \u003Clb n=\"7\"/>\u003Cg>((dolphin))\u003C/g>\n                    \u003Cmilestone unit=\"face\" n=\"e\"/>\n                    \u003Clb n=\"8\"/>\u003Cg>((swastika))\u003C/g>\n                    \u003Cmilestone unit=\"face\" n=\"f\"/>\n                    \u003Clb n=\"9\"/>\u003Chi rend=\"ligature\">\u003CpersName type=\"attested\">\u003Cname>Ἡρέα\u003C/name>\u003C/persName>\u003C/hi>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Manganaro\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Manganaro argues that this is a bread stamp, and connects the letters of the first two sides to form the name of one of the two bakers, along with that on side f.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>51.1395\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>2001\u003C/date>\n                        \u003CcitedRange>192 figs.23-27\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GZ4997ZA\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001805\">https://biblio.inscriptiones.org/epig10001805\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
