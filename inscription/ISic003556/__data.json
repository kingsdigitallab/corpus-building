 \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-09-06\" who=\"#JP\">Jonathan Prag revised file from publications\u003C/change>\n                \u003Cchange when=\"2026-02-15\" who=\"#RG\">tagged names and persons\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003556_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003556.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>συνβί\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"3\"/> καὶ ματρὶ \u003CpersName type=\"attested\">\u003Cname>\u003Cchoice>\u003Creg>Ἰχνατία\u003C/reg>\u003Corig>Ἰχνδτι\u003C/orig>\u003C/choice>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Ζαχαρίας\u003C/name>\u003C/persName> \u003Cgap reason=\"lost\" unit=\"character\" quantity=\"3\"/> καὶ \u003CpersName type=\"attested\">\u003Cname>Κούϊντος\u003C/name>\n                    \u003Clb n=\"3\"/>υἱὸς \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cchoice>\u003Creg>Πριμιγένεως\u003C/reg>\u003Corig>Πριμιγνίτως\u003C/orig>\u003C/choice>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"4\"/>μνήμης χάριν\n                    \u003Clb n=\"5\"/>ἐποίησαν\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Kaibel and Filippi, with suggested restorations of SEG, prioritising Kaibel's transcription of the manuscript tradition.\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>As Korhonen lucidly details, the inscription is one of a series of late 18th century local antiquarian forgeries, constructed on the basis of existing texts, principally those to be found in the 1769 first edition of the corpus of Torremuzza. Kaibel classed the entire series already as forgeries in IG XIV.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">22*\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>52.0901\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Filippi\u003C/author>\n                        \u003Cdate>2002\u003C/date>\n                        \u003CcitedRange>75 no.7/3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/PIPP325H\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001991\">https://biblio.inscriptiones.org/epig10001991\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Filippi\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003CcitedRange>65 no.7/3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/WBLZEBQ8\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002296\">https://biblio.inscriptiones.org/epig10002296\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2017\u003C/date>\n                        \u003CcitedRange>198\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/92ITYJC6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001484\">https://biblio.inscriptiones.org/epig10001484\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
