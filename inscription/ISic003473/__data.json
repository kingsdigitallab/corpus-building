{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":101,"html":213,"xml":279},"ISic003473",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":34,"dimensions":36,"layoutDesc":47,"handNote":56,"date":69,"places":74,"geo":84,"country":79,"provenance":76,"provenanceFound":88,"provenanceGeo":95,"provenanceObserved":96,"provenanceLost":20,"graphics":101,"region":121,"settlement":122,"repository":123,"idno":137,"textLang":140,"bibliographyEdition":144,"bibliographyDiscussion":168,"citation":171,"tmNumber":8,"facsimile":191,"letterHeights":192,"publications":195,"zotero":198,"keywords":201,"lettering_types":212},"Funerary monument of (?)Simylos",{"_":5},"edited",[7,10,12,14,17],{"_":8,"type":9},"644942","TM",{"type":11},"EDR",{"type":13},"EDH",{"_":15,"type":16},"70900809","EDCS",{"_":18,"type":19},"336066","PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","A quadrangular base, with a moulding around the lower edge, and the socket for a cylindrical column in the upper surface. The block is damaged on all sides, but parts of each face are preserved, showing that the moulding ran round all four sides, and only the front face was engraved. The block is most likely not a column capital, as suggested by Manganaro, but the base of an epitymbia style funerary monument. The inscribed face is preserved to a maximum width of 47cm. Dimensons recorded include the moulding, which projects c.5cm on each face. The stone appears to be the local breccia.",{"_":27,"ana":28,"ref":29},"funerary monument","#object.funerary_monument","http://www.eagle-network.eu/voc/objtyp/lod/230.html",{"_":31,"ana":32,"ref":33},"stone","#material.stone","http://www.eagle-network.eu/voc/material/lod/2.html",{"ana":35},"#condition.damaged",[37,41,44],{"_":38,"unit":39,"dimension":40},"25","cm","height",{"_":42,"unit":39,"dimension":43},"70","width",{"_":45,"unit":39,"dimension":46},"68","depth",{"layout":48},{"p":49,"rs":50,"damage":54},"Two lines of large Greek letters across the face above the moulding, of which the beginnings and ends are lost.",{"_":51,"ana":52,"ref":53},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":55},"#text_condition.incomplete",{"lettering":57,"dimensions":58},"Plain square letters of regular size without serifs. Mu has vertical first and last, midstrokes descending almost to the line; Alpha appears to have straight bar. Pi has equal length hastae, with overlapping top bar.",[59,66],{"type":60,"l":61,"from":62,"to":63,"h":64,"unit":65,"atLeast":64,"atMost":64},"letterHeight","Line 1-2","line1","line2","50","mm",{"type":67,"l":68,"from":62,"to":63,"unit":65},"interlinear","Interlineation line 1 to 2",{"_":70,"notBefore":71,"notAfter":72,"evidence":73},"later hellenistic",-200,-1,"lettering",[75,80],{"_":76,"type":77,"ref":78,"region":79},"Haluntium","ancient","http://pleiades.stoa.org/places/462228","Sicilia",{"_":81,"type":82,"ref":83,"region":79},"San Marco d'Alunzio","modern","http://sws.geonames.org/2523425",[85],[86,87],38.07261,14.70093,{"_":89,"type":90,"subtype":91,"geo":92},"Record as a casual find on via Colombo, which traverses the upper part of the hill on which the modern town stands, not far below the summit.. Now on display in the town museum.","found","discovered",[93,94],38.0728781,14.6995279,[93,94],{"_":97,"type":98,"subtype":99,"xml:id":100,"geo":20},"Prag, April 2006","observed","autopsied","autopsy",[102,109,112,115,118],{"n":103,"url":104,"height":105,"width":106,"desc":107,"surfaceType":108},"screen","ISic003473_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2018-07-05","front",{"n":103,"url