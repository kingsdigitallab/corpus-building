\u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-07-04\" who=\"#AA\">Alex Antoniou Epidoc editing and English translation\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-05-17\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001300_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001300.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#interpunct\">•\u003C/g> \u003Cw>\u003Cexpan>\u003Cabbr>Θ\u003C/abbr>\u003Cex>εοῖς\u003C/ex>\u003C/expan>\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>Κ\u003C/abbr>\u003Cex>ατακθονίοις\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Θρεπτύλο\u003Csupplied reason=\"lost\">ς\u003C/supplied>\u003C/name>\u003C/persName> \u003Cw>\u003Csupplied reason=\"lost\">ἔζησεν\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw>μῆνας\u003C/w> \u003Cnum>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/num>\n                    \u003Clb n=\"4\"/>\u003Cg ref=\"#interpunct\">•\u003C/g> \u003CpersName type=\"attested\">\u003Cname>Εὐφροσύνη\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">•\u003C/g> \u003Cw>μήτηρ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photographs\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>Kaibel: μήτηρ [ἐποίησεν] (but the inscription seems to be intact in the last line)\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>To the underworld spirits. Threptylos lived for [---] months. His mother Euphrosyne (made it).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>Agli Dei inferi. Threptylos visse [---] mesi. Sua madre Euphrosyne (realizzò).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The epitaph presents the traditional structure recurring in many pagan epitaphs from Catania: a main sentence with the name of the deceased and his/her age, followed by a second sentence with the name of the dedicant with an attribute qualifying his/her relationship with the deceased. The dedication verb is often omitted, as in this case (Korhonen 2004: 85-87). The name \u003Cforeign xml:lang=\"grc\">Θρεπτύλος\u003C/foreign> is not attested elsewhere, whereas in imperial times \u003Cforeign xml:lang=\"grc\">Θρεπτός\u003C/foreign> is well attested (\u003Cforeign xml:lang=\"la\">Threptus\u003C/foreign> in two inscriptions from Lilybaion: CIL 10.7243 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic000523\">ISic000523\u003C/ref>, Silvestrini (2014) 220-223 no.4 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic003459\">ISic003459\u003C/ref>, see LGPN 3a: 213). \u003Cforeign xml:lang=\"grc\">Θρεπτύλος\u003C/foreign> seems to be a diminutive (with the suffix -\u003Cforeign xml:lang=\"grc\">ύλος\u003C/foreign>) of the better-known \u003Cforeign xml:lang=\"grc\">Θρεπτός\u003C/foreign>, considering also the very young age of the deceased (\u003Cforeign xml:lang=\"grc\">μῆνας\u003C/foreign>).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">477\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>137\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"SGDI\">\n                        \u003Cauthor>Hoffmann\u003C/author>\n                        \u003Cdate>1904\u003C/date>\n                        \u003CcitedRange>5240\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DQDPC573\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000817\">https://biblio.inscriptiones.org/epig10000817\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                    \u003CcitedRange>85-87\u003C/citedRange>\n                    \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
