esc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000657.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan>\u003C/supplied>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Besa\u003Csupplied reason=\"lost\">s\u003C/supplied>\u003C/name>\u003C/persName> \u003Csupplied reason=\"lost\">qui\u003C/supplied> \u003Csupplied reason=\"lost\">vi\u003C/supplied>\n                    \u003Clb n=\"3\" break=\"no\"/>xit \u003Csupplied reason=\"lost\">annis\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"4\"/>\u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ecit\u003C/ex>\u003C/expan> m\u003Csupplied reason=\"lost\">ater\u003C/supplied>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Manganaro including restorations, checked against photograph\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>To the infernal shades. Besas, who lived for [--] years. His mother made it.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Manganaro notes that the name is rare, presumably that of a slave, and finds parallels in Egypt.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1993.0830\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1993\u003C/date>\n                        \u003CcitedRange>547, 544 fig. 1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JBI7CI5R\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001827\">https://biblio.inscriptiones.org/epig10001827\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
