         \u003Cchange when=\"2026-03-09\" who=\"#JP\">Jonathan Prag revised metadata\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001149_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001149.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#MH\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Νυ\u003Csupplied reason=\"lost\" cert=\"low\">μφόδω\u003C/supplied>ρος\u003C/w>\u003C/name>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw n=\"10\">Ἀρ\u003Csupplied reason=\"lost\" cert=\"low\">χαγάθ\u003C/supplied>ου\u003C/w>\u003C/name>\u003C/persName>\u003C/persName> \u003Cw n=\"15\">τοῦ\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"20\">\u003Cdesc>personal name\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Νυμφόδωρος\">Νυμφόδωρος\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Ἀρχαγάθος\">Ἀρχαγάθου\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ὁ\">τοῦ\u003C/w>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"20\">\u003Cdesc>[(personal name)]\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Kaibel in IG, following the conjectural restoraiton of Franz in CIG\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#MH\">\n                \u003Cp>Ny[mphodo]ros, son of Ar[chagath]os...\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>We are dependent entirely upon the antiquarian record, which suggests this is two non-joining but related fragments of a marble stone. It is impossible to know therefore whether it was true marble, or a polishable limestone, and whether it was a public or a private (i.e. likely funerary) inscription, since it appears to contain traces of perhaps two names.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">330\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5590\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/> \n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
