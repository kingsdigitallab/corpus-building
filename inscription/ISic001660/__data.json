5,256,257,258],"F2GG87EQ","77P5MNIR","Q2EG8WCI","VF9MMBI9","Q5PB252W","CH2A4ZD2","EE9HKNTC","H5GJ8WQW",[260,261,262,22,27,31,263,264,265,266,264,267,268,121],"isic001660","lilybaeum honours diognetos megas as euergetes",{"_":5},"lilybaeum","marsala","sicilia","sicily","museo archeologico regionale lilibeo marsala - baglio anselmi","ancient greek",[],{"title":271,"body":272,"divs":273,"editions":298,"images":308,"handnote":309},"ISic001660. Lilybaeum honours Diognetos Megas as euergetes","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Andoni Llamazares\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"ὁ\">ὁ\u003C/span>  \u003Cspan data-text=\"δᾶμος\">δᾶμος\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"τῶν\">τῶν\u003C/span> Λιλυβαιιτᾶν \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Διόγνητον\n                    Δαματρίου Μήγαν\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Διόγνητον\">Διόγνητον\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δαματρίου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Δαματρίου\">Δαματρίου\u003C/span>\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"secondName\" data-text=\"Μήγαν\">Μήγα[ν]\u003C/span>\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"εὐεργέταν\">ε̣ὐ̣ε̣ρ̣γ̣έ̣τ̣α̣ν̣\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Andoni Llamazares\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"ὁ\">Ο\u003C/span>\u003Cspan data-text=\"δᾶμος\">ΔΑΜΟΣ\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"τῶν\">ΤΩΝ\u003C/span>ΛΙΛΥΒΑΙΙΤΑΝ\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Διόγνητον\n                    Δαματρίου Μήγαν\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Διόγνητον\">ΔΙΟΓΝΗΤΟΝ\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δαματρίου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Δαματρίου\">ΔΑΜΑΤΡΙΟΥ\u003C/span>\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"secondName\" data-text=\"Μήγαν\">ΜΗΓΑ[.]\u003C/span>\u003C/span>\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"εὐεργέταν\">.........\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>text checked against photograph\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/a>\u003C/p>  \u003Cp>The people of the Lilybaitani honour Diognetos Megas, son of Damatrios as benefactor\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>This man is the father of one Marcus Valerius Chorton, honours for whom are recorded in two lost inscriptions (one from Mazara, one from Marsala), preserved in the antiquarian tradition (\u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001096\" target=\"_blank\">ISic001096\u003C/a> = IG XIV.273) and \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001097\" target=\"_blank\">ISic001097\u003C/a> = IG XIV.277). The inscription is a rare (for Sicily) attestation of an individual honoured as euergetes (benefactor).\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 34.0951 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000796\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000796\u003C/a>\u003C/li>\u003Cli> 1965.0507 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001282\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001282\u003C/a>\u003C/li>\u003Cli> Manni Piraino 1963 159-162 no.2 tav.52 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001782\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001782\u003C/a>\u003C/li>\u003Cli> Manni Piraino 1984 125-126 no. 155 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002035\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002035\u003C/a>\u003C/li>\u003Cli> Wilson 1990 361 n.107 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001509\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001509\u003C/a>\u003C/li>\u003Cli> Di Stefano 2006 547 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001365\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001365\u003C/a>\u003C/li>\u003Cli> Brugnone 2021 63 fig. 7 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002691\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002691\u003C/a>\u003C/li>\u003Cli> Brugnone 2024 469 fig.473 \u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>Regular and neat letters, thinly incised, all of equal height, and slightly variable width, without serifs. Alpha with broken bar, beta with closed loops (upper slightly smaller), Mu has full length slanting strokes; omicron full size; sigma has horizontal top and bottom, middle strokes taking the full width; rhomboid omega.\u003C/p> Line 1-5  25  Interlineation line 1 to 2    \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[274,277,280,283,286,289,292,295],{"id":275,"html":276},"editions","\u003Cdiv class=\"attribution\">Text encoding: Andoni Llamazares\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"ὁ\">ὁ\u003C/span>  \u003Cspan data-text=\"δᾶμος\">δᾶμος\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"τῶν\">τῶν\u003C/span> Λιλυβαιιτᾶν \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Διόγνητον\n                    Δαματρίου Μήγαν\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Διόγνητον\">Διόγνητον\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δαματρίου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Δαματρίου\">Δαματρίου\u003C/span>\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"secondName\" data-text=\"Μήγαν\">Μήγα[ν]\u003C/span>\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"εὐεργέταν\">ε̣ὐ̣ε̣ρ̣γ̣έ̣τ̣α̣ν̣\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Andoni Llamazares\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"ὁ\">Ο\u003C/span>\u003Cspan data-text=\"δᾶμος\">ΔΑΜΟΣ\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"τῶν\">ΤΩΝ\u003C/span>ΛΙΛΥΒΑΙΙΤΑΝ\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Διόγνητον\n                    Δαματρίου Μήγαν\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Διόγνητον\">ΔΙΟΓΝΗΤΟΝ\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δαματρίου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Δαματρίου\">ΔΑΜΑΤΡΙΟΥ\u003C/span>\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"secondName\" data-text=\"Μήγαν\">ΜΗΓΑ[.]\u003C/span>\u003C/span>\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"εὐεργέταν\">.........\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":278,"html":279},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>",{"id":281,"html":282},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>text checked against photograph\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":284,"html":285},"translation","\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/a>\u003C/p>  \u003Cp>The people of the Lilybaitani honour Diognetos Megas, son of Damatrios as benefactor\u003C/p>  ",{"id":287,"html":288},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>This man is the father of one Marcus Valerius Chorton, honours for whom are recorded in two lost inscriptions (one from Mazara, one from Marsala), preserved in the antiquarian tradition (\u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001096\" target=\"_blank\">ISic001096\u003C/a> = IG XIV.273) and \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic001097\" target=\"_blank\">ISic001097\u003C/a> = IG XIV.277). The inscription is a rare (for Sicily) attestation of an individual honoured as euergetes (benefactor).\u003C/p>  ",{"id":290,"html":291},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 34.0951 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000796\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000796\u003C/a>\u003C/li>\u003Cli> 1965.0507 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001282\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001282\u003C/a>\u003C/li>\u003Cli> Manni Piraino 1963 159-162 no.2 tav.52 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001782\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001782\u003C/a>\u003C/li>\u003Cli> Manni Piraino 1984 125-126 no. 155 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002035\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002035\u003C/a>\u003C/li>\u003Cli> Wilson 1990 361 n.107 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001509\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001509\u003C/a>\u003C/li>\u003Cli> Di Stefano 2006 547 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001365\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001365\u003C/a>\u003C/li>\u003Cli> Brugnone 2021 63 fig. 7 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002691\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002691\u003C/a>\u003C/li>\u003Cli> Brugnone 2024 469 fig.473 \u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  ",{"id":293,"html":294},"handnote","\u003Cp>Regular and neat letters, thinly incised, all of equal height, and slightly variable width, without serifs. Alpha with broken bar, beta with closed loops (upper slightly smaller), Mu has full length slanting strokes; omicron full size; sigma has horizontal top and bottom, middle strokes taking the full width; rhomboid omega.\u003C/p> Line 1-5  25  Interlineation line 1 to 2    ",{"id":296,"html":297},"license"," Licensed under a Creative Commons-Attribution 4.0 licence. ",[299,301,304,305],{"html":300},"Text encoding: Andoni Llamazares",{"id":302,"lang":121,"html":303},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"ὁ\">ὁ\u003C/span>  \u003Cspan data-text=\"δᾶμος\">δᾶμος\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"τῶν\">τῶν\u003C/span> Λιλυβαιιτᾶν \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Διόγνητον\n                    Δαματρίου Μήγαν\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Διόγνητον\">Διόγνητον\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δαματρίου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Δαματρίου\">Δαματρίου\u003C/span>\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"secondName\" data-text=\"Μήγαν\">Μήγα[ν]\u003C/span>\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"εὐεργέταν\">ε̣ὐ̣ε̣ρ̣γ̣έ̣τ̣α̣ν̣\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":300},{"id":306,"lang":121,"html":307},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-text=\"ὁ\">Ο\u003C/span>\u003Cspan data-text=\"δᾶμος\">ΔΑΜΟΣ\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"τῶν\">ΤΩΝ\u003C/span>ΛΙΛΥΒΑΙΙΤΑΝ\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Διόγνητον\n                    Δαματρίου Μήγαν\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Διόγνητον\">ΔΙΟΓΝΗΤΟΝ\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δαματρίου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Δαματρίου\">ΔΑΜΑΤΡΙΟΥ\u003C/span>\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"secondName\" data-text=\"Μήγαν\">ΜΗΓΑ[.]\u003C/span>\u003C/span>\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"εὐεργέταν\">.........\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",[],[310],{"html":56},"\u003C?xml version='1.0' encoding='UTF-8'?>\n\u003C?xml-model href=\"https://epidoc.stoa.org/schema/latest/tei-epidoc.rng\" type=\"application/xml\" schematypens=\"http://relaxng.org/ns/structure/1.0\"?>\n\u003C?xml-model href=\"../schematron/ircyr-checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XInclude\" xml:lang=\"en\">\n    \u003CteiHeader>\n        \u003CfileDesc>\n            \u003CtitleStmt>\n                \u003Ctitle>Lilybaeum honours Diognetos Megas as euergetes\u003C/title>\n                \u003Ceditor ref=\"#JP\">Jonathan Prag\u003C/editor>\n                \u003Cprincipal ref=\"#JP\">Jonathan Prag\u003C/principal>\n                \u003Cfunder>John Fell OUP Research Fund\u003C/funder>\n\t   \u003Cfunder>\u003Cref target=\"https://cordis.europa.eu/project/id/885040\">ERC Advanced Grant no.885040\u003C/ref>\u003C/funder>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>original data collection and editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JCu\" ref=\"http://orcid.org/0000-0002-6686-3728\">James Cummings\u003C/name>\n                    \u003Cresp>conversion to EpiDoc\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"AL\" ref=\"https://orcid.org/0000-0002-0000-7611\">Andoni Llamazares\u003C/name>\n                    \u003Cresp>text edition\u003C/resp>\n                \u003C/respStmt>\n\t    \u003CrespStmt>\n     \t       \u003Cname xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n     \t       \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n \t   \u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic001660\u003C/idno>\n                \u003Cidno type=\"TM\">284791\u003C/idno>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\">64900328\u003C/idno>\n                \u003Cidno type=\"PHI\">331219\u003C/idno>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic001660\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-22\">10.5281/zenodo.4386252\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Marsala\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/108\">Museo archeologico regionale Lilibeo Marsala - Baglio Anselmi\u003C/repository>\n                        \u003Cidno type=\"inventory\">4489\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>Although consistently described as marble in publications, the stone is a compact limestone, not a marble, in the form of a thick slab/plaque. The stone has suffered light damage to the edges, especially the right side; the final line is almost entirely worn away, as are some of the letters on the left.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.limestone\" ref=\"http://www.eagle-network.eu/voc/material/lod/66.html\">limestone\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/259\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--Manni Piraino-->\n                                        \u003Cheight unit=\"cm\">42\u003C/height>\n                                        \u003Cwidth unit=\"cm\">70\u003C/width>\n                                        \u003Cdepth unit=\"cm\">20.5\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.complete\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage ana=\"#text_condition.complete\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Regular and neat letters, thinly incised, all of equal height, and slightly variable width, without serifs. Alpha with broken bar, beta with closed loops (upper slightly smaller), Mu has full length slanting strokes; omicron full size; sigma has horizontal top and bottom, middle strokes taking the full width; rhomboid omega.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line5\">Line 1-5\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"25\" atMost=\"25\">25\u003C/height>\u003C!--Manni Piraino-->\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462281\">Lilybaeum\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/6542148\">Marsala\u003C/placeName>\n                            \t\u003Cgeo>37.80355, 12.4379\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0200\" notAfter-custom=\"-0001\" evidence=\"lettering\">2nd or 1st century BCE (as late as early Augustan acc. to Wilson and Manni Piraino; but Manni Piraino also suggests 2nd century BCE). The form of the letters might imply an earlier date in this range\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Found in the 1939 excavations of the domus romana in insula 1 of Capo Boeo, in the collapse in the frigidarium of the baths subsequently constructed in the domus (and so in secondary deposition)\u003Cgeo>37.8048631,12.4295153\u003C/geo>\u003C/provenance>\u003C!-- location of the frigidarium -->\n                        \u003Cprovenance type=\"observed\" subtype=\"photographed\">Observed on display by Metcalfe, 2015-04-18\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">none\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.honorific\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/69.html\">honorific\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-07-19\" who=\"#AL\">Andoni Llamazares added text edition\u003C/change>\n                \u003Cchange when=\"2023-06-27\" who=\"#JP\">Jonathan Prag revised metadata and text, added translation\u003C/change>\n                \u003Cchange when=\"2026-02-23\" who=\"#JP\">Jonathan Prag revised further\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001660_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001660.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#AL\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw>ὁ\u003C/w> \u003Cw>δᾶμος\u003C/w>\n                    \u003Clb n=\"2\"/>\u003Cw>τῶν\u003C/w> \u003CplaceName type=\"ethnic\">Λιλυβαιιτᾶν\u003C/placeName>\n                    \u003Clb n=\"3\"/>\u003CpersName type=\"attested\">\u003Cname>Διόγνητον\u003C/name>\n                    \u003Clb n=\"4\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Δαματρίου\u003C/name>\u003C/persName> \u003Cname type=\"secondName\">Μήγα\u003Csupplied reason=\"lost\">ν\u003C/supplied>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"5\"/>\u003CroleName type=\"paracivic\" subtype=\"euergetes\">\u003Cw>\u003Cunclear>εὐεργέταν\u003C/unclear>\u003C/w>\u003C/roleName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>text checked against photograph\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>The people of the Lilybaitani honour Diognetos Megas, son of Damatrios as benefactor\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>This man is the father of one Marcus Valerius Chorton, honours for whom are recorded in two lost inscriptions (one from Mazara, one from Marsala), preserved in the antiquarian tradition (\u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001096\">ISic001096\u003C/ref> = IG XIV.273) and \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001097\">ISic001097\u003C/ref> = IG XIV.277). The inscription is a rare (for Sicily) attestation of an individual honoured as euergetes (benefactor).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>34.0951\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1965.0507\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1963\u003C/date>\n                        \u003CcitedRange>159-162 no.2 tav.52\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2EG8WCI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001782\">https://biblio.inscriptiones.org/epig10001782\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Wilson\u003C/author>\n                        \u003Cdate>1990\u003C/date>\n                        \u003CcitedRange>361 n.107\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VF9MMBI9\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001509\">https://biblio.inscriptiones.org/epig10001509\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1984\u003C/date>\n                        \u003CcitedRange>125-126 no. 155\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q5PB252W\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002035\">https://biblio.inscriptiones.org/epig10002035\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Di Stefano\u003C/author>\n                        \u003Cdate>2006\u003C/date>\n                        \u003CcitedRange>547\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/CH2A4ZD2\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001365\">https://biblio.inscriptiones.org/epig10001365\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Brugnone\u003C/author>\n                        \u003Cdate>2021\u003C/date>\n                        \u003CcitedRange>63 fig. 7\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EE9HKNTC\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002691\">https://biblio.inscriptiones.org/epig10002691\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Brugnone\u003C/author>\n                        \u003Cdate>2024\u003C/date>\n                        \u003CcitedRange>469 fig.473\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/H5GJ8WQW\"/>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type