{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":100,"html":270,"xml":311},"ISic001660",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":34,"dimensions":36,"layoutDesc":47,"handNote":55,"date":69,"places":74,"geo":84,"country":79,"provenance":76,"provenanceFound":88,"provenanceGeo":95,"provenanceObserved":96,"provenanceLost":20,"graphics":100,"region":101,"settlement":81,"repository":102,"idno":116,"textLang":119,"bibliographyEdition":123,"bibliographyDiscussion":211,"citation":214,"tmNumber":8,"letterHeights":238,"publications":241,"zotero":250,"keywords":259,"lettering_types":269},"Lilybaeum honours Diognetos Megas as euergetes",{"_":5},"draft",[7,10,12,14,17],{"_":8,"type":9},"284791","TM",{"type":11},"EDR",{"type":13},"EDH",{"_":15,"type":16},"64900328","EDCS",{"_":18,"type":19},"331219","PHI",null,{"_":22,"ana":23,"ref":24},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html","Although consistently described as marble in publications, the stone is a compact limestone, not a marble, in the form of a thick slab/plaque. The stone has suffered light damage to the edges, especially the right side; the final line is almost entirely worn away, as are some of the letters on the left.",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":31,"ana":32,"ref":33},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":35},"#condition.complete",[37,41,44],{"_":38,"unit":39,"dimension":40},"42","cm","height",{"_":42,"unit":39,"dimension":43},"70","width",{"_":45,"unit":39,"dimension":46},"20.5","depth",{"layout":48},{"rs":49,"damage":53},{"_":50,"ana":51,"ref":52},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":54},"#text_condition.complete",{"lettering":56,"dimensions":57},"Regular and neat letters, thinly incised, all of equal height, and slightly variable width, without serifs. Alpha with broken bar, beta with closed loops (upper slightly smaller), Mu has full length slanting strokes; omicron full size; sigma has horizontal top and bottom, middle strokes taking the full width; rhomboid omega.",[58,65],{"type":59,"l":60,"from":61,"to":62,"h":63,"unit":64,"atLeast":63,"atMost":63},"letterHeight","Line 1-5","line1","line5","25","mm",{"type":66,"l":67,"from":61,"to":68,"unit":64},"interlinear","Interlineation line 1 to 2","line2",{"_":70,"notBefore":71,"notAfter":72,"evidence":73},"2nd or 1st century BCE (as late as early Augustan acc. to Wilson and Manni Piraino; but Manni Piraino also suggests 2nd century BCE). The form of the letters might imply an earlier date in this range",-200,-1,"lettering",[75,80],{"_":76,"type":77,"ref":78,"region":79},"Lilybaeum","ancient","http://pleiades.stoa.org/places/462281","Sicilia",{"_":81,"type":82,"ref":83,"region":79},"Marsala","modern","http://sws.geonames.org/6542148",[85],[86,87],37.80355,12.4379,{"_":89,"type":90,"subtype":91,"geo":92},"Found in the 1939 excavations of the domus romana in insula 1 of Capo Boeo, in the collapse in the frigidarium of the baths subsequently constructed in the domus (and so in secondary deposition)","found","discovered",[93,94],37.8048631,12.4295153,[93,94],{"_":97,"type":98,"subtype":99,"geo":20},"Observed on display by Metcalfe, 2015-04-18","observed","photographed",[],"Sicily",{"_":103,"role":104,"ref":105,"museum":106},"Museo archeologico regionale Lilibeo Marsala - Baglio Anselmi","museum","http://sicily.classics.ox.ac.uk/museum/108",{"slug":107,"type":104,"name":103,"uri":105,"description":108,"location":109},"108","Comprehensive collection of Archaeological material discovered at the site of Lilybaeum and in the surrounding area",{"settlement":81,"region":110,"country":111,"address":112,"geo":113},"Trapani","Italy","Lun