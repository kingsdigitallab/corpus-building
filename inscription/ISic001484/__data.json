{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":116,"html":290,"xml":346},"ISic001484",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":18,"type":19,"support":23,"objectType":24,"material":28,"condition":32,"dimensions":34,"layoutDesc":45,"handNote":54,"date":84,"places":89,"geo":97,"provenance":91,"provenanceFound":101,"provenanceGeo":109,"provenanceObserved":110,"provenanceLost":18,"graphics":116,"country":132,"region":133,"settlement":134,"repository":135,"idno":147,"textLang":150,"bibliographyEdition":154,"bibliographyDiscussion":225,"citation":228,"tmNumber":8,"facsimile":251,"letterHeights":252,"publications":265,"zotero":272,"keywords":279,"lettering_types":289},"Epitaph of Philistidas, son of Euxenos",{"_":5},"edited",[7,10,12,14,16],{"_":8,"type":9},"644992","TM",{"type":11},"EDR",{"type":13},"EDH",{"type":15},"EDCS",{"type":17},"PHI",null,{"_":20,"ana":21,"ref":22},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","The upper part of a rectangular block of soft white/yellow limestone, intact top, right, left and to the rear, but broken unevenly across the lower edge. All the intact faces are squared off. Some chipping to the top front edge, and some loss to the face across the break on the lower edge. A pinkish vein runs across the upper part of the stone. The stone tapers very slightly in thickness towards the top.",{"_":25,"ana":26,"ref":27},"stele","#object.stele","https://www.eagle-network.eu/voc/objtyp/lod/250",{"_":29,"ana":30,"ref":31},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":33},"#condition.damaged",[35,39,42],{"_":36,"unit":37,"dimension":38},"10.8","cm","height",{"_":40,"unit":37,"dimension":41},"23","width",{"_":43,"unit":37,"dimension":44},"7-7.5","depth",{"layout":46},{"p":47,"rs":48,"damage":52},"Three lines of Greek letters filling the width of th