hoto J. Prag 2016-10-10\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"screen\" url=\"ISic001484_copy2_tiled.tif\" height=\"5504px\" width=\"8256px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo V. Mignosa 2022-01-19\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001484_copy2.jpg\" height=\"5504px\" width=\"8256px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo V. Mignosa 2022-01-19\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n        \u003Csurface type=\"rear\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001484_rear_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2016-10-10\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001484_rear.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2016-10-10\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM #JP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Φιλιστίδας\u003C/name>\n                    \u003Clb n=\"2\"/>\u003Cname>Εὐξένο̄\u003C/name>\u003C/persName> hο\n                    \u003Clb n=\"3\"/>\u003Csupplied reason=\"lost\">κ\u003C/supplied>\u003Cunclear>αλ\u003C/unclear>ο̄ποιό\u003Csupplied reason=\"omitted\">ς\u003C/supplied>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text from autopsy\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Trace of the cross bar of the Τ is visible\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>Dubois: [κ]αλο̄ποιό(ς) \u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Philistidas, son of Euxenos, the ropemaker\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>An unusual example of an archaic funerary inscription with indication of the deceased's profession: the restoration of initial Κ and  interpretation of καλωποιός as 'rope-maker' is due to Orsi. The stone was presumed  lost  by Dubois (and speculatively attributed to Palermo Museum in LSAG(2), but seems always to have been in the Syracuse museum since its deposit in 1900.\u003C!--commented out pending revision-->\n                    \u003C!-- Jeffery Archive: J.WC 54 p.01. -->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                         \u003Cauthor>Dubois\u003C/author>\n                         \u003Cdate>1989\u003C/date> \n                        \u003CcitedRange>\n                            \u003Cref target=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\">130\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RWXNUFEX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1900\u003C/date>\n                        \u003CcitedRange>281-282 fig.4\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"SGDI\">\n                        \u003Cauthor>Hoffmann\u003C/author>\n                        \u003Cdate>1904\u003C/date>\n                        \u003CcitedRange>5216\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DQDPC573\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000817\">https://biblio.inscriptiones.org/epig10000817\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Roehl\u003C/author>\n                        \u003Cdate>1907\u003C/date>\n                        \u003CcitedRange>Tab.34 no.12\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/KV7SJ9VF\"/>\n                    \u003C/bibl>\n                    \u003Cbibl n=\"LSAG[2]\">\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003Cauthor>Johnston\u003C/author>\n                        \u003Cdate>1990\u003C/date>\n                        \u003CcitedRange>278 no.54\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/QUWGZA84\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000678\">https://biblio.inscriptiones.org/epig10000678\u003C/ref>\u003C/bibl>\n                    \u003Cbibl n=\"LSAG\">\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003Cdate>1961\u003C/date>\n                        \u003CcitedRange>278 no.54\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/V6CGSWPS\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000677\">https://biblio.inscriptiones.org/epig10000677\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
