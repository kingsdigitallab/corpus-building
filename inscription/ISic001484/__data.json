autopsied","#JP","autopsy",[117,124,129],{"n":118,"url":119,"height":120,"width":121,"desc":122,"surfaceType":123},"screen","ISic001484_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2016-10-10","front",{"n":118,"url":125,"height":126,"width":127,"desc":128,"surfaceType":123},"ISic001484_copy2_tiled.tif","5504px","8256px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo V. Mignosa 2022-01-19",{"n":118,"url":130,"height":120,"width":121,"desc":122,"surfaceType":131},"ISic001484_rear_tiled.tif","rear","Italy","Sicily","Siracusa",{"_":136,"role":137,"ref":138,"museum":139},"Museo Archeologico Regionale Paolo Orsi","museum","http://sicily.classics.ox.ac.uk/museum/097",{"slug":140,"type":137,"name":136,"uri":138,"description":141,"location":142},"097","An outstanding collection of archaeological material. The collection ranges from Siracusa and the surrounding territory (Megara Hyblaia, Akrai, Kasmenai etc) to encompass all of eastern Sicily, reaching as far as Gela and Agrigento. The ground floor covers prehistory through to the end of the Classical period. Upstairs includes Hellenistic and Roman Syracuse and a display of material from the catacombs. A gallery displaying material from Hellenistic eastern Sicily is in preparation.",{"settlement":134,"region":134,"country":132,"address":143,"geo":144},"Viale Teocrito 66, 96100 - Siracusa",{"lat":145,"lon":146},37.07636989,15.2866213,{"_":148,"type":149},"19817","inventory",{"_":151,"mainLang":152,"languages":153},"Ancient Greek","grc",[151],{"type":155,"bibl":156},"edition",[157,173,184,196,202,214],{"type":158,"n":159,"author":160,"date":161,"citedRange":162,"ptr":166,"ref":168,"title":170,"citation":171,"uri":172},"corpus","IGDS1","Dubois","1