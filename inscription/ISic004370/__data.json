03Cdamage/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>Neatly cut, regular and evenly spaced letters without serifs. Broken-bar alpha; sigma with parallel top and bottom bars; omicron almost full size\u003C/p>\n                                \u003Cp>\n                                    Types list:\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Α-type2.html\">Α type2\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Η-type1.html\">Η type1\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ι-type1.html\">Ι type1\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ν-type1.html\">Ν type1\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ν-type1.2.html\">Ν type1.2\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ο-type1.html\">Ο type1\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ρ-type1.html\">Ρ type1\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ρ-type1.3.html\">Ρ type1.3\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Σ-tyoe3.2.html\">Σ tyoe3.2\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Σ-type3.html\">Σ type3\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Τ-type2.html\">Τ type2\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Τ-type2.1.html\">Τ type2.1\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Χ-type3.html\">Χ type3\u003C/ref>\n                                \u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462153\">Centuripae\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525032\">Centuripe\u003C/placeName>\n                                \u003Cgeo>37.62336, 14.74049\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0200\" notAfter-custom=\"-0101\" evidence=\"lettering\">2nd century BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"first-seen\" when=\"2017\">Found in 2017 in re-use in the wall of a modern house in the old centre of Centuripe\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\