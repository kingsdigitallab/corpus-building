pan class=\"linenumber\">2\u003C/span> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",[],[],"\u003C?xml version=\"1.0\" encoding=\"UTF-8\"?>\n\u003C?xml-model href=\"https://epidoc.stoa.org/schema/latest/tei-epidoc.rng\" type=\"application/xml\" schematypens=\"http://relaxng.org/ns/structure/1.0\"?>\n\u003C?xml-model href=\"../schematron/ircyr-checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XInclude\" xml:lang=\"en\">\n    \u003CteiHeader>\n        \u003CfileDesc>\n            \u003CtitleStmt>\n                \u003Ctitle>I.Sicily inscription 002036\u003C/title>\n                \u003Ceditor ref=\"#JP\">Jonathan Prag\u003C/editor>\n                \u003Cprincipal ref=\"#JP\">Jonathan Prag\u003C/principal>\n                \u003Cfunder>John Fell OUP Research Fund\u003C/funder>\n                \u003Cfunder>\n                    \u003Cref target=\"https://cordis.europa.eu/project/id/885040\">ERC Advanced Grant no.885040\u003C/ref>\n                \u003C/funder>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>original data collection and editing\u003C/resp>\n                \u003C/respStmt>\n             \u003CrespStmt>\u003Cname xml:id=\"Coccato\" ref=\"https://orcid.org/0000-0002-6641-2820\">Alessia Coccato\u003C/name>\u003Cresp>Petrographic observation and analysis\u003C/resp>\u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic002036\u003C/idno>\n                \u003Cidno type=\"TM\"/>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\"/>\n                \u003Cidno type=\"PHI\"/>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic002036\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Siracusa\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/187\">Antiquarium della Pontificia Commissione di Archeologia Sacra, Siracusa\u003C/repository>\n                        \u003Cidno type=\"inventory\">37064\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"la\">Latin\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>Three non-joining fragments of an opisthographic marble plaque. The Latin inscription is the older, the plaque subsequently reused for a Greek text for which see \u003Cref sameAs=\"ISic002131.xml\">ISic002131\u003C/ref>.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.inorganic.stone\" type=\"stone.unspecified\" resp=\"#Coccato\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/259\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--Default values and requires editing-->\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragments.non-contiguous\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003Cp>The uppermost surviving line on fragment (a) is clearly larger than those below, and the surviving line on fragment (b) would seem to be of similar proportions.\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                    \u003Cdamage ana=\"#text_condition.incomplete\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462503\" corresp=\"#findspot\">Syracusae\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2523083\">Siracusa\u003C/placeName>\n                                \u003Cgeo>37.08415, 15.27628\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0051\" notAfter-custom=\"0250\">Roman Imperial\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Catacomb of Vigna Cassia\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n              \u003Cchange when=\"2026-04-01\" who=\"#JP\">Jonathan Prag created draft from publications\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002036_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002036.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cdiv type=\"textpart\" subtype=\"fragment-physical\" n=\"a\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"3\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\u003CpersName type=\"attested\">\u003Cname>Agathe\u003C/name>\u003C/persName> \u003Cg ref=\"#ivy-leaf\">❦ \u003C/g> \u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/> solo \u003Cg ref=\"#ivy-leaf\">❦ \u003C/g> \u003Cspace unit=\"character\" quantity=\"1\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\" cert=\"low\"/>\n                    \u003C/ab>\n            \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"fragment-physical\" n=\"b\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\u003Cunclear>TAN\u003C/unclear>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\n                    \u003C/ab>\n                \u003C/div>\n                  \u003Cdiv type=\"textpart\" subtype=\"fragment-physical\" n=\"c\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"2\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\n                        \u003Clb n=\"2\"/>\u003Cspace unit=\"character\" quantity=\"3\"/>\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\n                    \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based upon drawings in Agnello 1956\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The largest fragment (a) was published by Orsi in 1923, without reference to the existence of a Greek text on the reverse. The other two fragments were published, together with the first fragment, by Agnello in 1956, but he only provided drawings of each, stating that the fragments did not join and declined to attempt any editing of the text. The fragments appear to offer a typical example of the re-use of an imperial period Latin funerary plaque for a later Greek funerary plaque in the catacombs.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                   \u003Cbibl>\n                        \u003Cauthor>Agnello\u003C/author>\n                        \u003Cdate>1956\u003C/date>\n                        \u003CcitedRange>26 p, fig.7a-c\u003C/citedRange>\n                       \u003Cptr target=\"https://www.zotero.org/groups/382445/items/NW5FES25\"/>\n                       \u003Cref target=\"https://biblio.inscriptiones.org/epig10002207\">https://biblio.inscriptiones.org/epig10002207\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1923\u003C/date>\n                        \u003CcitedRange>no.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQ8HXJJE\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001699\">https://biblio.inscriptiones.org/epig10001699\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Marchese\u003C/author>\n                        \u003Cdate>2012\u003C/date>\n                        \u003CcitedRange>no.43\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/IQ93VIZM\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002550\">https://biblio.inscriptiones.org/epig10002550\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
