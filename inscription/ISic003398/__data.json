"0001\" notAfter-custom=\"0200\" evidence=\"lettering\">1st — 2nd century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Discovered by Guido Libertini during the excavation campaigns conducted starting in 1925, within the complex of spaces near the so-called former Barbagallo Mill, i.e. the area of the so-called \"Edificio degli Augustales\" \u003Cgeo>37.62257, 14.74099\u003C/geo>, in a zone overlooking the Vallata Difesa, near the Church of the Crucifix.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">Prado 2021-12-21, 2022-10-26, 2023-05-09\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.building\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/86.html\" cert=\"low\">building\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-02-01\" who=\"#JP\">Jonathan Prag made initial edits\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003398_a_tiled.tif\" height=\"4384px\" width=\"3552px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003398_a.jpg\" height=\"4384px\" width=\"3552px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"screen\" url=\"ISic003398_b_tiled.tif\" height=\"4088px\" width=\"3544px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003398_b.jpg\" height=\"4088px\" width=\"3544px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cdiv type=\"textpart\" subtype=\"fragment-physical\" n=\"a\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003Cspace unit=\"character\" quantity=\"1\"/>\u003Corig>PA\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                        \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>mpei \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Corig>CE\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"fragment-physical\" n=\"b\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>eum \u003Cg ref=\"#ivy-leaf\">❦\u003C/g>\n                        \u003Clb n=\"2\"/>Crispus \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Provisional text from photographs\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Two fragments (0.42x0.36m and 0.415 x 0.335m), large letters 15cm high in line 1, 10cm high in line 2. The fragments do not join, but are of the same inscription probably parts of an architectural element and probably part of a building inscription. Likely restoration of the name Pompeius in the first fragment, and to be linked to the statues from the same area.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1926\u003C/date>\n                        \u003CcitedRange>44 b\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VJZRAI26\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001874\">https://biblio.inscriptiones.org/epig10001874\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Patané\u003C/author>\n                        \u003Cdate>2011\u003C/date>\n                        \u003CcitedRange>47 and 154 fig. 36\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FK9SGQE7\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001682\">https://biblio.inscriptiones.org/epig10001682\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
