ype=\"edition\" subtype=\"transliteration-primary\" xml:space=\"preserve\" xml:lang=\"xpu-Latn\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/VAAUGZYC\">\n                \u003Cab>\n                    \u003Clb n=\"1\" style=\"text-direction:r-to-l\"/>lrb\u003Cunclear>t\u003C/unclear>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after Amadasi Guzzo 1980-1981\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#RDS\">\n                \u003Cp> To the lady [---]\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#RDS\">\n                \u003Cp>Alla signora [---]\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#RDS\">\n                \u003Cp>The text seems to be part of a votive text to the goddess Astarte.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Amadasi Guzzo\u003C/author>\n                        \u003Cdate>1980-1981\u003C/date>\n                        \u003CcitedRange>7-8 Tav.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VAAUGZYC\"/>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Simone\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>26 MO.3 fig.3a-b.\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EGNUE9CZ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002545\">https://biblio.inscriptiones.org/epig10002545\u003C/ref>\n                    \u003C/bibl>\n                  \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
