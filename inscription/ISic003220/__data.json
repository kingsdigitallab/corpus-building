jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"2\"/>Atilio · Ones\u003Csupplied reason=\"lost\" cert=\"high\">imo\u003C/supplied>\n                    \u003Clb n=\"3\"/>\u003Cexpan>\u003Cabbr>vix\u003C/abbr>\u003Cex>it\u003C/ex>\u003C/expan> · \u003Cexpan>\u003Cabbr>ann\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cunclear>C\u003C/unclear> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"4\"/>\u003Cnum value=\"40\">XL\u003C/num> · Rufio · f\u003Csupplied reason=\"lost\" cert=\"low\">ecit\u003C/supplied>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Korhonen 2004\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>Sacred to the shades of the underworld. For Atilius Onesimus, who lived for [about?] 40 years, Rufius built it.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--damaged on the right, traces of a cornice. DMS header. Atilio Onesimo (latter a probable restoration), vix(it) ann(is) C- - -XL, Rufio f[ecit?]. Atilius Onesimus a common/plausible name (Atilio Ones[imo]); the C in the age could be c[irciter]. Mommsen considered it urban.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Bormann and Henzen\u003C/author>\n                        \u003Cdate>1876\u003C/date>\n                        \u003CcitedRange>1262\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VVHPQFD3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001134\">https://biblio.inscriptiones.org/epig10001134\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buch/4004\">1088*.51\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/HSQETNGN\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001137\">https://biblio.inscriptiones.org/epig10001137\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>61\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
