Sic003468.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cname>\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>arco\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Vallio\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilio\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>Quir\u003C/abbr>\u003Cex>ina\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Rufo\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> equo \u003Cg ref=\"#interpunct\">·\u003C/g> pu\n                    \u003Clb n=\"2\" break=\"no\"/>blico \u003Cg ref=\"#interpunct\">·\u003C/g> exornato \u003Cg ref=\"#interpunct\">·\u003C/g> a \u003Cg ref=\"#interpunct\">·\u003C/g> Divo \u003Cg ref=\"#interpunct\">·\u003C/g> Antoni\n                    \u003Clb n=\"3\" break=\"no\"/>no \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>Aug\u003C/abbr>\u003Cex>usto\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> Pio \u003Cg ref=\"#interpunct\">·\u003C/g> plebs \u003Cg ref=\"#interpunct\">·\u003C/g> Gaulitana \u003Cg ref=\"#interpunct\">·\u003C/g> ex\n                    \u003Clb n=\"4\"/>aere \u003Cg ref=\"#interpunct\">·\u003C/g> conlato \u003Cg ref=\"#interpunct\">·\u003C/g> ob \u003Cg ref=\"#interpunct\">·\u003C/g> merita \u003Cg ref=\"#interpunct\">·\u003C/g> et \u003Cg ref=\"#interpunct\">·\u003C/g> in\n                    \u003Clb n=\"5\"/>solacium \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Valli\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Postumi\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CroleName type=\"paracivic\" subtype=\"patronus\">patro\n                    \u003Clb n=\"6\" break=\"no\"/>ni\u003C/roleName> \u003Cg ref=\"#interpunct\">·\u003C/g> municipii \u003Cg ref=\"#interpunct\">·\u003C/g> patris \u003Cg ref=\"#interpunct\">·\u003C/g> eius\n                    \u003Clb n=\"7\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>ATE\u003C/orig>\u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Following CIL and photograph\u003C/note>\u003C/app>\u003C/listApp>\n                \u003C!-- Photograph on EAGLE. Interpuncts not always certain from photograph, followed CIL on those but autopsy of stone needed to confirm -->\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>To Marcus Vallius Rufus son of Gaius, of tribe Quirina, honoured with the public horse by the deified Augustus Antoninus Pius, the plebs of Gaulus [set this up] from community collected money on account of his merits and to honour his father Gaius Vallius Postumus, the patron of the municipum [---] \u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Honorific for Marcus Vallius C.f. Quir Rufus, equo publico by the Divus Antoninus Augustus Pius, honoured by the Plebs Gaulitana; further bibl in the EDR entry.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7508\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Bruno\u003C/author>\n                        \u003Cdate>2004\u003C/date>\n                        \u003CcitedRange>20, 57\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DC35M7JM\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002111\">https://biblio.inscriptiones.org/epig10002111\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Pirino\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/A3394RTV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001389\">https://biblio.inscriptiones.org/epig10001389\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Christol and Pirino\u003C/author>\n                        \u003Cdate>2006\u003C/date>\n                        \u003CcitedRange>2610-2614\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/5NAZJMGT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001367\">https://biblio.inscriptiones.org/epig10001367\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
