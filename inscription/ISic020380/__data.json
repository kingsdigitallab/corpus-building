east=\"22\" atMost=\"22\">22\u003C/height>\n                                    \u003Cwidth unit=\"mm\">9\u003C/width>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"https://pleiades.stoa.org/places/462487\">Segesta\u003C/placeName>\n                                \u003CplaceName type=\"modern\"/>\n                                \u003Cgeo>37.94171, 12.83649\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" evidence=\"archaeological-context material-context lettering\" notBefore-custom=\"-0500\" notAfter-custom=\"-0480\">500—480 BCE (Biondi 1992)\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notBefore=\"1989\" notAfter=\"1990\">Found in the area of Grotta Vanella, on the north-east slope of Monte Barbaro between 1989 and 1990\u003Cgeo>37.94240, 12.84509\u003C/geo>, 1.9km east of temple of Segesta.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">No autopsy\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.unknown\" ref=\"https://www.eagle-network.eu/voc/typeins/lod/143.html\">unknown\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2021-02-16\" who=\"#VM\">Valentina Mignosa created preliminary blank file\u003C/change>\n                \u003Cchange when=\"2022-03-31\" who=\"#VM\">Valentina Mignosa added metadata, text\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020380_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020380.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"xly-Grek\" resp=\"#VM\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003Cg ref=\"#cross_uninterpreted\"/>\n                    \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" subtype=\"transliteration\" xml:lang=\"xly-Latn\">\n                \u003Cab/>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Biondi 1992\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp>\u003C!--No translation currently agreed-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp>\u003C!--No translation currently agreed-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>Cross-shaped sign recurrent as a mark throughout the ancient world. Cf. Agostiniani 1977, p.11, which reports some parallels with Attic ceramic: Graef, Langlotz 1933, p.128, no.1523, N 456; Milne 1936, fig. 34, no.14; F.Xanthos IV, p.174, nos. 400-401.\n                    The sign is very common in the Elymian corpus from Grotta Vanella (see records from \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020008\">ISic020008\u003C/ref> to \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020035\">ISic020035\u003C/ref>).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IAS I, App.\">\n                        \u003Cauthor>Agostiniani\u003C/author>\n                        \u003Cdate>2021\u003C/date>\n                        \u003CcitedRange>380\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VQEP8IPT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002320\">https://biblio.inscriptiones.org/epig10002320\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Biondi\u003C/author>\n                        \u003Cdate>1992\u003C/date>\n                        \u003CcitedRange>117, no. 2, pl. III.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/I5EWGXSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002322\">https://biblio.inscriptiones.org/epig10002322\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n                        \u003Cauthor>Metzger\u003C/author>\n                        \u003Cdate>1972\u003C/date>\n                        \u003CcitedRange>p.174, nos. 400-401\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/KG5M5D44\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001748\">https://biblio.inscriptiones.org/epig10001748\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Milne\u003C/author>\n                        \u003Cdate>1936\u003C/date>\n                        \u003CcitedRange>fig. 34, no.14\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FW7W6HTJ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002564\">https://biblio.inscriptiones.org/epig10002564\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Graef, Langlotz\u003C/author>\n                        \u003Cdate>1933\u003C/date>\n                        \u003CcitedRange>p.128, no.1523, N 456\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/MAEBB7ZT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002563\">https://biblio.inscriptiones.org/epig10002563\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
