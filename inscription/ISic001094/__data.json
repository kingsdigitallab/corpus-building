/382445/items/Q2SBPG9F\u003C/a>\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΚΑΙΣΑΡ\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>.]ΥΤΟΚΡΑ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΟΥΣΕΒΑ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΣΕΠΤΙΚ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΣΤΡΑΝΚΑ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al6-diplomatic\">\u003Cspan class=\"linenumber\">6\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Φλαουιο\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Φλαουιο\">\u003Cspan data-text=\"Φλαουιο\">ΦΛΑΟΥΙΟ\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":200,"html":201},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>",{"id":203,"html":204},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>  \u003Cspan>text of IG\u003C/span>  \u003C/span>\u003C/li>\u003C/ul>",{"id":206,