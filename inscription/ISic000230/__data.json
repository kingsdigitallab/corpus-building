{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":104,"html":251,"xml":297},"ISic000230",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":33,"dimensions":36,"layoutDesc":47,"handNote":54,"date":74,"places":78,"geo":88,"country":83,"provenance":80,"provenanceFound":92,"provenanceGeo":97,"provenanceObserved":98,"provenanceLost":20,"graphics":104,"region":112,"settlement":85,"repository":113,"idno":127,"textLang":130,"bibliographyEdition":134,"bibliographyDiscussion":187,"citation":190,"tmNumber":8,"facsimile":222,"letterHeights":223,"publications":230,"zotero":235,"keywords":240,"lettering_types":250},"Funerary inscription for Vecilia",{"_":5},"edited",[7,10,13,15,18],{"_":8,"type":9},"285307","TM",{"_":11,"type":12},"127533","EDR",{"type":14},"EDH",{"_":16,"type":17},"22100146","EDCS",{"type":19},"PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","Rectangular stele, grey limestone. Sides relatively squared, with chips on top and bottom faces. Rear tapers to flat surface. Significant later damage, including later graffiti scratched onto front face. Large scratches on front face.",{"_":27,"ana":28,"ref":29},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":31,"type":32,"subtype":33,"resp":34,"ref":35},"limestone","stone.calcite_limestone","","#Coccato","http://www.eagle-network.eu/voc/material/lod/66.html",[37,41,44],{"_":38,"unit":39,"dimension":40},"32","cm","height",{"_":42,"unit":39,"dimension":43},"67.5","width",{"_":45,"unit":39,"dimension":46},"21","depth",{"layout":48},{"p":49,"rs":50,"damage":33},"Two lines of Latin text, roughly centred on stone, but all contained within top half of the stone. Small dash interpunct is evident in line 1, but possible traces elsewhere. Graffiti squeezed into stone between left edge of stone and start of text, and roughly follows lines of inscription (but far from faithfully).",{"_":51,"ana":52,"ref":53},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":55,"dimensions":56},"Text is only lightly inscribed on stone. Letters even spaced and well-formed. Light serifs. Graffiti very rough, grey scratches on surface. Letters are imitative of main text, but thickness of lines, size of letters and orientation of letters are inconsistent.",[57,65,71],{"type":58,"l":59,"from":60,"to":60,"h":61,"unit":62,"atLeast":63,"atMost":64},"letterHeight","Line 1","line1","36-41","mm","36","41",{"type":58,"l":66,"from":67,"to":67,"h":68,"unit":62,"atLeast":69,"atMost":70},"Line 2","line2","35-42","35","42",{"type":72,"l":73,"from":60,"to":67,"unit":62},"interlinear","Interlineation line 1 to 2",{"_":75,"notBefore":76,"notAfter":77},"Bivona (1994, 239) dates to the first half of the 1st century CE based on the missing cognomen.",1,50,[79,84],{"_":80,"type":81,"ref":82,"region":83},"Thermae Himeraeae","ancient","http://pleiades.stoa.org/places/462513","Sicilia",{"_":85,"type":86,"ref":87,"region":83},"Termini Imerese","modern","http://sws.geonames.org/6539140",[89],[90,91],37.98365,13.69555,{"_":93,"type":94,"subtype":95,"when":96,"geo":20},"Found in Termini Imerese in 1783 (so Castelli 1784), and in the local senate house collection by 1829 (Romano).","found","discovered","1783",[],{"_":99,"type":100,"subtype":101,"when":102,"resp":103,"geo":20},"Antoniou, 2022-07-08. On display in the courtyard portico of Museo Civico Baldassare Romano","observed","autopsied","2022-07-08","#AA",[105],{"n":106,"url":107,"height":108,"width":109,"desc":110,"surfaceType":111},"screen","ISic000230_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-07-08","front","Sicily",{"_":114,"role":115,"ref":116,"museum":117},"Museo Civico Baldassare Romano","museum","http://sicily.classics.ox.ac.uk/museum/066",{"slug":118,"type":115,"name":114,"uri":116,"description":119,"location":120},"066","A large and well-displayed collection. It begins with three ante-rooms, in the first of which is a rich display of lithics (mainly Neolithic) from the surrounding area. A display of material from Himera (lion-head spouts from the Temple of Victory and red-figure craters being the principle pieces) and a numismatic gallery then follow before the main room which contains Hellenistic and Roman material from Termini Imerese itself. Small finds, sculpture and inscriptions predominate. The museum collection continues upstairs with non-archaeological material (and a single inscription). The courtyard of the building holds a large collection of architectural pieces and inscriptions",{"settlement":85,"region":121,"country":122,"address":123,"geo":124},"Palermo","Italy","Via Marco Tullio Cicerone, 90018 - Termini Imerese (PA)",{"lat":125,"lon":126},37.98655109,13.69587845,{"_":128,"type":129},"124","inventory",{"_":131,"mainLang":132,"languages":133},"Latin","la",[131],{"type":135,"bibl":136},"edition",[137,148,159,175,20],{"author":138,"date":139,"citedRange":140,"ptr":141,"ref":143,"inscriptionDate":139,"title":145,"citation":146,"uri":147,"year":139},"Castelli","1784","331 no.4",{"target":142},"https://www.zotero.org/groups/382445/items/7PSFHSUH",{"_":144,"target":144},"https://biblio.inscriptiones.org/epig10002083","Siciliae et objacentium insularum veterum inscriptionum nova collectio prolegomenis et notis illustrata, et iterum cum emendationibus, & auctariis evulgata","\u003Cspan>Gabriello Lancellotto Castelli Principe di Torremuzza, \u003Ci>Siciliae et objacentium insularum veterum inscriptionum nova collectio prolegomenis et notis illustrata, et iterum cum emendationibus, &#38; auctariis evulgata\u003C/i>, 2nd (1st is 1769) (Palermo: typis regiis, 