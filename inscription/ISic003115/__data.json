 height=\"3072px\" width=\"4080px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-18\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n        \u003Csurface type=\"rear\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003115_rear_tiled.tif\" height=\"3072px\" width=\"4080px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-18\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003115_rear.jpg\" height=\"3072px\" width=\"4080px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-18\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Δαμάτρι\u003Csupplied reason=\"lost\">ος\u003C/supplied>\u003C/w>\u003C/name>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw n=\"10\">Ποπλείο\u003Csupplied reason=\"lost\" cert=\"low\">υ\u003C/supplied>\u003C/w>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"15\">μακαρῖτα\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"20\">\u003Cchoice>\u003Corig>χαῖρη\u003C/orig>\u003Creg>χαῖρε\u003C/reg>\u003C/choice>\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Δαμάτριος\">Δαμάτριος\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Πόπλιος\">Ποπλείου\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"μακαρίτης\">μακαρῖτα\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"χαίρω\">χαῖρη\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Brugnone2024, checked against photograph\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"2\">\n                        \u003Cnote>Brugnone: alternatively Ποπλείο[ς]\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>Damatrios son of Popleios, blessed one, rejoice!\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The formula μακαρῖτα χαῖρε is found in another funerary epitaph at Lilybaeum, \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic003660\">ISic003660\u003C/ref>. The second name, Popleios (i.e. Latin Publius) could either be a patronymic, or else the adoption of a Latin name as a second name, as attested in other Sicilian cases (Cic. Verr. 2.4.35, 2.5.16).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>26.1075\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Di Stefano\u003C/author>\n                        \u003Cdate>1984\u003C/date>\n                        \u003CcitedRange>178-179 no.193 fig.97\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q5PB252W\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002035\">https://biblio.inscriptiones.org/epig10002035\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1976\u003C/date>\n                        \u003CcitedRange>213-215 no.1 tav.10.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DCD9JFZS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001771\">https://biblio.inscriptiones.org/epig10001771\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Brugnone\u003C/author>\n                        \u003Cdate>2024\u003C/date>\n                        \u003CcitedRange>316-318 G8.5 fig.314\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/H5GJ8WQW\"/>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
