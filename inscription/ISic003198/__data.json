partimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003198.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cchoice>\u003Corig>\u003Cname>Πριγομένια\u003C/name>\u003C/orig>\u003Creg>\u003Cname>Πριμογένια\u003C/name>\u003C/reg>\u003C/choice>\u003C/persName> χρη\n                    \u003Clb n=\"2\" break=\"no\"/>\u003Csupplied reason=\"lost\">στ\u003C/supplied>ὰ κὲ ἄμεμπτε κὲ\n                    \u003Clb n=\"3\"/>\u003Csupplied reason=\"lost\">πι\u003C/supplied>στὴ \u003Cunclear>κ\u003C/unclear>\u003Csupplied reason=\"lost\">ὲ\u003C/supplied> ἀμίμη\n                    \u003Clb n=\"4\"/>\u003Csurplus>μη\u003C/surplus>τος ἔζησε ἔτη \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after Ferrua and Rizzone, compared to Pace's drawing\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1-2\">\u003Cnote>Rizzone: χρη-|σ[τ]ὰ\u003C/note>\u003C/app>\n                    \u003Capp loc=\"2\">\u003Cnote>Rizzone: ἄμεμπτος\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>Ferrua: χρηστιανὴ('forse')\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>Rizzone: ἔζησεν\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Prigomenia, worthy and blameless and faithful and inimitable, lived [..] years\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"Rizzone\">\n                \u003Cp>Prigomenia, buona ed irreprensibile e fedele e inimitabile, visse anni [...]\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>04.0033\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Pace\u003C/author>\n                        \u003Cdate>1921\u003C/date>\n                        \u003CcitedRange>42 dr\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/XTQH2GQF\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001693\">https://biblio.inscriptiones.org/epig10001693\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Pace\u003C/author>\n                        \u003Cdate>1927\u003C/date>\n                        \u003CcitedRange>163 no.16\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZJ6KUFMM\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001692\">https://biblio.inscriptiones.org/epig10001692\u003C/ref>\u003C/bibl>\n           