guage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.unknown\" ref=\"https://www.eagle-network.eu/voc/typeins/lod/143.html\">unknown\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2019-11-14\" who=\"#JP\">Jonathan Prag created the file from template\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-21\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic004394_Orsi_tiled.tif\" height=\"285px\" width=\"615px\">\n                \u003Cdesc>Drawing of P.Orsi\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic004394_Orsi.jpg\" height=\"285px\" width=\"615px\">\n                \u003Cdesc>Drawing of P.Orsi\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"scx-grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\" style=\"text-direction:l-to-r\"/>οστιυͱαγε\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\"/>κ\n                    \u003Clb n=\"2\" style=\"text-direction:r-to-l\"/>ε\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"2\"/>ι\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\"/>δ\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\"/>\n               \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Orsi 1900 and Agostiniani 1992\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The sole record of this text is the report in Orsi 1900, reporting the discovery, his inability to locate it, and reproducing the drawing provided by the unnamed discoverer\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1900\u003C/date>\n                        \u003CcitedRange>59 no. 37\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/UE3VRJA7\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001707\">https://biblio.inscriptiones.org/epig10001707\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Agostiniani\u003C/author>\n                        \u003Cdate>1992\u003C/date>\n                        \u003CcitedRange>149 no. 10\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9PTH7BSP\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002200\">https://biblio.inscriptiones.org/epig10002200\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
