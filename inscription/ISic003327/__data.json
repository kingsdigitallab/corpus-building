003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-06-17\" who=\"#JP\">Jonathan Prag edited file from edition of Robert\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003327_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003327.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CplaceName type=\"ethnic\">Ἀδεονζίνο̄ν\u003C/placeName> \u003Cexpan>\u003Cabbr>δαμόσ\u003C/abbr>\u003Cex>ιον\u003C/ex>\u003C/expan>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Ampolo and Robert\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The Adeonzinoi are not identified. Some scholars (e.g. Guarducci) have interpreted this piece as a weight, rather than as an element from a caduceus, but the attribution to a caduceus is generally accepted.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>56.1077.B1\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Robert\u003C/author>\n                        \u003Cdate>1936\u003C/date>\n                        \u003CcitedRange>no.83 with pl. XLIII\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/6XN6SKDD\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001271\">https://biblio.inscriptiones.org/epig10001271\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                         \u003Cauthor>Dubois\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>201\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/RWXNUFEX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1996\u003C/date>\n                        \u003CcitedRange>142 n.65 with tav. 15 fig. 15\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/KS57W5TB\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001821\">https://biblio.inscriptiones.org/epig10001821\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ampolo\u003C/author>\n                        \u003Cdate>2006\u003C/date>\n                        \u003CcitedRange>185 appendix B no.1 with fig. 8\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/LCT7H63L\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002458\">https://biblio.inscriptiones.org/epig10002458\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\n\t       \u003Cbibl type=\"corpus\" n=\"DGE\">\n\t           \u003Cauthor>Schwyzer\u003C/author>\n\t           \u003Cdate>1923\u003C/date>\n\t           \u003CcitedRange>311\u003C/citedRange>\n\t           \u003Cptr target=\"http://zotero.org/groups/382445/items/GVRCGPHM\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10001230\">https://biblio.inscriptiones.org/epig10001230\u003C/ref>\u003C/bibl>\n\t       \u003Cbibl>\n\t           \u003Cauthor>Guarducci\u003C/author>\n\t           \u003Cdate>1967-1978\u003C/date>\n\t           \u003CcitedRange>vol. 2, p. 463 n.1\u003C/citedRange>\n\t