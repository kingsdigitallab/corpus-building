{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":129,"html":268,"xml":319},"ISic001397",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":34,"dimensions":36,"layoutDesc":47,"handNote":56,"date":99,"places":104,"geo":113,"provenance":106,"provenanceFound":117,"provenanceGeo":122,"provenanceObserved":123,"provenanceLost":20,"graphics":129,"country":142,"region":143,"settlement":144,"repository":145,"idno":157,"textLang":160,"bibliographyEdition":164,"bibliographyDiscussion":201,"citation":204,"tmNumber":8,"facsimile":227,"letterHeights":228,"publications":248,"zotero":252,"keywords":256,"lettering_types":267},"Epitaph for Glykera",{"_":5},"edited",[7,10,12,14,17],{"_":8,"type":9},"493012","TM",{"type":11},"EDR",{"type":13},"EDH",{"_":15,"type":16},"39101524","EDCS",{"_":18,"type":19},"140904","PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","A plaque of grey limestone. Intact top and right, minor damaged to the lower edge; broken on the left, especially upper left corner (loss of part of first letter of text). A long deep vertical stroke funs up the left margin, of which the upper part is lost. The rear is finished smooth. A hole for a metal fixing peg is visible in the middle of the upper edge (early modern, for display?).",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":31,"ana":32,"ref":33},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":35},"#condition.damaged",[37,41,44],{"_":38,"unit":39,"dimension":40},"23.8","cm","height",{"_":42,"unit":39,"dimension":43},"26","width",{"_":45,"unit":39,"dimension":46},"1.9-2.1","depth",{"layout":48},{"p":49,"rs":50,"damage":54},"The layout is unusual, with the text centred in a pseudo-stoichedon, the letters equal in number on each line, irrespective of word-breaks, and vertically aligned, and the final empty letter space in line 5 occupied by a hedera. ",{"_":51,"ana":52,"ref":53},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":55},"#text_condition.complete",{"lettering":57,"dimensions":58},"Neatly carved, regular letters of slightly uneven height (not v-cut, simple groove). Lunate epsilon and sigma, alpha with extended upper stroke, slight serifs to most strokes. Single interpunct before age.",[59,66,72,77,83,88,92,94,97],{"type":60,"l":61,"from":62,"to":62,"h":63,"unit":64,"atLeast":42,"atMost":65},"letterHeight","Line 1","line1","26-28 (Ε is 20)","mm","28",{"type":60,"l":67,"from":68,"to":68,"h":69,"unit":64,"atLeast":70,"atMost":71},"Line 2","line2","21-23 (Σ is 18)","21","23",{"type":60,"l":73,"from":74,"to":74,"h":75,"unit":64,"atLeast":71,"atMost":76},"Line 3","line3","23-25 (Ε is 20)","25",{"type":60,"l":78,"from":79,"to":79,"h":80,"unit":64,"atLeast":81,"atMost":82},"Line 4","line4","20-24","20","24",{"type":60,"l":84,"from":85,"to":85,"h":86,"unit":64,"atLeast":70,"atMost":87},"Line 5","line5","21-22","22",{"type":89,"l":90,"from":62,"to":68,"h":91,"unit":64,"atLeast":91,"atMost":91},"interlinear","Interlineation line 1 to 2","10",{"type":89,"l":93,"from":68,"to":74,"h":91,"unit":64,"atLeast":91,"atMost":91},"Interlineation line 2 to 3",{"type":89,"l":95,"from":74,"to":79,"h":96,"unit":64,"atLeast":96,"atMost":96},"Interlineation line 3 to 4","15",{"type":89,"l":98,"from":79,"to":85,"h":91,"unit":64,"atLeast":91,"atMost":91},"Interlineation line 4 to 5",{"_":100,"notBefore":101,"notAfter":102,"evidence":103},"1st-3rd century CE",1,300,"lettering, textual-context",[105,109],{"_":106,"type":107,"ref":108},"Centuripae","ancient","http://pleiades.stoa.org/places/462153",{"_":110,"type":111,"ref":112},"Centuripe","modern","http://sws.geonames.org/2525032",[114],[115,116],37.62336,14.74049,{"_":118,"type":119,"subtype":120,"when":121,"geo":20},"Found in February 1841 by a farmer, in proximity to the road running from the chiesa dell'Addolorata towards Acquanova, who gave it to D. Giuseppe Polizzi (where first reported by a traveller in 1844). Purchased by Siracusa Museum in 1914; currently in cassetta 4, Magazzino B.","found","discovered","1841-02",[],{"_":124,"type":125,"subtype":126,"resp":127,"xml:id":128,"geo":20},"Prag 2014-09-11","observed","autopsied","#JP","autopsy",[130,137],{"n":131,"url":132,"height":133,"width":134,"desc":135,"surfaceType":136},"screen","ISic001397_tiled.tif","2880px","3480px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-11","front",{"n":131,"url":138,"height":139,"width":140,"desc":135,"surfaceType":141},"ISic001397_rear_tiled.tif","2872px","3232px","rear","Italy","Sicily","Siracusa",{"_":146,"role":147,"ref":148,"museum":149},"Museo Archeologico Regionale Paolo Orsi","museum","http://sicily.classics.ox.ac.uk/museum/097",{"slug":150,"type":147,"name":146,"uri":148,"description":151,"location":152},"097","An outstanding collection of archaeological material. The collection ranges from Siracusa and the surrounding territory (Megara Hyblaia, Akrai, Kasmenai etc) to encompass all of eastern Sicily, reaching as far as Gela and Agrigento. The ground floor covers prehistory through to the end of the Classical period. Upstairs includes Hellenistic and Roman Syracuse and a display of material from the catacombs. A gallery displaying material from Hellenistic eastern Sicily is in preparation.",{"settlement":144,"region":144,"country":142,"address":153,"geo":154},"Viale Teocrito 66, 96100 - Siracusa",{"lat":155,"lon":156},37.07636989,15.2866213,{"_":158,"type":159},"35826","inventory",{"_":161,"mainLang":162,"languages":163},"Ancient Greek","grc",[161],{"type":165,"bibl":166},"edition",[167,173,