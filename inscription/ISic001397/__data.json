checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XInclude\" xml:lang=\"en\">\n    \u003CteiHeader>\n        \u003CfileDesc>\n            \u003CtitleStmt>\n                \u003Ctitle>Epitaph for Glykera\u003C/title>\n                \u003Ceditor ref=\"#JP\">Jonathan Prag\u003C/editor>\n                \u003Cprincipal ref=\"#JP\">Jonathan Prag\u003C/principal>\n                \u003Cfunder>John Fell OUP Research Fund\u003C/funder>\n\t   \u003Cfunder>\u003Cref target=\"https://cordis.europa.eu/project/id/885040\">ERC Advanced Grant no.885040\u003C/ref>\u003C/funder>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>original data collection and editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JCu\" ref=\"http://orcid.org/0000-0002-6686-3728\">James Cummings\u003C/name>\n                    \u003Cresp>conversion to EpiDoc\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"AL\" ref=\"https://orcid.org/0000-0002-0000-7611\">Andoni Llamazares\u003C/name>\n                    \u003Cresp>text edition\u003C/resp>\n                \u003C/respStmt>\n\t    \u003CrespStmt>\n     \t       \u003Cname xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n     \t       \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n \t   \u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic001397\u003C/idno>\n                \u003Cidno type=\"TM\">493012\u003C/idno>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\">39101524\u003C/idno>\n                \u003Cidno type=\"PHI\">140904\u003C/idno>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic001397\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-22\">10.5281/zenodo.4385878\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Siracusa\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/097\">Museo Archeologico Regionale Paolo Orsi\u003C/repository>\n                        \u003Cidno type=\"inventory\">35826\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>A plaque of grey limestone. Intact top and right, minor damaged to the lower edge; broken on the left, especially upper left corner (loss of part of first letter of text). A long deep vertical stroke funs up the left margin, of which the upper part is lost. The rear is finished smooth. A hole for a metal fixing peg is visible in the middle of the upper edge (early modern, for display?).\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.limestone\" ref=\"http://www.eagle-network.eu/voc/material/lod/66.html\">limestone\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/259\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">23.8\u003C/height>\n                                        \u003Cwidth unit=\"cm\">26\u003C/width>\n                                        \u003Cdepth unit=\"cm\">1.9-2.1\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.damaged\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003Cp>The layout is unusual, with the text centred in a pseudo-stoichedon, the letters equal in number on each line, irrespective of word-breaks, and vertically aligned, and the final empty letter space in line 5 occupied by a hedera. \u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage ana=\"#text_condition.complete\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Neatly carved, regular letters of slightly uneven height (not v-cut, simple groove). Lunate epsilon and sigma, alpha with extended upper stroke, slight serifs to most strokes. Single interpunct before age.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"26\" atMost=\"28\">26-28 (Ε is 20)\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line2\" to=\"line2\">Line 2\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"21\" atMost=\"23\">21-23 (Σ is 18)\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line3\" to=\"line3\">Line 3\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"23\" atMost=\"25\">23-25 (Ε is 20)\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line4\" to=\"line4\">Line 4\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"20\" atMost=\"24\">20-24\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line5\" to=\"line5\">Line 5\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"21\" atMost=\"22\">21-22\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"10\" atMost=\"10\">10\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line2\" to=\"line3\">Interlineation line 2 to 3\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"10\" atMost=\"10\">10\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line3\" to=\"line4\">Interlineation line 3 to 4\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"15\" atMost=\"15\">15\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line4\" to=\"line5\">Interlineation line 4 to 5\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"10\" atMost=\"10\">10\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462153\">Centuripae\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525032\">Centuripe\u003C/placeName>\n                            \t\u003Cgeo>37.62336, 14.74049\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0001\" notAfter-custom=\"0300\" evidence=\"lettering textual-context\">1st-3rd century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"1841-02\">Found in February 1841 by a farmer, in proximity to the road running from the chiesa dell'Addolorata towards Acquanova, who gave it to D. Giuseppe Polizzi (where first reported by a traveller in 1844). Purchased by Siracusa Museum in 1914; currently in cassetta 4, Magazzino B.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" resp=\"#JP\" xml:id=\"autopsy\">Prag 2014-09-11\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Pho