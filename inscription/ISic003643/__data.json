ible\" unit=\"character\" quantity=\"1\"/>\u003Corig>ΛΗ\u003C/orig>\n                    \u003Clb n=\"5\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cexpan>\u003Cabbr>μ\u003C/abbr>\u003Cex>ῆνας\u003C/ex>\u003C/expan> \u003Cspace unit=\"character\" quantity=\"1\"/> \u003Cnum value=\"5\">ε\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text by Prag from photo in Manganaro 1965\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Manganaro records but does not attempt to transcribe. There appear to be remains of symbols of some description beyond a vacat on the right side, which Manganaro suggests to be a cross.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1965\u003C/date>\n                        \u003CcitedRange>198 no.3 tav.70.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RGTHAFKT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001841\">https://biblio.inscriptiones.org/epig10001841\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>2001\u003C/date>\n                        \u003CcitedRange>81 no.XIII, fig. 13\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/MRSE35A9\"/>\n                    \u003Cref target=\