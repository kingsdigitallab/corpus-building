    \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2021-06-17\" who=\"#VM\">Valentina Mignosa added metadata, text\u003C/change>\n                \u003Cchange when=\"2022-09-15\" who=\"#VM\">Valentina Mignosa merged with ISic020449\u003C/change>\n                \u003Cchange when=\"2025-04-24\" who=\"#SS\">added letterform types to handNote\u003C/change>\n                \u003Cchange when=\"2025-10-15\" who=\"#RC\">Robert Crellin added local IDs to edition elements\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020600_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020600.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\" xml:id=\"UΙAAK\"/>\u003CpersName type=\"divine\" xml:id=\"UΙAAU\">\u003Cname xml:id=\"UΙAAe\">\u003Cw n=\"5\">ͱε̄ρακλεῖ\u003C/w>\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Arena 1998 (IGASM 5)\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#VM\">\n                \u003Cp>To Heracles.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#VM\">\n                \u003Cp>A Eracle.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>The dedication is written in an alphabet aberrant to the context of Syracuse, in which it was found. \n                    According to Jeffery (1961), the alphabet is of the Megarian type, which she explains by suggesting that those \n                    (the pacheis) transported by Gelon to Syracuse from Megara Hyblaea had made a dedication using, \n                    for reasons she does not further investigate, the alphabet of the mother country. \n                    According to Guarducci (1959-1960), on the other hand, the alphabet would undoubtedly be Corinthian \n                    and could easily be explained by the presence of Corinthians or Corcyraeans in Syracuse around the fifth century.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IGASM5\">\n                        \u003Cauthor>Arena\u003C/author>\n                        \u003Cdate>1998\u003C/date>\n                        \u003CcitedRange>95\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/KMTS6RQX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000637\">https://biblio.inscriptiones.org/epig10000637\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGASM1\">\n                        \u003Cauthor>Arena\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>75, fig. 13\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VC9IHZAR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000638\">https://biblio.inscriptiones.org/epig10000638\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                        \u003Cauthor>Dubois\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\">90\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RWXNUFEX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"archive\">\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003CcitedRange>J.WC.MegH.30.p.01\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/QV9CP9PX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002294\">https://biblio.inscriptiones.org/epig10002294\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl n=\"LSAG[2]\">\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003Cauthor>Johnston\u003C/author>\n                        \u003Cdate>1990\u003C/date>\n                        \u003CcitedRange>276 no.30\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/QUWGZA84\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000678\">https://biblio.inscriptiones.org/epig10000678\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003Cdate>1961\u003C/date>\n                        \u003CcitedRange>276 no.30\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/V6CGSWPS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000677\">https://biblio.inscriptiones.org/epig10000677\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Guarducci\u003C/author>\n                        \u003Cdate>1959-1960\u003C/date>\n                        \u003CcitedRange>250, fig. 2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GPUF5NUH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001928\">https://biblio.inscriptiones.org/epig10001928\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
