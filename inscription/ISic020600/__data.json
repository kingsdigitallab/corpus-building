ag","#JP",{"_":249,"ref":250},"Valentina Mignosa","#VM",[252,255,258,262],{"_":246,"xml:id":253,"ref":254},"JP","https://orcid.org/0000-0003-3819-8537",{"_":249,"xml:id":256,"ref":257},"VM","https://orcid.org/0000-0002-7122-2511",{"_":259,"xml:id":260,"ref":261},"Simona Stoyanova","SS","https://orcid.org/0000-0003-3914-9569",{"_":263,"xml:id":264,"ref":265},"Robert Crellin","RC","https://orcid.org/0000-0002-0100-7437",{"_":267,"when":268,"who":269},"Robert Crellin added local IDs to edition elements","2025-10-15","#RC",{"n":128,"url":129,"height":130,"width":131,"desc":132,"surfaceType":133},[],[273,274,275,276,277,278,279],"Arena, 1998, IGASM5","Arena, 1989, IGASM1","Dubois, 1989, IGDS1","Jeffery, Anne Jeffery Archive","Jeffery, Johnston, 1990, The local scripts of archaic Greece","Jeffery, 1961, The Local Scripts of Archaic Greece","Guarducci, 1959-1960, Nuove note di epigrafia siceliota arcaica",[281,282,283,284,285,286,287],"KMTS6RQX","VC9IHZAR","RWXNUFEX","QV9CP9PX","QUWGZA84","V6CGSWPS","GPUF5NUH",[289,289,290,23,28,32,291,292,293,294,292,295,296,153],"isic020600",{"_":4},"syracusae","siracusa","sicilia","sicily","museo archeologico regionale paolo orsi","ancient greek",[62,65,68,71,74,77,80,83,86],{"title":299,"body":300,"divs":301,"editions":328,"images":338,"handnote":344},"ISic020600. ISic020600","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"ͱε̄ρακλεῖ\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"ͱε̄ρακλεῖ\">\u003Cspan data-text=\"ͱε̄ρακλεῖ\" data-n=\"5\" data-lemma=\"\">ͱε̄ρακλεῖ\u003C/span>\u003C/span>\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"ͱε̄ρακλεῖ\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"ͱε̄ρακλεῖ\">\u003Cspan data-text=\"ͱε̄ρακλεῖ\" data-n=\"5\" data-lemma=\"\">ͰΕ̄ΡΑΚΛΕΙ\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic020600_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic020600_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic020600.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic020600-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>  \u003Cspan>Text after Arena 1998 (IGASM 5)\u003C/span>  \u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0002-7122-2511\">Valentina Mignosa\u003C/a>\u003C/p>  \u003Cp>To Heracles.\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0002-7122-2511\">Valentina Mignosa\u003C/a>\u003C/p>  \u003Cp>A Eracle.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>The dedication is written in an alphabet aberrant to the context of Syracuse, in which it was found. According to Jeffery (1961), the alphabet is of the Megarian type, which she explains by suggesting that those (the pacheis) transported by Gelon to Syracuse from Megara Hyblaea had made a dedication using, for reasons she does not further investigate, the alphabet of the mother country. According to Guarducci (1959-1960), on the other hand, the alphabet would undoubtedly be Corinthian and could easily be explained by the presence of Corinthians or Corcyraeans in Syracuse around the fifth century.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Jeffery J.WC.MegH.30.p.01 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002294\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002294\u003C/a>  \u003C/li>\u003Cli> Guarducci 1959-1960 250, fig. 2 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001928\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001928\u003C/a>  \u003C/li>\u003Cli> Jeffery 1961 276 no.30 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000677\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000677\u003C/a>  \u003C/li>\u003Cli> Arena 1989 75, fig. 13 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000638\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000638\u003C/a>  \u003C/li>\u003Cli> Dubois 1989 \u003Ca href=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\" target=\"_blank\">90\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10000187\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000187\u003C/a>  \u003C/li>\u003Cli> Jeffery Johnston 1990 276 no.30 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000678\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000678\u003C/a>  \u003C/li>\u003Cli> Arena 1998 95 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000637\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000637\u003C/a>  \u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">  \u003Cp> Types list: \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Α-type1.html\" target=\"_blank\">Α type1\u003C/a> \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Α-type1.3.html\" target=\"_blank\">Α type1.3\u003C/a> \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ε-type1.html\" target=\"_blank\">Ε type1\u003C/a> \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ι-type1.html\" target=\"_blank\">Ι type1\u003C/a> \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Κ-type1.html\" target=\"_blank\">Κ type1\u003C/a> \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Κ-type1.1.html\" target=\"_blank\">Κ type1.1\u003C/a> \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Λ-type2.html\" target=\"_blank\">Λ type2\u003C/a> \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ρ-type1.html\" target=\"_blank\">Ρ type1\u003C/a> \u003Ca href=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ρ-type1.5.html\" target=\"_blank\">Ρ type1.5\u003C/a> \u003C/p> Line 1    \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[302,305,308,311,314,316,319,322,325],{"id":303,"html":304},"editions","\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data