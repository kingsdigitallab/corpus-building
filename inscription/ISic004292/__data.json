tà Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab> \n                    \u003Clb n=\"1\"/>ἄρχουσιν\n                    \u003Clb n=\"2\"/>\u003Csupplied reason=\"lost\">Σ\u003C/supplied>κρειβωνίοις Νωμεντανῷ καὶ Μοδέστῳ\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" unit=\"line\" extent=\"unknown\"/>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"illegible\" unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"4\"/>\u003Cgap reason=\"illegible\" unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"5\"/>\u003Cgap reason=\"illegible\" unit=\"character\" extent=\"unknown\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of lines 1-2 after Meligunis-Lipara XII; the area below is worn; and editors to date have declined to read the final three illegible lines at the base of the stone.\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--archousin Skreiboniois Nomentano kai modesto [- - - -]. Seen by Houel, reported as lost by Libertini, redisocvered in 1993, with preliminary edition in I.Lipara. Tybout in SEG suggests that its atypical nature for Lipara means it might be a pierre errante.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>53.1010\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILipara\">\n \u2028                        \u003Cauthor>Bernabó-Brea\u003C/author>\n \u2028                        \u003Cauthor>Cavalier\u003C/author>\n \u2028                        \u003Cauthor>Campagna\u003C/author>\n \u2028                        \u003Cdate>2003\u003C/date> \n                        \u003CcitedRange>795\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VDAQH5D2\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000541\">https://biblio.inscriptiones.org/epig10000541\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1921\u003C/date>\n                        \u003CcitedRange>220 no.22\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/QECEVGHN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001875\">https://biblio.inscriptiones.org/epig10001875\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Bitto and Caliri\u003C/author>\n                        \u003Cdate>2018\u003C/date>\n                        \u003CcitedRange>25-27 fig. 1-2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/B6A5QCRR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002255\">https://biblio.inscriptiones.org/epig10002255\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
