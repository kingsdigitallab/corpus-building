u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-01-21\" who=\"#VM\">Valentina Mignosa added text and further data.\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020604_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020604.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"scx-Grek\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>ͱολ\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" subtype=\"transliteration\" xml:lang=\"scx-Latn\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>hol\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Manganaro 1961\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The document consists of two matching fragments, found accidentally during agricultural works. \n                    It was published by Cultraro (1989-1990, 451-452), who dates the piece to the second quarter of the \n                    5th century BCE on the basis of the archaeological context.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Cultraro\u003C/author>\n                        \u003Cdate>1989-1990\u003C/date>\n                        \u003CcitedRange>451-452\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/WZJDK5JD\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002383\">https://biblio.inscriptiones.org/epig10002383\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1961\u003C/date>\n                        \u003CcitedRange>110, pl. 50.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4356IBUF\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002677\">https://biblio.inscriptiones.org/epig10002677\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Agostiniani\u003C/author>\n                        \u003Cdate>2009\u003C/date>\n                        \u003CcitedRange>115-116, no.1 fig. 2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/63R3F4J2\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002427\">https://biblio.inscriptiones.org/epig10002427\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n                        \u003Cauthor>Mignosa\u003C/author>\n                        \u003Cdate>2017-2018\u003C/date>\n                        \u003CcitedRange>217, no. 3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EBZBFTF\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002428\">https://biblio.inscriptiones.org/epig10002428\u003C/ref>\u003C/bibl>\n                    \n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
