                           \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t   \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t               \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t   \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                            \u003Cchange when=\"2021-01-21\" who=\"#VM\">Valentina Mignosa encoded text division, cleaned up the autogenerated text and checked the edition\u003C/change>\n                \u003Cchange when=\"2026-02-18\" who=\"#JP\">Jonathan Prag revised from autopsy notes and photograph\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003500_tiled.tif\" height=\"5520px\" width=\"3680px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2018-03-15\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003500.jpg\" height=\"5520px\" width=\"3680px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2018-03-15\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n        \u003Csurface type=\"rear\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003500_rear_tiled.tif\" height=\"5520px\" width=\"3680px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2018-03-15\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003500_rear.jpg\" height=\"5520px\" width=\"3680px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2018-03-15\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM #JP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Corig>\u003Cunclear>Π\u003C/unclear>\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Corig>Μ\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"3\"/>\u003Corig>Α\u003C/orig>\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"4\"/>\u003Corig>Α\u003C/orig>\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"5\"/>\u003Corig>ΤΟ\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"6\"/>\u003Corig>Π\u003Cunclear>Ρ\u003C/unclear>\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text from autopsy\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Γ also possible\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>Manganaro: ΑΙ[--]; the vertical is visible, but whether it is isolated is impossible to say.\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>Omitted by Manganaro; second letter could be Μ or Ν\u003C/note>\u003C/app>\n                    \u003Capp loc=\"6\">\u003Cnote>Manganaro: ΠΙ[--]; if not Ρ then Γ\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Included by Manganaro in a list of fragments suggested to be lists of names, whether ephebes or others, but it is impossible to speculate on the content on the basis of initial letters alone. The size of the letters distinguishes it from other Hellenistic lists of names, where they are generally smaller. The piece has not so far been identified in the inventory, and origin is unknown (but presumably Syracusan). \u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>49.1331.6\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1999\u003C/date>\n                        \u003CcitedRange>68 no.62 fig.144\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GRB3IPD5\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001813\">https://biblio.inscriptiones.org/epig10001813\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
