           \u003Clb n=\"4\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Ἀντισθένεος\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"5\"/>\u003CorgName>Λυκύμνιοι\u003C/orgName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>text after Dubois IGDS II\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Nichomachos son of Hagesias, Gellias son of Antisthenes, Lykymnioi (dedicated this)\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--obelisk of local (one of three; the other inscribed one  is SEG 47.1416A); published inadequately by Fiorentini in Kokalos; not seen the QuadAMess publ. Texts given by Cordano for their names / c'ship details. This one mentions Nikomachos and Gellias, and a group of Lykymnioi-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>49.1318\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>47.1416b\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS2\">\n                         \u003Cauthor>Dubois\u003C/author>\n                         \u003Cdate>2008\u003C/date> \n                        \u003CcitedRange>091A\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SM2KDHZC\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000160\">https://biblio.inscriptiones.org/epig10000160\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Cordano\u003C/author>\n                        \u003Cdate>1997\u003C/date>\n                        \u003CcitedRange>404 n.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/WDH4NRJN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002069\">https://biblio.inscriptiones.org/epig10002069\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fiorentini\u003C/author>\n                        \u003Cdate>1984-1985\u003C/date>\n                        \u003CcitedRange>472\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F542RMP2\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001988\">https://biblio.inscriptiones.org/epig10001988\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fiorentini\u003C/author>\n                        \u003Cdate>1985-1986\u003C/date>\n                        \u003CcitedRange>31\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SDUA6DUA\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001987\">https://biblio.inscriptiones.org/epig10001987\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fiorentini\u003C/author>\n                        \u003Cdate>1991\u003C/date>\n                        \u003CcitedRange>362\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/QVPEGK9K\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001985\">https://biblio.inscriptiones.org/epig10001985\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1999\u003C/date>\n                        \u003CcitedRange>53 no.43 fig.121-122\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GRB3IPD5\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001813\">https://biblio.inscriptiones.org/epig10001813\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>2000\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/6YAXE2W5\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001810\">https://biblio.inscriptiones.org/epig10001810\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
