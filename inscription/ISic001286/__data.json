      \u003Csupport>\n                                    \u003Cp>Described as a very large fragment of high quality marble, seemingly part of a base, possibly belonging to a monumental structure or building. No measurements are recorded.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.inorganic.stone\" type=\"stone.unspecified\" subtype=\"unverified\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.base\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/57.html\" cert=\"low\">base\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Cp>parts of five lines are recorded, but with no indication of the relationship of the text to the preserved surface.\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                    \u003Cdamage/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>Lunate sigma and epsilon are indicated in Ferrara's transcription.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\