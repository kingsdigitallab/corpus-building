.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Orsi describes as being 'in attuario del II secolo'; and records comma-shaped interpuncts.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462503\">Syracusae\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2523083\">Siracusa\u003C/placeName>\n                            \t\u003Cgeo>37.08415, 15.27628\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0101\" notAfter-custom=\"199\" evidence=\"lettering\">2nd century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1900\">Found in an unknown location within Siracusa, and then in the possession of prof. Salv. Nicastro (so Orsi).\u003C/provenance>\n                       \u003Cprovenance type=\"not-observed\" subtype=\"lost\" cert=\"low\">Lost? Not recorded since Orsi's publication in 1900.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.honorific\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/69.html\" cert=\"low\">honorific\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2023-08-15\" who=\"#JP\">Jonathan Prag created draft file.\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001784_tiled.tif\" height=\"511px\" width=\"980px\">\n                \u003Cdesc>Drawing in Orsi 1900, p. 65 no. 50\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001784.jpg\" height=\"511px\" width=\"980px\">\n                \u003Cdesc>Drawing in Orsi 1900, p. 65 no. 50\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>A\u003C/orig> \u003Cg ref=\"#interpunct\">·\u003C/g> Valeriu\u003Csupplied reason=\"lost\" cert=\"low\">s\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>\u003Cunclear>A\u003C/unclear>\u003C/orig> \u003Cg ref=\"#interpunct\">·\u003C/g> Fabio \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Corig>CE\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>D\u003C/orig> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cspace unit=\"character\" quantity=\"4\"/> \u003Corig>E\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"4\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cw part=\"F\">us\u003C/w> \u003Cg ref=\"#interpunct\">·\u003C/g> esse \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cw part=\"I\">splend\u003C/w>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"5\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Cunclear>praesid\u003C/unclear> \u003Corig>\u003Cunclear>V\u003C/unclear>\u003C/orig>\u003Corig>\u003Cunclear>C\u003C/unclear>\u003C/orig> in\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                 \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text based on Orsi's drawing\u003C/note>\u003C/app>\n                    \u003Capp loc=\"2\">\u003Cnote>Ce[realis] or Ce[ler] or Ce[nsor]?\u003C/note>\u003C/app>\n                \u003Capp loc=\"5\">\u003Cnote>Upper half of the letters only: PRAESI seems clear; whether D, P or R follows is less clear; VC or VS follows; Orsi's drawing hints at extra space after the first I and before the second I, perhaps suggesting presence of an interpunct.\u003C/note>\u003C/app>\n                \u003C/listApp> \n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The text appears never to have been republished since Orsi 1900, and it has not been seen again.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                  \u003Cbibl>\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1900\u003C/date>\n                        \u003CcitedRange>65 no.50\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/UE3VRJA7\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001707\">https://biblio.inscriptiones.org/epig10001707\u003C/ref>\u003C/bibl>\n                  \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
