--\u003C/span>] p̣ṛạẹṣịḍ ṾC̣ in[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"la\">\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]A·VALERIU[.\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>].·FABIO·CE[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]D·&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;E[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan data-text=\"us\">US\u003C/span>·ESSE·\u003Cspan data-text=\"splend\">SPLEND\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>].........IN[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001784_tiled.tif\">\u003Cimg title=\"Drawing in Orsi 1900, p. 65 no. 50\" src=\"ISic001784_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001784.jpg\">\u003Cimg title=\"Drawing in Orsi 1900, p. 65 no. 50\" src=\"ISic001784-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\