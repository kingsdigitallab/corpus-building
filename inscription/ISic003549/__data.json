\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.dedication\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/88.html\">dedication\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-09-06\" who=\"#JP\">Jonathan Prag revised file from publications\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003549_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003549.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"divine\">\u003Cname type=\"epithet\">\u003Cchoice>\u003Corig>Ἀρχηγέτει\u003C/orig>\u003Creg>Ἀρχηγέτηι\u003C/reg>\u003C/choice>\u003C/name> εὐχὴ \u003Cname>Ἡρακλεῖ\u003C/name> \u003Cname type=\"epithet\">Θαλλοφόρῳ\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/> ἱερῷ \u003Cchoice>\u003Corig>εὐαπσεστάτωα\u003C/orig>\u003Creg>εὐαγεστάτῳ\u003C/reg>\u003C/choice> \u003CpersName type=\"attested\">\u003Cname type=\"praenomen\">\u003Csupplied reason=\"omitted\">\u003Cexpan>\u003Cabbr>Λ\u003C/abbr>\u003Cex>ούκιος\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/name> \u003Cname type=\"nomen\">Κορνήλιος\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"praenomen\">\u003Cexpan>\u003Cabbr>Λ\u003C/abbr>\u003Cex>ουκίου\u003C/ex>\u003C/expan>\u003C/name>\n                    \u003Clb n=\"3\"/>\u003Cname type=\"nomen\">Κορνηλίου\u003C/name>\u003C/persName> υἱὸς \u003Corig>ΠΑΝ\u003C/orig> \u003Cname type=\"cognomen\">Τερεντιανὸς\u003C/name>\u003C/persName>\n                    \u003Clb n=\"4\"/>καὶ \u003CpersName type=\"attested\">\u003Cname>Λήμνιος\u003C/name>\u003C/persName> ἀπελεύθερος ἐποίησαν\n                    \u003Clb n=\"5\"/>\u003Corig>\u003Cabbr>Π\u003C/abbr> \u003Cabbr>Π\u003C/abbr>\u003C/orig>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on comparison of Kaibel, Filippi and SEG, prioritising Kaibel's transcription of the manuscript tradition.\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>ΠΑΝ: perhaps for either Γαλ(ερια) Παλ(ατινα) (so Tybout, ap. SEG)\u003C/note>\u003C/app>\n                    \u003Capp loc=\"5\">\u003Cnote>ΠΠ: perhaps for p(ecunia) p(osuit) or p(ropria) p(ecunia) (so Tybout, ap. SEG)\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>As Korhonen lucidly details, the inscription is one of a series of late 18th century local antiquarian forgeries, constructed on the basis of existing texts, principally those to be found in the 1769 first edition of the corpus of Torremuzza. In the specific case of this inscription, De Bernardin noted this already in 2012. Kaibel classed the entire series already as forgeries in IG XIV.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">30*\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>52.0894\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>62.0654\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Filippi\u003C/author>\n                        \u003Cdate>2002\u003C/date>\n                        \u003CcitedRange>73 no. 15/5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/PIPP325H\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001991\">https://biblio.inscriptiones.org/epig10001991\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Filippi\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003CcitedRange>69 no. 15/5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/WBLZEBQ8\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002296\">https://biblio.inscriptiones.org/epig10002296\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Bernardin\u003C/author>\n                        \u003Cdate>2012\u003C/date>\n                        \u003CcitedRange>307-308\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JFJSHRKI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002297\">https://biblio.inscriptiones.org/epig10002297\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2017\u003C/date>\n                        \u003CcitedRange>198\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/92ITYJC6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001484\">https://biblio.inscriptiones.org/epig10001484\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
