\u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic030016_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic030016.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003ChandShift new=\"#h1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Csupplied reason=\"lost\">Μ\u003C/supplied>υσκο̄ν \u003Cg type=\"dipunct\">:\u003C/g> Δάμιος \u003Cg type=\"dipunct\">:\u003C/g> τοῦ Κοβέτου\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Csupplied reason=\"lost\">Ἀνθ\u003C/supplied>εμόκριτος \u003Cg type=\"dipunct\">:\u003C/g> ἐφίετο Ἄπελιν ἐνγυάσασθαι\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cunclear>μ\u003C/unclear>α δὲ ἔφα εἴμειν κατελάζετο το͂ν Λεοντίνο̄ν ξε\n                    \u003Clb n=\"4\" break=\"no\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> Μύσκο̄να \u003Cg type=\"dipunct\">:\u003C/g> ἐν τᾶι πλατείαι θο̄κέοντας \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> ἀργύριον ἔχο̄ν hῖκε βοο͂ν τιμάν οὐκ ἐπρίατο\n                    \u003Clb n=\"5\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cunclear>αι\u003C/unclear> ποτ’ Ἐνπεδοκλε͂ τὸν Μνασιμάχου ποτε̄́νθετο\n                    \u003Clb n=\"6\"/>\u003ChandShift new=\"#h2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>γενέσθο̄ ἐν\u003Csupplied reason=\"lost\">γ\u003C/supplied>υάσασθαι\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Arena 1989 (IGASM I)\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"2\">\n                        \u003Cnote>Miller: Απέ\u003Cunclear>λ\u003C/unclear>\u003Csupplied reason=\"omitted\">λ\u003C/supplied>\u003Cunclear>ι\u003C/unclear>\u003Cdel rend=\"erasure\">ν\u003C/del>ν\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#VM\">\n                \u003Cp>[...] Myskon, son of Damis son of Kobetos [...] Anthemokritos bade Apellis offer security \n                    [...] said [...] was; he came upon [...] of the Leontines [...] Myskon sitting along the avenue [...] \n                    came (not?) having the money, the price of the cattle; he did not buy [...] went to Empedokles, \n                    son of Mnasimachos [...] let [...] become (liable?) to act as surety (trans. by Miller).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#VM\">\n                \u003Cp>[...] Myskon, figlio di Damis figlio di Kobetos [...] Anthemokritos ordinò ad Apelis(?) di agire da garante  \n                    [...] disse [...] era; si imbatté [...] dei Leontini [...] Myskon seduto lungo il viale [...] \n                    venne (non?) avendo il denaro, il prezzo del bestiame; non comprò [...] andò da Empedokles, \n                    figlio di Mnasimachos [...] lasciò che [...] diventasse garante.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>\u003C!-- (in progress) The text appears on the obverse of an opisthographic lamina with a defixio on the reverse (ISic030019, Arena II(2), no. 45). -->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IGASM1\">\n                        \u003Cauthor>Arena\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>77\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VC9IHZAR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000638\">https://biblio.inscriptiones.org/epig10000638\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Miller\u003C/author>\n                        \u003Cdate>1973\u003C/date>\n                        \u003CcitedRange>fig. p. 37\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/INAEX86G\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002516\">https://biblio.inscriptiones.org/epig10002516\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Brugnone\u003C/author>\n                        \u003Cdate>1980-1981\u003C/date>\n                        \u003CcitedRange>437-438\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/86H6PMPS\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001462\">https://biblio.inscriptiones.org/epig10001462\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Van Effenterre and Ruzé\u003C/author>\n                        \u003Cdate>1995\u003C/date>\n                        \u003CcitedRange>228-230 no.63\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/MMGV74CD\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001022\">https://biblio.inscriptiones.org/epig10001022\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
