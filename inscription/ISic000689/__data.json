ag (2018)\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n        \u003Csurface type=\"left\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000689_left_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>Photo J. Prag (2018)\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000689_left.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>Photo J. Prag (2018)\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n        \u003Csurface type=\"right\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000689_right_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>Photo J. Prag (2018)\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000689_right.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>Photo J. Prag (2018)\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n        \u003Csurface type=\"top\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000689_top_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>Photo J. Prag (2018)\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000689_top.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>Photo J. Prag (2018)\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Csupplied reason=\"lost\" cert=\"low\">aditu\u003C/supplied>s \u003Cexpan>\u003Cabbr>\u003Chi rend=\"ligature\">tab\u003C/hi>\u003C/abbr>\u003Cex>ularii\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>civ\u003C/abbr>\u003Cex cert=\"low\">itatis\u003C/ex>\u003C/expan>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text: Manganaro 1989\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Although Manganaro resolved as [?Aditu]s Tab(ularii) civ(itatis), as currently presented here (cf.ANRW 1988, p.38 n.180-181), this should surely be understood as a quarry mark, and requires fresh resolution.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>164 no.17bis fig.17bis\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EZMBJ6GN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001831\">https://biblio.inscriptiones.org/epig10001831\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fasolo\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>89 no.48 fig.68\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/X2SEXMRX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002011\">https://biblio.inscriptiones.org/epig10002011\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
