>\n        \u003Csurface type=\"left\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003647_left_tiled.tif\" height=\"3072px\" width=\"2048px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2006-04-24\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003647_left.jpg\" height=\"3072px\" width=\"2048px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2006-04-24\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Νυμ\n                    \u003Clb n=\"2\" break=\"no\"/>φοι\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>χαῖ\n                    \u003Clb n=\"4\" break=\"no\"/>ρε\n                 \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text from autopsy\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>Nymphoi, farewell\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The form of the name is peculiar, but there appears to a second example from Akrai, in \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001024\">ISic001024\u003C/ref>, line 3 (Νυμφοι Ἱέρωνος). The stone appears never to have been formally published, and there is no clear reference which can be aligned to it in the summary of Scibona on Mistretta in the BTCGI.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
