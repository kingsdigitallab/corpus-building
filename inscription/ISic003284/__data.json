Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-12-22\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003284_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003284.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\"/>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>Α\u003C/orig>\u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>Α\u003C/orig>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/> \u003Cw>\u003Cexpan>\u003Cabbr>κ\u003C/abbr>\u003Cex cert=\"low\">αὶ\u003C/ex>\u003C/expan>\u003C/w> \u003CpersName type=\"attested\">\u003Cname>Κυριακή\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 2\">\u003Cnote>Ferrua, Korhonen: κ(αὶ)\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>… and Kyriake.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>... e Kyriake.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>The fragment is probably part of a Christian epitaph: \u003Cforeign xml:lang=\"grc\">Κυριακή\u003C/foreign> must have been the name of the deceased (perhaps not the only one mentioned in the epitaph if \u003Cforeign xml:lang=\"grc\">κ\u003C/foreign> is an abbreviation for \u003Cforeign xml:lang=\"grc\">καί\u003C/foreign> as in IMusCatania 167 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001648\">ISic001648\u003C/ref>) and not the indication of the day of Sunday (\u003Cforeign xml:lang=\"grc\">κυριακὴ [ἡμήρα]\u003C/foreign>), as Ferrua believed. This is the only occurrence of this name in Catania, whereas it is more widespread in Christian inscriptions from Syracuse (see LGPN 3A: 262).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>180\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1931\u003C/date>\n                        \u003CcitedRange>43 no.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/T67M4XMU\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001870\">https://biblio.inscriptiones.org/epig10001870\u003C/ref>\u003C/bibl>\n\t       \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1981\u003C/date>\n                        \u003CcitedRange>93 no.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZJ65DX74\"/>\n\t       \u003Cref target=\"https://biblio.inscriptiones.org/epig10001863\">https://biblio.inscriptiones.org/epig10001863\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1931\u003C/date>\n                        \u003CcitedRange>370 no.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n\t       \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1981\u003C/date>\n                        \u003CcitedRange>113 no.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZJ65DX74\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001863\">https://biblio.inscriptiones.org/epig10001863\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>110 no.420\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/759ZXHKQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001995\">https://biblio.inscriptiones.org/epig10001995\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1938\u003C/date>\n                        \u003CcitedRange>70\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/BPRRV8SB\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002004\">https://biblio.inscriptiones.org/epig10002004\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
