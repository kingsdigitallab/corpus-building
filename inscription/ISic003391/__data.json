surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\" xml:id=\"DnKAK\"/>\u003CpersName type=\"attested\">\u003Cname type=\"praenomen\">\u003Cw xml:id=\"DnKAU\" n=\"5\">Γναΐου\u003C/w>\u003C/name> \u003Cname type=\"nomen\">\u003Cw xml:id=\"DnKAe\" n=\"10\">Μοδίου\u003C/w>\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text from autopsy\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>(House of) Gnaius Modius\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Archaeologically, the 'baths of Cnaius Modius' (so called because of this inscription at the entrance) should be dated to the first century BC (so Tréziny 2018: 274), not the third-century BC as discussed in Torelli 2007\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>2007.0671\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>59.1107\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>26.1102\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1975\u003C/date>\n                        \u003CcitedRange>152 no.18 tav.34.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/UUNP76BF\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001772\">https://biblio.inscriptiones.org/epig10001772\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Torelli\u003C/author>\n                        \u003Cdate>2007\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/B35EFD2T\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001558\">https://biblio.inscriptiones.org/epig10001558\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Tréziny\u003C/author>\n                        \u003Cdate>2018\u003C/date>\n                        \u003CcitedRange>273-274\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/5UHWUE4K\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002599\">https://biblio.inscriptiones.org/epig10002599\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
