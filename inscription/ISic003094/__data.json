pe=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Ferrua proposes restoration including hemerai Selenes; two poss. cos. restorations, both later C4.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>36.0865\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1982-1983\u003C/date>\n                        \u003CcitedRange>6 no.12 fig.1d\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q7DDNWD6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001996\">https://biblio.inscriptiones.org/epig10001996\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1895\u003C/date>\n                        \u003CcitedRange>520 no.266\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/M7C8KM46\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001714\">https://biblio.inscriptiones.org/epig10001714\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1946-1947\u003C/date>\n                        \u003CcitedRange>231 no.6\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9TZ8AM