 Prag\u003C/desc>\n              \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n              \u003Cdiv type=\"edition\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Σώσι\u003C/name> \u003Cname>Νύμφων\u003C/name>\n                    \u003Clb n=\"2\"/>\u003Cname>Κραφάγε\u003C/name>\u003C/persName> χαῖρε\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text from autopsy\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Sosis Nymphon 'the meat-eater', farewell!\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>SEG 37.763 reports the observation of Masson that Κραφάγε should be an epithet, meaning 'eater of meat'. Νύμφων is either the patronymic (in which case the genitive ending has either been omitted, or the right edge of the stone was trimmed for re-use in the church wall), or else a second name in the Sicilian fashion, with Κραφάγε then an additional epithet.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">351\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>58.1045\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>37.0763\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5593\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1965\u003C/date>\n                        \u003CcitedRange>200 tav. 72.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RGTHAFKT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001841\">https://biblio.inscriptiones.org/epig10001841\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Tullio\u003C/author>\n                        \u003Cdate>1974\u003C/date>\n                        \u003CcitedRange>131 n. 70\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/QRB9I8X3\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002336\">https://biblio.inscriptiones.org/epig10002336\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Arena\u003C/author>\n                        \u003Cdate>1987\u003C/date>\n                        \u003CcitedRange>14-15\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/DMCKW4KJ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002335\">https://biblio.inscriptiones.org/epig10002335\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Montalbano\u003C/author>\n                        \u003Cdate>2008\u003C/date>\n                        \u003CcitedRange>177 VS 4 tav. 33.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/N8BEV89J\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001740\">https://biblio.inscriptiones.org/epig10001740\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Brugnone\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003CcitedRange>849\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZDDSRBHN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002116\">https://biblio.inscriptiones.org/epig10002116\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
