             \u003Cchange when=\"2024-09-24\" who=\"#JP\">Jonathan Prag added pilot bilingualism annotation\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001307_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001307.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cforeign xml:lang=\"la\">\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g>\u003C/foreign>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Κλωδία\u003C/name> \u003Cname>Βαλεντεῖνα\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>χαῖρε \u003Cexpan>\u003Cabbr>ἔζη\u003C/abbr>\u003Cex>σεν\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>ἔ\u003C/abbr>\u003Cex>τη\u003C/ex>\u003C/expan> \u003Cnum value=\"40\">\u003Cforeign xml:lang=\"la\">XXXX\u003C/foreign>\u003C/num>\n                    \u003Clb n=\"4\"/>ἐποίησε ἰδίᾳ γυναι\n                    \u003Clb n=\"5\" break=\"no\"/>κὶ \u003CpersName type=\"attested\">\u003Cname>Ἰγνᾶτις\u003C/name> \u003Cname>Κάρικος\u003C/name>\u003C/persName>\n                    \u003Clb n=\"6\"/>\u003Cexpan>\u003Cabbr>μνή\u003C/abbr>\u003Cex>μης\u003C/ex>\u003C/expan> χάριν\n                    \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Kaibel in IG\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Sacred to the spirits of the underworld. Klodia Balenteina, farewell. She lived 40 years. Ignatis Karikos made this for his own wife, for the sake of her memory.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>The text is distinctive for a number of features illustrating linguistic interference from Latin: the use of the Latin abbreviated header DMS (with interpuncts according to the transcriptions, not used in the rest of the text); the use of Latin numerals in line 3; the use of abbreviations both for \u003Cforeign xml:lang=\"grc\">ἔζη(σεν) ἔ(τη)\u003C/foreign> and \u003Cforeign xml:lang=\"grc\">μνή(μης) χάριν\u003C/foreign>. The unusual structure of the text (and use of χαῖρε which is not generally attested at Catania) further marks it out as distinctive, and Korhonen emphasises its extra-urban provenance.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrara\u003C/author>\n                        \u003Cdate>1829\u003C/date>\n                        \u003CcitedRange>387 no.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/82T4IWDN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002005\">https://biblio.inscriptiones.org/epig10002005\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">484\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5396\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2004\u003C/date>\n                        \u003CcitedRange>249\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/NMS48IZF\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001897\">https://biblio.inscriptiones.org/epig10001897\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
