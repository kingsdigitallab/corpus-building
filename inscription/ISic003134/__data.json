  \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\" source=\"https://www.zotero.org/groups/382445/items/DT8J5F5A\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#staurogram\" n=\"5\">𐆠\u003C/g> \u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"10\">Θεόκτιστος\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"15\">ναύκλη\n                    \u003Clb n=\"2\" break=\"no\"/>ρος\u003C/w> \u003CplaceName type=\"ethnic\">\u003Cw n=\"20\">Λύκιος\u003C/w>\u003C/placeName> \u003Corig n=\"25\">ΚΟΛΛΥ\u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\" n=\"30\"/>ϹΑ\u003C/orig>\n                    \u003Clb n=\"3\"/>\u003Corig n=\"35\">ΔΟΝΑΔ\u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\" n=\"40\"/>Φ\u003C/orig> \u003Cg ref=\"#staurogram\" n=\"45\">𐆠\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cw n=\"10\" lemma=\"Θεόκτιστος\">Θεόκτιστος\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ναύκληρος\">ναύκληρος\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"Λύκιος\">Λύκιος\u003C/w>\n                    \u003Corig n=\"25\">ΚΟΛΛΥϹΑ\u003C/orig>\n                    \u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\" n=\"30\">\u003Cdesc>[.]\u003C/desc>\u003C/gap>ϹΑ\n                    \u003Corig n=\"35\">ΔΟΝΑΔΦ\u003C/orig>\n                    \u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\" n=\"40\">\u003Cdesc>[.]\u003C/desc>\u003C/gap>Φ\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Agnello 1955\u003C/note>\n                    \u003C/app>\n                    \u003Cap