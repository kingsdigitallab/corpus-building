{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":103,"html":214,"xml":259},"ISic003988",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":18,"type":19,"support":23,"objectType":31,"material":35,"condition":40,"dimensions":42,"layoutDesc":53,"handNote":61,"date":75,"places":76,"geo":86,"country":81,"provenance":78,"provenanceFound":90,"provenanceGeo":98,"provenanceObserved":99,"provenanceLost":18,"graphics":103,"region":111,"settlement":83,"repository":112,"idno":126,"textLang":129,"bibliographyEdition":133,"bibliographyDiscussion":159,"citation":162,"tmNumber":143,"facsimile":191,"letterHeights":192,"publications":196,"zotero":199,"keywords":202,"lettering_types":213},"I.Sicily inscription 003988",{"_":5},"draft",[7,9,11,13,15],{"type":8},"TM",{"type":10},"EDR",{"type":12},"EDH",{"type":14},"EDCS",{"_":16,"type":17},"334476","PHI",null,{"_":20,"ana":21,"ref":22},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",[24,25,26,27],"Large stele with poorly polished surfaces, rougher on the back; missing corner on the left","The slab bears two distinct inscriptions on the front, relating to two different phases of use: the first (a) placed in the upper part, the second (b) on a projecting band at the base of the same face. Here is the text of (a)","The surface of the upper part of the front face shows clear traces of gradine work and seems to have been lowered with respect to the original surface, probably to erase an older text and to engrave the inscription (a). This could therefore be attributed to the reused of the slab as a funerary stele. The inscription (b) should instead belong to a first use of the stone; the position at the lower end of the forehead leads us to believe that the slab was originally not a stele – in which case the base would have been buried – but a slab covering an unidentifiable struture (funerary monument? enclosure?)",{"_":28,"ref":29},"On same support as ",{"_":30,"sameAs":30},"ISic004283",{"_":32,"ana":33,"ref":34},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":36,"type":37,"subtype":38,"ref":39},"volcanic (pietra di Fuardo)","stone.volcanic","unverified","http://www.eagle-network.eu/voc/material/lod/28.html",{"ana":41},"#condition.damaged",[43,47,50],{"_":44,"unit":45,"dimension":46},"108","cm","height",{"_":48,"unit":45,"dimension":49},"42.5","width",{"_":51,"unit":45,"dimension":52},"14","depth",{"layout":54},{"rs":55,"damage":59},{"_":56,"ana":57,"ref":58},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":60},"#text_condition.complete",{"dimensions":62},[63,71],{"type":64,"l":65,"from":66,"to":66,"h":67,"unit":68,"atLeast":69,"atMost":70},"letterHeight","Line 1","line1","35-70","mm","35","70",{"type":72,"l":73,"from":66,"to":74,"unit":68},"interlinear","Interlineation line 1 to 2","line2",{"notBefore":18,"notAfter":18},[77,82],{"_":78,"type":79,"ref":80,"region":81},"Lipara","ancient","http://pleiades.stoa.org/places/462283","Sicilia",{"_":83,"type":84,"ref":85,"region":81},"Lipari","modern","http://sws.geonames.org/2524378",[87],[88,89],38.48333,14.93333,{"_":91,"type":92,"subtype":93,"when":94,"geo":95},"Discovered in 1971 during the excavation of trench XXXI, face O (Bishop's property). It was reused in masonry tomb no. 1225 (dated to the 2nd century CE)","found","discovered","1971",[96,97],38.46713,14.953871,[96,97],{"_":100,"type":101,"subtype":102,"geo":18},"None","observed","autopsied",[104],{"n":105,"url":106,"height":107,"width":108,"desc":109,"surfaceType":110},"screen","ISic003988_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":113,"role":114,"ref":115,"museum":116},"Museo Archeologico Regionale Eoliano \"Luigi Bernab� Brea\"","museum","http://sicily.classics.ox.ac.uk/museum/048",{"slug":117,"type":114,"name":113,"uri":115,"description":118,"location":119},"048","The enormous collection is displayed in several neighbouring buildings, each with a particular focus: Prehistory, Prehistory of the minor islands, Epigraphy, Geology, the Classical period and later. The finds come from across the Aeolian islands, under the sea that surrounds them, and from the site of Milazzo on Sicily. One of the 3 largest Sicilian collections, it is truly comprehensive in scope and contains a few finds (e.g. the terracotta tragic theatre masks) that are near unique",{"settlement":83,"region":120,"country":121,"address":122,"geo":123},"Messina","Italy","Via del Castello, 98055 Lipari (ME)",{"lat":124,"lon":125},38.46719,14.957314,{"_":127,"type":128},"11632","inventory",{"_":130,"mainLang":131,"languages":132},"Ancient Greek","grc",[130],{"type":134,"bibl":135},"edition",[136,148,18],{"type":137,"n":138,"citedRange":139,"ptr":140,"ref":141,"title":142,"author":143,"date":144,"citation":145,"uri":146,"year":147},"bulletin","SEG","51.1273",{"target":141},"https://www.zotero.org/groups/382445/items/F2GG87EQ","Supplementum epigraphicum graecum","","1923-","\u003Cspan>‘Supplementum Epigraphicum Graecum’, \u003Ci>Supplementum Epigraphicum Graecum\u003C/i>, 1923, \u003Ca href=\"http://www.worldcat.org/oclc/1607583\">http://www.worldcat.org/oclc/1607583\u003C/a>\u003C/span>","https://www.zotero.org/groups/isicily/items/F2GG87EQ","1923",{"type":149,"n":150,"author":151,"date":152,"citedRange":153,"ptr":154,"ref":155,"inscriptionDate":152,"title":156,"citation":157,"uri":158,"year":152},"corpus","ILipara","Bernabò Brea, Cavalier, Campagna","2003","373",{"target":155},"https://www.zotero.org/groups/382445/items/VDAQH5D2","Meligunìs Lipára. XII. Le iscrizioni lapidarie greche e latine delle isole eolie","\u003Cspan>L. Bernabò Brea, M. Cavalier, e L. Campagna, \u003Ci>Meligunìs Lipára. XII. Le iscrizioni lapidarie grec