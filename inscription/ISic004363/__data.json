627px\" width=\"2245px\">\n                \u003Cdesc>Photo J. Prag, 2014-09-11, by permission of Museo Archeologico Regionale Paolo Orsi\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"screen\" url=\"ISic004363_rear.jpg\" height=\"2627px\" width=\"2245px\">\n                \u003Cdesc>Photo J. Prag, 2014-09-11, by permission of Museo Archeologico Regionale Paolo Orsi\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Εὐκαρπί\u003Csupplied reason=\"lost\">α\u003C/supplied>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>χρηστ\u003Csupplied reason=\"lost\">ὰ\u003C/supplied>\n                    \u003Clb n=\"3\"/>χαῖρ\u003Csupplied reason=\"lost\">ε\u003C/supplied>\n                    \u003Clb n=\"4\"/>ἔζη\u003Cunclear>σ\u003C/unclear>\u003Csupplied reason=\"lost\">ες\u003C/supplied>\n                    \u003Clb n=\"5\"/>ἔτη \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\">\u003Cdesc>age\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div> \n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text based on autopsy\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Farewell worthy Eukarpia, you lived [--] years\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Other Greek funerary texts from Centuripe, such ISic001397 suggest that \u003Cforeign xml:lang=\"grc\">ἔζησες\u003C/foreign>is most likely in line 4.\u003C/p>\n            \u003C/div>\n           