/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000325_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000325.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#GC\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw n=\"5\">\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"10\">·\u003C/g> \u003Cw n=\"15\">\u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"20\">·\u003C/g> \u003Cw n=\"25\">\u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan>\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"30\">Gallicano\u003C/w>\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\" n=\"35\">·\u003C/g> \u003Cw n=\"40\">fi\n                    \u003Clb n=\"3\" break=\"no\"/>delissimo\u003C/w> \u003Cg ref=\"#interpunct\" n=\"45\">·\u003C/g> \u003Cw n=\"50\">qui\u003C/w> \u003Cw n=\"55\">fuit\u003C/w> \u003Cg ref=\"#interpunct\" n=\"60\">·\u003C/g> \u003Cw n=\"65\">vi\n                    \u003Clb n=\"4\" break=\"no\"/>licus\u003C/w> \u003Cg ref=\"#interpunct\" n=\"70\">·\u003C/g> \u003CplaceName type=\"ancient\">\u003Cw n=\"75\">Afinianis\u003C/w>\u003C/placeName>\n                    \u003Clb n=\"5\"/>\u003Cw n=\"80\">\u003Cexpan>\u003Cabbr>vix\u003C/abbr>\u003Cex>it\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"85\">·\u003C/g> \u003Cw n=\"90\">\u003Cexpan>\u003Cabbr>ann\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan>\u003C/w> \u003Cnum value=\"45\">\u003Cw n=\"95\">XLV\u003C/w>\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"dis\">Dis\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"manes\">Manibus\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"sacrum\">Sacrum\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"Gallicanus\">Gallicano\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"fidelis\">fidelissimo\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"qui\">qui\u003C/w>\n                    \u003Cw n=\"55\" lemma=\"sum\">fuit\u003C/w>\n                    \u003Cw n=\"65\" lemma=\"vilicus\">vilicus\u003C/w>\n                    \u003Cw n=\"75\" lemma=\"Afiniana\">Afinianis\u003C/w>\n                    \u003Cw n=\"80\" lemma=\"vivo\">vixit\u003C/w>\n                    \u003Cw n=\"90\" lemma=\"annus\">annis\u003C/w>\n                    \u003Cw n=\"95\" lemma=\"XLV\">XLV\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Unedited text of CIL\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#GC\">\n                \u003Cp>Sacred to the spirits of the dead. To the very loyal Gallicano, who was estate manager at Afiniana. He lived for 45 years.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#GC\">\n                \u003Cp>Sacro agli spiriti dei defunti. Al fedelissimo Gallicano, che fu sovrintendente ad Afiniana. Visse per 45 anni.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7041\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>30 tav.7.12\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
