{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":101,"html":205,"xml":251},"ISic001494",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":31,"condition":37,"dimensions":39,"layoutDesc":50,"handNote":59,"date":73,"places":78,"geo":88,"country":83,"provenance":80,"provenanceFound":92,"provenanceGeo":96,"provenanceObserved":97,"provenanceLost":20,"graphics":101,"region":109,"settlement":85,"repository":110,"idno":123,"textLang":126,"bibliographyEdition":130,"bibliographyDiscussion":156,"citation":159,"tmNumber":8,"facsimile":184,"letterHeights":185,"publications":188,"zotero":191,"keywords":194,"lettering_types":204},"I.Sicily inscription 001494",{"_":5},"draft",[7,10,12,14,17],{"_":8,"type":9},"493875","TM",{"type":11},"EDR",{"type":13},"EDH",{"_":15,"type":16},"38200026","EDCS",{"_":18,"type":19},"313672","PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","Part of a marble stele (or plaque), intact on left and right, but broken above and below (although as Ferrua notes, probably not much is lost below, one line at most). Mouldings are preserved on left and right. Bitto suggests that the stone is an architectural piece in reuse already in antiquity for the inscription, but this is based upon the poor fitting of the text to the borders alone, which is not a sufficient argument.",{"_":27,"ana":28,"ref":29,"cert":30},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250.html","low",{"_":32,"ana":33,"type":34,"subtype":35,"ref":36},"marble","#material.inorganic.stone.metamorphic_rock.marble","stone.marble","unverified","http://www.eagle-network.eu/voc/material/lod/48.html",{"ana":38},"#condition.fragment",[40,44,47],{"_":41,"unit":42,"dimension":43},"20","cm","height",{"_":45,"unit":42,"dimension":46},"28","width",{"_":48,"unit":42,"dimension":49},"10","depth",{"layout":51},{"p":52,"rs":53,"damage":57},"Remains of five lines of text, poorly fitted to the width of the stone, overlapping the right border repeatedly.",{"_":54,"ana":55,"ref":56},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":58},"#text_condition.incomplete",{"lettering":60,"dimensions":61},"Lunate epsilon and sigma.",[62,69],{"type":63,"l":64,"from":65,"to":66,"h":67,"unit":68,"atLeast":67,"atMost":67},"letterHeight","Line 2-4","line2","line4","40","mm",{"type":70,"l":71,"from":72,"to":65,"unit":68},"interlinear","Interlineation line 1 to 2","line1",{"_":74,"notBefore":75,"notAfter":76,"evidence":77},"First half of 4th century CE (Ferrua)",301,350,"lettering",[79,84],{"_":80,"type":81,"ref":82,"region":83},"Messana","ancient","http://pleiades.stoa.org/places/462538","Sicilia",{"_":85,"type":86,"ref":87,"region":83},"Messina","modern","http://sws.geonames.org/2524170",[89],[90,91],38.19394,15.55256,{"_":93,"type":94,"subtype":95,"geo":20},"Chiesa della Cattolica, Messina","found","discovered",[],{"_":98,"type":99,"subtype":100,"geo":20},"None","observed","autopsied",[102],{"n":103,"url":104,"height":105,"width":106,"desc":107,"surfaceType":108},"screen","ISic001494_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":111,"role":112,"ref":113,"museum":114},"Museo regionale interdisciplinare di Messina","museum","http://sicily.classics.ox.ac.uk/museum/147",{"slug":115,"type":112,"name":111,"uri":113,"description":116,"location":117},"147","The collection is focused on finds made within the city of Messina itself (the warship ram from Acqualadroni being one of the only notable exceptions). Beginning with the prehistoric periods (a single case) it progresses through the different areas and periods of the city, focusing at the end on the sculpture and inscriptions. The accompanying boards set the objects into a clear historical context. One of the highlights of the collection is the aforementioned warship ram. Two other objects given prominence are two of the four Oscan inscriptions in the collection, from the time of Mamertine domination. The principle display cases focus on the cemeteries and religious areas of the city. The grounds of the museum contain a number of monuments and architectural pieces (many from the post-medieval city that was destroyed in the 1908 earthquake) but some earlier as well, principally Roman in date",{"settlement":85,"region":85,"country":118,"address":119,"geo":120},"Italy","Viale della Liberta 465, Messina",{"lat":121,"lon":122},38.2166927,15.5639472,{"_":124,"type":125},"A3565","inventory",{"_":127,"mainLang":128,"languages":129},"Ancient Greek","grc",[127],{"type":131,"bibl":132},"edition",[133,144],{"author":134,"date":135,"citedRange":136,"ptr":137,"ref":139,"inscriptionDate":135,"title":141,"citation":142,"uri":143,"year":135},"Ferrua","1941","254 no.3",{"target":138},"https://www.zotero.org/groups/382445/items/P7QQ9SB6",{"_":140,"target":140},"https://biblio.inscriptiones.org/epig10002655","Analecta sicula","\u003Cspan>Antonio Ferrua, «Analecta sicula», \u003Ci>Epigraphica\u003C/i> 3 (1941): 252–70\u003C/span>","https://www.zotero.org/groups/isicily/items/P7QQ9SB6",{"type":145,"n":146,"author":147,"date":148,"citedRange":67,"ptr":149,"ref":151,"inscriptionDate":148,"title":153,"citation":154,"uri":155,"year":148},"corpus","IMusMessina","Bitto","2001",{"target":150},"https://www.zotero.org/groups/382445/items/M9HMEP2R",{"_":152,"target":152},"https://biblio.inscriptiones.org/epig10000029","Le iscrizioni greche e latine di Messina","\u003Cspan>Irma Bitto, \u003Ci>Le iscrizioni greche e latine di Messina\u003C/i>, vol. 1, Pelorias 7 (Messina: Dipartimento di Scienze dell’Antichità dell’Università degli Studi di Messina, 2001)\u003C/span>","https://www.zotero.or