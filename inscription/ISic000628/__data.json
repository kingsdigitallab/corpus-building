Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\" source=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Abdalas\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CpersName type=\"attested\">\u003Cname>Domi\n                    \u003Clb n=\"3\" break=\"no\"/>tiae\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CpersName type=\"attested\">\u003Cname>Domi\u003Chi rend=\"tall\">t\u003C/hi>iani\u003C/name>\u003C/persName>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"4\"/>magis\u003Chi rend=\"tall\">t\u003C/hi>er \u003Cg ref=\"#interpunct\">·\u003C/g> magnus\n                    \u003Clb n=\"5\"/>ovium qui \u003Cg ref=\"#interpunct\">·\u003C/g> bene \u003Cg ref=\"#interpunct\">·\u003C/g> vix(it)\n                    \u003Clb n=\"6\"/>in officio \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>ann\u003C/abbr>\u003Cex>os\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cnum value=\"80\">LXXX\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text from photograph\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lan