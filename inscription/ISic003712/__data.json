voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.basin\" ref=\"https://www.eagle-network.eu/voc/objtyp/lod/144.html\">basin\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">3.8-4\u003C/height>\n                                        \u003Cwidth unit=\"cm\">20\u003C/width>\n                                        \u003Cdepth unit=\"cm\">13\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Cp>Greek letters fill the height of the rim in a single line\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                    \u003Cdamage ana=\"#text_condition.incomplete\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>Neat, regular deeply incised letters with pronounced terminations to the strokes and a broad module. Alpha has straight bar; epsilon has slightly shorter middle bar.\u003C/p>\n                                \u003Cp>\n                                    Types list:\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Α-type1.html\">Α type1\u003C/ref>\n                                    \u003Cref target=\"https://kingsdigitallab.github.io/crossreads/data/allograph