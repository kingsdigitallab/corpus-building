C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.dedication\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Dedication\">dedication\u003Ccertainty locus=\"value\" match=\"../@ana\" assertedValue=\"#function.funerary\">\u003Cdesc>possibly funerary\u003C/desc>\u003C/certainty>\u003C/term>\n                   \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-02-22\" who=\"#VM\">Valentina Mignosa encoded text division, cleaned up the autogenerated text and checked the edition\u003C/change>\n                \u003Cchange when=\"2023-07-06\" who=\"#VM\">Valentina Mignosa added name tokenisation\u003C/change>\n                \u003Cchange when=\"2025-04-24\" who=\"#SS\">added letterform types to handNote\u003C/change>\n                \u003Cchange when=\"2025-10-15\" who=\"#RC\">Robert Crellin added local IDs to edition elements\u003C/change>\n                \u003Cchange when=\"2026-02-02\" who=\"#RG\">tagged names and persons\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001483_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001483.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\" xml:id=\"BweAK\"/>\u003CpersName type=\"attested\" xml:id=\"BweAU\">\u003Cname xml:id=\"BweAe\">\u003Csupplied reason=\"lost\" xml:id=\"BweAo\">Κ\u003C/supplied>υναίθο̄\u003C/name> \u003Cw xml:id=\"BweAy\" n=\"5\">ε̄̓μὶ\u003C/w> \u003Cw xml:id=\"BweAΙ\" n=\"10\">τὸ\u003C/w>\n                    \u003Clb n=\"2\" xml:id=\"BweAΤ\"/>\u003Cw xml:id=\"BweAε\" n=\"15\">\u003Csupplied reason=\"lost\" xml:id=\"BweAο\">ἄγαλ\u003C/supplied>μα\u003C/w> \u003Cw xml:id=\"BweBA\" n=\"20\">το͂\u003C/w> \u003CpersName type=\"attested\">\u003Cname type=\"patronymic\" xml:id=\"BweBK\">Ἐπόχο̄\u003C/name>\u003C/persName>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Arena 1992 (IGASM II)\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Dubois would propose σᾶμα in line 2, rather than e.g. ἄγαλμα, and so make this a funerary inscription rather than a dedication.\u003C!--commented out pending revision-->\n                    \u003C!--base, surmounted by a large rim; re-used in wall of Timoleontic period, on N.side of Acropolis; text reads, 'I am the monument of Kunaithos, son of Epochos.' However, poss. restoration is I am the dedication of....-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>61.0742\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>19.0609\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                        \u003Cauthor>Dubois\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\">129\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RWXNUFEX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Guarducci\u003C/author>\n                        \u003Cdate>1959-1960\u003C/date>\n                        \u003CcitedRange>270 fig.14\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GPUF5NUH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001928\">https://biblio.inscriptiones.org/epig10001928\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGASM2\">\n                        \u003CcitedRange>no.5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/CNP5CJ7G\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000639\">https://biblio.inscriptiones.org/epig10000639\u003C/ref>\n     