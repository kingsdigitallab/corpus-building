.uk/inscription/ISic004234\">ISic004234\u003C/ref>) and just outside Syracuse (\u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic000825\">ISic000825\u003C/ref>)\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Bacci et al.\u003C/author>\n                        \u003Cdate>2015\u003C/date>\n                        \u003CcitedRange>163 and fig.84\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ILQ4RQGU\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002593\">https://biblio.inscriptiones.org/epig10002593\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Sofia\u003C/author>\n                        \u003Cdate>2015\u003C/date>\n                        \u003CcitedRange>116 fig.121\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/9QTE4E3Z\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001575\">https://biblio.inscriptiones.org/epig10001575\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Sofia\u003C/author>\n                        \u003Cdate>2018\u003C/date>\n                        \u003CcitedRange>107 no.2 and fig.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JQQKI6JP\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001574\">https://biblio.inscriptiones.org/epig10001574\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
