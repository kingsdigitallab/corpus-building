λικία\u003C/w>\u003C/name>\n                    \u003Clb n=\"3\"/>\u003Cname>\u003Cw n=\"20\">Μέλλουσα\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"25\">ἔζησεν\u003C/w>\n                    \u003Clb n=\"5\"/>\u003Cw n=\"30\">ἔτη\u003C/w> \u003Cnum value=\"14\">\u003Cforeign xml:lang=\"la\">\u003Cw n=\"35\">XIIII\u003C/w>\u003C/foreign>\u003C/num>\n                    \u003Clb n=\"6\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"θεός\">Θεοῖς\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"καταχθόνιος\">καταχθονίοις\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"Σειλικία\">Σειλικία\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"Μέλλουσα\">Μέλλουσα\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"ζάω\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"XIIII\">XIIII\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#MH\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text according to Kaibel in IG\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"1\">\n                        \u003Cnote>Gualtherus: ΚΥ\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" resp=\"#MH\">\n                \u003Cp>To the gods of the Underworld. Seilikia Mellousa lived 14 years.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Th, KX as header; Seilikia Mellousa, age in years. NB, the number of years is given in Roman nume