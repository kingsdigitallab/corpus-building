mage":102,"thumb":262,"title":105},"ISic004373_tiled-thumb.tif",{"image":264,"thumb":265,"title":105},"ISic004373.jpg","ISic004373-thumb.jpg",[267],{"html":268},"The letters are well cut in a relatively refined v-cut, with modest serifs. The letters are tend towards the tall and narrow and are very regular and evenly spaced. P and R are open, O is somewhat ovoid, E has bars of equal length, D is quite full, the diagonal of the N does not always start from the top of the first hasta. Interpuncts are not consistently used, with one elegant example in line 2","\u003C?xml version='1.0' encoding='UTF-8'?>\n\u003C?xml-model href=\"https://epidoc.stoa.org/schema/latest/tei-epidoc.rng\" type=\"application/xml\" schematypens=\"http://relaxng.org/ns/structure/1.0\"?>\n\u003C?xml-model href=\"../schematron/ircyr-checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XInclude\" xml:lang=\"en\">\n    \u003CteiHeader>\n        \u003CfileDesc>\n            \u003CtitleStmt>\n                \u003Ctitle>Dedication by a curator of the res publica Liparitanorum\u003C/title>\n                \u003Ceditor ref=\"#JP\">Jonathan Prag\u003C/editor>\n                \u003Cprincipal ref=\"#GV\">Giulio Vallarino\u003C/principal>\n                \u003Cfunder>John Fell OUP Research Fund\u003C/funder>\n\t   \u003Cfunder>\u003Cref target=\"https://cordis.europa.eu/project/id/885040\">ERC Advanced Grant no.885040\u003C/ref>\u003C/funder>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>original data collection and editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"GV\">Giulio Vallarino\u003C/name>\n                    \u003Cresp>Original research and publication\u003C/resp>\n                \u003C/respStmt>\n\t    \u003CrespStmt>\n     \t       \u003Cname xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n     \t       \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n \t   \u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic004373\u003C/idno>\n                \u003Cidno type=\"TM\"/>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\"/>\n                \u003Cidno type=\"PHI\"/>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic004373\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-21\">10.5281/zenodo.4381828\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\n                    \u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Agrigento\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/130\">Museo Regionale Archeologico Pietro Griffo\u003C/repository>\n                        \u003Cidno type=\"inventory\"/>\u003C!-- no inv nr yet assigned? -->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"la\">Latin\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>A polished slab of white marble, broken into six joining fragments, with only the left margin partially preserved.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.marble\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/259\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\u003C!-- measurements of GV -->\n                                        \u003Cheight unit=\"cm\">50.5\u003C/height>\n                                        \u003Cwidth unit=\"cm\">48\u003C/width>\n                                        \u003Cdepth unit=\"cm\">3\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Cp>The remains of six evenly spaced lines of Latin letters are preserved, with a regular left margin; the right margin is not preserved for any line\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>The letters are well cut in a relatively refined v-cut, with modest serifs. The letters are tend towards the tall and narrow and are very regular and evenly spaced.  P and R are open, O is somewhat ovoid, E has bars of equal length, D is quite full, the diagonal of the N does not always start from the top of the first hasta. Interpuncts are not consistently used, with one elegant example in line 2\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line6\">Lines 1-6\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"72\" atMost=\"72\">72\u003C/height>\u003C!-- Vallarino -->\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Line 1-2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\">not measured\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462086\">Agrigentum\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/6541860\">Agrigento\u003C/placeName>\n                            \t\u003Cgeo>37.32084, 13.58876\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0151\" notAfter-custom=\"0300\" evidence=\"lettering\">later 2nd or 3rd century CE (Vallarino on palaeographic grounds)\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"2015\">Found in secondary deposition during excavations in the summer of 2015: in a substantial stratum of waste material (US2211), dateable to the C4 CE, in a trench to the north of the 'West stenopos' in the western part of the area of the 'Hellenistic-Roman temple'\u003Cgeo>37.298238, 13.589125\u003C/geo>\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" resp=\"#GV\">2016 (Vallarino)\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/lang