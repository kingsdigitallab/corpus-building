003C/xi:include>         \n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.tessera.civic\" ref=\"https://www.eagle-network.eu/voc/typeins/lod/130.html\">tessera (civic)\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2022-01-19\" who=\"#VM\">Valentina Mignosa added metadata and text\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic030269_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic030269.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"a\">\n                    \u003Cab>\n                        \u003Cmilestone unit=\"face\" n=\"a\"/>\n                        \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Δαμέ\u003Csupplied reason=\"lost\">ας\u003C/supplied>\u003C/name>\n                        \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cchoice>\u003Creg>Ἐπιστά\u003Csupplied reason=\"lost\">σιος\u003C/supplied>\u003C/reg>\u003Corig>Ἐπισστά\u003Csupplied reason=\"lost\">σιος\u003C/supplied>\u003C/orig>\u003C/choice>\u003C/name>\u003C/persName>\u003C/persName>\n                        \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Cnum atLeast=\"4\" atMost=\"14\">τε\u003Cunclear>τ\u003C/unclear>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/num>\n                    \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"b\">\n                    \u003Cab>\n                        \u003Cmilestone unit=\"face\" n=\"b\"/>\n                        \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Δ\u003Cunclear>αμ\u003C/unclear>έ\u003Csupplied reason=\"lost\">ας\u003C/supplied>\u003C/name>\u003C/persName>\n                    \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Cordano 1992\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>This document is one of a large deposit (c. 150) of lead tesserae found in a storeroom of Athena's sanctuary at the archaeological site of Kamarina.\n                        The occurrence of the same name on both faces a and b would suggest, according to the editor, a double use of the lamina by the same person. \n                        However, it is worth noting that the name is integrated on both faces.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Cordano\u003C/author>\n                        \u003Cdate>1992\u003C/date>\n                        \u003CcitedRange>142\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/XTMUJ38N\"/> \n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002437\">https://biblio.inscriptiones.org/epig10002437\u003C/ref>\u003C/bibl>\n           