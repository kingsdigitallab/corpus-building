twork.eu/voc/writing/lod/1",{"ana":53},"#text_condition.incomplete",{"dimensions":55},[56,65],{"type":57,"l":58,"from":59,"to":60,"h":61,"unit":62,"atLeast":63,"atMost":64},"letterHeight","Lines 1-4","line1","line4","55-65","mm","55","65",{"type":66,"l":67,"from":59,"to":68,"unit":62},"interlinear","Interlineation line 1 to 2","line2",{"notBefore":18,"notAfter":18},[71,76],{"_":72,"type":73,"ref":74,"region":75},"Lipara","ancient","http://pleiades.stoa.org/places/462283","Sicilia",{"_":77,"type":78,"ref":79,"region":75},"Lipari","modern","http://sws.geonames.org/2524378",[81],[82,83],38.48333,14.93333,{"_":85,"type":86,"geo":18},"Original discovery not recorded.","found",[],{"_":89,"type":90,"subtype":91,"geo":18},"Seen by Libertini (1921) in 'giardino dell'Episcopio'","observed","seen",[93],{"n":94,"url":95,"height":96,"width":97,"desc":98,"surfaceType":99},"screen","ISic003975_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":102,"role":103,"ref":104,"museum":105},"Museo Archeologico Regionale Eoliano \"Luigi Bernab� Brea\"","museum","http://sicily.classics.ox.ac.uk/museum/048",{"slug":106,"type":103,"name":102,"uri":104,"description":107,"location":108},"048","The enormous collection is displayed in several neighbouring buildings, each with a particular focus: Prehistory, Prehistory of the minor islands, Epigraphy, Geology, the Classical period and later. The finds come from across the Aeolian islands, under the sea that surrounds them, and from the site of Milazzo on Sicily. One of the 3 largest Sicilian collections, it is truly comprehensive in scope and contains a few finds (e.g. the terracotta tragic theatre masks) that are near unique",{"settlement":77,"region":109,"country":110,"address":111,"geo":112},"Messina","Italy","Via del Castello, 98055 Lipari (ME)",{"lat":113,"lon":114},38.46719,14.957