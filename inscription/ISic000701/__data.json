 permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n                    \u003C/graphic>\n                  \u003Cgraphic n=\"print\" url=\"ISic000701.jpg\" height=\"3423px\" width=\"4068px\">\n                      \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09\u003C/desc>\n                 \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname type=\"nomen\">Rustia\u003C/name> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cexpan>\u003Cabbr>G\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name>\u003C/persName> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g>\n                    \u003Clb n=\"2\"/>\u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilia\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname type=\"cognomen\">Festa\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>ann\u003C/abbr>\u003Cex>os\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"3\"/>\u003Cnum value=\"13\">XIII\u003C/num> \u003Cg ref=\"#interpunct\">·\u003C/g> pia \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>sal\u003C/abbr>\u003Cex>ve\u003C/ex>\u003C/expan> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text from autopsy\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Rustia Festa, daughter of Gaius, aged 13 years, dutiful, farewell!\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#FP\">\n                \u003Cp>Addio pia Rustia Festa, figlia di Caius. (È vissuta) 13 anni.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--marble slab, rectangular with typanum upper; etched border concentric to stone. Commemorates Rustia Festa, daughter of Gaius, known also from AE 1989.0340b = Manganaro, Epigraphica 51 (1989), 166-7.30 = ISic000700. Autopsy.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1949\u003C/date>\n                        \u003CcitedRange>97 no. 4 fig. 5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VQURX85J\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001865\">https://biblio.inscriptiones.org/epig10001865\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>52 n.257\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
