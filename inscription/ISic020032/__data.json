gible\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003C!-- Stylised drawing or symbol of a cross. Id: symbol01.-->\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"12\" atMost=\"12\">12\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"https://pleiades.stoa.org/places/462487\">Segesta\u003C/placeName>\n                                \u003CplaceName type=\"modern\"/>\n                                \u003Cgeo>37.94171, 12.83649\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" evidence=\"archaeological-context material-context lettering\" notBefore-custom=\"-0500\" notAfter-custom=\"-0480\">500—480 BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" when=\"1965-09-10\">Found during the excavations (on the 10th of September 1965) by the Soprintendenza alle Antichità della Sicilia Occidentale in the area of Grotta Vanella, on the north-east slope of Monte Barbaro\u003Cgeo>37.94240, 12.84509\u003C/geo>, 1.9km east of temple of Segesta.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" resp=\"#VM\" when=\"2021-12-14\">