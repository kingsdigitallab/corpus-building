grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>ΤΑΙΝ\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" quantity=\"1\" unit=\"line\"/>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" quantity=\"1\" unit=\"line\"/>\n                    \u003Clb n=\"4\" break=\"no\"/>\u003Cunclear>κ\u003C/unclear>ας \u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Θράσυς\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Ἐμ\n                    \u003Clb n=\"5\" break=\"no\"/>μενίδας\u003C/name> \u003CorgName>Δορι\n                    \u003Clb n=\"6\" break=\"no\"/>στόνφο̄ν\u003C/orgName>\u003C/persName>\u003C/persName> ͱαπ\n                    \u003Clb n=\"7\" break=\"no\"/>άντο̄ν ἐστὶ ͱυ\n                    \u003Clb n=\"8\" break=\"no\"/>πέρτατος ἀκίδ\n                    \u003Clb n=\"9\" break=\"no\"/>ον\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Cassio 1994 with minor emendation of Cordano 2020\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp>[...] Thrasys Emmenidas di tutti i coraggiosi con la lancia è il migliore degli arcieri (trans. Cordano)\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>This document is physically and archaeologically distinct from the tesserae with which it was originally published, from a different context in the sanctuary of Athena at the archaeological site of Kamarina. The revised reading of Cassio, followed by Cordano makes it a dedication by Thrasys for his success with the bow.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Cordano\u003C/author>\n                        \u003Cdate>1992\u003C/date>\n                        \u003CcitedRange>6\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/XTMUJ38N\"/> \n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002437\">https://biblio.inscriptiones.org/epig10002437\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>42.0846\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Cassio\u003C/author>\n                        \u003Cdate>1994\u003C/date>\n                        \u003CcitedRange>5-20\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/IVWJJBZZ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002762\">https://biblio.inscriptiones.org/epig10002762\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Cordano\u003C/author>\n                        \u003Cdate>2020\u003C/date>\n                        \u003CcitedRange>263-266 fig.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DEFDF5JL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002276\">https://biblio.inscriptiones.org/epig10002276\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>52.0920\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>54.0892\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
