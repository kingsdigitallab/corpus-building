{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":106,"html":277,"xml":338},"ISic000366",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":45,"dimensions":46,"layoutDesc":57,"handNote":64,"date":79,"places":84,"geo":94,"country":89,"provenance":86,"provenanceFound":98,"provenanceGeo":102,"provenanceObserved":103,"provenanceLost":20,"graphics":106,"region":122,"settlement":91,"repository":123,"idno":136,"textLang":139,"bibliographyEdition":143,"bibliographyDiscussion":215,"citation":218,"tmNumber":8,"facsimile":246,"letterHeights":247,"publications":251,"zotero":258,"keywords":265,"lettering_types":276},"Epitaph of Caius Pompeius Felix and Scribonia Restituta",{"_":5},"draft",[7,10,13,15,18],{"_":8,"type":9},"491577","TM",{"_":11,"type":12},"139166","EDR",{"type":14},"EDH",{"_":16,"type":17},"21900406","EDCS",{"type":19},"PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","Two non-joining fragments of a marble plaque. Fragment (a) from the left half of the plaque is intact along the upper edge, but broken on the other three sides (H 11cm, W 11cm, D 2.3cm); fragment (b) preserves the right half of the plaque, intact top, right and below, but broken on the left side (H 14cm, W 22cm, D 2.3cm). A simple relief moulding is preserved across the top of the plaque. The rear of the plaque is rough and uneven. Fragment (b) has been heavily repainted with a brown paint. The surface of fragment (a) is less well preserved, but the letters retain traces of a bright red paint.",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":31,"ana":32,"type":33,"subtype":34,"resp":36,"ref":37,"placeName":38},"Very fine to fine-grained, homogeneous, white, calcitic marble, likely Lunense. Optical microsco