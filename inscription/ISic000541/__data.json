 \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000541_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000541.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>-->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#GC\">\n                \u003Cab>\n                 \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Petronia\u003C/name>\n                    \u003Clb n=\"3\"/>\u003Cname>Cyane\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">·\u003C/g> sibi\n                    \u003Clb n=\"4\"/>viva \u003Cg ref=\"#interpunct\">·\u003C/g> posuit\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of CIL\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#GC\">\n                \u003Cp>To the spirits of the dead. Petronia Cyane, while living, placed this for herself.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:la