=\"4\"/>\u003Cname>Fortunata\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">·\u003C/g> fratri \u003Cg ref=\"#ivy-leaf\">❦\u003C/g>\n                    \u003Clb n=\"5\"/>suo \u003Cg ref=\"#ivy-leaf\">❦\u003C/g> fecit \u003Cg ref=\"#ivy-leaf\">❦\u003C/g>\n                \u003C/ab>\n             \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n               \u003ClistApp>\u003Capp>\u003Cnote>Text based on autopsy\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>To the shades of the underworld. Calbentius Motho lived for 40 years. Calbentia Fortunata made (this)\n                    for her brother\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp>Agli dei Mani. Calbentius Motho visse 40 anni, Calbentia Fortunata dedicò (questa iscrizione) a suo fratello\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/650772\">7193\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
