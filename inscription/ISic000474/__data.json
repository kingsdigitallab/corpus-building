/1.0\"?>\n\u003C?xml-model href=\"../schematron/ircyr-checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XInclude\" xml:lang=\"en\">\n    \u003CteiHeader>\n        \u003CfileDesc>\n            \u003CtitleStmt>\n                \u003Ctitle>Funerary inscription for Calbentius Motho\u003C/title>\n                \u003Ceditor ref=\"#JP\">Jonathan Prag\u003C/editor>\n                \u003Cprincipal ref=\"#JP\">Jonathan Prag\u003C/principal>\n                \u003Cfunder>John Fell OUP Research Fund\u003C/funder>\n\t   \u003Cfunder>\u003Cref target=\"https://cordis.europa.eu/project/id/885040\">ERC Advanced Grant no.885040\u003C/ref>\u003C/funder>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>original data collection and editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JCu\" ref=\"http://orcid.org/0000-0002-6686-3728\">James Cummings\u003C/name>\n                    \u003Cresp>conversion to EpiDoc\u003C/resp>\n                \u003C/respStmt>\n\t    \u003CrespStmt>\n     \t       \u003Cname xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n     \t       \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n \t   \u003C/respStmt>\n            \u003CrespStmt>\u003Cname xml:id=\"Coccato\" ref=\"https://orcid.org/0000-0002-6641-2820\">Alessia Coccato\u003C/name>\u003Cresp>Petrographic observation and analysis\u003C/resp>\u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic000474\u003C/idno>\n                \u003Cidno type=\"TM\">491699\u003C/idno>\n                \u003Cidno type=\"EDR\">142396\u003C/idno>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\">21900534\u003C/idno>\n                \u003Cidno type=\"PHI\"/>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic000474\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-17\">10.5281/zenodo.4337551\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Agrigento\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/130\">Museo Regionale Archeologico Pietro Griffo\u003C/repository>\n                        \u003Cidno type=\"inventory\">C1881\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"la\">Latin\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>A slab of coarse bluish marble. Intact on all sides, but missing the top right corner. The sides are rough, the rear is finished and smooth.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.inorganic.stone.metamorphic_rock.marble\" type=\"stone.marble\" subtype=\"unspecified\" resp=\"#Coccato\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\n                                    \u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/259\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">15.7\u003C/height>\n                                        \u003Cwidth unit=\"cm\">24.8\u003C/width>\n                                        \u003Cdepth unit=\"cm\">2.4\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003Cp>Five lines of latin letters with guidelines marked out for a sixth also. The text is centred, but slightly off the horizontal; hedera/interpuncts mark the line ends.\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>The letters show the beginnings of a shift towards the later cursive style, with extended serifs on the A and M, T tending to be narrow with upward sloping head, E likewise tall, narrow, with top stroke sloping upwards. Interpuncts, sometimes in the form of hedera, used between all words except after Calbentius\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"10\" atMost=\"11\">10-11\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line2\" to=\"line2\">Line 2\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"11\" atMost=\"13\">11-13\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line3\" to=\"line3\">Line 3\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"10\" atMost=\"13\">10-13\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line4\" to=\"line4\">Line 4\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"11\" atMost=\"13\">11-13\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line5\" to=\"line5\">Line 5\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"11\" atMost=\"14\">11-14\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"11\" atMost=\"11\">11\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line2\" to=\"line3\">Interlineation line 2 to 3\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"5\" atMost=\"8\">5-8\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line3\" to=\"line4\">Interlineation line 3 to 4\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"5\" atMost=\"8\">5-8\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line4\" to=\"line5\">Interlineation line 4 to 5\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"4\" atMost=\"5\">4-5\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462086\">Agrigentum\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/6541860\">Agrigento\u003C/placeName>\n                            \t\u003Cgeo>37.32084, 13.58876\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0051\" notAfter-custom=\"0250\">Roman Imperial period\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1877\">Found near the so-called 'Tomb of Theron', and donated to the musem by Evangelista Zucchi (so Mommsen in CIL); seen by Mommsen in 1877.\u003Cgeo>37.2888341,13.5853883\u003C/geo>\u003C/provenance>\u003C!-- location of the tomb of Theron -->\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" resp=\"#JP\">2018.07.17 Prag, on display in the museum\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/languag