{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":99,"html":260,"xml":306},"ISic001395",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":37,"dimensions":38,"layoutDesc":49,"handNote":55,"date":67,"places":72,"geo":82,"country":77,"provenance":74,"provenanceFound":86,"provenanceGeo":94,"provenanceObserved":95,"provenanceLost":20,"graphics":99,"region":107,"settlement":108,"repository":109,"idno":113,"textLang":116,"bibliographyEdition":120,"bibliographyDiscussion":203,"citation":206,"tmNumber":8,"letterHeights":231,"publications":232,"zotero":240,"keywords":248,"lettering_types":259},"I.Sicily inscription 001395",{"_":5},"draft",[7,10,12,14,17],{"_":8,"type":9},"493010","TM",{"type":11},"EDR",{"type":13},"EDH",{"_":15,"type":16},"39101522","EDCS",{"_":18,"type":19},"140902","PHI",null,{"_":22,"ana":23,"ref":24},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html","A rectangular slab of white marble, broken away at the top left corner, but otherwise intact.",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":31,"ana":32,"type":33,"subtype":34,"ref":36},"marble (white)","#material.inorganic.stone","stone.unspecified",[35],"unverified","http://www.eagle-network.eu/voc/material/lod/48.html","",[39,43,46],{"_":40,"unit":41,"dimension":42},"8.9","cm","height",{"_":44,"unit":41,"dimension":45},"34.93","width",{"_":47,"unit":41,"dimension":48},"4.45","depth",{"layout":50},{"rs":51,"damage":37},{"_":52,"ana":53,"ref":54},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":56,"dimensions":57},"Note presence of rhomboid omega and omicron, regular epsilon and sigma according to the transcription in the BM catalogue",[58,63],{"type":59,"l":60,"from":61,"to":61,"unit":62},"letterHeight","Line 1","line1","mm",{"type":64,"l":65,"from":61,"to":66,"unit":62},"interlinear","Interlineation line 1 to 2","line2",{"_":68,"notBefore":69,"notAfter":70,"evidence":71},"Lettering of this sort can be observed already in the later Hellenistic period in Sicily, but the use of marble may suggest that the piece belongs in the Roman period, although the absence of Roman names in turn might suggest an earlier date. Perhaps second century CE?",101,200,"lettering, material-context",[73,78],{"_":74,"type":75,"ref":76,"region":77},"Centuripae","ancient","http://pleiades.stoa.org/places/462153","Sicilia",{"_":79,"type":80,"ref":81,"region":77},"Centuripe","modern","http://sws.geonames.org/2525032",[83],[84,85],37.62336,14.74049,{"_":87,"type":88,"subtype":89,"when":90,"geo":91},"First reported by Ansaldi 1851 as found in 1844 at Centuripe, 'nell'orto laterale all chiesa di Maria delle Grazie', and subsequently in the possession of the provost D. Paolino Riolo (note that this location puts it in the vicinity of the Roman forum). The later BM register (acquisition of 1863) records it as found by George Dennis in excavations at Agrigentum, one of many items acquired by the museum from Dennis at this point, including several other pieces from Agrigentum, but it seems more likely that Dennis acquired it from a dealer in Agrigento, given the clear local evidence of discovery at Centuripe 20 years earlier","found","discovered","1844",[92,93],37.620376,14.743822,[92,93],{"_":96,"type":97,"subtype":98,"geo":20},"None","observed","autopsied",[20,100],{"n":101,"url":102,"height":103,"width":104,"desc":105,"surfaceType":106},"screen","ISic001395_Marshall_tiled.tif","495px","1761px","Scan of drawing in Marshall 1916, no.1104","front","England","London",{"_":110,"role":111,"ref":112},"The British Museum","museum","https://www.britishmuseum.org/",{"_":114,"type":115},"1863,0728.190","inventory",{"_":117,"mainLang":118,"languages":119},"Ancient Greek","grc",[117],{"type":121,"bi