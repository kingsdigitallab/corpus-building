alendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.expressive.explicit\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Explicit\">explicit\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-09-22\" who=\"#MB\">encoded text\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!--  \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003659_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003659.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>-->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#MB\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cnum value=\"17\">XVII\u003C/num> \u003Cexpan>\u003Cabbr>K\u003C/abbr>\u003Cex>alendas\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>Septemb\u003C/abbr>\u003Cex>res\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Feridius\u003C/name> \u003CpersName type=\"attested\">\u003Cname>Cereris\u003C/name>\u003C/persName> dominae \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>ervus\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/persName>\n                    \u003Clb n=\"3\"/>hic sibi \u003Cchoice>\u003Creg>suaviter\u003C/reg>\u003Corig>suabiter\u003C/orig>\u003C/choice> \u003Cexpan>\u003Cabbr>fec\u003C/abbr>\u003Cex>it\u003C/ex>\u003C/expan> e\u003Csupplied reason=\"lost\">o\u003C/supplied>\n                    \u003Clb n=\"4\" break=\"no\"/>rum tres adulescentes\n                    \u003Clb n=\"5\"/>quorum nomina lege\n                    \u003Clb n=\"6\"/>\u003CpersName type=\"attested\">\u003Cname>Onesimus\u003C/name>\u003C/persName> et \u003CpersName type=\"attested\">\u003Cname>\u003Cexpan>\u003Cabbr>L\u003C/abbr>\u003Cex>ucius\u003C/ex>\u003C/expan>\u003C/name> \u003Cname>Valerius\u003C/name>\n                    \u003Clb n=\"7\"/>\u003Cname>\u003Cchoice>\u003Creg>Cassianus\u003C/reg>\u003Corig>Casianus\u003C/orig>\u003C/choice>\u003C/name>\u003C/persName> et \u003CpersName type=\"attested\">\u003Cname>Filumenus\u003C/name>\u003C/persName>\n                    \u003Clb n=\"8\"/>unus cum \u003Cchoice>\u003Creg>muliere\u003C/reg>\u003Corig>mulierae\u003C/orig>\u003C/choice> ea\n                    \u003Clb n=\"9\"/>\u003CpersName type=\"attested\">\u003Cname>Taurus\u003C/name>\u003C/persName> multis annis \u003Cchoice>\u003Creg>have\u003C/reg>\u003Corig>habe\u003C/orig>\u003C/choice> \u003Cexpan>\u003Cabbr>facian\u003C/abbr>\u003Cex>t\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"10\"/>\u003Cchoice>\u003Creg>coniunximus\u003C/reg>\u003Corig>coiuximus\u003C/orig>\u003C/choice>\n                    \u003Clb n=\"11\"/>propitiam\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Orsi 1918\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#MB\">\n                \u003Cp> Il 16 Agosto Feridius servo della dea Cerere si unì carnalmente con tre adolescenti dei quali i nomi erano per legge Onesimus, L. Valerius Cassianus e Filumenus. Il solo Taurus (giacque) con quella donna, augurio ----.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>A substantial text incised in the wall of room of a Roman house (late Republican / early Empire according to Orsi), but in a phase of dereliction after the original use of the house in Orsi's view. The text is incised within an outline of a tabula ansata. In large letters below the main text is the word PROPITIAM. Several other graffiti are recorded in the same room.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1919.0057\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1918\u003C/date>\n                        \u003CcitedRange>58-60 fig.7\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1962\u003C/date>\n                        \u003CcitedRange>490-491\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q7KT855P\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001851\">https://biblio.inscriptiones.org/epig10001851\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>68 n.348\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
