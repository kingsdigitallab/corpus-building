03Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilio\u003C/ex>\u003C/expan>\u003C/supplied>\n                    \u003Clb n=\"2\"/>\u003Cexpan>\u003Cabbr>Pom\u003C/abbr>\u003Cex>ptina\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Flaccus\u003C/name> \n                    \u003Clb n=\"3\"/>\u003Cname>Licinia\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>\u003Cexpan>\u003Cabbr>C\u003C/abbr>\u003Cex>ai\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilia\u003C/ex>\u003C/expan> \n                    \u003Clb n=\"4\"/>\u003Cname>Thoria\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>onumentum\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ecit\u003C/ex>\u003C/expan> \n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text: CIL\u003C/note>\u003C/app>\u003C/listApp>\n                \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>Gaius Rabonius Flaccus, son of Publius. Licinia Thoria, daughter of Caius, built this monument\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--CIL add. states: 'dele. Repertum esse Bovillis ait Lupi a.1733 diss. (ed.2 Faenza 1785), 2, p.146. Monuit Dessau'.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7316 and p.993 add.\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\u003C!-- = CIL 14.2422 -->\n                    \u003Cbibl/>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
