imary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>Ἀγορασία\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Φηλίκος\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>εἰατροῦ \u003Cexpan>\u003Cabbr>ὁλ\n                    \u003Clb n=\"4\" break=\"no\"/>οκ\u003C/abbr>\u003Cex>οτίνου\u003C/ex>\u003C/expan> \u003Cnum value=\"1\">α\u003C/num> συνμα\n                    \u003Clb n=\"5\"/>ρτυροῦντος \u003CpersName type=\"attested\">\u003Cname>Πέ\n                    \u003Clb n=\"6\" break=\"no\"/>τρου\u003C/name>\u003C/persName> καὶ \u003CpersName type=\"attested\">\u003Cname>Μαρκιά\n                    \u003Clb n=\"7\" break=\"no\"/>νου\u003C/name>\u003C/persName> καὶ \u003CpersName type=\"attested\">\u003Cname>Μεθίου\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Agnello 1953\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--epitaph marking purchase of the locus by Phelikos (Felix) the doctor, with three witness, Petros, Markianos, Methios. Note the cost, one aureus, for which cf. IG14.142.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Agnello\u003C/author>\n                        \u003Cdate>1953\u003C/date>\n                        \u003CcitedRange>no.21\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/D9BZFDDR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002211\">https://biblio.inscriptiones.org/epig10002211\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1895\u003C/date>\n                        \u003CcitedRange>486 no.165\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/3T2DS245\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001711\">https://biblio.inscriptiones.org/epig10001711\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>64, 85\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Lamagna and Amato\u003C/author>\n                        \u003Cdate>2014\u003C/date>\n                        \u003CcitedRange>22 ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/BRWNQRHF\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001892\">https://biblio.inscriptiones.org/epig10001892\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
