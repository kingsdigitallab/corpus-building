0,"ref":191},"Simona Stoyanova","SS","https://orcid.org/0000-0003-3914-9569",{"_":193,"when":194,"who":195},"Marta Fogagnolo revised the text encoding, added dimensions, italian translation and commentary","2022-10-31","#martaf",{"n":99,"url":100,"height":101,"width":102,"desc":103,"surfaceType":104},[198],{"atLeast":199,"atMost":200},20,30,[202,203,204],"Ferrara, 1829, Storia di Catania sino alla fine del secolo XVIII","Kaibel, 1890, IG","Korhonen, 2004, IMusCatania",[206,207,208],"82T4IWDN","Q2SBPG9F","2EUC82DH",[210,211,212,24,29,33,213,214,215,216,214,217,218,124],"isic001326","epitaph for statilia theagenis",{"_":5},"catina","catania","italy","sicily","museo civico di catania","ancient greek",[],{"title":221,"body":222,"divs":223,"editions":250,"images":260,"handnote":266},"ISic001326. Epitaph for Statilia Theagenis","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Στατειλία Θεαγενὶς\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Στατειλία\">Στατειλία\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Θεαγενὶς\">Θε-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>αγενὶς\u003C/span>\u003C/span>  \u003Cspan data-text=\"ἔζησεν\">ἔζ\u003Cspan class=\"small\" title=\"small character: η\">η\u003C/span>-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>σεν̣\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Στατειλία Θεαγενὶς\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Στατειλία\">ΣΤΑΤΕΙΛΙΑ\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Θεαγενὶς\">ΘΕ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>ΑΓΕΝΙΣ\u003C/span>\u003C/span>\u003Cspan data-text=\"ἔζησεν\">ΕΖ\u003Cspan class=\"small\" title=\"small character: η\">Η\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>ΣΕ.\u003C/span> &nbsp;&nbsp; \u003Cspan data-text=\"ἔτη\">ΕΤΗ\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001326_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001326_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001326.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001326-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photographs\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0001-7077-0703\">Alex Antoniou\u003C/a>\u003C/p>  \u003Cp>Stateilia Theagenis lived for [?] years.\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Statilia Theagenis visse [?] anni.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>The epitaph presents the name of the deceased and the indication of her age (the years are assumed to be in a missing fourth line). The gentilicium \u003Cspan class=\"lang\" lang=\"grc\">Στατείλια\u003C/span> is also found in the Latin funerary inscription of the 2nd-3rd century CE, CIL 10.7094 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic000376\" target=\"_blank\">ISic000376\u003C/a>. The name \u003Cspan class=\"lang\" lang=\"grc\">Θεαγενίς\u003C/span> is not well attested (for the masculine form \u003Cspan class=\"lang\" lang=\"grc\">Θεαγένης\u003C/span> attested in South Italy, see LGPN 3A 199). For \u003Cspan class=\"lang\" lang=\"grc\">Θεαγενίς\u003C/span> in two urban inscriptions, see Solin 1982: 84.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli>\u003C/li>\u003Cli> Ferrara 1829 391 no.6 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002005\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002005\u003C/a>\u003C/li>\u003Cli> Kaibel 1890 \u003Ca href=\"https://clio.columbia.edu/catalog/6873760\" target=\"_blank\">505\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10001072\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001072\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 133 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>Letters with serifs: Ε and Σ lunate, Η at l. 2 in smaller size.\u003C/p> Lines 1-3  20-30  Interlineation line 1 to 2  not recorded  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[224,227,230,233,236,238,241,244,247],{"id":225,"html":226},"editions","\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Στατειλία Θεαγενὶς\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Στατειλία\">Στατειλία\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Θεαγενὶς\">Θε-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>αγενὶς\u003C/span>\u003C/span>  \u003Cspan data-text=\"ἔζησεν\">ἔζ\u003Cspan class=\"small\" title=\"small character: η\">η\u003C/span>-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>σεν̣\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Στατειλία Θεαγενὶς\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Στατειλία\">ΣΤΑΤΕΙΛΙΑ\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Θεαγενὶς\">ΘΕ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>ΑΓΕΝΙΣ\u003C/span>\u003C/span>\u003Cspan data-text=\"ἔζησεν\">ΕΖ\u003Cspan class=\"small\" title=\"small character: η\">Η\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>ΣΕ.\u003C/span> &nbsp;&nbsp; \u003Cspan data-text=\"ἔτη\">ΕΤΗ\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":228,"html":229},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001326_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001326_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001326.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001326-thumb.jpg\">\u003C/a>",{"id":231,"html":232},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photographs\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":234,"html":235},"translation","\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0001-7077-0703\">Alex Antoniou\u003C/a>\u003C/p>  \u003Cp>Stateilia Theagenis lived for [?] years.\u003C/p>  ",{"id":234,"html":237},"\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Statilia Theagenis visse [?] anni.\u003C/p>  ",{"id":239,"html":240},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>The epitaph presents the name of the deceased and the indication of her age (the years are assumed to be in a missing fourth line). The gentilicium \u003Cspan class=\"lang\" lang=\"grc\">Στατείλια\u003C/span> is also found in the Latin funerary inscription of the 2nd-3rd century CE, CIL 10.7094 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic000376\" target=\"_blank\">ISic000376\u003C/a>. The name \u003Cspan class=\"lang\" lang=\"grc\">Θεαγενίς\u003C/span> is not well attested (for the masculine form \u003Cspan class=\"lang\" lang=\"grc\">Θεαγένης\u003C/span> attested in South Italy, see LGPN 3A 199). For \u003Cspan class=\"lang\" lang=\"grc\">Θεαγενίς\u003C/span> in two urban inscriptions, see Solin 1982: 84.\u003C/p>  ",{"id":242,"html":243},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli>\u003C/li>\u003Cli> Ferrara 1829 391 no.6 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002005\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002005\u003C/a>\u003C/li>\u003Cli> Kaibel 1890 \u003Ca href=\"https://clio.columbia.edu/catalog/6873760\" target=\"_blank\">505\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10001072\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001072\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 133 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  ",{"id":245,"html":246},"handnote","\u003Cp>Letters with serifs: Ε and Σ lunate, Η at l. 2 in smaller size.\u003C/p> Lines 1-3  20-30  Interlineation line 1 to 2  not recorded  ",{"id":248,"html":249},"license"," Licensed under a Creative Commons-Attribution 4.0 licence. ",[251,253,256,257],{"html":252},"Text encoding: Marta Fogagnolo",{"id":254,"lang":124,"html":255},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Στατειλία Θεαγενὶς\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Στατειλία\">Στατειλία\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Θεαγενὶς\">Θε-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>αγενὶς\u003C/span>\u003C/span>  \u003Cspan data-text=\"ἔζησεν\">ἔζ\u003Cspan class=\"small\" title=\"small character: η\">η\u003C/span>-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>σεν̣\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":252},{"id":258,"lang":124,"html":259},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Στατειλία Θεαγενὶς\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Στατειλία\">ΣΤΑΤΕΙΛΙΑ\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Θεαγενὶς\">ΘΕ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>ΑΓΕΝΙΣ\u003C/span>\u003C/span>\u003Cspan data-text=\"ἔζησεν\">ΕΖ\u003Cspan class=\"small\" title=\"small character: η\">Η\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>ΣΕ.\u003C/span> &nbsp;&nbsp; \u003Cspan data-text=\"ἔτη\">ΕΤΗ\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\