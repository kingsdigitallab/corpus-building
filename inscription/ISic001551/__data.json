                  \u003Cdimensions>\u003C!--from Vento-->\n                                        \u003Cheight unit=\"cm\">93.5\u003C/height>\n                                        \u003Cwidth unit=\"cm\">57\u003C/width>\n                                        \u003Cdepth unit=\"cm\">50\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.painted\" ref=\"http://www.eagle-network.eu/voc/writing/lod/10\">painted\u003C/rs>\n                                    \u003Cdamage/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>Relatively broad brushstrokes with some fluidity. Alpha is broad with straight bar; beta has distinct closed eyes, somewhat angular; eta is broad with outward turning lower strokes; theta is ovid with horizontal bar; mu is broad with vertical uprights, and the middle strokes only descending half-way; omicron is sometimes slightly smaller and above the line; sigma is lunate; omega is lunate.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462281\">Lilybaeum\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/6542148\">Marsala\u003C/placeName>\n                                \u003Cgeo>37.80355, 12.4379\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0100\" notAfter-custom=\"0100\">1st century BCE — 1st century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"1895\">One of thirteen found in Marsala in 1895; the original findspot was concealed.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include