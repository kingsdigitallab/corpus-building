              \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462281\">Lilybaeum\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/6542148\">Marsala\u003C/placeName>\n                                \u003Cgeo>37.80355, 12.4379\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0100\" notAfter-custom=\"0100\">1st century BCE — 1st century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"1895\">One of thirteen found in Marsala in 1895; the original findspot was concealed.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-10-26\" who=\"#VM\">Valentina Mignosa encoded text division, cleaned up the autogenerated text and checked the edition\u003C/change>\n                \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-03-09\" who=\"#JP\">Jonathan Prag edited metadata and bibliography, revised text from photograph\u003C/change>\n                \u003Cchange when=\"2025-12-18\" who=\"#ZG\">Zoe Greblunas tagged names and persons\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#DD\">Dmitry Dundua's lemmatizations were added from source CoNLL-U files\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc using PyEpiDoc and associated scripts\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001551_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001551.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Μάρχος\u003C/w>\u003C/name> \u003Cname>\u003Cw n=\"10\">Σημβρόνις\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"15\">ἥρως\u003C/w> \u003Cw n=\"20\">ἀγαθός\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Μάρκος\">Μάρχος\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Σεμπρώνιος\">Σημβρόνις\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἥρως\">ἥρως\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ἀγαθός\">ἀγαθός\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>text checked against photograph in Vento\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"line 1\">\n                        \u003Cnote>Kretschmer: Μάρχιος (mislead by part of the decoration); Manni Piraino: Σημβρῶνις\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--painted inscr., with banqueting scene. Marchos Sembronis heros agathos - again notes the bad greek, transliterating a Latin name - cf. IGLPa 20; The name Sempronius is attested for Lilybaeum in C1 BC (coinage) and C2 AD (praetor, 187).-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>04.0040\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGMusPalermo\">\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1973\u003C/date>\n                        \u003CcitedRange>21\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F66S4X3M\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000531\">https://biblio.inscriptiones.org/epig10000531\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Kretschmer\u003C/author>\n                        \u003Cdate>1927\u003C/date>\n                        \u003CcitedRange>306 no.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/NT9TNH4M\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002533\">https://biblio.inscriptiones.org/epig10002533\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gabrici\u003C/author>\n                        \u003Cdate>1929\u003C/date>\n