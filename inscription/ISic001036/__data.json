pe=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001036_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001036.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"a\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Ἱέρ\u003Csupplied reason=\"omitted\">ω\u003C/supplied>νος\u003C/name>\u003C/persName>\n                    \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"b\">\n                    \u003Cab>\n                        \u003Clb n=\"2\"/>\u003CroleName type=\"supracivic\" subtype=\"basileus\">βασιλέως\u003C/roleName>\n                        \u003Clb n=\"3\"/>\u003CpersName type=\"attested\">\u003Cname>Ἱέρωνος\u003C/name>\n                        \u003Clb n=\"4\"/>\u003CplaceName type=\"ethnic\">Ἀκραίων\u003C/placeName>\u003C/persName>\n                        \u003Clb n=\"5\"/>\u003Corig>\u003Cunclear>Ε\u003C/unclear>ΠΙΛΑΥΘΑΝ\u003C/orig>\n                    \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Pugliese Carratelli 1956\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--FALSE: of Hieron king of the Akraians; Pugliese Carratelli thinks it false, pointing out that the cave was only excavated in the Byzantine period! This probably based upon Hellenistic coinage. IGLPa 159 is a false inscr. apparently based upon this one. I have a slide of what I think must be IGLPa 159* in Palermo Museum). BE accepts the falsity, as does Dimartino.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">215\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>56.1103.3.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1959.0546\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Pugliese Carratelli\u003C/author>\n                        \u003Cdate>1956\u003C/date>\n                        \u003CcitedRange>no.71\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/PJDRZH66\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001394\">https://biblio.inscriptiones.org/epig10001394\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Dimartino\u003C/author>\n                        \u003Cdate>2006\u003C/date>\n                        \u003CcitedRange>709 no.3.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/7AQ7W2MW\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002022\">https://biblio.inscriptiones.org/epig10002022\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
