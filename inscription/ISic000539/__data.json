her description is provided.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.marble\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.arch_element.arch\" ref=\"http://vocab.getty.edu/page/aat/300000994\">arch\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462201\">Eryx\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2524815\">Erice\u003C/placeName>\n                            \t\u003Cgeo>38.03785, 12.58778\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0001\" notAfter-custom=\"0100\" evidence=\"prosopography\">Imperial - possibly to be identified with the proconsul L. Seius on Augustan coinage of Panormus\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1624\">Recorded by Gualtherus as 'apud Vinc. Maiorem'; also recorded in the manuscript of Antonio Cordici, and said there to come from contrada della Piscina Apolline, and subsequently in Cordici's possession.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cprovenance type=\"not-observed\" subtype=\"lost\">Lost\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.dedication\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/88.html\">dedication\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2017-11-10\" who=\"#JP\">Jonathan Prag added basic text edition and additional bibl\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-17\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-12-04\" who=\"#JP\">Jonathan Prag revised from publications\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000539_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000539.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cexpan>\u003Cabbr>L\u003C/abbr>\u003Cex>ucius\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Seius\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cexpan>\u003Cabbr>L\u003C/abbr>\u003Cex>uci\u003C/ex>\u003C/expan>\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilius\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>Aem\u003C/abbr>\u003Cex>ila\u003C/ex>\u003C/expan> \u003Csupplied reason=\"subaudible\">tribu\u003C/supplied> \u003Cname>\u003Cw part=\"I\">Fir\u003C/w>\u003C/name>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Corig>p\u003C/orig> \u003Cg ref=\"#interpunct\">·\u003C/g> pec \u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/> inpen\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of CIL, after Gualtherus and Cordici\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Gualtherus: FIR omitted, lacuna marked; FIR recorded by Ventimiglia (so Mommsen); Cordici: I·PCC, later deleted\u003C/note>\u003C/app>\n                    \u003Capp loc=\"2\">\u003Cnote>Cordici: EFFE·INPEN, later deleted\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Manganaro and Mommsen both noted that the name L.Seius also appears on coins of Panhormus as proconsul of Sicily, in the late Augustan period, and identification with the L. Seius here, making a dedication at Erice, would be attractive, but far from certain. The consul of 18 CE seems less likely, as his cognomen Tubero does not seem to align with the traces variously recorded at the end of line 1 in the antiquarian tradition. P.PEC might be p(osuit) pec(unia).\n                    \u003C!--fr. Manganaro would attribute to L. Seius, procos. of Sicily, known from quadrantes of Panhormus at the end of the Augustan period, but this is not certain as an identification (cogn. of the governor unknown). Bivona observes also the absence of career elements in the inscr, and that the gens Seia ought to belong to the Pomptina, not the Aemilia (as this e.g.). But, B does accept that marble arch, etc. does suggest someone with a public career, but whether municipal or urban uncertain.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                 \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>no. 156\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1769\u003C/date>\n                        \u003CcitedRange>cl. 7, no. 24\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/SPTB56H3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002084\">https://biblio.inscriptiones.org/epig10002084\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1784\u003C/date>\n                        \u003CcitedRange>cl. 7, no. 25\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/7PSFHSUH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002083\">https://biblio.inscriptiones.org/epig10002083\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7259\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Bivona\u003C/author>\n                        \u003Cdate>2000\u003C/date>\n                        \u003CcitedRange>155\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/94ICR94M\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002135\">https://biblio.inscriptiones.org/epig10002135\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1987\u003C/date>\n                        \u003CcitedRange>583\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RVZG5HIX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001833\">https://biblio.inscriptiones.org/epig10001833\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>22 n.83\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/RZSFKACR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
