.eu/voc/writing/lod/1",{"ana":56},"#text_condition.incomplete",{"lettering":58,"dimensions":59},"Simple v-cut lunate letters with terminal serifs, of regular size.",[60,69],{"type":61,"l":62,"from":63,"to":64,"h":65,"unit":66,"atLeast":67,"atMost":68},"letterHeight","Line 1-2","line1","line2","21-23","mm","21","23",{"type":70,"l":71,"from":63,"to":64,"h":72,"unit":66,"atLeast":72,"atMost":72},"interlinear","Interlineation line 1 to 2","18",{"_":74,"notBefore":75,"notAfter":76},"1st — 3rd century CE",1,300,[78,83],{"_":79,"type":80,"ref":81,"region":82},"Centuripae","ancient","http://pleiades.stoa.org/places/462153","Sicilia",{"_":84,"type":85,"ref":86,"region":82},"Centuripe","modern","http://sws.geonames.org/2525032",[88],[89,90],37.62336,14.74049,{"_":92,"type":93,"subtype":94,"notAfter":95,"geo":17},"One of 8 epigraphic fragments acquired from Centuripe by the museum, 19 February 1914 (and Orsi was unable to confirm more precisely the locale in which they were found). Currently in storage, magazzino B, cassette 13","found","discovered","1914",[],{"_":98,"type":99,"subtype":100,"resp":101,"xml:id":102,"geo":17},"Prag  2014-09","observed","autopsied","#JP","autopsy",[104,111],{"n":105,"url":106,"height":107,"width":108,"desc":109,"surfaceType":110},"screen","ISic001856_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-11","front",{"n":105,"url":112,"height":107,"width":108,"desc":109,"surfaceType":113},"ISic001856_rear_tiled.tif","rear","Sicily","Siracusa",{"_":117,"role":118,"ref":119,"museum":120},"Museo Archeologico Regionale Paolo Orsi","museum","http://sicily.classics.ox.ac.uk/museum/097",{"slug":121,"type":118,"name":117,"uri":119,"description":122,"location":123},"097","An outstanding collection of archaeological material. The collection ranges from Siracusa and the surrounding territory (Megara Hyblaia, Akrai, Kasmenai etc) to encompass all of eastern Sicily, reaching as far as Gela and Agrigento. The ground floor covers prehistory through to the end of the Classical period. Upstairs includes Hellenistic and Roman Syracuse and a display of material from the catacombs. A gallery displaying material from Hellenistic eastern Sicily is in preparation.",{"settlement":115,"region":115,"country":124,"address":125,"geo":126},"Italy","Viale Teocrito 66, 96100 - Siracusa",{"lat":127,"lon":128},37.07636989,15.2866213,{"_":130,"type":131},"34733b","inventory",{"_":133,"mainLang":134,"languages":135},"Ancient Greek","grc",[133],{"type":137,"bibl":138},"edition",[139],{"type":140,"n":141,"author":142,"title":143,"date":144,"citedRange":145,"ptr":146,"ref":147,"inscriptionDate":148,"citation":149,"uri":150,"year":151},"bulletin","NSA","","Notizie degli scavi di antichità","1876-","231",{"target":147},"https://www.zotero.org/groups/382445/items/4MCP2PVV","1915","\u003Cspan>Accademia nazionale dei Lincei, Istituto nazionale di archeologia e storia dell’arte (Italy), e Reale Accademia d’Italia, «Notizie degli scavi di antichità», \u003Ci>Notizie degli Scavi di Antichità\u003C/i>, 1876, \u003Ca href=\"http://www.worldcat.org/oclc/1646037\">http://www.worldcat.org/oclc/1646037\u003C/a>\u003C/span>","https://www.zotero.org/groups/isicily/items/4MCP2PVV","1876",{"type":153,"bibl":154},"discussion",[17],{"editor":156,"principal":158,"contributors":159,"change":167},{"_":157,"ref":101},"Jonathan Prag",{"_":157,"ref":101},[160,163],{"_":157,"xml:id":161,"ref":162},"JP","http://orcid.org/0000-0003-3819-8537",{"_":164,"xml:id":165,"ref":166},"Alessia Coccato","Coccato","https://orcid.org/0000-0002-6641-2820",{"_":168,"when":169,"who":101},"Jonathan Prag created file from autopsy","2025-08-13",{"n":105,"url":106,"height":107,"width":108,"desc":109,"surfaceType":110},[172,175],{"atLeast":173,"atMost":174},21,23,{"atLeast":176,"atMost":176},18,[178],"Notizie degli scavi di antichità, 1876-",[180],"4MCP2PVV",[182,183,184,19,24,28,185,186,187,188,189,190,191,134],"isic001856","fragment of an epitaph",{"_":5},"centuripae","centuripe","sicilia","sicily","siracusa","museo archeologico regionale paolo orsi","ancient greek",[],{"title":194,"body":195,"divs":196,"editions":221,"images":231,"handnote":242},"ISic001856. Fragment of an epitaph","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag; edition source: autopsy Prag 2014-09\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"ικη\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"ικη\">[\u003Cspan dir=\"ltr\" class=\"gap\">. 4-6.\u003C/span>]\u003Cspan data-text=\"ικη\">ικη\u003C/span>\u003C/span>\u003C/span> χρησ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[τά χαῖ]ρε ἔζη \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[σες ἔτη] \u003Cspan class=\"supraline\" title=\"line above\">\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>]\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag; edition source: autopsy Prag 2014-09\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"ικη\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"ικη\">[\u003Cspan dir=\"ltr\" class=\"gap\">. 4-6.\u003C/span>]\u003Cspan data-text=\"ικη\">ΙΚΗ\u003C/span>\u003C/span>\u003C/span>ΧΡΗΣ\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[.....]ΡΕΕΖΗ\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[........]\u003Cspan class=\"supraline\" title=\"line above\">\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>]\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001856_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-11\" src=\"ISic001856_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001856.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-11\" src=\"ISic001856-thumb.jpg\">\u003C/a>\u003Ca href=\"ISic001856_rear_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-11\" src=\"ISic001856_rear_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001856_rear.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-11\" src=\"ISic001856_rear-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>text from autopsy\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/a>\u003C/p>  \u003Cp>Farewell, worthy [---]ike, you lived [--] years.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>On the parallel of other imperial period Greek epitaphs from Centuripe, this is likely to be the upper right part of a simple funerary epitaph, for a female individual, with a name ending in -ike. If it follows the common χρηστά χαῖρε pattern, then no more than 4-6 letters are missing from the name. Orsi proposed a name such as Εὐριδικη. The length of the supraline, which would have stood over the numeral recording the age in line 3, together with the surviving letter trace, suggests that the numeral was made up of two letters, so an age of at least 11. Orsi omitted the supraline from his published edition.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Orsi NSA 1915 231 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001392\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001392\u003C/a>  \u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>Simple v-cut lunate letters with terminal serifs, of regular size.\u003C/p> Line 1-2  21-23  Interlineation line 1 to 2  18  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[197,200,203,206,209,212,215,218],{"id":198,"html":199},"editions","\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag; edition source: autopsy Prag 2014-09\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"ικη\">\u003Cspan data-type=\"name\" data-name-t