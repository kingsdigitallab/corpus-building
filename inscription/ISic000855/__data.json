             \u003Clb n=\"2\"/>\u003Cname type=\"cognomen\">\u003Cw n=\"20\">Ὀνήσιμος\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003Cspace unit=\"line\" quantity=\"1\" n=\"25\"/>\n                    \u003Clb n=\"4\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"30\">Ὑγία\u003C/w>\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\" n=\"35\">·\u003C/g> \u003Cw n=\"40\">ἐτῶν\u003C/w> \u003Cgap reason=\"lost\" quantity=\"2\" unit=\"character\" n=\"45\"/>\n                    \u003Clb n=\"5\"/>\u003Cw n=\"50\">μηνῶ\u003Csupplied reason=\"lost\">ν\u003C/supplied>\u003C/w> \u003Cgap reason=\"lost\" quantity=\"2\" unit=\"character\" n=\"55\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Λοῦκις\">Λοῦκις\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"Κορνῆλις\">Κορνῆλις\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"Ὀνήσιμος\">Ὀνήσιμος\u003C/w>\n                    \u003Cspace quantity=\"1\" unit=\"line\" n=\"25\"/>\n                    \u003Cw n=\"30\" lemma=\"Ὑγία\">Ὑγία\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"ἔτος\">ἐτῶν\u003C/w>\n                    \u003Cgap reason=\"lost\" quantity=\"2\" unit=\"character\" n=\"45\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cw n=\"50\" lemma=\"μείς\">μηνῶν\u003C/w>\n                    \u003Cgap reason=\"lost\" quantity=\"2\" unit=\"character\" n=\"55\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of IG\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Loukis Cornelis Onesimos. Hygia [--] years, [--] months [---].\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>Kaibel proposes that the epitaph was originally for Cornelius, and that subsequently his wife(?) Hygeia was added to the burial, hence the space between the two.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">38\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5407\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/> \n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
