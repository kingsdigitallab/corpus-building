003C/change>\n                \u003Cchange when=\"2021-01-22\" who=\"#VM\">Valentina Mignosa encoded text division, cleaned up the autogenerated text and checked the edition\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#VF\">Victoria Fendel's lemmatizations were added from source CoNLL-U files using PyEpiDoc and associated scripts\u003C/change>\n                \u003Cchange when=\"2025-11-05\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc\u003C/change>\n                \u003Cchange when=\"2026-02-18\" who=\"#ZG\">Zoe Greblunas tagged names and persons\u003C/change> \n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003682_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003682.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"a\">\n                    \u003Cab>\n                        \u003Ccb n=\"1\"/>\n                        \u003Clb n=\"1\"/>\u003ChandShift new=\"#h1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Μεγαλλίδος\u003C/w>\u003C/name>\n                        \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw n=\"10\">Σωσιστράτου\u003C/w>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"b\">\n                    \u003Cab>\n                        \u003Ccb n=\"2\"/>\n                        \u003Clb n=\"1\"/>\u003ChandShift new=\"#h2\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"15\">Χρυσίου\u003C/w>\u003C/name>\n                        \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw n=\"20\">Φιλίσκου\u003C/w>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"a\">\n                    \u003Cab>\n                        \u003Cw n=\"5\" lemma=\"Μεγαλλίς\">Μεγαλλίδος\u003C/w>\n                        \u003Cw n=\"10\" lemma=\"Σωσίστρατος\">Σωσιστράτου\u003C/w>\n                    \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"b\">\n                    \u003Cab>\n                        \u003Cw n=\"15\" lemma=\"Χρύσιος\">Χρυσίου\u003C/w>\n                        \u003Cw n=\"20\" lemma=\"Φιλίσκος\">Φιλίσκου\u003C/w>\n                    \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Orsi 1892\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--limestone slab, used to close up one of the loculi of the hypogeum on the east side; slab broken and lying on the floor when found. 1.13 x 0.86 x 0.12 m. On the upper part had an inscription in letters 5cm high, 'piuttosto graffite che incise (sopratutto l'ultimo nome e appena avvertibile, tanto leggermente e tracciato) ma tuttavia di una certa eleganza' (Orsi). Text is two names side-by-side: Megallidos Sosistratou and Chrusiou Philiskou. Orsi notes different hand for each, but also argues strongly for Hieronian parallels in letter forms, noring in the first name sigma with outer arms open (so not later than C3 BC) and mixed quadrate and lunate sigma in second (end of C3 or early C2 he thinks). I have seen no mention of this text subsequently. The hypogeum is thought by Orsi to be abandoned perhaps by the end of the C2 BC; the loculi have painted and graffito texts above them, also of the mid-hellenistic, and a splendid graffito of a temple.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1892\u003C/date>\n                        \u003CcitedRange>357-358 no.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"SGDI\">\n                        \u003Cauthor>Hoffmann\u003C/author>\n                        \u003Cdate>1904\u003C/date>\n                        \u003CcitedRange>5244a\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DQDPC573\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000817\">https://biblio.inscriptiones.org/epig10000817\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
