idth=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001234.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw n=\"5\">Θεοῖς\u003C/w> \u003Cw n=\"10\">Κατα\n                    \u003Clb n=\"2\" break=\"no\"/>\u003Csupplied reason=\"lost\">χθονίοις\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"3\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"15\">Ζωσίμα\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"20\">ἔ\n                    \u003Clb n=\"4\" break=\"no\"/>ζησεν\u003C/w> \u003Cg ref=\"#interpunct\" n=\"25\">·\u003C/g> \u003Cw n=\"30\">ἔ\n                    \u003Clb n=\"5\" break=\"no\"/>τη\u003C/w> \u003Cg ref=\"#interpunct\" n=\"35\">·\u003C/g> \u003Cnum value=\"25\" cert=\"low\">\u003Cw n=\"40\">εκ\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"45\">·\u003C/g> \u003Corig n=\"50\">ΟΙ\u003C/orig>\n                    \u003Clb n=\"6\"/>\u003Corig n=\"55\">ΣΩΑΕ\u003C/orig>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"θεός\">Θεοῖς\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"καταχθόνιος\">Καταχθονίοις\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"Ζωσίμα\">Ζωσίμα\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ζῶ\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"κε\">εκ\u003C/w>\n                    \u003Corig n=\"50\">ΟΙ\u003C/orig>\n                    \u003Corig n=\"55\">ΣΩΑΕ\u003C/orig>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Gualtherus, derived 'ex schedis Alb. Piccoli'\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>It seems plausible to read the ΕΚ in line 5 as the age in years, although the numeral is of ascending format in that case.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/310931\">no.24\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1769\u003C/date>\n           