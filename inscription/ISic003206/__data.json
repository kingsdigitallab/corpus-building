no>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\">22200387\u003C/idno>\n                \u003Cidno type=\"PHI\"/>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic003206\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-18\">10.5281/zenodo.4357232\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Catania\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/018\">Museo Civico di Catania\u003C/repository>\n                        \u003C!--No inventory number found-->\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"la\">Latin\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                \u003Cmaterial ana=\"#material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Aphrodisian #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-1 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-2 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-3 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-4 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Proconnesian #material.inorganic.stone.metamorphic_rock.marble.dolomitic_marble.Thasian-3 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Ephesian_scritto #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Ephesian_white\" type=\"stone.marble\" subtype=\"Aphrodisian|Parian-1|Parian-2|Parian-3|Parian-4|Proconnesian|Thasian-3|Ephesian_scritto|Ephesian_white\" resp=\"#Coccato\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">Medium-grained, homogeneous, white marble, likely Aphrodisian, Parian-1, Parian-2, Parian-3, Parian-4, Proconnesian, Thasian-3, Ephesian_scritto, Ephesian_white. Digital microscopy: homeoblastic to heteroblastic fabric (identification based on pXRF, digital microscopy)\u003C/material>\n                                \u003CobjectType ana=\"#object.statue_base\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/57.html\">statue base\u003C/objectType>\n                                \u003Cp>Two joining fragments from a statue base, extensively damaged on all sides. Parts of each original surface are preserved, such that it is possible to estimate the overall original dimensions. Only a small portion of the lower right of the front face and its moulded right margin is preserved, together with the right face, also with vertical mouldings as borders. A substantial part of the rear face is preserved, bearing a later Latin inscription (\u003Cref sameAs=\"ISic000631.xml\">ISic000631\u003C/ref>). A single foothole is preserved on the upper face, towards the rear left corner.\u003C/p>\n                                \u003Cdimensions>\n                                    \u003Cheight unit=\"cm\">31\u003C/height>\n                                    \u003Cwidth unit=\"cm\">60\u003C/width>\n                                    \u003Cdepth unit=\"cm\">47\u003C/depth>\n                                \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragments.contiguous\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003Cp>Ends of two lines of Latin letters, with uneven right margin.\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage ana=\"#text_condition.incomplete\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Large v-cut letters of very regular shape and elegant serifs.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462270\">Catina\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525068\">Catania\u003C/placeName>\n                            \t\u003Cgeo>37.49223, 15.07041\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0001\" notAfter-custom=\"0200\" evidence=\"lettering\">1st — 2nd century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Found near the lowest seats of the central part of the Roman theatre\u003Cgeo>37.502748, 15.083639\u003C/geo> during excavation by G. Libertini in 1951. Now on display in the Civic museum.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" resp=\"#JP\" xml:id=\"autopsy\">Prag 2016.10.13\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>                    \n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n     