>Νοβ\u003C/abbr>\u003Cex>εμβρίαις\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#ivy-leaf\" n=\"50\">❦\u003C/g> \u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"55\">Νύμφιος\u003C/w>\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Χρηστός\">Χρηστὸς\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"ζάω\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"κζ\">κζ\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"καί\">καὶ\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"τελευτάω\">ἐτελεύτα\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"kalendae\">καλάνδαις\u003C/w>\n                    \u003Cw n=\"45\" lemma=\"November\">Νοβεμβρίαις\u003C/w>\n                    \u003Cw n=\"55\" lemma=\"Νύμφιος\">Νύμφιος\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Agnello 1955\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Chrestos ezesen ete kz', kai eteleuta kalandais Nobembriais Nymphios. SEG (Ferrua 1989) interprets as tomb of Chrestos (and thus l.4 as Adj. νύμφιος); Agnello as tomb of Nymphios.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>15.0582\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Agnello\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1955\u003C/date>\n                        \u003CcitedRange>236 ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>no.303\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/759ZXHKQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001995\">https://biblio.inscriptiones.org/epig10001995\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
