003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000869_tiled.tif\" height=\"2183px\" width=\"2292px\">\n                \u003Cdesc>Reproduction of the drawing in Avolio 1827: 292\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000869.jpg\" height=\"2183px\" width=\"2292px\">\n                \u003Cdesc>Reproduction of the drawing in Avolio 1827: 292\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\" source=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Φοιβίου\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of IG (after Gaetani)\u003C/note>\n                    \u003C/app>\n                    \u003Capp>\u003Cnote>Avolio, MARPO inv: ΦΟΙΒΟΥ\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Not so far identified. The equivalence of MARPO inv. 2 with IG XIV.52 seems highly likely, but is not certain.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Sgarlata\u003C/author>\n                        \u003Cdate>1993\u003C/date>\n                        \u003CcitedRange>128 no.12\u003C/citedRange>\n   