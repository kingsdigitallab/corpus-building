reative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Palermo\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/064\">Museo Archeologico Regionale Antonino Salinas\u003C/repository>\n                        \u003Cidno type=\"inventory\">54361\u003C/idno>\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"xly\">Elymian\u003Ccertainty locus=\"value\" match=\"../@mainLang\" assertedValue=\"grc\">\u003Cdesc>Ancient Greek\u003C/desc>\u003C/certainty>\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>Fragments of foot of a black-glaze lekythos (?).\u003C/p>\n                                    \u003Cmaterial ana=\"#material.inorganic.ceramic\" type=\"ceramic\" subtype=\"unverified\" ref=\"https://www.eagle-network.eu/voc/material/lod/131.html\">ceramic\u003C/material>\n                                    \u003CobjectType ana=\"#object.vessel.lekythos\" cert=\"low\" ref=\"http://kerameikos.org/id/lekythos\">lekythos\u003C/objectType> \u003C!-- ref=\"https://www.eagle-network.eu/voc/objtyp/lod/305.html\" -->\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cdim type=\"diameter\" subtype=\"min\" unit=\"cm\"/>\n                                        \u003Cdim type=\"diameter\" subtype=\"max\" unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragments\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.scratched\" ref=\"https://www.eagle-network.eu/voc/writing/lod/9\">scratched\u003C/rs>\n                                    \u003Cp>The text consists of two inscriptions, arranged on two different sides of the same object. \n                                        The first one (face a) is on the underside of the foot: it is arranged in a clockwise spiral, on one line. \n                                        The second one (face b) is on the underside of the foot: it is arranged in a clockwise spiral, on one line.\n                                        On both faces the text has been highlighted with white painting in modern times to make it more legible.\u003C/p>\n                                    \u003Cdamage ana=\"#text_condition.incomplete text_condition.partly_legible\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003C!--Based on Glyph table: (a) alpha09; epsilon09(?); iota01; pi11; sigma02; upsilon03. (b) iota01; mu01; pi11. -->\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions xml:id=\"faceA\" type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"4\" atMost=\"4\">4\u003C/height>\n                                \u003C/dimensions>\n                                \u003Cdimensions xml:id=\"faceB\" type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"8\" atMost=\"9\">8-9\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"https://pleiades.stoa.org/places/462487\">Segesta\u003C/placeName>\n                                \u003CplaceName type=\"modern\"/>\n                                \u003Cgeo>37.94171, 12.83649\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" evidence=\"archaeological-context material-context lettering\" notBefore-custom=\"-0500\" notAfter-custom=\"-0480\">500—480 BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Accidentally found by a local shepherd in the excavations area and attributed (Voza 1966, p.218, n.7) to the Segesta area of Grotta Vanella, on the north-east slope of Monte Barbaro\u003Cgeo>37.94240, 12.84509\u003C/geo>, 1.9km east of temple of Segesta.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" resp=\"#VM\" when=\"2021-12-15\">Mignosa 2021-12-15\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        