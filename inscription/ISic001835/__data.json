SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-10-13\" who=\"#MB\">Maria Barbieri encoded text\u003C/change>\n                \u003Cchange when=\"2024-01-25\" who=\"#JP\">Jonathan Prag separated file from ISic001262\u003C/change>\n                \u003Cchange when=\"2024-08-15\" who=\"#JP\">Jonathan Prag added images and amended the text\u003C/change>\n                \u003Cchange when=\"2025-10-15\" who=\"#RC\">Robert Crellin added local IDs to edition elements\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001835_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2017-03-22\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001835.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2017-03-22\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n        \u003Csurface type=\"right\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001835_left_tiled.tif\" height=\"5520px\" width=\"3680px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2017-03-22\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001835_left.jpg\" height=\"5520px\" width=\"3680px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2017-03-22\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" resp=\"#MB #JP\" xml:lang=\"grc\">\n                \u003Cab>\n                    \u003Clb n=\"1\" xml:id=\"BθyAK\"/>\u003CpersName type=\"attested\" xml:id=\"BθyAU\">\u003Cname xml:id=\"BθyAe\">Φιλιστοῦς\u003C/name>\u003C/persName> \u003Cw xml:id=\"BθyAo\" n=\"5\">Δ\u003C/w> \u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\" xml:id=\"BθyAy\" n=\"10\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text from autopsy\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"1\">\n                        \u003Cnote>Dimartino: ΔΒ; Kaibel ΔΙ// (intended to illustrate damage to the right of the vertical); lapis: the surface is lost to the right of a vertical stroke, compatible with e.g. Β also\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>of Philisto D[-]\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>It is not possible to say whether the final letter is an Iota or another letter beginning with a vertical, given the damage to the stone. It is  possible that this bore same ΔΒ as on ISic001834; but Β, Γ, Ε, Η, Ι, Κ, Μ, Ν, Π, Ρ are all theoretically possible.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">437.4\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>59.1132\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"SGDI\">\n                        \u003Cauthor>Hoffmann\u003C/author>\n                        \u003Cdate>1904\u003C/date>\n                        \u003CcitedRange>5233\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/DQDPC573\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000817\">https://biblio.inscriptiones.org/epig10000817\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Dimartino\u003C/author>\n                        \u003Cdate>2017\u003C/date>\n                        \u003CcitedRange>testo e\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Z4M8APUF\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002579\">https://biblio.inscriptiones.org/epig10002579\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Dimartino\u003C/author>\n                        \u003Cdate>2009\u003C/date>\n                        \u003CcitedRange>722 no. e\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RPETDZMZ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001364\">https://biblio.inscriptiones.org/epig10001364\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Spuches\u003C/author>\n                        \u003Cdate>1864\u003C/date>\n                        \u003CcitedRange>13\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/NBACXKXQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002042\">https://biblio.inscriptiones.org/epig10002042\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
