ere added from source CoNLL-U files\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc using PyEpiDoc and associated scripts\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001480_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001480.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Corig n=\"5\">ΔΥ\u003Cunclear>ΛΙΙ\u003C/unclear>ΑΩΝ\u003C/orig> \u003Cw n=\"10\">υἱὸς\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"15\">Κόρυδός\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"20\">με\u003C/w>\n                    \u003Clb n=\"3\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"25\">\u003Csupplied reason=\"lost\">Γ\u003C/supplied>έλων\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"30\">ἐποίησε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Corig n=\"5\