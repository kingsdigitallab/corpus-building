abase\u003C/change>\n                \u003Cchange when=\"2019-07-11\" who=\"#AA\">Alex Antoniou Epidoc editing and English translation\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-10-31\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translation and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001328_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001328.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw>\u003Cexpan>\u003Cabbr>Θ\u003C/abbr>\u003Cex>εοῖς\u003C/ex>\u003C/expan>\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>Κ\u003C/abbr>\u003Cex>αταχθονίοις\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Σωτ\u003Csupplied reason=\"lost\" cert=\"low\">ηρ\u003C/supplied>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photographs\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 2\">\u003Cnote>Kaibel, Korhonen: Σωτ[ῆρ? ---]\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>To the subterranean deities, Sot---\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>Agli dèi inferi, Sot---\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The invocation to the subterranean deities is followed by the name of the deceased, probably \u003Cforeign xml:lang=\"grc\">Σωτῆρ\u003C/foreign>, \u003Cforeign xml:lang=\"grc\">Σώταιρος\u003C/foreign>, \u003Cforeign xml:lang=\"grc\">Σώτειρα\u003C/foreign>, \u003Cforeign xml:lang=\"grc\">Σωτηρία\u003C/foreign>, \u003Cforeign xml:lang=\"grc\">Σωτηρίδας\u003C/foreign>, \u003Cforeign xml:lang=\"grc\">Σωτηρίς\u003C/foreign> (attested in an inscription from Catania dated to the 3rd-5th cent. CE: IG 14.550 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001369\">ISic001369\u003C/ref>), \u003Cforeign xml:lang=\"grc\">Σωτήριχος\u003C/foreign> (attested in an inscription from Catania dated to the imperial age: CIL 10.7054 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic000338\">ISic000338\u003C/ref>): on the names, see LGPN 3A: 417-419.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">507\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>130\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
