{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":108,"html":254,"xml":310},"ISic002984",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":36,"dimensions":38,"layoutDesc":49,"handNote":58,"date":75,"places":80,"geo":89,"country":85,"provenance":82,"provenanceFound":93,"provenanceGeo":101,"provenanceObserved":102,"provenanceLost":20,"graphics":108,"region":125,"settlement":82,"repository":126,"idno":139,"textLang":142,"bibliographyEdition":146,"bibliographyDiscussion":204,"citation":207,"tmNumber":8,"facsimile":226,"letterHeights":227,"publications":232,"zotero":238,"keywords":244,"lettering_types":253},"Inscription erected by Tettia, priestess of Ceres for her son",{"_":5},"edited",[7,10,13,15,18],{"_":8,"type":9},"175842","TM",{"_":11,"type":12},"073827","EDR",{"type":14},"EDH",{"_":16,"type":17},"13900574","EDCS",{"type":19},"PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","The left half of a marble plaque, broken diagonally down the middle from upper left to lower right. The surface has been engraved in relief with the form of a tabula ansata, with a triple moulding, the inscription set inside the frame. The edges are roughly finished, the rear not visible.",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":31,"ana":32,"type":33,"subtype":34,"ref":35},"marble","#material.inorganic.stone.metamorphic_rock.marble","stone.marble","unverified","http://www.eagle-network.eu/voc/material/lod/48.html",{"ana":37},"#condition.fragment",[39,43,46],{"_":40,"unit":41,"dimension":42},"31","cm","height",{"_":44,"unit":41,"dimension":45},"27","width",{"_":47,"unit":41,"dimension":48},"3.5-4.0","depth",{"layout":50},{"p":51,"rs":52,"damage":56},"Six lines of Latin letters, lines 1 and 3 (the start of each individual name) set hard against the left margin, lines 2, 4-6 consistently indented by approximately half a letter space. The inscription neatly fills the available field.",{"_":53,"ana":54,"ref":55},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":57},"#text_condition.legible",{"lettering":59,"dimensions":60},"Clear v-cut letters, relatively short and broad, with modest serifs. Cross-strokes are faint, width of letters somewhat uneven; C, V, M notably broad; M has four sloping, full-length strokes; R is slightly open with extended tail; T has upward sloping / curved horizontal; deep triangular interpuncts.",[61,67,72],{"type":62,"l":63,"from":64,"to":64,"h":65,"unit":66,"atLeast":65,"atMost":65},"letterHeight","Line 1","line1","24","mm",{"type":62,"l":68,"from":69,"to":70,"h":71,"unit":66,"atLeast":71,"atMost":71},"Line 2-6","line2","line6","22",{"type":73,"l":74,"from":64,"to":69,"unit":66},"interlinear","Interlineation line 1 to 2",{"_":76,"notBefore":77,"notAfter":78,"evidence":79},"Julio-Claudian (Manganaro)",14,68,"lettering",[81,86],{"_":82,"type":83,"ref":84,"region":85},"Enna","ancient","http://pleiades.stoa.org/places/462236","Sicilia",{"_":82,"type":87,"ref":88,"region":85},"modern","http://sws.geonames.org/2524819",[90],[91,92],37.5655,14.27433,{"_":94,"type":95,"subtype":96,"when":97,"geo":98},"Found 'in localita Porto Salvo, non lungi dalla torre di Federico II' during military works in November 1942. Now on display in the Museo Varisano.","found","discovered","1942-11",[99,100],37.5631813,14.2720323,[99,100],{"_":103,"type":104,"subtype":105,"xml:id":106,"resp":107,"geo":20},"Autopsy by Prag 2026-02-04, on display in the Museum.","observed","autopsied","autopsy","#JP",[109,116,120],{"n":110,"url":111,"height":112,"width":113,"desc":114,"surfaceType":115},"screen","ISic002984_tiled.tif","4216px","3594px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e del