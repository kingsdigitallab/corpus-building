"unit":60,"atLeast":64,"atMost":64},"Line 2","line2","31",{"type":56,"l":66,"from":67,"to":67,"h":68,"unit":60,"atLeast":68,"atMost":68},"Line 3","line3","25",{"type":70,"l":71,"from":58,"to":63,"unit":60},"interlinear","not measured",{"_":73,"notBefore":74,"notAfter":75},"2nd — 4th century CE",101,400,[77,82],{"_":78,"type":79,"ref":80,"region":81},"Messana","ancient","http://pleiades.stoa.org/places/462538","Sicilia",{"_":83,"type":84,"ref":85,"region":81},"Messina","modern","http://sws.geonames.org/2524170",[87],[88,89],38.19394,15.55256,{"_":91,"type":92,"subtype":93,"geo":94},"Largo di Chiesa di San Giovanni Gerosolimitano Di Malta\n                        ","found","discovered",[95,96],38.199072,15.556499,[95,96],{"_":99,"type":100,"subtype":101,"geo":22},"None","observed","autopsied",[103],{"n":104,"url":105,"height":106,"width":107,"desc":108,"surfaceType":109},"screen","ISic001243_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":112,"role":113,"ref":114,"museum":115},"Museo regionale interdisciplinare di Messina","museum","http://sicily.classics.ox.ac.uk/museum/147",{"slug":116,"type":113,"name":112,"uri":114,"description":117,"location":118},"147","The collection is focused on finds made within the city of Messina itself (the warship ram from Acqualadroni being one of the only notable exceptions). Beginning with the prehistoric periods (a single case) it progresses through the different areas and periods of the city, focusing at the end on the sculpture and inscriptions. The accompanying boards set the objects into a clear historical context. One of the highlights of the collection is the aforementioned warship ram. Two other objects given prominence are two of the four Oscan inscriptions in the collection, from the time of Mamertine domination. The principle display cases focus on the cemeteries and religious areas of the city. The grounds of the museum contain a number of monuments and architectural pieces (many from the post-medieval city that was destroyed in the 1908 earthquake) but some earlier as well, principally Roman in date",{"settlement":83,"region":83,"country":119,"address":120,"geo":121},"Italy","Viale della Liberta 465, Messina",{"lat":122,"lon":123},38.2166927,15.5639472,{"_":125,"type":126},"A3548","inventory",{"_":128,"mainLang":129,"languages":130},"Ancient Greek","grc",[128],{"type":132,"bibl":133},"edition",[134,148,159],{"type":135,"n":136,"author":137,"date":138,"citedRange":139,"ptr":143,"ref":144,"inscriptionDate":138,"title":145,"citation":146,"uri":147,"year":138},"corpus","IG","Kaibel","1890",{"ref":140},{"_":141,"target":142},"416","https://clio.columbia.edu/catalog/6873760",{"target":144},"https://www.zotero.org/groups/382445/items/Q2SBPG9F","Inscriptiones Graecae Siciliae et Italiae, additis graecis Galliae Hispaniae, Britanniae, Germaniae inscriptionibus","\u003Cspan>G. Kaibel, \u003Ci>Inscriptiones Graecae Siciliae et Italiae, additis graecis Galliae Hispaniae, Britanniae, Germaniae inscriptionibus\u003C/i>, Inscriptiones Graecae consilio et auctoritate Academiae Litterarum Regiae Borussicae Editae. Volumen XIV., XIV (Berlin: Georgius Reimerus, 1890)\u003C/span>","https://www.zotero.org/groups/isicily/items/Q2SBPG9F",{"type":135,"n":149,"author":150,"date":151,"citedRange":64,"ptr":152,"ref":154,"inscriptionDate":151,"title":156,"citation":157,"uri":158,"year":151},"IMusMessina","Bitto","2001",{"target":153},"https://www.zotero.org/groups/382445/items/M9HMEP2R",{"_":155,"target":155},"https://biblio.inscriptiones.org/epig10000029","Le iscrizioni greche e latine di Messina","\u003Cspan>Irma Bitto, \u003Ci>Le iscrizioni greche e latine di Messina\u003C/i>, vol. 1, Pelorias 7 (Messina: Dipartimento di Scienze dell’Antichità dell’Università degli Studi di Messina, 2001)\u003C/span>","https://www.zotero.org/groups/isicily/it