:44},"#condition.complete",[46,50,53],{"_":47,"unit":48,"dimension":49},"23","cm","height",{"_":51,"unit":48,"dimension":52},"28.5","width",{"_":54,"unit":48,"dimension":55},"3.3","depth",{"layout":57},{"p":58,"rs":59,"damage":63},"The text is roughly centred on the stone.",{"_":60,"ana":61,"ref":62},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":64},"#text_condition.complete",{"lettering":66,"dimensions":67},"V-cut letters of slightly irregular module and height, with pronounced serifs. Interpuncts are above the line and not clearly distinguishable from apices",[68,77],{"type":69,"l":70,"from":71,"to":72,"h":73,"unit":74,"atLeast":75,"atMost":76},"letterHeight","Line 1-7","line1","line7","17-21","mm","17","21",{"type":78,"l":79,"from":71,"to":80,"unit":74},"interlinear","Interlineation line 1 to 2","line2",{"_":82,"notBefore":83,"notAfter":84,"evidence":85},"Second half of 2nd century CE or early 3rd century CE (Korhonen)",151,250,"prosopography",[87,92],{"_":88,"type":89,"ref":90,"region":91},"Catina","ancient","http://pleiades.stoa.org/places/462270","Sicilia",{"_":93,"type":94,"ref":95,"region":91},"Catania","modern","http://sws.geonames.org/2525068",[97],[98,99],37.49223,15.07041,{"_":101,"type":102,"subtype":103,"notAfter":104,"geo":105},"First observed, in the Biscari collection, by Mommsen. Mommsen considered it to be from Rome, but Korhonen rightly argues that the well attested presence of the Pompeii Sosii in Centuripe and Catania, and the physical form of the epitaph make a Catania - or Centuripe - provenance far more likely. Now in the Museo Civico (sala VII.229, mag. sup.)","found","discovered","1883",null,[],{"_":108,"type":109,"subtype":110,"geo":105},"Photographed but not transcribed, Prag 2016-10-14","observed","autopsied",[112,119],{"n":113,"url":114,"height":115,"width":116,"desc":117,"surfaceType":118},"screen","ISic003150_tiled.tif","4912px","7360px","I.Sicily with the permission of the Assessorato Regi