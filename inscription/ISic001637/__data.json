=\"paracivic.religious\" subtype=\"clerecus\">cle\n                        \u003Clb n=\"3\" break=\"no\"/>recus\u003C/roleName> de\n                        \u003Clb n=\"4\"/>Aqileia\n                    \u003Cmilestone unit=\"section\" n=\"c\"/>\n                        \u003Clb n=\"1\"/>Superianus\n                        \u003Clb n=\"2\"/>\u003CroleName type=\"paracivic.religious\" subtype=\"clerecus\">c\u003Csupplied reason=\"lost\">lerecus\u003C/supplied>\u003C/roleName> \u003Csupplied reason=\"lost\">de\u003C/supplied>\n                        \u003Clb n=\"3\"/>\u003Csupplied reason=\"lost\">Aqileia\u003C/supplied> \u003Csupplied reason=\"lost\">hic\u003C/supplied>\n                        \u003Clb n=\"4\"/>reqe\u003Csupplied reason=\"lost\">scet qui vix\u003C/supplied>\n                        \u003Clb n=\"5\" break=\"no\"/>et an\u003Csupplied reason=\"lost\">nos\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Agnello 1953\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--epitaph of Superianus, a clericus from Aquileia; inscr. is painted; Orsi records only the first text, writing that after it the inscription should continue on the ground or on the horizontal cover\nof the sarcophagus, which had been removed in his time... So where does the Agnello's edition come from? -->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n            