3C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"55\">·\u003C/g> \u003Cw n=\"60\">\u003Cexpan>\u003Cabbr>κ\u003C/abbr>\u003Cex>α\u003C/ex>\u003Cabbr>λ\u003C/abbr>\u003Cex>ανδῶν\u003C/ex>\u003C/expan>\u003C/w> \u003Cw n=\"65\">\u003Cexpan>\u003Cabbr>\u003Chi rend=\"ligature\">Μαρτ\u003C/hi>\u003C/abbr>\u003Cex>ί\u003C/ex>\u003Cabbr>\u003Chi rend=\"ligature\">ων\u003C/hi>\u003C/abbr>\u003C/expan>\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Θεοδούλη\">Θεοδούλη\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"ζάω\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ιη\">ιη\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"τελευτάω\">τελευτᾷ\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"ὁ\">τῇ\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"πρό\">πρὸ\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ε\">ε\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"kalendae\">καλανδῶν\u003C/w>\n                    \u003Cw n=\"65\" lemma=\"Martius\">Μαρτίων\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Agnello 1955\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Theodoule ezesen ete ih'. teleutai tei pro e' kalandon Martion (there is a graffito on the wall in the same 