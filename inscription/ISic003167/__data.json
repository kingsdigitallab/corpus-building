ons into EpiDoc\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003167_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003167.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Θεοδούλη\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"10\">ἔζησεν\u003C/w> \u003Cw n=\"15\">ἔ\u003Chi rend=\"ligature\">τη\u003C/hi>\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cnum value=\"18\">\u003Cw n=\"20\">\u003Chi rend=\"supraline\">ιη\u003C/hi>\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"25\">·\u003C/g> \u003Cw n=\"30\">\u003Chi rend=\"ligature\">τε\u003C/hi>λευτᾷ\u003C/w> \u003Cw n=\"35\">\u003Chi rend=\"ligature\">τῇ\u003C/hi>\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"40\">\u003Chi rend=\"ligature\">πρ\u003C/hi>ὸ\u003C/w> \u003Cg ref=\"#interpunct\" n=\"45\">·\u003C/g> \u003Cnum value=\"5\">\u003Cw n=\"50\">ε\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"55\">·\u003C/g> \u003Cw n=\"60\">\u003Cexpan>\u003Cabbr>κ\u003C/abbr>\u003Cex>α\u003C/ex>\u003Cabbr>λ\u003C/abbr>\u003Cex>ανδῶν\u003C/ex>\u003C/expan>\u003C/w> \u003Cw n=\"65\">\u003Cexpan>\u003Cabbr>\u003Chi rend=\"ligature\">Μαρτ\u003C/hi>\u003C/abbr>\u003Cex>ί\u003C/ex>\u003Cabbr>\u003Chi rend=\"ligature\">ων\u003C/hi>\u003C/abbr>\u003C/expan>\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Θεοδούλη\">Θεοδούλη\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"ζάω\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ιη\">ιη\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"τελευτάω\">τελευτᾷ\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"ὁ\">τῇ\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"πρό\">πρὸ\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ε\">ε\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"kalendae\">καλανδῶν\u003C/w>\n                    \u003Cw n=\"65\" lemma=\"Martius\">Μαρτίων\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Agnello 1955\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Theodoule ezesen ete ih'. teleutai tei pro e' kalandon Martion (there is a graffito on the wall in the same tomb, but although Agnello publishes a photo of a squeeze, and SEG mentions it, no-one ventures a text - it's very worn. We should record the graffito from the same arcosolium - see Agnello 1955, p.237 fig.18 - as a separate text).-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>15.0583\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Agnello\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1955\u003C/date>\n                        \u003CcitedRange>237 ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
