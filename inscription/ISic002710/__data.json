Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002710_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002710.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/IWUZJCRM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Λίπαρος\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>ἔζησεν ἔ\n                    \u003Clb n=\"3\" break=\"no\"/>τη \u003Cnum value=\"75\">οε\u003C/num> \u003CpersName type=\"attested\">\u003Cname>Π\n                    \u003Clb n=\"4\" break=\"no\"/>οσιδώνια\u003C/name>\u003C/persName> \u003Cchoice>\u003Corig>ποι\n                    \u003Clb n=\"5\" break=\"no\"/>ῖ\u003Creg>ποιι\u003C/reg>\u003C/orig>\u003C/choice> ἰδίῳ συνβίῳ\n                    \u003Clb n=\"6\"/>μνήμης χάριν\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Calderone\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>Liparos lived 75 years. Posidonia made (this) for her own partner, for the sake of memory\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The text is otherwise unknown, published by Calderone on the basis of autopsy and with a photograph of a what appears to be a squeeze in the publication.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Calderone\u003C/author>\n                        \u003Cdate>1949\u003C/date>\n                        \u003CcitedRange>59-60 ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/IWUZJCRM\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002101\">https://biblio.inscriptiones.org/epig10002101\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
