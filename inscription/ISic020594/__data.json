7\">Museo Archeologico di Giardini Naxos\u003C/repository>\u003C!-- check this information -->\n                        \u003Cidno type=\"inventory\"/>\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>    \n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>Black-glazed kylix (Attic).\u003C/p>\n                                    \u003Cmaterial ana=\"#material.clay.fired\" ref=\"https://www.eagle-network.eu/voc/material/lod/131.html\">ceramic\u003C/material>\n                                    \u003CobjectType ana=\"#object.vessel.kylix\" ref=\"http://kerameikos.org/id/kylix\">kylix\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cdim type=\"diameter\" unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.scratched\" ref=\"https://www.eagle-network.eu/voc/writing/lod/9\">scratched\u003C/rs>\n  