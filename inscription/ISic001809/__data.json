ang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"0\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" n=\"5\"/>\n                    \u003Clb n=\"1\"/>\u003Cw n=\"10\">ἔζησ\n                    \u003Clb n=\"2\" break=\"no\"/>η\u003C/w> \u003Cw n=\"15\">ἔτη\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cnum value=\"30\">\u003Cw n=\"20\">λ\u003C/w>\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" n=\"5\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cw n=\"10\" lemma=\"ζάω\">ἔζηση\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"λ\">λ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based upon transcription in museum inventory\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp>[--] lived for 30 years\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Although the fragment appears from the drawing in the inventory to be broken on all sides, space is visible before and after the lambda in line 3, and the text appears intact as it stands, missing only the earlier part naming the deceased. The fragment appears to be unpublished.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"di