C/change>\n                \u003Cchange when=\"2025-07-24\" who=\"#VF\">Victoria Fendel's lemmatizations were added\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000641_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000641.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#AL\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname type=\"nomen\">\u003Cw n=\"5\">Σεπτίκις\u003C/w>\u003C/name> \u003Cg ref=\"#ivy-leaf\" n=\"10\">❦\u003C/g> \u003Cname type=\"cognomen\">\u003Cw n=\"15\">Ὡραὶς\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"20\">χρηστὸς\u003C/w> \u003Cw n=\"25\">καὶ\u003C/w> \u003Cw n=\"30\">ἄμε\u003Csupplied reason=\"omitted\">μ\u003C/supplied>\n                    \u003Clb n=\"3\" break=\"no\"/>πτος\u003C/w> \u003Cg ref=\"#ivy-leaf\" n=\"35\">❦\u003C/g> \u003Cw n=\"40\">ἔζησεν\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"45\">ἔτη\u003C/w> \u003Cg ref=\"#ivy-leaf\" n=\"50\">❦\u003C/g> \u003Cnum value=\"55\">\u003Cw n=\"55\">νε\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"60\">·\u003C/g> \u003Cw n=\"65\">μῆνες\u003C/w> \u003Cg ref=\"#interpunct\" n=\"70\">·\u003C/g>\n                    \u003Clb n=\"5\"/>\u003Cnum value=\"3\">\u003Cw n=\"75\">γ\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"80\">·\u003C/g> \u003Cw n=\"85\">ἡμέρες\u003C/w>\n                    \u003Clb n=\"6\"/>\u003Cnum value=\"15\">\u003Cw n=\"90\">ει\u003C/w>\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Σεπτίκις\">Σεπτίκις\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"Ὡραίς\">Ὡραὶς\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"χρηστός\">χρηστὸς\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"καί\">καὶ\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"ἄμεμπτος\">ἄμεμπτος\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"ζάω\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"45\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"55\" lemma=\"νε\">νε\u003C/w>\n                    \u003Cw n=\"65\" lemma=\"μείς\">μῆνες\u003C/w>\n                    \u003Cw n=\"75\" lemma=\"γ\">γ\u003C/w>\n                    \u003Cw n=\"85\" lemma=\"ἡμέρα\">ἡμέρες\u003C/w>\n                    \u003Cw n=\"90\" lemma=\"ει\">ει\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>text according to Manganaro 1994, 85-86, with photograph\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Manganaro's edition depicts an interpunct between the epsilon and the iota of the final line, but in the photograph he provides it is not clear, and it seems unlikely\u003C/p>\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Septikis Horais, chrestos kai amemptos, age in years, months, days;a freedman of gens Septicia (cf. Q. Septicius, eques, in Verr. 2.3.36). name also at IG 14.510, cf. BE 1974.422 - interesting for the (fairly common) Sicilian name form in -is.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1994.0764\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>44.0762\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1994\u003C/date>\n                        \u003CcitedRange>85-86 no.4 fig.7\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/532NF7SV\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001825\">https://biblio.inscriptiones.org/epig10001825\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
