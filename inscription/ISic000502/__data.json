csimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>arcus\u003C/ex>\u003C/expan> Paconius \u003Cexpan>\u003Cabbr>L\u003C/abbr>\u003Cex>uci\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilius\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>Pomp\u003C/abbr>\u003Cex>tina tribu\u003C/ex>\u003C/expan> Vipsanus Pr\u003Csupplied reason=\"lost\">o\u003C/supplied>culus\n                    \u003Clb n=\"2\"/>\u003CroleName type=\"civic\" subtype=\"aedilis\">\u003Cexpan>\u003Cabbr>aed\u003C/abbr>\u003Cex>ilis\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cexpan>\u003Cabbr>aed\u003C/abbr>\u003Cex>em\u003C/ex>\u003C/expan> Genio \u003Cexpan>\u003Cabbr>Col\u003C/abbr>\u003Cex>oniae\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>Aug\u003C/abbr>\u003Cex>ustae\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>Lilybit\u003C/abbr>\u003Cex>anorum\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>ua\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex>ecunia \u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ecit\u003C/ex>\u003C/expan>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                    \u003ClistApp>\u003Capp>\u003Cnote>text of CIL\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Marcus Paconius Vipsanus Proculus, son of Lucius, of the Pomptina tribe, aedile, constructed a temple for the Genius of the Colonia Augusta Lilybitanorum at his own expense.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Marcus Paconius, Lucii filius, Pomp. Vipsanus, Proculus aedilis aedem genio coloniae Augustae Lilybitanorum s(ua) p(ecunia) f(ecit).-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1769\u003C/date>\n                        \u003CcitedRange>cl.2, no.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SPTB56H3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002084\">https://biblio.inscriptiones.org/epig10002084\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1784\u003C/date>\n                        \u003CcitedRange>cl.2, no.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/7PSFHSUH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002083\">https://biblio.inscriptiones.org/epig10002083\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7222\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                