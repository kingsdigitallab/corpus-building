                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"d\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003Corig>Υ\u003C/orig>\n                    \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"e\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003Corig>ΙΑ\u003C/orig>\u003Cgap reason=\"lost\" quantity=\"2\" unit=\"character\"/>\u003Corig>ΑΣΝ\u003C/orig> \u003Corig>Θ\u003C/orig> \u003Corig>Π\u003C/orig>\n                    \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"f\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003Corig>Λ\u003C/orig>\n                    \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Gentili 1956\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--depicts, i.a., a ship, with letters. Graffiti and drawings on wall plaster. According to Gentili they were made by inexperienced hands, perhaps a beginner practising his writing. They are found on the same wall and are certainly part of the same design but are located on different points of it.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>16.0537\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Gentili\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1956\u003C/date>\n                        \u003CcitedRange>135-138 figs.1-3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
