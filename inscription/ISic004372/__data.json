//www.eagle-network.eu/voc/writing/lod/1",{"ana":59},"#text_condition.incomplete",{"dimensions":61},[62,69],{"type":63,"l":64,"from":65,"to":66,"h":67,"unit":68,"atLeast":67,"atMost":67},"letterHeight","Lines 1-3","line1","line3","90","mm",{"type":70,"l":71,"from":65,"to":72,"unit":68},"interlinear","Interlineation line 1 to 2","line2",{"_":74,"notBefore":75,"notAfter":76,"evidence":77},"Assuming Manganaro's hypothesis that this side is secondary is correct, this text post-dates 96 CE. Attribution to Lucilla would date this to 164-168/9 CE.",96,169,"prosopography",[79,84],{"_":80,"type":81,"ref":82,"region":83},"Tauromenium","ancient","http://pleiades.stoa.org/places/462506","Sicilia",{"_":85,"type":86,"ref":87,"region":83},"Taormina","modern","http://sws.geonames.org/2522975",[89],[90,91],37.85358,15.28851,{"_":93,"type":94,"subtype":95,"notAfter":96,"geo":17},"First recorded by Manganaro in storage at the antiquarium prior to 1964.","found","discovered","1964",[],{"_":99,"type":100,"subtype":101,"geo":17},"None","observed","autopsied",[103,110],{"n":104,"url":105,"height":106,"width":107,"desc":108,"surfaceType":109},"screen","ISic004372_tiled.tif","2592px","1944px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31","front",{"n":104,"url":111,"height":106,"width":107,"desc":108,"surfaceType":112},"ISic004372_rear_tiled.tif","rear","Sicily",{"_":115,"role":116,"ref":117,"museum":118},"Antiquarium del Teatro Antico","museum","http://sicily.classics.ox.ac.uk/museum/062",{"slug":119,"type":116,"name":115,"uri":117,"description":120,"location":121},"062","The collection in the \"Casina degli Inglesi\" consists of 20 inscriptions, 1 statue, two busts, a few mosaics, a 2nd C AD marble sarcophagus and some modern art",{"settlement":85,"region":122,"country":123,"address":124,"geo":125},"Messina","Italy","Via del Teatro Greco 40, 98039 - Taormina (ME)",{"lat":126,"lon":127},37.85178,15.29253,{"_":129,"mainLang":130,"languages":131},"Latin","la",[129],{"type":133,"bibl":134},"edition",[135],{"author":136,"date":96,"citedRange":137,"ptr":138,"ref":139,"inscriptionDate":96,"title":140,"citation":141,"uri":142,"year":96},"Manganaro","42 no.4 tav.XVI.1",{"target":139},"https://www.zotero.org/groups/382445/items/FQZIP29F","Iscrizioni latine e greche dal nuovo edificio termale di Taormina","\u003Cspan>Giacomo Manganaro, «Iscrizioni latine e greche dal nuovo edificio termale di Taormina», \u003Ci>Cronache di archeologia e di storia dell’arte\u003C/i> 3 (1964): 38–68\u003C/span>","https://www.zotero.org/groups/isicily/items/FQZIP29F",{"type":144,"bibl":145},"discussion",[17],{"editor":147,"principal":150,"contributors":151,"change":167},{"_":148,"ref":149},"Jonathan Prag","#JP",{"_":148,"ref":149},[152,155,159,163],{"_":148,"xml:id":153,"ref":154},"JP","http://orcid.org/0000-0003-3819-8537",{"_":156,"xml:id":157,"ref":158},"James Cummings","JCu","http://orcid.org/0000-0002-6686-3728",{"_":160,"xml:id":161,"ref":162},"Simona Stoyanova","SS","https://orcid.org/0000-0003-3914-9569",{"_":164,"xml:id":165,"ref":166},"Alessia Coccato","Coccato","https://orcid.org/0000-0002-6641-2820",{"_":168,"when":169,"who":149},"Jonathan Prag revised from publication and photograph and added images","2024-08-13","",{"n":104,"url":105,"height":106,"width":107,"desc":108,"surfaceType":109},[173],{"atLeast":174,"atMost":174},90,[176],"Manganaro, 1964, Iscrizioni latine e greche dal nuovo edificio termale di Taormina",[178],"FQZIP29F",[180,181,182,183,28,32,184,185,186,187,185,188,189,130],"isic004372","fragment of an imperial honorific",{"_":5},"honorific","tauromenium","taormina","sicilia","sicily","antiquarium del teatro antico","latin",[],{"title":192,"body":193,"divs":194,"editions":219,"images":229,"handnote":240},"ISic004372. Fragment of an imperial honorific","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"la\">  \u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span> A]ug(- - -) \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span> Lucil?]lae \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ịani \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"la\">\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>.]UG\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>.....]LAE\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>].ANI\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic004372_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\" src=\"ISic004372_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic004372.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\" src=\"ISic004372-thumb.jpg\">\u003C/a>\u003Ca href=\"ISic004372_rear_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\" src=\"ISic004372_rear_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic004372_rear.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\" src=\"ISic004372_rear-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text from photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"1\">1: \u003Cspan>Manganaro: [Divae A]ug(ustae) [---]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"2\">2: \u003Cspan>Manganaro: [Lucil]lae\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"3\">3: \u003Cspan>Manganaro: [Tauromenit]ani\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2> translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>  \u003C/p>\u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>Manganaro's text cannot stand, firstly as there is clearly no missing text at the end of line 1, and secondly because an upright, presumably an 'I' (although H or N would also be possible) is clearly visible at the start of line 3, making the exempli gratia restoration of Tauromenitani impossible. Parallels for dedications to the Diva Lucilla are hard to find, and the sequence here with AVG before Lucilla (assuming [--]lae is Lucilla) would suggest a dedication to e.g. either one or more of her brothers and herself (compare \u003Ca href=\"https://irt2021.inslib.kcl.ac.uk/en/inscriptions/IRT0025.html\" target=\"_blank\">IRT0025\u003C/a>), or one or her children, or some other such familial combination in which she does not appear first. However, it should also be noted that other imperial female names from the first century CE could fit here too, such as Drusilla and Domitilla, and the palaeography makes it far from certain that this face is later than the other side.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Manganaro 1964 42 no.4 tav.XVI.1 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001842\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001842\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\"> Lines 1-3  90  Interlineation line 1 to 2    \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence.  \u003C/div>",[195,198,201,204,207,210,213,216],{"id":196,"html":197},"editions","\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"la\">  \u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span> A]ug(- - -) \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span> Lucil?]lae \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ịani \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"la\">\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>.]UG\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>.....]LAE\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>].ANI\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":199,"html":200},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic004372_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\" src=\"ISic004372_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic004372.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\" src=\"ISic004372-thumb.jpg\">\u003C/a>\u003Ca href=\"ISic004372_rear_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\" src=\"ISic004372_rear_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic004372_rear.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\" src=\"ISic004372_rear-thumb.jpg\">\u003C/a>",{"id":202,"html":203},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text from photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"1\">1: \u003Cspan>Manganaro: [Divae A]ug(ustae) [---]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"2\">2: \u003Cspan>Manganaro: [Lucil]lae\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"3\">3: \u003Cspan>Manganaro: [Tauromenit]ani\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":205,"html":206},"translation","\u003Ch2> translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>  \u003C/p>",{"id":208,"html":209},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>Manganaro's text cannot stand, firstly as there is clearly no missing text at the end of line 1, and secondly because an upright, presumably an 'I' (although H or N would also be possible) is clearly visible at the start of line 3, making the exempli gratia restoration of Tauromenitani impossible. Parallels for dedications to the Diva Lucilla are hard to find, and the sequence here with AVG before Lucilla (assuming [--]lae is Lucilla) would suggest a dedication to e.g. either one or more of her brothers and herself (compare \u003Ca href=\"https://irt2021.inslib.kcl.ac.uk/en/inscriptions/IRT0025.html\" target=\"_blank\">IRT0025\u003C/a>), or one or her children, or some other such familial combination in which she does not appear first. However, it should also be noted that other imperial female names from the first century CE could fit here too, such as Drusilla and Domitilla, and the palaeography makes it far from certain that this face is later than the other side.\u003C/p>  ",{"id":211,"html":212},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Manganaro 1964 42 no.4 tav.XVI.1 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001842\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001842\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  ",{"id":214,"html":215},"handnote"," Lines 1-3  90  Interlineation line 1 to 2    ",{"id":217,"html":218},"license"," Licensed under a Creative Commons-Attribution 4.0 licence.  ",[220,222,225,226],{"html":221},"Text encoding: Jonathan Prag",{"id":223,"lang":130,"html":224},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span> A]ug(- - -) \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span> Lucil?]lae \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ịani \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":221},{"id":227,"lang":130,"html":228},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>.]UG\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>.....]LAE\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>].ANI\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",[230,232,235,237],{"image":105,"thumb":231,"title":108},"ISic004372_tiled-thumb.tif",{"image":233,"thumb":234,"title":108},"ISic004372.jpg","ISic004372-thumb.jpg",{"image":111,"thumb":236,"title":108},"ISic004372_rear_tiled-thumb.tif",{"image":238,"thumb":239,"title":108},"ISic004372_rear.jpg","ISic004372_rear-thumb.jpg",[],"\u003C?xml version='1.0' encoding='UTF-8'?>\n\u003C?xml-model href=\"https://epidoc.stoa.org/schema/latest/tei-epidoc.rng\" type=\"application/xml\" schematypens=\"http://relaxng.org/ns/structure/1.0\"?>\n\u003C?xml-model href=\"../schematron/ircyr-checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XInclude\" xml:lang=\"en\">\n    \u003CteiHeader>\n        \u003CfileDesc>\n            \u003CtitleStmt>\n                \u003Ctitle>Fragment of an imperial honorific\u003C/title>\n                \u003Ceditor ref=\"#JP\">Jonathan Prag\u003C/editor>\n                \u003Cprincipal ref=\"#JP\">Jonathan Prag\u003C/principal>\n                \u003Cfunder>John Fell OUP Research Fund\u003C/funder>\n\t   \u003Cfunder>\u003Cref target=\"https://cordis.europa.eu/project/id/885040\">ERC Advanced Grant no.885040\u003C/ref>\u003C/funder>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>original data collection and editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JCu\" ref=\"http://orcid.org/0000-0002-6686-3728\">James Cummings\u003C/name>\n                    \u003Cresp>conversion to EpiDoc\u003C/resp>\n                \u003C/respStmt>\n\t    \u003CrespStmt>\n     \t       \u003Cname xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n     \t       \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n \t   \u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic004372\u003C/idno>\n                \u003Cidno type=\"TM\"/>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\"/>\n                \u003Cidno type=\"PHI\"/>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic004372\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-21\">10.5281/zenodo.4381825\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\n                    \u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Taormina\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/062\">Antiquarium del Teatro Antico\u003C/repository>\n                        \u003C!--No inventory number found-->\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"la\">Latin\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>Eight joining fragments of the upper right corner of a marble plaque, broken on the left and below (only seven fragments were seen by Manganaro). The other side of the plaque bears a similar text, a dedication to Domitia wife of Domitian (same support as \u003Cref sameAs=\"ISic004371.xml\">ISic004371\u003C/ref>).\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.marble\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/259\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">48\u003C/height>\n                                        \u003Cwidth unit=\"cm\">32\u003C/width>\n                                        \u003Cdepth unit=\"cm\">2\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragments.contiguous\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage ana=\"#text_condition.incomplete\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Clocus from=\"line1\" to=\"line3\">Lines 1-3\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"90\" atMost=\"90\">90\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462506\">Tauromenium\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2522975\">Taormina\u003C/placeName>\n                            \t\u003Cgeo>37.85358, 15.28851\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0096\" notAfter-custom=\"0169\" evidence=\"prosopography\">Assuming Manganaro's hypothesis that this side is secondary is correct, this text post-dates 96 CE. Attribution to Lucilla would date this to 164-168/9 CE.\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"1964\">First recorded by Manganaro in storage at the antiquarium prior to 1964.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>                    \n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.honorific\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/69.html\">Honorific\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2017-11-10\" who=\"#JP\">Jonathan Prag created draft file from publication\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-21\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2024-08-13\" who=\"#JP\">Jonathan Prag revised from publication and photograph and added images\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic004372_tiled.tif\" height=\"2592px\" width=\"1944px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\u003C/desc>            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic004372.jpg\" height=\"2592px\" width=\"1944px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\u003C/desc>            \u003C/graphic>\n        \u003C/surface>\n        \u003Csurface type=\"rear\">\n            \u003Cgraphic n=\"screen\" url=\"ISic004372_rear_tiled.tif\" height=\"2592px\" width=\"1944px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\u003C/desc>            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic004372_rear.jpg\" height=\"2592px\" width=\"1944px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\u003C/desc>            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Cabbr>\u003Csupplied reason=\"lost\">A\u003C/supplied>ug\u003C/abbr>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Csupplied reason=\"lost\" cert=\"low\">Lucil\u003C/supplied>lae\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cunclear>i\u003C/unclear>ani\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text from photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Manganaro: [Divae A]ug(ustae) [---]\u003C/note>\u003C/app>\n                    \u003Capp loc=\"2\">\u003Cnote>Manganaro: [Lucil]lae\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>Manganaro: [Tauromenit]ani\u003C/note>\u003C/app>                    \n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Manganaro's text cannot stand, firstly as there is clearly no missing text at the end of line 1, and secondly because an upright, presumably an 'I' (although H or N would also be possible) is clearly visible at the start of line 3, making the exempli gratia restoration of Tauromenitani impossible. Parallels for dedications to the Diva Lucilla are hard to find, and the sequence here with AVG before Lucilla (assuming [--]lae is Lucilla) would suggest a dedication to e.g. either one or more of her brothers and herself (compare \u003Cref target=\"https://irt2021.inslib.kcl.ac.uk/en/inscriptions/IRT0025.html\">IRT0025\u003C/ref>), or one or her children, or some other such familial combination in which she does not appear first. However, it should also be noted that other imperial female names from the first century CE could fit here too, such as Drusilla and Domitilla, and the palaeography makes it far from certain that this face is later than the other side.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1964\u003C/date>\n                        \u003CcitedRange>42 no.4 tav.XVI.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FQZIP29F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001842\">https://biblio.inscriptiones.org/epig10001842\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
