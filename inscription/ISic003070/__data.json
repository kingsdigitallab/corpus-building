3Cgraphic n=\"screen\" url=\"ISic003070_detail_tiled.tif\" height=\"4000px\" width=\"6000px\">\n                \u003Cdesc>Photo R.J.A. Wilson\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003070_detail.jpg\" height=\"4000px\" width=\"6000px\">\n                \u003Cdesc>Photo R.J.A. Wilson\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Ἀχιλλεὺς\u003C/w>\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw n=\"10\">Προθύμου\u003C/w>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"15\">χαῖρε\u003C/w> \u003Cw n=\"20\">καὶ\u003C/w> \u003Cw n=\"25\">κατὰ\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"30\">χθονός\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Ἀχιλλεύς\">Ἀχιλλεὺς\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Πρόθυμος\">Προθύμου\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"χαίρω\">χαῖρε\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"καί\">καὶ\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"κατά\">κατὰ\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"χθών\">χθονός\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text from photograph\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--limestone column, with white stucco, on which a painted panel, depicting standing male figure between two large raised hands, of probable apotropaic signif. epitaph is: Achilleus Prothumou | chaire kai kata chthonos-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>39.1005\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>34.0955\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Di Stefano\u003C/author>\n                        \u003Cdate>1984\u003C/date>\n                        \u003CcitedRange>175 no.191 ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q5PB252W\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002035\">https://biblio.inscriptiones.org/epig10002035\u003C/ref>\n                    \u003C/bibl>\n                    \