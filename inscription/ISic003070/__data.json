x\" width=\"6000px\">\n                \u003Cdesc>Photo R.J.A. Wilson\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Ἀχιλλεὺς\u003C/w>\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw n=\"10\">Προθύμου\u003C/w>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"15\">χαῖρε\u003C/w> \u003Cw n=\"20\">καὶ\u003C/w> \u003Cw n=\"25\">κατὰ\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"30\">χθονός\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Ἀχιλλεύς\">Ἀχιλλεὺς\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Πρόθυμος\">Προθύμου\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"χαίρω\">χαῖρε\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"καί\">καὶ\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"κατά\">κατὰ\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"χθών\">χθονός\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text from photograph\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision--