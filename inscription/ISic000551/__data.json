003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.honorific\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/69.html\">honorific\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-03-15\" who=\"#GC\">edited text and added english and italian translations\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000551_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000551.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#GC\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Paconio\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Clodiano\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003CroleName type=\"paracivic\" subtype=\"patronus\">patrono\u003C/roleName> \u003Cg ref=\"#interpunct\">·\u003C/g> bene\n                    \u003Clb n=\"3\"/>merenti\n                    \u003Clb n=\"4\"/>ex \u003Cg ref=\"#interpunct\">·\u003C/g> aere \u003Cg ref=\"#interpunct\">·\u003C/g> conlato\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of CIL\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#GC\">\n                \u003Cp>To Paconius Clodianus, most deserving patron, (gift) from communally collected money.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#GC\">\n                \u003Cp>A Paconius Clodianus, meritevole patrono, (dono) finanziato con denaro pubblico.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Mommsen rightly notes that there is a very close overlap between this text and the slightly fuller one recorded at Marsala in CIL 10.7238, such that it is possible that these are corrupted records of the same original inscription\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624\u003C/date>\n                        \u003CcitedRange>75\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GIN6NANU\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002388\">https://biblio.inscriptiones.org/epig10002388\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>223\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7294\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
