"screen\" url=\"ISic003543_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003543.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>\u003Chi rend=\"ligature\">ma\u003C/hi>\u003C/abbr>\u003Cex>nibus\u003C/ex>\u003C/expan> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Victor\u003C/name>\u003C/persName> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g> \u003Cexpan>\u003Cabbr>vix\u003C/abbr>\u003Cex>it\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"3\"/>\u003Cexpan>\u003Cabbr>ann\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cnum value=\"51\">L\u003Cg ref=\"#interpunct\">·\u003C/g>I\u003C/num> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>fec\u003C/abbr>\u003Cex>it\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003CpersName type=\"attested\">\u003Cname>Cha\u003Chi rend=\"ligature\">ri\u003C/hi>s\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Bivona\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Ferrua recorded as being in Taormina museum, but from Palermo; in reality, it was part of the Museo di S. Martino, now in the Palermo archaeological museum, and original from Rome.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1982.0418\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1941\u003C/date>\n                        \u003CcitedRange>267 no.35\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/P7QQ9SB6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002655\">https://biblio.inscriptiones.org/epig10002655\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILMusPalermo\">\n                        \u003Cauthor>Bivona\u003C/author>\n                        \u003Cdate>1970\u003C/date> \n                        \u003CcitedRange>342\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\"/>\n                       