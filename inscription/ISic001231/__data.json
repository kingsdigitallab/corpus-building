3C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#ivy-leaf\">❦\u003C/g> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>Θ\u003C/abbr>\u003Cex>εοῖς\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>Κ\u003C/abbr>\u003Cex>αταχθονίοις\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g>\n                    \u003Clb n=\"2\"/>Ἀνδρόβιος \u003Cg ref=\"#interpunct\">·\u003C/g> Λύκιος \u003Cg ref=\"#interpunct\">·\u003C/g> ναύ\n                    \u003Clb n=\"3\" break=\"no\"/>κληρος \u003Cg ref=\"#interpunct\">·\u003C/g> ἔζησε \u003Cg ref=\"#interpunct\">·\u003C/g> ἀ\u003Chi rend=\"ligature\">πρ\u003C/hi>όσκοπτ\u003Chi rend=\"small\">ο\u003C/hi>ς \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"4\"/>ἔτη \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Chi rend=\"supraline\">λϛ\u003C/hi> \u003Cg ref=\"#interpunct\">·\u003C/g> Ἀπολλώνιος \u003Cg ref=\"#interpunct\">·\u003C/g> σὺν\n                    \u003Clb n=\"5\"/>Μουσαίῳ \u003Cg ref=\"#interpunct\">·\u003C/g> καὶ Θεοδώρῳ \u003Cg ref=\"#interpunct\">·\u003C/g> ἀ\n                    \u003Clb n=\"6\" break=\"no\"/>δελφῷ \u003Cg ref=\"#interpunct\">·\u003C/g> ἰδίῳ \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Chi rend=\"ligature\">μν\u003C/hi>ήμης \u003Cg ref=\"#interpunct\">·\u003C/g> εἵνεκεν\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based on I.Messina 29\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>To the underworld deities, Androbios Lukios, shipowner, lived without offence for 36 years. Erected by his brother Apollonios, with Mousiaos and Theodoros, for the memory of our brother\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Androbios Lukios, naukleros; erected by his brother Apollonios, with Mousiaos and Theodoros; use of idios as poss. pron.; Th.K. heading; hederae. Given that he's a naukleros, it should be compared to IG.14.401? It is presumably relatively late? Cf. SEG 4.21 for another later inscr. of a naukleros.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">404\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusMessina\">\n                         \u003Cauthor>Bitto\u003C/author>\n                         \u003Cdate>2001\u003C/date> \n                        \u003CcitedRange>29\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/M9HMEP2R\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000029\">https://biblio.inscriptiones.org/epig10000029\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5625\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Salvo\u003C/author>\n                        \u003Cdate>1979\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/CIECXWAT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002046\">https://biblio.inscriptiones.org/epig10002046\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1965\u003C/date>\n                        \u003CcitedRange>207\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RGTHAFKT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001841\">https://biblio.inscriptiones.org/epig10001841\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzo\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>no.69\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/K83EWCEC\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001640\">https://biblio.inscriptiones.org/epig10001640\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Salvo\u003C/author>\n                        \u003Cdate>1992\u003C/date>\n                  