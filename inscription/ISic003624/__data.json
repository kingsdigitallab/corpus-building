/>\u003CpersName type=\"attested\">\u003Cname>Ἀρκαδείῳ\u003C/name>\u003C/persName> τὸ \u003Cnum value=\"5\">ε\u003C/num> καὶ \u003CpersName type=\"attested\">\u003Cname>Ὁνορίῳ\u003C/name>\u003C/persName> τὸ \u003Cnum value=\"5\">ε\u003C/num>\n                    \u003Clb n=\"2\"/>πρὸ \u003Cnum value=\"8\">η\u003C/num> καλανδῶν ἰουλίων \u003CpersName type=\"attested\">\u003Cname>Ζ\u003Csupplied reason=\"lost\">ώσι\u003C/supplied>\n                    \u003Clb n=\"3\" break=\"no\"/>μος\u003C/name>\u003C/persName> χρηστὸς ἐτελεύτησεν ἐ\u003Csupplied reason=\"lost\">τῶν\u003C/supplied>\n                    \u003Clb n=\"4\"/>\u003Cnum value=\"45\">με\u003C/num> ἡμέρᾳ \u003CpersName type=\"divine\">\u003Cname>Ἄρεος\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after Rizzone\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Orsi, Ferrua: Ὁνωρίῳ\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>Rizzone: μ ρᾳ (presumably a typographic omission)\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>In the consulship of Arkadios for the fifth time and of Honorios for the fifth time, 8 days before the Kalend of July, worthy Zosimos passed away aged 45 years, on the day of Ares\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"Rizzone\">\n                \u003Cp>Nel quinto consolato di Arcadio e nel quinto consolato di Onorio, 8 giorni prima delle calende di luglio, il buon Zosimos morì, a 45 anni, nel giorno di Ares\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1934\u003C/date>\n                        \u003CcitedRange>151 no.2 fig.21\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JKHW55K5\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001697\">https://biblio.inscriptiones.org/epig10001697\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1982-1983\u003C/date>\n                        \u003CcitedRange>no.27\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q7DDNWD6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001996\">https://biblio.inscriptiones.org/epig10001996\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzone\u003C/author>\n                        \u003Cdate>2009\u003C/date>\n                        \u003CcitedRange>54 no.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/8ENX9UZ5\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001633\">https://biblio.inscriptiones.org/epig10001633\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
