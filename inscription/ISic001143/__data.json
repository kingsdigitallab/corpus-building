7","width",{"_":50,"unit":44,"dimension":51},"2.3","depth",{"layout":53},{"rs":54,"damage":40},{"_":55,"ana":56,"ref":57},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"dimensions":59},[60,65],{"type":61,"l":62,"from":63,"to":63,"unit":64},"letterHeight","Line 1","line1","mm",{"type":66,"l":67,"from":63,"to":68,"unit":64},"interlinear","Interlineation line 1 to 2","line2",{"_":70,"notBefore":71,"notAfter":72},"5th century CE",401,500,[74,79],{"_":75,"type":76,"ref":77,"region":78},"Thermae Himeraeae","ancient","http://pleiades.stoa.org/places/462513","Sicilia",{"_":80,"type":81,"ref":82,"region":78},"Termini Imerese","modern","http://sws.geonames.org/6539140",[84],[85,86],37.98365,13.69555,{"_":88,"type":89,"subtype":90,"geo":20},"Found with CIL 10.7412 (ISic000183) outside the city gates of Termini in 1824","found","discovered",[],{"_":93,"type":94,"subtype":95,"geo":20},"None","observed","autopsied",[97],{"n":98,"url":99,"height":100,"width":101,"desc":102,"surfaceType":103},"screen","ISic001143_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Sicily",{"_":106,"role":107,"ref":108,"museum":109},"Museo Civico Baldassare Romano","museum","http://sicily.classics.ox.ac.uk/museum/066",{"slug":110,"type":107,"name":106,"uri":108,"description":111,"location":112},"066","A large and well-displayed collection. It begins with three ante-rooms, in the first of which is a rich display of lithics (mainly Neolithic) from the surrounding area. A display of material from Himera (lion-head spouts from the Temple of Victory and red-figure craters being the principle pieces) and a numismatic gallery then follow before the main room which contains Hellenistic and Roman material from Termini Imerese itself. Small finds, sculpture and inscriptions predominate. The museum collection continues upstairs with non-archaeological material (and a single inscription). The courtyard of the building holds a large collection of architectural pieces and inscriptions",{"settlement":80,"region":113,"country":114,"address":115,"geo":116},"Palermo","Italy","Via Marco Tullio Cicerone, 90018 - Termini Imerese (PA)",{"lat":117,"lon":118},37.98655109,13.69587845,{"_":120,"type":121},"137","inventory",{"_":123,"mainLang":124,"languages":125},"Ancient Greek","grc",[123],{"type":127,"bibl":128},"edition",[129,140,154,166],{"author":130,"date":131,"citedRange":132,"ptr":133,"ref":135,"inscriptionDate":131,"title":137,"citation":138,"uri":139,"year":131},"Crispi","1824","82 no.1",{"target":134},"https://www.zotero.org/groups/382445/items/43IBXI4E",{"_":136,"target":136},"https://biblio.inscriptiones.org/epig10002585","Spiegazione di due iscrizioni trovate nella citta di Termini","\u003Cspan>Giuseppe Crispi, «Spiegazione di due iscrizioni trovate nella citta di Termini», \u003Ci>Giornale di scienze, letteratura ed arti per la Sicilia\u003C/i> 7, fasc. 2 (1824): 82–84\u003C/span>","https://www.zotero.org/groups/isicily/items/43IBXI4E",{"type":141,"n":142,"author":143,"date":144,"citedRange":145,"ptr":149,"ref":150,"inscriptionDate":144,"title":151,"citation":152,"uri":153,"year":144},"corpus","IG","Kaibel","1890",{"ref":146},{"_":147,"target":148},"324","https://clio.columbia.edu/catalog/6873760",{"target":150},"https://www.zotero.org/groups/382445/items/Q2SBPG9F","Inscriptiones Graecae Siciliae et Italiae, additis graecis Galliae Hispaniae, Britanniae, Germaniae inscriptionibus","\u003Cspan>G. Kaibel, \u003Ci>Inscriptiones Graecae Siciliae et Italiae, additis graecis Galliae Hispaniae, Britanniae, Germaniae inscriptionibus\u003C/i>, Inscriptiones Graecae consilio et auctoritate Academiae Litterarum Regiae Borussicae Editae. Volumen XIV., XIV (Berlin: Georgius Reimerus, 1890)\u003C/span>","https://www.zotero.org/groups/isicily/items/Q2SBPG9F",{"type":141,"n":155,"author":156,"date":15