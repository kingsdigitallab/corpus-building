 Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Μάξιμος\u003C/w>\u003C/name>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw n=\"10\">Διδύμου\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"15\">υἱὸς\u003C/w>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"20\">ἔζησεν\u003C/w> \u003Cw n=\"25\">ἔτη\u003C/w> \u003Cnum value=\"23\">\u003Cw n=\"30\">κγ\u003C/w>\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Μάξιμος\">Μάξιμος\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Δίδυμος\">Διδύμου\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"υἱός\">υἱὸς\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ζῶ\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"κγ\">κγ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of IGTermini\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Maximos son of Didymos lived for 23 years\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n           