ear>πεν βιότο\u003Cunclear>υ\u003C/unclear>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Guarducci 1987 with slight changes based on photograph\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#VM\">\n                \u003Cp>Honouring wisdom and venerating justice, in his youth Hippò left the breath of life.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp>Guarducci: Onorando la saggezza e venerando la giustizia, Hippò in gioventù il soffio lasciò della vita.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--funerary epigram for Hippo. 3 lines: Sophrosuneh timwsa dikaiosunhn te sebousa Hippw en helikiai pneum elipen biotou-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>42.0848\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Lavore\u003C/author>\n                        \u003Cdate>1985\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/M26DNRHT\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001886\">https://biblio.inscriptiones.org/epig10001