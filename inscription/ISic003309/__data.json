Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΦΡΟ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΩΝ\u003Cspan data-text=\"τῇ\">ΤΗ\u003C/span>\u003Cspan data-text=\"πρὸ\">[...]\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>\u003Cspan data-text=\"καλανδῶν\">.]ΑΛΑΝΔ[..]\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"Ὀκτωβρίων\">[..]ΤΩΒΡ[...]\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",[252,254],{"image":102,"thumb":253,"title":105},"ISic003309_tiled-thumb.tif",{"image":255,"thumb":256,"title":105},"ISic003309.jpg","ISic003309-thumb.jpg",[258],{"html":58},"\u003C?xml version='1.0' encoding='UTF-8'?>\n\u003C?xml-model href=\"https://epidoc.stoa.org/schema/latest/tei-epidoc.rng\" type=\"application/xml\" schematypens=\"http://relaxng.org/ns/structure/1.0\"?>\n\u003C?xml-model href=\"../schematron/ircyr-checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XInclude\" xml:lang=\"en\">\n    \u003CteiHeader>\n        \u003CfileDesc>\n            \u003CtitleStmt>\n                \u003Ctitle>Fragment of an epitaph\u003C/title>\n                \u003Ceditor ref=\"#JP\">Jonathan Prag\u003C/editor>\n                \u003Cprincipal ref=\"#JP\">Jonathan Prag\u003C/principal>\n                \u003Cfunder>John Fell OUP Research Fund\u003C/funder>\n\t   \u003Cfunder>\u003Cref target=\"https://cordis.europa.eu/project/id/885040\">ERC Advanced Grant no.885040\u003C/ref>\u003C/funder>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JP\" ref=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/name>\n                    \u003Cresp>origina