phic n=\"screen\" url=\"ISic003069_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003069.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\n                    \u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>ου\n                    \u003Cspace unit=\"character\" quantity=\"1\"/>\n                    καλ\n                    \u003Clb n=\"2\"/>\n                    \u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>τες εἰς\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Manganaro 1990\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Manganaro 1990: 407 suggests that the final three letters of line 1, following the vacat, are a\n                    demotic-type abbreviation, as found in other Hellenistic epigraphy in Sicily\u003C/p>\n            \u