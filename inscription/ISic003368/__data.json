cily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Εὐχάρειτος\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"10\">χρη\u003Cspace quantity=\"4\" unit=\"character\" n=\"15\"/>\u003Csupplied reason=\"omitted\">σ\u003C/supplied>τὸς\u003C/w>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"20\">καὶ\u003C/w> \u003Cg ref=\"#interpunct\" n=\"25\">·\u003C/g> \u003Cw n=\"30\">ἄμε\u003Cchoice>\u003Creg>μ\u003C/reg>\u003Corig>ν\u003C/orig>\u003C/choice>πτος\u003C/w> \u003Cg ref=\"#interpunct\" n=\"40\">·\u003C/g> \u003Cw n=\"45\">ἔζησεν\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"50\">ἔτη\u003C/w> \u003Cg ref=\"#interpunct\" n=\"55\">·\u003C/g> \u003Cnum value=\"80\">\u003Cw n=\"60\">π\u003C/w>\u003C/num> \u003Cg ref=\"#interpunct\" n=\"65\">·\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Εὐχάρειτος\">Εὐχάρειτος\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"χρηστός\">χρηστὸς\u003C/w>\n                    \u003Cspace quantity=\"4\" unit=\"character\" n=\"15\"/>\n                    \u003Cw n=\"20\" lemma=\"καί\">καὶ\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"ἄμεμπτος\">ἄμενπτος\u003C/w>\n                    \u003Cw n=\"45\" lemma=\"ζάω\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"π\">π\u003C/w>\n                \u00