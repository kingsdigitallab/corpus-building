03C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-12-12\" who=\"#JP\">Jonathan Prag revised from publication\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003614_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003614.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/K7PQWD75\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Σάλβιε\u003C/name>\u003C/persName> \u003Cgap reason=\"lost\" unit=\"character\" quantity=\"2\"/>ΗΣ\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"2\"/>\u003Cunclear>ΘΙΚ\u003C/unclear>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of Rizzone 2008\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Fuehrer and Schultze: ΣΑΛΒΝ [---] ΙΡΟ(?)\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Rizzone notes a parallel in \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic003076\">ISic003076 for the likely construction, vocative followed by a prayer for remembrance. Agnello merely reported Fuehrer's text, claiming the text was no longer legible.\u003C/ref>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Fuehrer\u003C/author>\n                        \u003Cauthor>Schultze\u003C/author>\n                        \u003Cdate>1907\u003C/date>\n                        \u003CcitedRange>192 no.5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/52GBQ6AW\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001979\">https://biblio.inscriptiones.org/epig10001979\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Agnello\u003C/author>\n                        \u003Cdate>1955\u003C/date>\n                        \u003CcitedRange>209\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/3Z7NQCM4\"/>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>58.1049.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzone\u003C/author>\n                        \u003Cdate>2008\u003C/date>\n                        \u003CcitedRange>18 fig.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/K7PQWD75\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001636\">https://biblio.inscriptiones.org/epig10001636\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
