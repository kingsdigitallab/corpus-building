retive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σάλβιε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Σάλβιε\">Σάλβιε\u003C/span>\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>]ΗΣ[\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>]Θ̣Ι̣Κ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag; edition source: \u003Ca href=\"https://www.zotero.org/groups/382445/items/K7PQWD75\">https://www.zotero.org/groups/382445/items/K7PQWD75\u003C/a>\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σάλβιε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Σάλβιε\">ΣΑΛΒΙΕ\u003C/span>\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">··\u003C/span>]ΗΣ[\u003Cspan dir=\"ltr\" class=\"gap\">··\u003C/span>]...[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text of Rizzone 2008\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"1\">1: \u003Cspan>Fuehrer and Schultze: ΣΑΛΒΝ [---] ΙΡΟ(?)\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2> translation\u003C/h2>\u003Cp class=\"translation-auth