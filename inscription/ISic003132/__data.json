3C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--F simply refers to pietra tenera (!); the inscr. is faint and is read as: - - -MIAS.D.[O]RON. It's quite a typical winged/horned little altar; dimensions are not given, just described as 'un'arula'; from the building 'ai piedi dell'acropoli (the large one with the store rooms, on the right as you ascend; this comes from room 2b (back room of the pair second on the left from the entrance court).-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>28.0768\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Miro and Fiorentini\u003C/author>\n                        \u003Cdate>1976-1977\u003C/date>\n                        \u003CcitedRange>453 tav.48 fig.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/IIEBEJNX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002049\">https://biblio.inscriptiones.org/epig10002049\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
