>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.unknown\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Unable_to_determine\">unknown\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2018-10-16\" who=\"#TA\">Tuuli Ahlholm cleaned up the autogenerated text and added an apparatus\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-17\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2024-04-09\" who=\"#JP\">Jonathan Prag revised from publication\u003C/change>\n                \u003Cchange when=\"2025-10-15\" who=\"#RC\">Robert Crellin added local IDs to edition elements\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000109_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000109.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#TA #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\" xml:id=\"AKοAK\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" xml:id=\"AKοAU\" n=\"5\"/>\u003Cw xml:id=\"AKοAe\" n=\"10\">\u003Csupplied reason=\"lost\" xml:id=\"AKοAo\">c\u003C/supplied>ura\u003C/w> \u003Cw xml:id=\"AKοAy\" n=\"15\">vic\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" xml:id=\"AKοAΙ\" n=\"20\"/>\n                    \u003Clb n=\"2\" xml:id=\"AKοAΤ\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" xml:id=\"AKοAε\" n=\"25\"/>\u003Cw xml:id=\"AKοAο\" n=\"30\">per\u003C/w> \u003Cw xml:id=\"AKοBA\" n=\"35\">\u003Cexpan xml:id=\"AKοBK\">\u003Cabbr xml:id=\"AKοBU\">sing\u003C/abbr>\u003Cex xml:id=\"AKοBe\">ulos\u003C/ex>\u003C/expan>\u003C/w> \u003Cw xml:id=\"AKοBo\" n=\"40\">\u003Cexpan xml:id=\"AKοBy\">\u003Cabbr xml:id=\"AKοBΙ\">mens\u003C/abbr>\u003Cex xml:id=\"AKοBΤ\">es\u003C/ex>\u003C/expan>\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" xml:id=\"AKοBε\" n=\"45\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text from Gualtherus\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"2\">\n                        \u003Cnote>Mommsen: PER · SING · MENS (but there is no basis for the interpunctuation)\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Mommsen speculated that line 1 might be \"cura(vit)\", and that the fragment might be part of the same inscription as the two fragments united under CIL 10.7360 = ISic000111 (also lost) (Bivona's suggestion that this is plausible because the graphical representation in Gualtherus is analogous is of little value, since this is a very generic type of representation in Gualtherus' edition).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624\u003C/date>\n                        \u003CcitedRange>115\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GIN6NANU\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002388\">https://biblio.inscriptiones.org/epig10002388\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>272\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/650797\">7359\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILMusTermini\">\n                        \u003Cauthor>Bivona\u003C/author>\n                        \u003Cdate>1994\u003C/date>\n                        \u003CcitedRange>27\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JCV85C79\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002137\">https://biblio.inscriptiones.org/epig10002137\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
