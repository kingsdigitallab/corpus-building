Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Φουρία\u003C/name>\u003C/persName> χρηστὰ καὶ ἄμεμπτος\n                    \u003Clb n=\"2\"/>χαῖρε ἔζησεν ἔτη \u003Cnum value=\"34\">λδ\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Pugliese Carratelli 1956\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Phouria chresta kai amempta chaire; age in years; ligature of sigma inside omicron at end line 1. Funerary chest with neat mouldings top and bottom. P-C fails to note that it's already in IG, and states that the S museum inv. has 'di prov. incerta', while Libertini says it's from Palazzolo Acreide. He gives no further reason as to why it should be from Akrai. NB ORSI TACCUINI 1.120 STATES THAT IT COMES FROM CANICATTINI, WITHOUT EXPLANATION-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">53\u003C/ref>\n                        \u003C/citedRange>\n           