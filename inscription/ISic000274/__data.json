   \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000274_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000274.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#DM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>A\u003C/abbr>\u003Cex>ulo\u003C/ex>\u003C/expan> · Magullio\n                    \u003Clb n=\"2\"/>\u003Cexpan>\u003Cabbr>A\u003C/abbr>\u003Cex>uli\u003C/ex>\u003C/expan> · \u003Cexpan>\u003Cabbr>l\u003C/abbr>\u003Cex>iberto\u003C/ex>\u003C/expan> · Euhodo\n                    \u003Clb n=\"3\"/>Magullia · Tyche\n                    \u003Clb n=\"4\"/>patrono · et · co\n                    \u003Clb n=\"5\" break=\"no\"/>\u003Cchoice>\u003Creg>niugi\u003C/reg>\u003Corig>iugi\u003C/orig>\u003C/choice> · monumen    \n                    \u003Clb n=\"6\" break=\"no\"/>tum · fecit\n                    \u003Clb n=\"7\"/>\u003Cexpan>\u003Cabbr>o\u003C/abbr>\u003Cex>ptime\u003C/ex>\u003C/expan> · \u003Cexpan>\u003Cabbr>d\u003C/abbr>\u003Cex>e\u003C/ex>\u003C/expan> · \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>e\u003C/ex>\u003C/expan> · \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>erito\u003C/ex>\u003C/expan>\n                \u003C/ab>\n            \u003C/