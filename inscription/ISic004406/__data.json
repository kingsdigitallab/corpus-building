i e dell’Identità Siciliana; photo J. Prag 2023-07-18\u003C/desc>\n        \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#JP #AT\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\" subtype=\"imperial\">\u003CroleName type=\"supracivic\" subtype=\"imperator\">\u003Cexpan>\u003Cabbr>\u003Cunclear>Im\u003C/unclear>\u003Csupplied reason=\"lost\">p\u003C/supplied>\u003C/abbr>\u003Cex>eratori\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cname>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>Caes\u003C/abbr>\u003Cex>ari\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/name> \u003Cname>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>arco\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/name> \u003Cname>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>Aur\u003C/abbr>\u003Cex>elio\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/name> \u003Cname>\u003Csupplied reason=\"lost\">An\u003C/supplied>\n                        \u003Clb n=\"2\" break=\"no\"/>tonino\u003C/name> \u003Cname>\u003Cunclear>Pi\u003C/unclear>\u003Csupplied reason=\"lost\">o\u003C/supplied>\u003C/name> \u003Cname>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>Fel\u003C/abbr>\u003Cex>ici\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/name> \u003Cname>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>Aug\u003C/abbr>\u003Cex>usto\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/name>\n                    \u003Clb n=\"3\"/>\u003Cname>\u003Cexpan>\u003Cabbr>Par\u003Cunclear>t\u003C/unclear>\u003Csupplied reason=\"lost\">h\u003C/supplied>\u003C/abbr>\u003Cex>ico\u003C/ex>\u003C/expan>\u003C/name> \u003Cname>\u003Cexpan>\u003Cabbr>Max\u003C/abbr>\u003Cex>imo\u003C/ex>\u003C/expan>\u003C/name> \u003Cname>\u003Csupplied reason=\"lost\">Britanni\u003C/supplied>\n                        \u003Clb n=\"4\" break=\"no\"/>co\u003C/name> \u003Cname>\u003Cexpan>\u003Cabbr>\u003Csupplied reason=\"lost\">M\u003C/supplied>ax\u003C/abbr>\u003Cex>imo\u003C/ex>\u003C/expan>\u003C/name>\n                    \u003Cname>\u003Cexpan>\u003Cabbr>G\u003Cunclear>e\u003C/unclear>rm\u003C/abbr>\u003Cex>anico\u003C/ex>\u003C/expan>\u003C/name> \u003Cname>\u003Cexpan>\u003Cabbr>\u003Cunclear>M\u003C/unclear>\u003Csupplied reason=\"lost\">ax\u003C/supplied>\u003C/abbr>\u003Csupplied reason=\"lost\">\u003Cex>imo\u003C/ex>\u003C/supplied>\u003C/expan>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"5\"/>\u003CroleName type=\"supracivic\" subtype=\"pontifex.maximus\">\u003Cexpan>\u003Cabbr>pont\u003C/abbr>\u003Cex>ifici\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>max\u003C/abbr>\u003Cex>imo\u003C/ex>\u003C/expan>\u003C/roleName> \u003CroleName type=\"supracivic\" subtype=\"tribunicia.potestas\">\u003Cexpan>\u003Cabbr>trib\u003C/abbr>\u003Cex>unicia\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>\u003Chi rend=\"ligature\">pot\u003C/hi>est\u003C/abbr>\u003Cex>ate\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"6\"/>\u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex cert=\"low\">elicissimo\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex cert=\"low\">io\u003C/ex>\u003C/expan> \u003CroleName type=\"supracivic\" subtype=\"princeps\">\u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex cert=\"low\">rincipi\u003C/ex>\u003C/expan>\u003C/roleName> \u003CroleName type=\"supracivic\" subtype=\"imperator\">\u003Cexpan>\u003Cabbr>imp\u003C/abbr>\u003Cex>eratori\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cnum value=\"4\">\u003Chi rend=\"supraline\">IIII\u003C/hi>\u003C/num> \u003CroleName type=\"supracivic\" subtype=\"consul\">\u003Cexpan>\u003Cabbr>co\u003C/abbr>\u003Cex>n\u003C/ex>\u003Cabbr>s\u003C/abbr>\u003Cex>uli\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cnum value=\"4\">\u003Chi rend=\"supraline\">III\u003C/hi>\u003Csupplied reason=\"lost\">I\u003C/supplied>\u003C/num> \u003CroleName type=\"supracivic\" subtype=\"pater.patriae\">\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex>atri\u003C/ex>\u003C/expan>\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex>atriae\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/roleName>\n                    \u003Clb n=\"7\"/>\u003CroleName type=\"supracivic\" subtype=\"proconsul\">\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>proco\u003C/abbr>\u003Cex>n\u003C/ex>\u003Cabbr>s\u003C/abbr>\u003Cex>uli\u003C/ex>\u003C/expan>\u003C/supplied>\u003C/roleName> res \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex>ublica\u003C/ex>\u003C/expan>\u003C/supplied>\n                    \u003Clb n=\"8\"/>\u003Csupplied reason=\"lost\">Lilybita\u003C/supplied>\u003Cunclear>n\u003C/unclear>o\u003Csupplied reason=\"lost\">rum\u003C/supplied>\n                    \u003Clb n=\"9\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of Silvestrini 2022\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The text is notable for the presence at the start of line 6 of the letters F P P separated by interpuncts, and somewhat smaller than the other letters of the inscription, which seem to abbreviate a series of sigla/epithets honouring Caracalla, and which by comparison with various other honorifics for Caracalla Silvestrini proposes to read (speculatively) as felicissimus, pius, princeps.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                      \u003Cbibl>\n                        \u003Cauthor>Silvestrini\u003C/author>\n                        \u003Cdate>2020\u003C/date>\n                        \u003CcitedRange>298-299 no.2 with fig.6\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JU3LWCJM\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002609\">https://biblio.inscriptiones.org/epig10002609\u003C/ref>\n                      \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Silvestrini\u003C/author>\n                        \u003Cdate>2022\u003C/date>\n                        \u003CcitedRange/>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/MRDSWFG9\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001579\">https://biblio.inscriptiones.org/epig10001579\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
