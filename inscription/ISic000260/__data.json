{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":100,"html":199,"xml":245},"ISic000260",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":34,"dimensions":35,"layoutDesc":46,"handNote":53,"date":71,"places":75,"geo":85,"provenance":77,"provenanceFound":89,"provenanceGeo":93,"provenanceObserved":94,"provenanceLost":20,"graphics":100,"country":108,"region":109,"settlement":82,"repository":110,"idno":123,"textLang":126,"bibliographyEdition":130,"bibliographyDiscussion":146,"citation":149,"tmNumber":8,"facsimile":177,"letterHeights":178,"publications":184,"zotero":186,"keywords":188,"lettering_types":198},"I.Sicily inscription 000260",{"_":5},"edited",[7,10,13,15,18],{"_":8,"type":9},"285211","TM",{"_":11,"type":12},"127144","EDR",{"type":14},"EDH",{"_":16,"type":17},"10900682","EDCS",{"type":19},"PHI",null,{"_":22,"ana":23,"ref":24},"unknown","#function.unknown","https://www.eagle-network.eu/voc/objtyp/lod/2.html","Fragment of dull grey stone plaque, set into modern mortar and traces of modern paint on sides. Top and bottom edges are original, sides are broken. A long chip in the face on the top right.",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":31,"ana":32,"ref":33},"marble","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html","",[36,40,43],{"_":37,"unit":38,"dimension":39},"14.5","cm","height",{"_":41,"unit":38,"dimension":42},"14","width",{"_":44,"unit":38,"dimension":45},"5 (not including mortar) 6.2 (including mortar)","depth",{"layout":47},{"p":48,"rs":49,"damage":34},"Two lines of a highly fragmentary Latin inscription. Use of seagul shaped interpuncts",{"_":50,"ana":51,"ref":52},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":54,"dimensions":55},"Letters are deeply incised. Letters are extremely neat and upright, except for a slant towards the left on the 'E' in line 1 to support what is presumably a ligature of the 'M and E'. Letters are well-spaced, and meticulous use of serifs.",[56,62,68],{"type":57,"l":58,"from":59,"to":59,"h":60,"unit":61,"atLeast":60,"atMost":60},"letterHeight","Line 1","line1","46","mm",{"type":57,"l":63,"from":64,"to":64,"h":65,"unit":61,"atLeast":66,"atMost":67},"Line 2","line2","47-48","47","48",{"type":69,"l":70,"from":59,"to":64,"unit":61},"interlinear","Interlineation line 1 to 2",{"_":72,"notBefore":73,"notAfter":74},"Imperial - good letters(?)",1,300,[76,81],{"_":77,"type":78,"ref":79,"cert":80},"Thermae Himeraeae","ancient","http://pleiades.stoa.org/places/462513","low",{"_":82,"type":83,"ref":84},"Termini Imerese","modern","http://sws.geonames.org/6539140",[86],[87,88],37.98365,13.69555,{"_":90,"type":91,"subtype":92,"geo":20},"The place, date, and circumstances of the discovery are unknown, but the inscription is assumed to come from Termini Imerese","found","discovered",[],{"_":95,"type":96,"subtype":97,"when":98,"resp":99,"geo":20},"Antoniou, 2023-07-06. In the Depositi of Museo Civico Baldassare Romano, room 1, scaffold 13, shelf 3","observed","autopsied","2023-07-06","#AA",[101],{"n":102,"url":103,"height":104,"width":105,"desc":106,"surfaceType":107},"screen","ISic000260_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front","Italy","Sicily",{"_":111,"role":112,"ref":113,"museum":114},"Museo Civico Baldassare Romano","museum","http://sicily.classics.ox.ac.uk/museum/066",{"slug":115,"type":112,"name":111,"uri":113,"description":116,"location":117},"066","A large and well-displayed collection. It begins with three ante-rooms, in the first of which is a rich display of lithics (mainly Neolithic) from the surrounding area. A display of material from Himera (lion-head spouts from the Temple of Victory and red-figure craters being the principle pieces) and a numismatic gallery then follow before the main room which contains Hellenistic and Roman material from Termini Imerese itself. Small finds, sculpture and inscriptions predominate. The museum collection continues upstairs with non-archaeological material (and a single inscription). The courtyard of the building holds a large collection of architectural pieces and inscriptions",{"settlement":82,"region":118,"country":108,"address":119,"geo":120},"Palermo","Via Marco Tullio Cicerone, 90018 - Termini Imerese (PA)",{"lat":121,"lon":122},37.98655109,13.69587845,{"_":124,"type":125},"18","inventory",{"_":127,"mainLang":128,"languages":129},"Latin","la",[127],{"type":131,"bibl":132},"edition",[133,20],{"type":134,"n":135,"author":136,"date":137,"citedRange":138,"ptr":139,"ref":141,"title":143,"citation":144,"uri":145},"corpus","ILMusTermini","Bivona","1994","186",{"target":140},"https://www.zotero.org/groups/382445/items/JCV85C79",{"_":142,"target":142},"https://biblio.inscriptiones.org/epig10002137","Iscrizioni latine lapidarie del museo civico di Termini Imerese","\u003Cspan>Livia Bivona, \u003Ci>Iscrizioni latine lapidarie del museo civico di Termini Imerese\u003C/i>, vol. 9/8, Kokalos Supplementi / Sikelika serie storica (Palermo / Rome, 1994)\u003C/span>","https://www.zotero.org/groups/isicily/items/JCV85C79",{"type":147,"bibl":148},"discussion",[20],{"editor":150,"principal":153,"contributors":154,"change":174},{"_":151,"ref":152},"Jonathan Prag","#JP",{"_":151,"ref":152},[155,158,162,166,170],{"_":151,"xml:id":156,"ref":157},"JP","http://orcid.org/0000-0003-3819-8537",{"_":159,"xml:id":160,"ref":161},"James Cummings","JCu","http://orcid.org/0000-0002-6686-3728",{"_":163,"xml:id":164,"ref":165},"Simona Stoyanova","SS","https://orcid.org/0000-0003-3914-9569",{"_":167,"xml:id":168,"ref":169},"Valentina Mignosa","VM","https://orcid.org/0000-0002-7122-2511",{"_":171,"xml:id":172,"ref":173},"Alex Antoniou","AA","http://orcid.org/0000-0001-7077-0703",{"_":175,"when":176,"who":99},"edition on basis of autopsy","2024-04-26",{"n":102,"url":103,"height":104,"width":105,"desc":106,"surfaceType":107},[179,181],{"atLeast":180,"atMost":180},46,{"atLeast":182,"atMost":183},47,48,[185],"Bivona, 1994, ILMusTermini",[187],"JCV85C79",[189,190,191,22,27,31,192,193,194,195,193,196,197,128],"isic000260","i.sicily inscription 000260",{"_":5},"thermae himeraeae","termini imerese","italy","sicily","museo civico baldassare romano","latin",[],{"title":200,"body":201,"divs":202,"editions":227,"images":237,"handnote":243},"ISic000260. I.Sicily inscription 000260","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"la\">  \u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">M͡E\u003C/span>I · C[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]E · VIS\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"la\">\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">M͡E\u003C/span>I·C[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]E·VIS\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic000260_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic000260_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic000260.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic000260-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text of autopsy\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 1\">line.1: \u003Cspan>The character at the end of line 1 could equally be a 'C' or 'O'\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>At the end of line 2, there is clearly a straight line, with a serif, but there is no indication of what letter this is due to the break in the stone.\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2> translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>  \u003C/p>\u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>Bivona (1994) suggests that the second line refers to a member of the gens Visellia, although this can only be conjecture based on the fragmentary nature of the stone.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> Bivona 1975-1976 554 no.22 tav.10 \u003C/li>\u003Cli> Bivona 1994 186 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002137\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002137\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>Letters are deeply incised. Letters are extremely neat and upright, except for a slant towards the left on the 'E' in line 1 to support what is presumably a ligature of the 'M and E'. Letters are well-spaced, and meticulous use of serifs.\u003C/p> Line 1  46  Line 2  47-48  Interlineation line 1 to 2    \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[203,206,209,212,215,218,221,224],{"id":204,"html":205},"editions","\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"la\">  \u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">M͡E\u003C/span>I · C[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]E · VIS\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Valentina Mignosa, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"la\">\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">M͡E\u003C/span>I·C[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]E·VIS\u003Cspan dir=\"ltr\" class=\"gap\">·\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":207,"html":208},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic000260_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic000260_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic000260.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic000260-thumb.jpg\">\u003C/a>",{"id":210,"html":211},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text of autopsy\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 1\">line.1: \u003Cspan>The character at the end of line 1 could equally be a 'C' or 'O'\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>At the end of line 2, there is clearly a straight line, with a serif, but there is no indication of what letter this is due to the break in the stone.\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":213,"html":214},"translation","\u003Ch2> translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>  \u003C/p>",{"id":216,"html":217},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>Bivona (1994) sug