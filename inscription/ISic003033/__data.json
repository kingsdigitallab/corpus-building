     \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-10-20\" who=\"#JP\">Jonathan Prag revised from publications\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003033_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003033.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/JVCEV98D\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#cross_uninterpreted\">+\u003C/g> Τύ\u003Chi rend=\"ligature\">μβος\u003C/hi> ἐν \u003Cexpan>\u003Cabbr>\u003Chi rend=\"supraline\">Θ\u003C/hi>\u003C/abbr>\u003Cex>ε\u003C/ex>\u003Cabbr>\u003Chi rend=\"supraline\">ῷ\u003C/hi>\u003C/abbr>\u003C/expan> κειμένων ἐνθάδε ἐν ἀναπαύ\n                    \u003Clb n=\"2\" break=\"no\"/>σει Κωνσταντίν\u003Chi rend=\"ligature\">ου\u003C/hi> ζήσαντος ἔ\u003Chi rend=\"ligature\">τη\u003C/hi> \u003Cnum value=\"12\">ιβ\u003C/num> Μελλώ\n                    \u003Clb n=\"3\" break=\"no\"/>σ\u003Chi rend=\"ligature\">ου\u003C/hi> ζήσαντος ἔ\u003Chi rend=\"ligature\">τη\u003C/hi> \u003Cnum value=\"10\">ι\u003C/num> \u003Cexpan>\u003Cabbr>κ\u003C/abbr>\u003Cex>αὶ\u003C/ex>\u003C/expan> Νικήτα ζήσαντος ἔ\u003Chi rend=\"ligature\">τη\u003C/hi> \u003Cnum value=\"8\">η\u003C/num>\n                    \u003Clb n=\"4\"/>τούτων \u003Chi rend=\"ligature\">μνή\u003C/hi>σθητι \u003Cexpan>\u003Cabbr>\u003Chi rend=\"supraline\">Κ\u003C/hi>\u003C/abbr>\u003Cex>ύρι\u003C/ex>\u003Cabbr>\u003Chi rend=\"supraline\">ε\u003C/hi>\u003C/abbr>\u003C/expan> ἐν \u003Chi rend=\"ligature\">τῇ\u003C/hi> βασιλείᾳ σου\n                    \u003Clb n=\"5\"/>Ἐτελειώθησαν \u003Cexpan>\u003Cabbr>μ\u003C/abbr>\u003Cex>ηνὶ\u003C/ex>\u003C/expan> Δεκε\u003Chi rend=\"ligature\">μβ\u003C/hi>ρίῳ \u003Cnum value=\"27\">κζ\u003C/num>\n                    \u003Clb n=\"6\"/>\u003Cexpan>\u003Cabbr>Ἰν\u003Chi rend=\"intraline\">δ\u003C/hi>\u003C/abbr>\u003Cex>ικτιῶνος\u003C/ex>\u003C/expan> \u003Cnum value=\"6\">ἕκ\u003Chi rend=\"ligature\">τη\u003C/hi>ς\u003C/num> \u003Cg ref=\"#palm\">⸙\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Manganaro 2001, with ligatures added\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Tomb of those lying in God at rest, of Constantine, who lived 12 years, of Mellosos, who lived 10 years and of Niketas who lived 8 years. Remember these in your kingdom, O Lord! They died in the month of December on the 27th (day), in the 6th Indiction.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"Manganaro\">\n                \u003Cp>Tomba dei giacenti in Dio qui in pace, di Costantino vissuto anni dodici, di Melloso vissuto anni dieci e di Niceta vissuto anni otto. Di questi ricordati, o Signore, nel tuo regno! Morirono nel mese di dicesmbre (il giorno) ventisette. della indizione sesta.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--epitaph of Konstantinos, Mellosos and Niketas; rectangular white marble plaque, found 1960 and built into a wall of the sacristy of the cathedral. Rocco is the ed. pr. Many ligatures; letter forms suggested C4-5 AD date to Rocco; Brugnone prefers later b/c of absence of consular date in indiction; evidence of persistence of Doricisms in Sicily in the names. The three boys may be brothers?-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>51.1378\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>42.0869\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rocco\u003C/author>\n                        \u003Cdate>1983\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/7TN6MEG4\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001619\">https://biblio.inscriptiones.org/epig10001619\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Brugnone\u003C/author>\n                        \u003Cdate>1988-1989\u003C/date>\n                        \u003CcitedRange>360-361\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/7PA8GV9C\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002120\">https://biblio.inscriptiones.org/epig10002120\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>2001\u003C/date>\n                        \u003CcitedRange>131-134 fig.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JVCEV98D\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001807\">https://biblio.inscriptiones.org/epig10001807\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
