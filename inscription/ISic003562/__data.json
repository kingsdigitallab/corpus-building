rce=\"http://zotero.org/groups/382445/items/F2GG87EQ\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>Α\u003C/orig> \u003Cspace unit=\"character\" quantity=\"2\"/> \u003Corig>EIΔEKV\u003C/orig> \u003Cspace unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>Ν\u003C/orig> \u003Cspace unit=\"character\" quantity=\"2\"/> \u003Corig>ΓΓΝΗ\u003C/orig> \u003Cspace unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"1\"/>Ν \u003Cspace unit=\"character\" quantity=\"2\"/> \u003Corig>ΩΜΓ\u003C/orig> \u003Cspace unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"4\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>ΣΚ\u003C/orig> \u003Cspace unit=\"character\" quantity=\"2\"/>  \u003Corig>ΣΣΤΟΣ\u003C/orig> \u003Cspace unit=\"character\" extent=\"unknown\"/>\n                    \u003Clb n=\"5\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>ΟΝΟΣ\u003Cunclear>Π\u003C/unclear>ΟΚΑΙ\u003C/orig>\n                    \u003Clb n=\"6\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>ΧΣΟΡΟΦΑΝΕ\u003C/orig>\n                    \u003Clb n=\"7\"/>\u003Corig>ΚΛΕΗ\u003C/orig> \u003Cspace unit=\"character\" quantity=\"2\"/> \u003Corig>ΤΟΣΑΝΕ\u003C/orig>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" cert=\"low\"/>\n                    \u003Clb n=\"8\"/>Α \u003Cspace unit=\"character\" quantity=\"2\"/> Σ \u003Cspace unit=\"character\" extent=\"unknown\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of SEG based upon the drawing in DiStefano (non vidi)\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>SEG: second letter is Ν or Μ\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>DiStefano presents a full restoration of the text, as an epitaph, but SEG is very sceptical and prints the visible letters only, as here.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>52.0930\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Distefano\u003C/author>\n                        \u003Cdate>2002\u003C/date>\n                        \u003CcitedRange>102 n.54, 100 fig.12, 106 no.11\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/KEVTRMCV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002018\">https://biblio.inscriptiones.org/epig10002018\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
