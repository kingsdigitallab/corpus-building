desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001093.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#AR #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"4\"/>\u003Corig>ΣΟΙΣ\u003C/orig>\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"6\"/> \u003CpersName type=\"attested\">\u003Cname type=\"cognomen\">Μαικιανὸ\u003Csupplied reason=\"lost\">ς\u003C/supplied>\u003C/name>\u003C/persName> \u003Cgap reason=\"lost\" unit=\"character\" quantity=\"4\"/>\u003Cgap reason=\"illegible\" quantity=\"1\" unit=\"character\"/> \u003Cchoice>\u003Corig>φᾶσι\u003C/orig>\u003Creg>πᾶσι\u003C/reg>\u003C/choice>  \u003Cg ref=\"#interpunct\">·\u003C/g> π\u003Cunclear>οθε\u003C/unclear>\u003Csupplied reason=\"lost\">ι\u003C/supplied>\u003Cunclear>ν\u003C/unclear>\u003Csupplied reason=\"lost\">ός\u003C/supplied> \u003Csupplied reason=\"lost\">δια\u003C/supplied>νοίαις \u003Cgap reason=\"illegible\" unit=\"character\" quantity=\"6\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>text of IG\u003C/note>\n                       \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--inscr. is damaged, p'haps reads: 'kanthie Markiane pasi pothinotate'. T's comments incl.: #Da notare altresi l'uso della lingua greca in questo periodo particolarmente usata nelle iscrizioni cristiane e che, com'e noto, cesso nel V secolo. L'iscrizione quindi, e forse anche il sarcofago allora, potrebbero essere stati dedicati a un cristiano come smemberebbe anche confermare il nome 'Marciano' abbastanza commune nell'eta cristiana. Non si esclude pero che possa essere di origine pagana.'-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>120\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">274\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5494\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Tusa\u003C/author>\n                        \u003Cdate>1995\u003C/date>\n                        \u003CcitedRange>no.36\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/MKRMHRK2\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001531\">https://biblio.inscriptiones.org/epig10001531\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
