8.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.table\" ref=\"https://www.eagle-network.eu/voc/objtyp/lod/157.html\">table\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--table top-->\n                                        \u003Cheight unit=\"cm\">7.8\u003C/height>\n                                        \u003Cwidth unit=\"cm\">145.7\u003C/width>\n                                        \u003Cdepth unit=\"cm\">72\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.complete\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003Cp>The text is inscised in a single line along the right half of the smooth lower portion of the front profile, with a two-step moulding projecting above. Text is 494 mm long.\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage ana=\"#text_condition.legible\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"4\" atMost=\"14\">4-14\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003C