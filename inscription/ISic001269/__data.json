3Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Funerary\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-10-13\" who=\"#MB\">Maria Barbieri encoded text\u003C/change>\n                \u003Cchange when=\"2024-07-29\" who=\"#JP\">Jonathan Prag revised metadata\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001269_tiled.tif\" height=\"1944px\" width=\"2592px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001269.jpg\" height=\"1944px\" width=\"2592px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo L. Campagna 2005-03-31\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#MB\">\n                    \u003Cab>\n                        \u003Clb n=\"1\"/>ἐνθάδε κῖτε \u003Cg ref=\"#staurogram\">𐆠\u003C/g>\n                        \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Ἀγάθων\u003C/name>\u003C/persName> πιστὸς\n                        \u003Clb n=\"3\"/>ζήσας ἔτη \u003Cnum value=\"7\">ζ\u003C/num> \u003Cexpan>\u003Cabbr>μ\u003C/abbr>\u003Cex>ῆ\u003C/ex>\u003Chi rend=\"ligature\">\u003Cabbr>νας\u003C/abbr>\u003C/hi>\u003C/expan>\n                        \u003Clb n=\"4\"/>\u003Cnum value=\"7\">ζ\u003C/num> ἀνεπαύσατο\n                    \u003Clb n=\"5\"/>\u003CroleName type=\"supracivic\" subtype=\"consul\">\u003Cexpan>\u003Cabbr>ὑ\u003Chi rend=\"ligature\">πατ\u003C/hi>\u003C/abbr>\u003Cex>ίᾳ\u003C/ex>\u003C/expan>\u003C/roleName> \u003CpersName type=\"attested\">\u003Cname>Ὀνωρίου\u003C/name>\u003C/persName> τὸ \u003Cnum value=\"8\">η\u003C/num>\n                        \u003Clb n=\"6\"/>\u003Cchoice>\u003Corig>κὲ\u003C/orig>\u003Creg>καὶ\u003C/reg>\u003C/choice> \u003CpersName type=\"attested\">\u003Cname>Θεοδοσίου\u003C/name>\u003C/persName> τὸ \u003Cnum value=\"3\">γ\u003C/num> \u003Cexpan>\u003Cabbr>Σε\n                    \u003Clb n=\"7\" break=\"no\"/>β\u003C/abbr>\u003Cex>αστῶν\u003C/ex>\u003C/expan>  \u003Cexpan>\u003Cabbr>Α\u003Cam>α\u003C/am>υ\u003Cam>ὐ\u003C/am>γ\u003Cam>γ\u003C/am>\u003C/abbr>\u003Cex>ούστων δυοῖν\u003C/ex>\u003C/expan> τῇ πρὸ \u003Cnum value=\"5\">\u003Cchoice>\u003Csic>γ\u003C/sic>\u003Ccorr>ε\u003C/corr>\u003C/choice>\u003C/num> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                        \u003Clb n=\"8\"/>εἰδῶν Ὀκτωβρίων\n                        \u003Clb n=\"9\"/>ἡμέρᾳ Σελήνης \u003Cg ref=\"#staurogram\">𐆠\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of IG 14.0444\u003C/note>\u003C/app>\u003C/listApp>\n                \u003Capp loc=\"7\">\u003Cnote>Ferrua 1982 and 1989: corrects Γ to Ε\u003C/note>\u003C/app>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Ferrua notes that the date must be corrected, if it is to align with the consulship year of 409. Note the day recorded as day of the moon; and note the combined use of Greek and Latin abbreviations for Augustus, the latter in Greek letters.\n                    \u003C!--enthade keitai; chi-rho symbol; Agathon; Age in years and months; cos. date of death, together with day and month; Note that the day is specified as that of Selene. F corrects the date from 409 to 411. Photograph from Lorenzo Campagna-->\u003C/p>\n            \u003C/div>\n          