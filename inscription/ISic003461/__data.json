Desc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-12-08\" who=\"#JP\">Jonathan Prag revised from publication\u003C/change>\n                \u003Cchange when=\"2026-02-09\" who=\"#RG\">tagged names and persons\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003461_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003461.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/P44QBETH\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Csupplied reason=\"lost\">ἐν\u003C/supplied>θάδε κῆτε ὡ ἐν μακαρίᾳ\n                    \u003Clb n=\"2\"/>\u003Csupplied reason=\"lost\">μ\u003C/supplied>νήμῃ \u003CpersName type=\"attested\">\u003Cname>Γρηγώριος\u003C/name> υἱὸς \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw part=\"I\">Πο\u003C/w>\n                    \u003Clb n=\"3\" break=\"no\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003C/name>\u003C/persName>\u003C/persName> του \u003CroleName type=\"paracivic.religious\" subtype=\"presbyteros\">\u003Cexpan>\u003Cabbr>π\u003Chi rend=\"supraline\">ρ\u003C/hi>\u003C/abbr>\u003Cex>εσ\u003C/ex>\u003Cabbr>\u003Chi rend=\"supraline\">β\u003C/hi>\u003C/abbr>\u003Cex>υτέρου\u003C/ex>\u003C/expan>\u003C/roleName> ζήσας ἔτη \u003Cnum value=\"22\">κβ\u003C/num>\n                    \u003Clb n=\"4\"/>\u003Cexpan>\u003Csupplied reason=\"lost\">\u003Cabbr>τ\u003C/abbr>\u003Cex>ελ\u003C/ex>\u003C/supplied>\u003Cabbr>ευτᾷ\u003C/abbr>\u003C/expan> δὲ ἐν \u003Cexpan>\u003Cabbr>\u003Chi rend=\"supraline\">Κ\u003C/hi>\u003C/abbr>\u003Cex>υρί\u003C/ex>\u003Cabbr>\u003Chi rend=\"supraline\">ῳ\u003C/hi>\u003C/abbr>\u003C/expan> μηνὴ \u003Cexpan>\u003Cabbr>Ἰ\u003Chi rend=\"supraline\">ου\u003C/hi>\u003C/abbr>\u003Cex>λίῳ\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"5\"/>\u003Cexpan>\u003Cabbr>ἰν\u003Chi rend=\"intraline\">δ\u003C/hi>\u003C/abbr>\u003Cex>ικτιῶνος\u003C/ex>\u003C/expan> \u003Cnum value=\"8\">η\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after Rizzone 2009, checked against photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Cnote>Manganaro restores a christogram at the start of the line, which can only be hypothetical\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Cnote>Rizzone: Πο-|[θή]του; Manganaro πρ(εσ)β(ύτερος) \u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Cnote>Manganaro: ἐν κώ(μη)ͅ Μηνηνίου; ἰου(λίου) or ἰου(νίου) is possible.\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>There seems no clear basis on which to decide whether Gregorios or his father was the presbuteros, since the ending is lost in the abbreviation, but it clearly affects the debate regarding celibacy of priests. Manganaro assumed the word referred to Gregorios; Rizzone to his father Po[--]tos.\u003C!--commented out pending revision-->\n                    \u003C!--Enthade kete w en makaria  mnemei Gregorios uios Pothetou presbuterou zesas ete kb teleuta de en Kuriwi mene iouniou/iouliou indiktiwnos h. So it's for Gregorios, son of a priest. Note that Manganaro originally read this as recording the kwme of Meneion, i.e. Menae / Mineo, but this reading is rejected and replaced with a date by month by Feissel in BE, by Rizzone, and by Felle per litteras to Manganaro. The inscription is known by a photograph given to Manganaro by a pupil, provenance unknown and current location unknown. Rizzone speculates that the formula is similar to another from Mineo and so perhaps from this region.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>2004.0665\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>56.1107\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>54.0944\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>2006.0566\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003CcitedRange>35-37 fig.1\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/XRJWG8D3\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001799\">https://biblio.inscriptiones.org/epig10001799\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro Perrone\u003C/author>\n                        \u003Cdate>2006\u003C/date>\n                        \u003CcitedRange>92 n.20\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/6KPB9V5B\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001787\">https://biblio.inscriptiones.org/epig10001787\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzone\u003C/author>\n                        \u003Cdate>2009\u003C/date>\n                        \u003CcitedRange>431 fig.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/P44QBETH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001634\">https://biblio.inscriptiones.org/epig10001634\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
