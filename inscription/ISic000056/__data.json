{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":108,"html":249,"xml":306},"ISic000056",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":20,"type":21,"support":25,"objectType":26,"material":30,"condition":34,"dimensions":36,"layoutDesc":47,"handNote":56,"date":78,"places":82,"geo":93,"country":88,"provenance":84,"provenanceFound":97,"provenanceGeo":102,"provenanceObserved":103,"provenanceLost":20,"graphics":108,"region":116,"settlement":117,"repository":118,"idno":131,"textLang":134,"bibliographyEdition":138,"bibliographyDiscussion":178,"citation":181,"tmNumber":8,"facsimile":217,"letterHeights":218,"publications":229,"zotero":233,"keywords":237,"lettering_types":248},"Funerary inscription for Claudius Maximus",{"_":5},"draft",[7,10,13,15,18],{"_":8,"type":9},"284852","TM",{"_":11,"type":12},"111049","EDR",{"type":14},"EDH",{"_":16,"type":17},"22100092","EDCS",{"type":19},"PHI",null,{"_":22,"ana":23,"ref":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","Quadrangular plaque of grey marble with white veining. Minor damage to the lower right corner only, which does not affect the epigraphic text. The edges are all cut regularly. The lower edge has two small holes (8 mm), probably of modern date for display.",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","https://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":31,"ana":32,"ref":33},"marble","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html",{"ana":35},"#condition.damaged",[37,41,44],{"_":38,"unit":39,"dimension":40},"23","cm","height",{"_":42,"unit":39,"dimension":43},"25.5","width",{"_":45,"unit":39,"dimension":46},"4","depth",{"layout":48},{"p":49,"rs":50,"damage":54},"The epigraphic field, of three lines of Latin letters, decreasing in size, is approximately centred on the plaque, with an upper margin of 4.5cm, a lower margin of 1.8cm, left margin of 2.5 cm and right margin of 2 cm.",{"_":51,"ana":52,"ref":53},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":55},"#text_condition.complete",{"lettering":57,"dimensions":58},"The letters are v-cut in a tall and narrow module, with triangular serifs. The letters are regularly spaced, with the size / spacing decreasing towards the right and from line 1 to line 3. A has a cross bar descending to the left; M has four full length strokes, all off vertical. Interpuncts in the form of ivy-leaf (somewhat various in form) at the end of each line; plainer interpuncts between words in line 3.",[59,65,69,73,76],{"type":60,"l":61,"from":62,"to":62,"h":63,"unit":64,"atLeast":63,"atMost":63},"letterHeight","Line 1","line1","55","mm",{"type":60,"l":66,"from":67,"to":67,"h":68,"unit":64,"atLeast":68,"atMost":68},"Line 2","line2","52",{"type":60,"l":70,"from":71,"to":71,"h":72,"unit":64,"atLeast":72,"atMost":72},"Line 3","line3","30",{"type":74,"from":62,"to":67,"h":75,"unit":64,"atLeast":75,"atMost":75},"interlinear","25",{"type":74,"from":67,"to":71,"h":77,"unit":64,"atLeast":77,"atMost":77},"15",{"_":79,"notBefore":80,"notAfter":81},"1st century CE",1,100,[83,89],{"_":84,"type":85,"ref":86,"cert":87,"region":88},"Thermae Himeraeae","ancient","http://pleiades.stoa.org/places/462513","low","Sicilia",{"_":90,"type":91,"ref":92,"region":88},"Termini Imerese","modern","http://sws.geonames.org/6539140",[94],[95,96],37.98365,13.69555,{"_":98,"type":99,"subtype":100,"when":101,"geo":20},"First recorded in Termini Imerese in 1867 by Benndorf who saw it at an antique dealer, who subsequently sold it to Palermo museum.","found","first-seen","1867",[],{"_":104,"type":105,"subtype":106,"resp":107,"geo":20},"Maria Randazzo 2022-05-23, Museo Archeologico Regionale, Palermo, on display in the courtyard.","observed","autopsied","#MR",[109],{"n":110,"url":111,"height":112,"width":113,"desc":114,"surfaceType":115},"screen","ISic000056_tiled.tif",