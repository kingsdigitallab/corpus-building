       \u003Cref target=\"https://biblio.inscriptiones.org/epig10001623\">https://biblio.inscriptiones.org/epig10001623\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Mason\u003C/author>\n                        \u003Cdate>1974\u003C/date>\n                        \u003CcitedRange>10\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/IED5JW6G\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001383\">https://biblio.inscriptiones.org/epig10001383\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>19 n.71\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/RZSFKACR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
