\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"xpu\">Punic\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>A quadrangular block of limestone, some damage to the face.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.limestone\" ref=\"http://www.eagle-network.eu/voc/material/lod/66.html\">limestone\u003C/material>\n                                    \u003CobjectType ana=\"#object.stele\" ref=\"https://www.eagle-network.eu/voc/objtyp/lod/250\">stele\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">42.8\u003C/height>\n                                        \u003Cwidth unit=\"cm\">84\u003C/width>\n                                        \u003Cdepth unit=\"cm\">37.5\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.damaged\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003Cp>Text over two lines on the upper part of the face, with three letters lost in the first line.\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                    \u003Crs ana=\"#execution.rubrication.red\">rubrication, red colour\u003C/rs>\n                                \t\u003Cdamage ana=\"#text_condition.partly_illegible\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Clocus from=\"line1\" to=\"line2\">Line 1-2\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"50\" atMost=\"108\">50-108\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462373\">Motya\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2524039\">Mozia\u003C/placeName>\n                            \t\u003Cgeo>37.86503, 12.46798\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0500\" notAfter-custom=\"-0401\">5th century BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notBefore=\"2014\" notAfter=\"2019\">Found during excavations 1972-1974, in re-use in a wall of the West fortifications by the necropolis, Motya\u003Cgeo>37.8703471,12.4676733\u003C/geo>\u003C/provenance>\u003C!-- area of the fortifications / necropolis -->\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" xml:id=\"autopsy\" resp=\"#RDS\">De Simone 2025-03-23\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"edited\">\n            \u003ClistChange>\n                \u003Cchange when=\"2025-12-01\" who=\"#JP\">Jonathan Prag created file based upon scheda provided by Rossana De Simone\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002006_tiled.tif\" height=\"762px\" width=\"992px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo R. De Simone\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002006.jpg\" height=\"762px\" width=\"992px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo R. De Simone\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"transliteration-primary\" xml:space=\"preserve\" xml:lang=\"xpu-Latn\" resp=\"#JP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\" style=\"text-direction:r-to-l\"/>qbr \u003CpersName type=\"attested\">\u003Cname>ḥ\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"3\"/>ʿṣ\u003C/name>\n                    \u003Clb n=\"2\" style=\"text-direction:r-to-l\"/>bn \u003CpersName type=\"attested\">\u003Cname>ʿzry\u003C/name>\u003C/persName>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of De Simone from autopys\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#RDS\">\n                \u003Cp>Tomb of ḥ[...]ʿṣ, son of ʿzry\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#RDS\">\n                \u003Cp>Tomba di ḥ[...]ʿṣ, figlio di ʿzry\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#RDS\" xml:lang=\"en\">\n                \u003Cp>The name of the deceased cannot be reconstructed. ʿ\u003Cforeign xml:lang=\"xpu-Latn\">zry\u003C/foreign> is a hypocoristic Phoenician personal name with suffix -y from the root \u003Cforeign xml:lang=\"xpu-Latn\">ʿzr\u003C/foreign> \"to help\". \u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Coacci Polselli\u003C/author>\n                        \u003Cdate>1978\u003C/date>\n                        \u003CcitedRange>163-166 no.1, tav. LXXXV.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/D8YT5N6Y\"/>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>De Simone\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>25 MO.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EGNUE9CZ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002545\">https://biblio.inscriptiones.org/epig10002545\u003C/ref>\n                    \u003C/bibl>\n                  \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
