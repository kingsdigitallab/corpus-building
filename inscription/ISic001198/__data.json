               \u003Cname xml:id=\"GC\" ref=\" https://orcid.org/0000-0003-1030-5679\">Giorgia Capra\u003C/name>\n                    \u003Cresp>epidoc editing\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"AA\" ref=\"http://orcid.org/0000-0001-7077-0703\">Alex Antoniou\u003C/name>\n                    \u003Cresp>Addition to bibliography\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"ZL\" ref=\"https://orcid.org/0009-0007-0586-7956\">Zoé Lienard\u003C/name>\n                    \u003Cresp>named entity annotation\u003C/resp>\n                \u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic001198\u003C/idno>\n                \u003Cidno type=\"TM\">492802\u003C/idno>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\">39101562\u003C/idno>\n                \u003Cidno type=\"PHI\">140682\u003C/idno>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic001198\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-22\">10.5281/zenodo.4385584\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Copenhagen, Denmark\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"https://www.glyptoteket.com/\">Ny Carlsberg Glyptotek\u003C/repository>\n                        \u003Cidno type=\"inventory\">IN 0516\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>A white marble relief plaque (marble from Thasos according to the Ny Glyptotek). Description from the Ny Glyptotek site: \"Composed of three fragments. A piece of the lower left corner has been broken off, part of Artemis' right leg, right hand with part of the torch, front part of Protos' head. Otherwise well preserved. Two antique holes on each side. The relief depicts a votive scene. The goddess Artemis, dressed in a short robe (khiton), which exposes her left breast, stands with a lowered torch in her right hand and lights the sacrificial fire on an altar. In her raised left hand she holds a bridal basket. Two worshippers (cult seekers), a man, a woman and a young girl, approach the altar from the right. They are mortals, as is evident from their much lesser height in relation to the goddess.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.marble\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.stele\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/250\">stele\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--Default values and requires editing-->\n                                        \u003Cheight unit=\"cm\"/>\n                                        \u003Cwidth unit=\"cm\">40-36 (bottom to top)\u003C/width>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003C!--Default value and requires checking-->\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003C!--Default value and requires editing-->\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462527\">Tyndaris\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/10282151\">Tindari\u003C/placeName>\n                            \t\u003Cgeo>38.14227, 15.04385\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0200\" notAfter-custom=\"-0001\">2nd — 1st century BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Found in the first half of the 19th century in contrada 'Orti del Vescovo', Sant'Eramo, not far from the beach, approximately one mile to the east of Patti.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.dedication\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/88.html\">dedication\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-22\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2021-04-30\" who=\"#GC\">edited text and added italian and english translation\u003C/change>\n                \u003Cchange when=\"2021-05-27\" who=\"#AA\">Bibliography addition\u003C/change>\n                \u003Cchange when=\"2025-12-16\" who=\"#ZL\">tagged names and persons\u003C/change>\n                \u003Cchange when=\"2026-03-09\" who=\"#JP\">Jonathan Prag revised metadata\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001198_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001198.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#GC\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Πρῶτος\u003C/name>\u003C/persName> καὶ \u003CpersName type=\"attested\">\u003Cname>Μενίππη\u003C/name>\u003C/persName> \u003CpersName type=\"divine\">\u003Cname>Ἀρτέμιδι\u003C/name> \u003Cname type=\"epithet\">Εὐπραξίαι\u003C/name>\u003C/persName>.\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of IG\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#GC\">\n                \u003Cp>Protos and Menippe, to Artemis Eupraxia.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#GC\">\n                \u003Cp>Protos e Menippe, per Artemide Eupraxia.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>For the museum's digital record, see \u003Cref target=\"https://samlinger.slks.dk/samlinger/5797655b-235f-482a-a083-9501a21a8667\">https://samlinger.slks.dk/samlinger/5797655b-235f-482a-a083-9501a21a8667\u003C/ref>\n                    \u003C!--relief, of a man, women and slave girl approaching an altar to sacrifice; inscr. is Protos and Menippe, to Artemis Eupraxia (p'haps Euporia?) ( IG XIV 375. P.Veyne, Metis 5 (1990) [1991] 21, comments on the unusual epithet Εὐπραξία. He argues that in the mind of the dedicants some good luck which they experienced became a goddess itself (‘Succès’). Subsequently a priest (or the goddess herself in an oracle or dream) suggested to them to assign it as a ‘surnom de circumstance’ to the god held to be responsible for the happy event (in this case Artemis). On the relief Artemis is represented as kindling the fire on the altar. She establishes the offering to be brought by Πρῶτος and Μενίππη ramer than being offering to herself. [SEG online] Glpytotek webpage record: https://www.kulturarv.dk/mussam/VisGenstand.action?genstandId=7550400-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Bruun\u003C/author>\n                        \u003Cdate>1849\u003C/date>\n                        \u003CcitedRange>264-269 with tab.H\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/3XJJ24LV\"/>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">375\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>41.0839\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>04.0046\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5613b\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Deubner\u003C/author>\n                        \u003Cdate>1925\u003C/date>\n                        \u003CcitedRange>210-211 ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/74989KXK\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002036\">https://biblio.inscriptiones.org/epig10002036\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fasolo\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>57 no.1 fig.19\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/X2SEXMRX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002011\">https://biblio.inscriptiones.org/epig10002011\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
