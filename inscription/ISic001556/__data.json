\">\u003Cw n=\"65\">ζ\u003C/w>\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Ἰάσων\">Ἰάσων\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Ἀρτάφαν\">Ἀρταφᾶντος\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ζῶ\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ἄμεμπτος\">ἀμέμπτως\u003C/w>\n                    \u003Cspace quantity=\"1\" unit=\"character\" n=\"25\"/>\n                    \u003Cw n=\"30\" lemma=\"ἕτος\">ἕτη\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"ο\">ο\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"Θεοδώρα\">Θευδώρα\u003C/w>\n                    \u003Cw n=\"45\" lemma=\"ζῶ\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ἄμεμπτος\">ἀμέμπτως\u003C/w>\n                    \u003Cspace quantity=\"1\" unit=\"character\" n=\"55\"/>\n                    \u003Cw n=\"60\" lemma=\"ἕτος\">ἕτη\u003C/w>\n                    \u003Cw n=\"65\" lemma=\"ζ\">ζ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003Cp>Text of IGPalermo\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Museum records incl. a note which says it comes from Marsala, from the house of...(lost), but that is all; double epitaph, of Iason, son of Aristophan and of Theudora. The layout of the inscr. on the stone is v.curious, with the word amemptos in both cases broken between the o and s, to allow the s to balance the number of years after 'ete' on the next line; the names are also oddly layed out.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>26.1077\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1976.0058\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGMusPalermo\">\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1973\u003C/date>\n                        \u003CcitedRange>26\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F66S4X3M\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000531\">https://biblio.inscriptiones.org/epig10000531\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl/>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
