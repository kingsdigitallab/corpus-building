pe=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Μαρία\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"10\">ἥρυς\u003C/w>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"15\">ἀγαθά\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Μαρία\">Μαρία\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"ἥρυς\">ἥρυς\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἀγαθός\">ἀγαθά\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003Cp>Text of IGPalermo\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--painted inscr., with banqueting scene; Maria herys agatha; NB, that the form of heros here is 'forma \"scorrettissima e con un inesplicabile tardo dorismo\". Del cattivo greco che si parlava a Lilibeo abbiamo un'altra testimonianza in una tessera ospitale a Lilibeo (=IG 14.0279) e nella critica che di esso fa Cicerone a Cecilio (Div.in Caec. 39).'; note also tanit symbols, caduceus and cresc.moon with disc.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>34.0950\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u0