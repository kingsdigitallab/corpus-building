/1",{"ana":54},"#text_condition.incomplete",{"lettering":56,"dimensions":57},"Standard later Hellenistic letters, of moderately square module, with simple terminal serifs. Epsilon with shorter middle bar; Mu with four full length, oblique strokes; omicron slightly smaller and above the line (12-13 mm); sigma with parallel top and bottom strokes.",[58,67,71],{"type":59,"l":60,"from":61,"to":62,"h":63,"unit":64,"atLeast":65,"atMost":66},"letterHeight","Line 1-3","line1","line3","15-17","mm","15","17",{"type":68,"l":69,"from":61,"to":62,"h":70,"unit":64},"interlinear","Interlineation line 1 to 3","12-15",{"type":68,"l":72,"from":62,"to":73,"h":74,"unit":64},"Interlineation line 3 to 4","line4","7-9",{"_":76,"notBefore":77,"notAfter":78,"evidence":79},"2nd century BCE by the lettering",-200,-101,"lettering",[81,86],{"_":82,"type":83,"ref":84,"region":85},"Syracusae","ancient","http://pleiades.stoa.org/places/462503","Sicilia",{"_":87,"type":88,"ref":89,"region":85},"Siracusa","modern","http://sws.geonames.org/2523083",[91],[92,93],37.08415,15.27628,{"_":95,"type":96,"subtype":97,"notBefore":98,"notAfter":99,"geo":100,"geoCert":103},"Found during work to remove earth at the souther extremity of the Roman amphitheatre (wrongly attributed to the theatre by Manganaro), Siracusa, between 1916 and 1918.","found","discovered","1916","1918",[101,102],37.0738381,15.2785243,"high",[101,102],{"_":106,"type":107,"subtype":108,"xml:id":109,"geo":19},"Prag, 2015-07-02, in Magazzino B, MARPO","observed","autopsied","autopsy",[111,118],{"n":112,"url":113,"height":114,"width":115,"desc":116,"surfaceType":117},"screen","ISic003484_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2015-07-02","front",{"n":112,"url":119,"height":114,"width":115,"desc":116,"surfaceType":120},"ISic003484_rear_tiled.tif","rear","Sicily",{"_":123,"role":1