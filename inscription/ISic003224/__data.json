ing, translation and commentary\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"JCu\" ref=\"http://orcid.org/0000-0002-6686-3728\">James Cummings\u003C/name>\n                    \u003Cresp>conversion to EpiDoc\u003C/resp>\n                \u003C/respStmt>\n                \u003CrespStmt>\n                    \u003Cname xml:id=\"AA\" ref=\"http://orcid.org/0000-0001-7077-0703\">Alex Antoniou\u003C/name>\n                    \u003Cresp>EpiDoc editing and English translation\u003C/resp>\n                \u003C/respStmt>\n\t    \u003CrespStmt>\n     \t       \u003Cname xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n     \t       \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n \t   \u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic003224\u003C/idno>\n                \u003Cidno type=\"TM\">636409\u003C/idno>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\">39101071\u003C/idno>\n                \u003Cidno type=\"PHI\">316211\u003C/idno>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic003224\u003C/idno>\n                \u003Cidno type=\"DOI\" when=\"2020-12-18\">10.5281/zenodo.4357304\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Catania\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/018\">Museo Civico di Catania\u003C/repository>\n                        \u003Cidno type=\"inventory\">544\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"grc\">Ancient Greek\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>Two joining fragments of marble plaque, slightly damaged in the middle.\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.marble\" ref=\"http://www.eagle-network.eu/voc/material/lod/48.html\">marble\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/257\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--measurements from Korhonen-->\n                                        \u003Cheight unit=\"cm\">18\u003C/height>\n                                        \u003Cwidth unit=\"cm\">24\u003C/width>\n                                        \u003Cdepth unit=\"cm\">1.6\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.damaged\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Letters with small apices, lunate Ε and Σ, cursive Μ. Four ivy-leaves and a palmette.\u003C/p>\u003C!--measurements from Korhonen-->\n                                \u003Clocus from=\"line1\" to=\"line5\">Lines 1-5\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\">11-15\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\">not recorded\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462270\">Catina\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525068\">Catania\u003C/placeName>\n                            \t\u003Cgeo>37.49223, 15.07041\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0101\" notAfter-custom=\"0250\" precision=\"low\">2nd century CE or first half of 3rd century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Original discovery not recorded. Kaibel thought this inscription was ‘urbanae fortasse originis’, but the structure of the epitaph is in line with other epitaphs from Catania and this led Korhonen to consider it to be from Catania.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\">Observed by Castelli in Monastero di San Nicolò l’Arena, later by Korhonen in Magazzino superiore, Collezione dei Benedettini (formerly sala VII 188).\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-07-30\" who=\"#AA\">Alex Antoniou Epidoc editing and English translation\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-12-22\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003224_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003224.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#ivy-leaf\">❦\u003C/g> \u003CpersName type=\"attested\">\u003Cname>Κατυλλεῖνος\u003C/name>\u003C/persName> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g>\n                    \u003Clb n=\"2\"/>\u003Cw>ἒζη\u003Csupplied reason=\"lost\">σε\u003C/supplied>ν\u003C/w> \u003Cw>ἔτη\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cnum value=\"13\">ιγ\u003C/num> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g> \u003Cw>ἐποίησεν\u003C/w>\n                    \u003Clb n=\"4\"/>\u003CpersName type=\"attested\">\u003Cname>Εὐοδία\u003C/name>\u003C/persName> \u003Cw>μνήμης\u003C/w>\n                    \u003Clb n=\"5\"/>\u003Cw>χάριν\u003C/w> \u003Cspace quantity=\"1\" unit=\"character\"/> \u003Cg ref=\"#ivy-leaf\">❦\u003C/g> \u003Cg ref=\"#palm\">⸙\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 2\">\u003Cnote>Castelli read the text without the lacuna, but according to Korhonen, this is a not recorded supplement by the previous editors\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf #AA\">\n                \u003Cp>Katylleinos lived for 13 years. Eudoia made (this) for his memory\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>Katylleinos visse per 13 anni. Euodia fece (questo) in sua memoria.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>According to Korhonen, the form of this epitaph is one of the most common in Catania, with two main sentences, the first containing the name of the deceased and his age, the second the indication of the dedicant with the aorist of \u003Cforeign xml:lang=\"grc\">ποιέω\u003C/foreign>, which in this case precedes the name of the dedicant, as in IG 14.467 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001291\">ISic001291\u003C/ref>. For this reason, Korhonen rejects Kaibel’s classification (adopted by Moretti in IGUR) of this inscription among the urban inscriptions. The expression \u003Cforeign xml:lang=\"grc\">μνήμης χάριν\u003C/foreign> occurs in many epitaphs from Catania: e.g. IG 14.485 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001308\">ISic00001308\u003C/ref>, IG 14.509 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001330\">ISic001330\u003C/ref>, IG 14.511 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001332\">ISic001332\u003C/ref>. The name of the deceased, \u003Cforeign xml:lang=\"grc\">Κατυλλεῖνος\u003C/foreign>, recurs also in an inscription from Syracuse: SEG 36.862 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001650\">ISic001650\u003C/ref>. \u003Cforeign xml:lang=\"grc\">Εὐοδία\u003C/foreign> could be the mother of the young deceased: the name is possibly found in an inscription from Syracuse (Agnello 1960: no.39 + Ferrua 1989: no.243).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">1745\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>68\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5711\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/> \n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGUR\">\n\t\t\t    \u003Cauthor>Moretti\u003C/author>\n\t\t\t    \u003Cdate>1968-1990\u003C/date>\n\t\t\t    \u003CcitedRange>670\u003C/citedRange>\n\t\t\t    \u003Cptr target=\"https://www.zotero.org/groups/382445/items/MCBAPQH7\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000015\">https://biblio.inscriptiones.org/epig10000015\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
