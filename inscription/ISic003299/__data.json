      \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-09-17\" who=\"#AA\">Alex Antoniou Epidoc editing and English translation\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-12-22\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003299_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003299.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cw>\u003Csupplied reason=\"lost\">ἐνθάδε\u003C/supplied>\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">κῖτε\u003C/supplied>\u003C/w> \u003CpersName type=\"attested\">\u003Cname>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Clb n=\"2\" break=\"no\"/>νος\u003C/name>\u003C/persName> \u003Cw>ζή\u003Csupplied reason=\"lost\">σας\u003C/supplied>\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">ἔτη\u003C/supplied>\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"3\"/>\u003Cw>ἀμέμπ\u003Csupplied reason=\"lost\">τως\u003C/supplied>\u003C/w> \u003Cw>\u003Csupplied reason=\"lost\">τελευτᾷ\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw>τῇ\u003C/w> \u003Cw>πρὸ\u003C/w> \u003Chi rend=\"supraline\">\u003Cnum value=\"14\">ιδ\u003C/num>\u003C/hi> \u003Cw>\u003Csupplied reason=\"lost\">καλανδῶν\u003C/supplied>\u003C/w>\n                    \u003Clb n=\"5\"/>\u003Cw>\u003Cexpan>\u003Cabbr>Μαρτ\u003C/abbr>\u003Cex>ίων\u003C/ex>\u003C/expan>\u003C/w> \u003Cw>ἡμέρ\u003Csupplied reason=\"lost\">ᾳ\u003C/supplied>\u003C/w> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text based on photograph\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 1\">\u003Cnote>Ferrua: [κεῖται]; Korhonen: [κῖτε]\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 5\">\u003Cnote>In the lacuna, a day of the week should be mentioned\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>Here lies -nos, having lived for ... years blamelessly. He died 14 days before the kalends of March on the day of…\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>Qui giace -nos, avendo vissuto ... anni senza colpa. Morì 14 giorni prima delle Calende di marzo, nel giorno di …\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>This Christian epitaph has the traditional structure with the \u003Cforeign xml:lang=\"grc\">ἐνθάδε κεῖται\u003C/foreign> formula, the name of the deceased (here in the lacuna) followed by his age and by another independent sentence with the day of death (with the present of \u003Cforeign xml:lang=\"grc\">τελευτάω\u003C/foreign>), as recurring in other inscriptions from Catania, such as IG 14.556 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic001375\">ISic001375\u003C/ref>. In the lacuna there should also have been the specification of the day of the week (\u003Cforeign xml:lang=\"grc\">ἡμέρ[ᾳ---]\u003C/foreign>).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>208\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>120 no.459\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/759ZXHKQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001995\">https://biblio.inscriptiones.org/epig10001995\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
