\"ISic000579.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cname>Domitia\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Chimen\n                    \u003Clb n=\"2\" break=\"no\"/>na\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>\u003Cexpan>\u003Cabbr>A\u003C/abbr>\u003Cex>ulo\u003C/ex>\u003C/expan>\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cname>Aemilio\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"3\"/>\u003Cname>Aristomeni\u003C/name> \u003Cg ref=\"#interpunct\">·\u003C/g> et \u003Cg ref=\"#interpunct\">·\u003C/g> suis\n                    \u003Clb n=\"4\"/>\u003Cexpan>\u003Cabbr>h\u003C/abbr>\u003Cex>oc\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>onumentum\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g>\n                    \u003Clb n=\"5\"/>\u003Cexpan>\u003Cabbr>h\u003C/abbr>\u003Cex>eredem\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>n\u003C/abbr>\u003Cex>on\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>equetur\u003C/ex>\u003C/expan>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>CIL\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>Domitia Chimenna for Aulus Aemilius Aristomenus and his children. This monument does not pass to the heir.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Korhonen makes a convincing case that the text is originally from Termini, not an importation from Rome; he also notes the unusual name, attested also in CIL 10.7394, with suffix similar to other Greek examples, and perhaps a Sikel onomastic example (noting that linguistic interference is rare in the Termini Latin inscriptions).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624\u003C/date>\n                        \u003CcitedRange>89\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GIN6NANU\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002388\">https://biblio.inscriptiones.org/epig10002388\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624 [1625]\u003C/date>\n                        \u003CcitedRange>249\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/ZP8DE8KS\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001931\">https://biblio.inscriptiones.org/epig10001931\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/books/CILv10pII1883\">7400\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Bormann and Henzen\u003C/author>\n                        \u003Cdate>1876\u003C/date>\n                        \u003CcitedRange>1700\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VVHPQFD3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001134\">https://biblio.inscriptiones.org/epig10001134\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILMusTermini\">\n                         \u003Cauthor>Bivona\u003C/author>\n                         \u003Cdate>1994\u003C/date> \n                        \u003CcitedRange>B2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JCV85C79\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002137\">https://biblio.inscriptiones.org/epig10002137\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2001\u003C/date>\n                        \u003CcitedRange>98-102\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/CVTW89H4\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001425\">https://biblio.inscriptiones.org/epig10001425\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
