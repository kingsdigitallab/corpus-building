ntità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\">\u003Cdesc>personal name\u003C/desc>\u003C/gap> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Csupplied reason=\"lost\">Ν\u003C/supplied>εικάνδρου\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Csupplied reason=\"lost\">ἔζησεν\u003C/supplied> ἔτη \u003Cnum value=\"45\">με\u003C/num>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/> \u003Csupplied reason=\"lost\">ὑιὸ\u003C/supplied>ς πατρί\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003Cp>Text of IGPalermo\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--fragment; donated by Salinas to the museum. M.-P. is somewhat confusing in assertion that epig. is late C3AD, but then noting a coin of Constantine from 337-350 AD, but which however is not clearly linkable to this tomb from the ref. to Salinas, NSc (1901), 38 which she gives. The name may be Neikandros; age in years; erected by his son.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003Cci