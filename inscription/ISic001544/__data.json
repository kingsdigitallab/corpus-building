445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGMusPalermo\">\n                         \u003Cauthor>Manni Piraino\u003C/author>\n                         \u003Cdate>1973\u003C/date> \n                        \u003CcitedRange>3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F66S4X3M\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000531\">https://biblio.inscriptiones.org/epig10000531\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1999\u003C/date>\n                        \u003CcitedRange>39 no.13 fig.90\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GRB3IPD5\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001813\">https://biblio.inscriptiones.org/epig10001813\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
