te\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003Cp>Well spaced plain letters, showing some tendency to curvature on the longer strokes. Alpha has straight bar; epsilon has bars of equal length; nu leans to the right; omicron appears to be small; initial aspirate of the 'half-eta' form.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                    \u003Cwidth/>\n                                    \u003Cdepth/>\n                                    \u003C/dimensions>\n                                \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462236\">Enna\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2524819\">Enna\u003C/placeName>\n                                \u003Cgeo>37.5655, 14.27433\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0400\" notAfter-custom=\"-0301\" evidence=\"lettering\">4th century BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" notAfter=\"2007\"/>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">none\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.document.public\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/360.html\">public document\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2021-06-21\" who=\"#JP\">Jonathan Prag created file from published data\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic030121_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic030121.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n               \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CplaceName type=\"ethnic\">ͱενναί\u003Cunclear>ο̄\u003C/unclear>\u003Csupplied reason=\"lost\">ν\u003C/supplied>\u003C/placeName> \u003Csupplied reason=\"lost\">δαμόσιον\u003C/supplied>\n                \u003C/ab>\n           \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Manganaro\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>public property of the people of Enna\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Assuming that Manganaro's reading of final omicron is correct (and not omega; the published photograph does not provide sufficient clarity to judge), then a date in the early fourth century rather than later seems likely (the semi-aspirate itself is rare in Sicily, and usage otherwise appears to date between the late fifth and c.300 BCE).\n                \u003C!-- Jeffery Archive: J.WC. Leont. NL p.01a-c -->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>56.1077.B11\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>2008.0635\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro Perrone\u003C/author>\n                        \u003Cdate>2007\u003C/date>\n                        \u003CcitedRange>35 with fig.5\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/N3XMMAJZ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002447\">https://biblio.inscriptiones.org/epig10002447\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"archive\">\n                        \u003Cauthor>Jeffery\u003C/author>\n                        \u003CcitedRange>J.WC.Leont.NL.p.01a-c\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/QV9CP9PX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002294\">https://biblio.inscriptiones.org/epig10002294\u003C/ref>\u003C/bibl>\n                   \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\n                        \u003Cbibl/>\t       \n\t   \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
