C/rs>\n                                    \u003Crs ana=\"#execution.rubrication\">Rubrication\u003C/rs>\n                                \t\u003Cdamage ana=\"#text_condition.complete\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Clocus from=\"line1\" to=\"line5\">Line 1-5\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\">58-105\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462373\">Motya\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2524039\">Mozia\u003C/placeName>\n                            \t\u003Cgeo>37.86503, 12.46798\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0525\" notAfter-custom=\"-0475\">End of 6th or early 5th century BCE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"2014\">Found in 2014, in the Motya necropolis; it was reemployed inside the West Wall of Tower B8.1\u003Cgeo>37.8703771,12.4678083\u003C/geo>\u003C/provenance>\u003C!-- coordinates for tower B8 -->\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\" xml:id=\"autopsy\" resp=\"#RDS\">De Simone, 2014-07\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"edited\">\n            \u003ClistChange>\n                \u003Cchange when=\"2025-09-02\" who=\"#JP\">Jonathan Prag created file based upon scheda provided by Rossana De Simone\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001886_tiled.tif\" height=\"2144px\" width=\"1424px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001886.jpg\" height=\"2144px\" width=\"1424px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"transliteration\" xml:space=\"preserve\" xml:lang=\"xpu-Latn\" resp=\"#JP\" source=\"#autopsy\">\n                \u003Cab>\n                    \u003Clb n=\"1\" style=\"text-direction:r-to-l\"/>mnṣpt\n                    \u003Clb n=\"2\" style=\"text-direction:r-to-l\"/>\u003CpersName type=\"attested\">\u003Cname>ḥṭʾlm\u003C/name>\n                    \u003Clb n=\"3\" style=\"text-direction:r-to-l\"/>\u003Cname>mms\u003C/name>\n                    \u003Clb n=\"4\" style=\"text-direction:r-to-l\"/>bn \u003Cname>bʿ\n                    \u003Clb n=\"5\" style=\"text-direction:r-to-l\"/>lytn\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of De Simone\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#RDS\">\n                \u003Cp>Stele of ḥṭʾlm mms son of bʿlytn.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#RDS\">\n                \u003Cp>Stele di ḥṭʾlm mms figlio di bʿlytn.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#RDS\">\n                \u003Cp>ḥṭʾlm: a hapax in phoenician onomastics. mms: punic personal name, unexplained. bʿlytn: phoenician personal name “Baal has given”, Latin transcription attested in various inscriptions, e.g.: BALITHONIS (CIL V 4920), BALIATON (CIL VIII 16011, 27491), BALIATHO (CIL VIII 68, AE 1992 1781).\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                   \u003Cbibl>\n                        \u003Cauthor>De Simone\u003C/author>\n                        \u003Cdate>2023\u003C/date>\n                        \u003CcitedRange>55 fig.1\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/YNRMMBXA\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002543\">https://biblio.inscriptiones.org/epig10002543\u003C/ref>\n                    \u003C/bibl>\n                  \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
