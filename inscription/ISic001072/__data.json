eg>\u003C/choice> ἡμε\u003Csupplied reason=\"lost\">ρῶν\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text after Kaibel, compared against Paci\u003C/note>\u003C/app>\n                    \u003Capp loc=\"1\">\u003Crdg>ΚΑΛΑΝΔΕΙΝ\u003C/rdg>\u003Cnote>Bergk, ap. Kaibel from the stone\u003C/note>\u003C/app>\n                    \u003Capp loc=\"2\">\u003Crdg>[Φ]ε[βρ]αρίων\u003C/rdg>\u003Cnote>Paci\u003C/note>\u003C/app>\n                    \u003Capp loc=\"3\">\u003Crdg>ΗΛ...Α\u003C/rdg>\u003Cnote>Bergk, ap. Kaibel, from the stone, for ἡμ[έρ]α\u003C/note>\u003C/app>\n                    \u003Capp loc=\"4\">\u003Crdg>ϹΥΝΛΡΙΟϹΜΑΛΙΚΟϹΙΗΜΕ\u003C/rdg>\u003Cnote>Bergk, ap. Kaibel from the stone; reading here is that proposed by Kirchhoff (Kaibel \"vix vera sunt\"), followed by Paci\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>The text is preserved only in a manuscript tradition, and readings, particularly of the final line, depend upon conjectural interpretation of the letters originally recorded by Schubart.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">252\u003C/ref>\n                        \u003C/citedRange