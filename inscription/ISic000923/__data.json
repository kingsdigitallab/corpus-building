tà Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM #JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Ἐπαφρό\u003Csupplied reason=\"omitted\">δ\u003C/supplied>ειτος\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"10\">ἐτελεύτησεν\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"15\">\u003Cexpan>\u003Cabbr>μην\u003C/abbr>\u003Cex>ὶ\u003C/ex>\u003C/expan>\u003C/w> \u003Cname>\u003Cw n=\"20\">Δεκεν\n                    \u003Clb n=\"4\" break=\"no\"/>βρί\u003Csurplus>α\u003C/surplus>ῳ\u003C/w>\u003C/name> \u003Cg ref=\"#alpha\" n=\"25\">α\u003C/g> \u003Cname>\u003Cw n=\"30\">\u003Cexpan>\u003Cabbr>Ἰ\u003C/abbr>\u003Cex>ησοῦς\u003C/ex>\u003C/expan>\u003C/w>\u003C/name> \u003Cw n=\"35\">\u003Cexpan>\u003Cabbr>\u003Cam>\u003Cg ref=\"#christogram\" n=\"40\">☧\u003C/g>\u003C/am>\u003C/abbr>\u003Cex>Χριστὸ\u003C/ex>\u003Cabbr>ς\u003C/abbr>\u003C/expan>\u003C/w> \u003Cg ref=\"#omega\" n=\"45\">ω\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Ἐπαφρόδειτος\">Ἐπαφρόδειτος\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"τελευτάω\">ἐτελεύτησεν\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"μείς\">μηνὶ\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"December\">Δεκενβρίῳ\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"Ἰησοῦς\">Ἰησοῦς\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"Χριστός\">Χριστὸς\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after transcription of Orsi (correcting Carini / Kaibel)\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>Epaphrodeitos passed away in the month of December. ((Alpha)) Jesus Christ ((Omega))\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">106\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1893\u003C/date>\n                        \u003CcitedRange>296 no. 65\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/V7HNHTAG\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001715\">https://biblio.inscriptiones.org/epig10001715\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Wessel\u003C/author>\n                        \u003Cdate>1989