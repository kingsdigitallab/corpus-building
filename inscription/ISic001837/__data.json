pan> Pompe\u003Csupplied reason=\"lost\">i\u003C/supplied> \u003Csupplied reason=\"lost\">Falconis\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>co\u003C/abbr>\u003Cex>n\u003C/ex>\u003Cabbr>s\u003C/abbr>\u003Cex>ulis\u003C/ex>\u003C/expan>\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>nep\u003C/abbr>\u003Cex>ti\u003C/ex>\u003C/expan>\u003C/supplied>\n                    \u003Clb n=\"4\"/>\u003Cexpan>\u003Cabbr>Q\u003C/abbr>\u003Cex>uinti\u003C/ex>\u003C/expan> \u003Cunclear>S\u003C/unclear>\u003Csupplied reason=\"lost\">osi\u003C/supplied> \u003Csupplied reason=\"lost\">Senecionis\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>co\u003C/abbr>\u003Cex>n\u003C/ex>\u003Cabbr>s\u003C/abbr>\u003Cex>ulis\u003C/ex>\u003C/expan>\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cnum value=\"2\">II\u003C/num>\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>pro\u003C/abbr>\u003Cex>nepti\u003C/ex>\u003C/expan>\u003C/supplied>\n                    \u003Clb n=\"5\"/>\u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>Sex\u003C/abbr>\u003Cex>ti\u003C/ex>\u003C/expan>\u003C/supplied> \u003Csupplied reason=\"lost\">Iuli\u003C/supplied> \u003Csupplied reason=\"lost\">Frontini\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>co\u003C/abbr>\u003Cex>n\u003C/ex>\u003Cabbr>s\u003C/abbr>\u003Cex>ulis\u003C/ex>\u003C/expan>\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cnum value=\"3\">III\u003C/num>\u003C/supplied> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>abn\u003C/abbr>\u003Cex>epti\u003C/ex>\u003C/expan>\u003C/supplied>\n                    \u003Clb/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Prado from autopsy, after Eck and Barbera\u