Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#christogram\">☧\u003C/g>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cgap reason=\"lost\" quantity=\"1\" unit=\"character\"/>\u003Corig>ΔΙ\u003Cunclear>Ο\u003C/unclear>\u003C/orig>\n                    \u003Clb n=\"3\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>ΣΙΣΑΧΩΝΩΝ\u003C/orig>\n                    \u003Clb n=\"4\"/>τελεύτ\u003Csupplied reason=\"lost\">α\u003C/supplied> ἐτῶν\n                    \u003Clb n=\"5\"/>\u003Cgap reason=\"lost\" quantity=\"1\" unit=\"line\"/>\n                    \u003Clb n=\"6\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Corig>Ι\u003Cunclear>ΙΙ\u003C/unclear>ΔΙΚΛ\u003C/orig>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Pugliese Carratelli 1956 with changes\u003C/note> \u003C!-- check other editions: I left the unintelligible letters, even if not reported by P.C. to check other editions and see if they are really visible -->\n                    \u003C/app>\n                    \u003Capp>\n                        \u003Cnote>Führer: ἐ]τελεύτ[ησε\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--largely lost inscr. at the entrance to the 'catacomba maggiore'; surmounted by Christian monogram, and outlined by a small timpanum. An 'imperfetta copia' was made, on a limestone block, or the inscr. when it was still in better condition, and this now in the Museo Iudica coll. Only line 3 still readable on original, having: teleuta eteleutese eton-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>42.0820.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Pugliese Carratelli\u003C/author>\n                        \u003Cdate>1956\u003C/date>\n                        \u003CcitedRange>no.48 ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/PJDRZH66\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001394\">https://biblio.inscriptiones.org/epig10001394\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"NSA\">\n                        \u003Cauthor>Pugliese Carratelli\u003C/author>\n                        \u003Ctitle>NSA\u003C/title>\n                        \u003Cdate>1953\u003C/date>\n                        \u003CcitedRange>350\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4MCP2PVV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001392\">https://biblio.inscriptiones.org/epig10001392\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1992\u003C/date>\n                        \u003CcitedRange>455\u003C/citedRange