"width",{"_":50,"unit":44,"dimension":51},"6","depth",{"layout":53},{"p":54,"rs":55,"damage":59},"Text over four lines to fit the width of the stone, below a menorah",{"_":56,"ana":57,"ref":58},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":60},"#text_condition.complete",{"lettering":62,"dimensions":63},"Crudely incised / scratched letters, Alpha with downard left-sloping bar, eyes of the beta are not closed, epsilon is lunate, sigma is lunate but with straight lines.",[64,71],{"type":65,"l":66,"from":67,"to":68,"h":69,"unit":70},"letterHeight","Line 2-5","line2","line5","40-70","mm",{"type":72,"l":73,"from":74,"to":67,"unit":70},"interlinear","Interlineation line 1 to 2","line1",{"_":76,"notBefore":77,"notAfter":78,"evidence":79},"5th century CE (so Brugnone)",401,500,"lettering, textual-context",[81,85],{"_":82,"type":83,"ref":84},"Philosophiana","ancient","http://pleiades.stoa.org/places/462423",{"_":86,"type":87,"ref":88,"offset":89},"Mazzarino","modern","http://sws.geonames.org/2524200","near",[91],[92,93],37.30188,14.20959,{"_":95,"type":96,"subtype":97,"notBefore":98,"notAfter":99,"geo":100},"Found in contrada Fontanazzi (during excavations of 1954 / 1961), in the eastern part of the Sofiana cemetery, re-use in a boundary wall between two lots of the cemetery","found","discovered","1954","1961",[101,102],37.3185981,14.3024473,[101,102],{"_":105,"type":106,"subtype":107,"geo":108},"none","observed","autopsied",null,[],"Italy","Sicily","Gela",{"_":114,"role":115,"ref":116,"museum":117},"Museo Archeologico Regionale di Gela","museum","http://sicily.classics.ox.ac.uk/museum/010",{"slug":118,"type":115,"name":114,"uri":116,"description":119,"location":120},"010","Arranged over two floors, the lower floor is devoted to a geographically organised exhibit of material from the site of Gela, and includes some marvellous pieces. The upper floor is split into several discrete sections. A comprehensive display of the coins is preceded by the famous altars found in Bosco Littorale, and a pi-shaped corridor begins with material from the enormous Thesmophorion at Contrada Bitelemi and then runs through material from the territory around Gela in chronological order from prehistory to the Greeks, Romans and Byzantines",{"settlement":112,"region":121,"country":110,"address":122,"geo":123},"Caltanissetta","Corso Vittorio Emanuele 1, 93012 - Gela (CL)",{"lat":124,"lon":125},37.063605,14.257248,{"_":127,"type":128},"9361","inventory",{"_":130,"mainLang":131,"languages":132},"Ancient Greek","grc",[130],{"type":134,"bibl":135},"edition",[136,144,154,158,162,166,177,185,194,203],{"type":137,"n":138,"citedRange":139,"ptr":140,"ref":142},"bulletin","AE","1996.0808",{"target":141},"http://zotero.org/groups/382445/items/R46KDTZX",{"_":143,"target":143},"https://biblio.inscriptiones.org/epig10001283",{"type":137,"n":145,"citedRange":146,"ptr":147,"ref":149,"title":151,"author":22,"date":152,"citation":153},"SEG","56.1081",{"target":148},"http://zotero.org/groups/382445/items/F2GG87EQ",{"_":150,"target":150},"https://biblio.inscriptiones.org/epig10000796","Supplementum epigraphicum graecum","1923-","\u003Cspan>‘Supplementum Epigraphicum Graecum’, \u003Ci>Supplementum Epigraphicum Graecum\u003C/i>, 1923, \u003Ca href=\"http://www.worldcat.org/oclc/1607583\">http://www.worldcat.org/oclc/1607583\u003C/a>\u003C/span>",{"type":137,"n":145,"citedRange":155,"ptr":156,"ref":157,"title":151,"author":22,"date":152,"citation":153},"52.0908",{"target":148},{"_":150,"target":150},{"type":137,"n":145,"citedRange":159,"ptr":160,"ref":161,"title":151,"author":22,"date":152,"citation":153},"46.1245",{"target":148},{"_":150,"target":150},{"type":137,"n":145,"citedRange":163,"ptr":164,"ref":165,"title":151,"author":22,"date":152,"citation":153},"15.0599",{"target":148},{"_":150,"target":150},{"type":137,"n":167,"citedRange":168,"ptr":169,"ref":171,"title":173,"author":174,"date":175,"citation":176},"BE","1958.0563",{"target":1