  \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-09-12\" who=\"#JP\">Jonathan Prag made preliminary draft, text edition etc. from ISegesta\u003C/change>\n                \u003Cchange when=\"2025-12-30\" who=\"#ZG\">Zoe Greblunas tagged names and persons\u003C/change> \n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002939_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002939.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Csupplied reason=\"lost\">ἐ\u003C/supplied>\u003Cunclear>π\u003C/unclear>ὶ \u003CroleName type=\"civic.religious\" subtype=\"hierothytes\">ἱε\u003Csupplied reason=\"lost\">ρ\u003C/supplied>οθύ\u003Csupplied reason=\"lost\">τ\u003C/supplied>α\u003C/roleName> \u003CpersName type=\"attested\">\u003Cname>\u003Cunclear>Δ\u003C/unclear>ιο\u003Cunclear>ν\u003C/unclear>υσ\u003Cunclear>ί\u003C/unclear>\u003Csupplied reason=\"lost\">ου\u003C/supplied>\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cunclear>Σ\u003C/unclear>ωπάτ\u003Csupplied reason=\"lost\">ρου\u003C/supplied>\u003C/name>\u003C/persName>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003CroleName type=\"civic.religious\" subtype=\"hieromnamon\">\u003Csupplied reason=\"lost\">ἱ\u003C/supplied>\u003Cunclear>ε\u003C/unclear>ρομναμονέοντος\u003C/roleName>\n                    \u003Clb n=\"3\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Csupplied reason=\"lost\">Ἀ\u003C/supplied>ρτεμιδώρου\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Δόσσιος\u003C/name>\u003C/persName> \u003Cname>Γραδαναίου\u003C/name>\u003C/persName>\n                    \u003Clb n=\"4\"/>τὸ δίπυλον οἱ ἀνδρεῶνες\n                    \u003Clb n=\"5\"/>ἁ προέδρα ἐστεγάσθεν ἐθυ\u003Csupplied reason=\"lost\">ρ\u003C/supplied>\u003Cgap reason=\"lost\" unit=\"character\" quantity=\"2\"/>\n                    \u003Clb n=\"6\"/>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\u003Corig>\u003Cunclear>Σ\u003C/unclear>ΔΙΣ\u003C/orig>\u003Cgap reason=\"lost\" unit=\"character\" extent=\"unknown\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text of Ampolo and Erdas 2019\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--essentially restudied by Nenci, with autopsy, found in the stores at Segesta; Guarducci's publ. based on a photo. Text appears to record multiple 'andreones', presumably rooms of the gymnasion for the Andres (cf. nenci, ASNP 21 (1991), p.921 no.1 = SEG 41.826; and IG 14.291). Note the Elymian elements to the onomastics also.-->\u003C/p>\n            \u003C/div>\n            \u003C