  \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000637_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000637.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#TA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname type=\"praenomen\">\u003Cw n=\"5\">\u003Cexpan>\u003Cabbr>Π\u003C/abbr>\u003Cex>ούβλιε\u003C/ex>\u003C/expan>\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"10\">·\u003C/g> \u003Cname type=\"nomen\">\u003Cw n=\"15\">Κλώδιε\u003C/w>\u003C/name>\n                    \u003Clb n=\"2\"/>\u003Cname type=\"cognomen\">\u003Cw n=\"20\">Κορνηλιανὲ\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"25\">εὐσεβῆ\u003C/w> \u003Cg ref=\"#interpunct\" n=\"30\">·\u003C/g> \u003Cw n=\"35\">\u003Cchoice>\u003Corig>χαέρε\u003C/orig>\u003Creg>χαῖρε\u003C/reg>\u003C/choice>\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Πούβλιος\">Πούβλιε\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"Κλώδιος\">Κλώδιε\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"Κορνηλιανός\">Κορνηλιανὲ\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"εὐσεβής\">εὐσεβῆ\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"χαίρω\">χαῖρε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Manganaro 1994\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#TA\">\n                \u003Cp>Publius Claudius Cornelianus, a pious man, farewell.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--P. Klodius Kornelianus (Publius Claudius Cornelianus). Eusebe, Chaire (chaere). The urn has rams heads on the corner. Mang photographed it, but doesn't say where it now is.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1994.0760\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>44.0791\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n         