7,"xml:id":218,"ref":219},"Robert Crellin","RC","https://orcid.org/0000-0002-0100-7437",{"_":221,"xml:id":222,"ref":223},"Zoé Lienard","ZL","https://orcid.org/0009-0007-0586-7956",{"_":225,"when":226,"who":227},"tagged names and persons","2025-12-16","#ZL",{"n":101,"url":102,"height":103,"width":104,"desc":105,"surfaceType":106},[230],{"atLeast":231,"atMost":232},30,75,[234,235,236,237,238],"Kaibel, 1890, IG","Manni Piraino, 1973, IGMusPalermo","Notizie degli scavi di antichità, 1876-","Hoffmann, 1904, SGDI","Sofia, 2015, Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi",[240,241,242,243,244],"Q2SBPG9F","F66S4X3M","4MCP2PVV","DQDPC573","9QTE4E3Z",[246,247,248,25,30,249,250,251,252,253,254,255,256,127],"isic001206","epitaph for diokles",{"_":5},"sandstone","abacaenum","tripi","sicilia","sicily","palermo","museo archeologico regionale antonino salinas","ancient greek",[],{"title":259,"body":260,"divs":261,"editions":286,"images":305,"handnote":311},"ISic001206. Epitaph for Diokles","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δίοκλε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Δίοκλε\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">Δίοκλε\u003C/span>\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Dmitry Dundua, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-interpretive-simple-lemmatized\">  \u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">Δίοκλε\u003C/span>  \u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δίοκλε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Δίοκλε\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">ΔΙΟΚΛΕ\u003C/span>\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">ΧΑΙΡΕ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Dmitry Dundua, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-diplomatic-simple-lemmatized\">\u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">ΔΙΟΚΛΕ\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">ΧΑΙΡΕ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001206_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001206_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001206.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001206-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>  \u003Cspan>Text as per IG and IGMusPal\u003C/span>  \u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/a>\u003C/p>  \u003Cp>Diokles, farewell!\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>The name is in the vocative form of \u003Ca href=\"http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?name=%CE%94%CE%B9%CE%BF%CE%BA%CE%BB%E1%BF%86%CF%82\" target=\"_blank\">Διοκλῆς\u003C/a>, a common name, widely attested in Sicily. The suggestion of Manni Piraino that it derives from a form Δίοκλος (suggested to be attested by \u003Ca href=\"http://data.perseus.org/citations/urn:cts:latinLit:phi0474.phi005.perseus-eng1:2.5.16\" target=\"_blank\">Cic. Verr. 2.5.16\u003C/a>: de Apollonio, Diocli1 filio, Panhormitano, cui gemino cognomen est) seems implausible. The form Δίοκλος (LGPN V3B: 37428) is only attested once, and the form in the Verrines is surely a latinisation of convenience. There is no obvious reason to date this to the early imperial period (as Manni Piraino does); the letter forms - as well as the contextual evidence of the Hellenistic necropolis at Abakainon - suggest a Hellenistic date.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli>  \u003Ca href=\"https://clio.columbia.edu/catalog/6873760\" target=\"_blank\">382a\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10001072\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001072\u003C/a>  \u003C/li>\u003Cli> Salinas NSA 1886 464 no.d \u003Ca href=\"https://biblio.inscriptiones.org/epig10001392\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001392\u003C/a>  \u003C/li>\u003Cli> Hoffmann 1904 5208a \u003Ca href=\"https://biblio.inscriptiones.org/epig10000817\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000817\u003C/a>  \u003C/li>\u003Cli> Manni Piraino 1973 125 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000531\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000531\u003C/a>  \u003C/li>\u003Cli> Sofia 2015 108 and fig.112 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001575\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001575\u003C/a>  \u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\"> \u003Cp>Crude and irregular letters of unequal size, deeply incised. Omicron is small and mid-line; kappa has short equal length arms attached to the vertical; epsilon has shorter middle bar (i the first instance detached from the vertical); alpha has straight bar; rho has rounded closed eye.\u003C/p> Line 1-2  30-75  Interlineation line 1 to 2    \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence.  \u003C/div>",[262,265,268,271,274,277,280,283],{"id":263,"html":264},"editions","\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δίοκλε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Δίοκλε\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">Δίοκλε\u003C/span>\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Dmitry Dundua, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-interpretive-simple-lemmatized\">  \u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">Δίοκλε\u003C/span>  \u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δίοκλε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Δίοκλε\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">ΔΙΟΚΛΕ\u003C/span>\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">ΧΑΙΡΕ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Dmitry Dundua, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-diplomatic-simple-lemmatized\">\u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">ΔΙΟΚΛΕ\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">ΧΑΙΡΕ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":266,"html":267},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic001206_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001206_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic001206.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic001206-thumb.jpg\">\u003C/a>",{"id":269,"html":270},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>  \u003Cspan>Text as per IG and IGMusPal\u003C/span>  \u003C/span>\u003C/li>\u003C/ul>",{"id":272,"html":273},"translation","\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/a>\u003C/p>  \u003Cp>Diokles, farewell!\u003C/p>  ",{"id":275,"html":276},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>The name is in the vocative form of \u003Ca href=\"http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?name=%CE%94%CE%B9%CE%BF%CE%BA%CE%BB%E1%BF%86%CF%82\" target=\"_blank\">Διοκλῆς\u003C/a>, a common name, widely attested in Sicily. The suggestion of Manni Piraino that it derives from a form Δίοκλος (suggested to be attested by \u003Ca href=\"http://data.perseus.org/citations/urn:cts:latinLit:phi0474.phi005.perseus-eng1:2.5.16\" target=\"_blank\">Cic. Verr. 2.5.16\u003C/a>: de Apollonio, Diocli1 filio, Panhormitano, cui gemino cognomen est) seems implausible. The form Δίοκλος (LGPN V3B: 37428) is only attested once, and the form in the Verrines is surely a latinisation of convenience. There is no obvious reason to date this to the early imperial period (as Manni Piraino does); the letter forms - as well as the contextual evidence of the Hellenistic necropolis at Abakainon - suggest a Hellenistic date.\u003C/p>  ",{"id":278,"html":279},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli>  \u003Ca href=\"https://clio.columbia.edu/catalog/6873760\" target=\"_blank\">382a\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10001072\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001072\u003C/a>  \u003C/li>\u003Cli> Salinas NSA 1886 464 no.d \u003Ca href=\"https://biblio.inscriptiones.org/epig10001392\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001392\u003C/a>  \u003C/li>\u003Cli> Hoffmann 1904 5208a \u003Ca href=\"https://biblio.inscriptiones.org/epig10000817\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000817\u003C/a>  \u003C/li>\u003Cli> Manni Piraino 1973 125 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000531\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000531\u003C/a>  \u003C/li>\u003Cli> Sofia 2015 108 and fig.112 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001575\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001575\u003C/a>  \u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  ",{"id":281,"html":282},"handnote"," \u003Cp>Crude and irregular letters of unequal size, deeply incised. Omicron is small and mid-line; kappa has short equal length arms attached to the vertical; epsilon has shorter middle bar (i the first instance detached from the vertical); alpha has straight bar; rho has rounded closed eye.\u003C/p> Line 1-2  30-75  Interlineation line 1 to 2    ",{"id":284,"html":285},"license"," Licensed under a Creative Commons-Attribution 4.0 licence.  ",[287,289,292,294,297,298,301,302],{"html":288},"Text encoding: Jonathan Prag",{"id":290,"lang":127,"html":291},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δίοκλε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Δίοκλε\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">Δίοκλε\u003C/span>\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":293},"Text encoding: Dmitry Dundua, Robert Crellin",{"id":295,"html":296},"edition-interpretive-simple-lemmatized","\u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">Δίοκλε\u003C/span>  \u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":288},{"id":299,"lang":127,"html":300},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δίοκλε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Δίοκλε\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">ΔΙΟΚΛΕ\u003C/span>\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">ΧΑΙΡΕ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",{"html":293},{"id":303,"html":304},"edition-diplomatic-simple-lemmatized","\u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">ΔΙΟΚΛΕ\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">ΧΑΙΡΕ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",[306,308],{"image":102,"thumb":307,"title":105},"ISic001206_tiled-thumb.tif",{"image":309,"thumb":310,"title":105},"ISic001206.jpg","ISic001206-thumb.jpg",[312],{