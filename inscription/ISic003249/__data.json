ge>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003249_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003249.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#EK\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>D\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>M\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"2\"/>Octavius The\n                    \u003Clb n=\"3\" break=\"no\"/>rmitanus Co\n                    \u003Clb n=\"4\" break=\"no\"/>mico bene me\n                    \u003Clb n=\"5\" break=\"no\"/>renti fecit\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                    \u003ClistApp>\n                        \u003Capp>\u003Cnote>Text from Korhonen 2004\u003C/note>\u003C/app>\n                    \u003C/listApp>\n           \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#EK\">\n                \u003Cp>Sacred to the Shades of the Underworld. Octavius Thermitanus made it for the well-deserving Comicus.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--DMS header; Octavius Thermitanus Comico bene merenti fecit ('il nome grecanico 'Comicus' e ben attestato a Roma e nell'Italia meridionale, ma poco comune nell'Oriente greco', K, p.222). Mommsen considered it urban.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Bormann et al.\u003C/author>\n                        \u003Cdate>1886\u003C/date>\n                        \u003CcitedRange>23320\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/T9UNUAJD\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000269\">https://biblio.inscriptiones.org/epig10000269\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buch/4004\">1088*.259\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/HSQETNGN\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001137\">https://biblio.inscriptiones.org/epig10001137\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>115\u003C/citedRange>\n                        \u003Cptr target=