dition ana=\"#condition.fragments.contiguous\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                \t\u003Cdamage ana=\"#text_condition.complete\"/>\n\t\t\t\u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\u003C!--Bivona-->\n                                \u003Clocus from=\"line1\" to=\"line6\">Line 1-6\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"68\" atMost=\"75\">68-75\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462527\">Tyndaris\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/10282151\">Tindari\u003C/placeName>\n                            \t\u003Cgeo>38.14227, 15.04385\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0102\" notAfter-custom=\"0103\" evidence=\"office\">dated by consular year\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\">Found in Tyndaris, in close proximity to a statue of Trajan.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.honorific\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/69.html\">honorific\u003Ccertainty locus=\"value\" match=\"../@ana\" assertedValue=\"#function.building\">\u003Cdesc>possibly building\u003C/desc>\u003C/certainty>\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2018-05-11\" who=\"#TA\">Tuuli Ahlholm cleaned up the autogenerated text and added an apparatus\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-17\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-12-02\" who=\"#JP\">Jonathan Prag added metadata, image, and translations and comment of Alfredo Tosques\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic000063_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-05-23\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000063.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-05-23\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#TA\" source=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CroleName type=\"supracivic\" subtype=\"imperator\">\u003Cexpan>\u003Cabbr>Imp\u003C/abbr>\u003Cex>erator\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cg ref=\"#ivy-leaf\"/> Caesar \u003Cg ref=\"#ivy-leaf\"/> divi \u003Cg ref=\"#ivy-leaf\"/> Nervae \u003Cg ref=\"#ivy-leaf\"/>\n                    \u003Clb n=\"2\"/>\u003Cg ref=\"#ivy-leaf\"/> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilius\u003C/ex>\u003C/expan> \u003Cg ref=\"#ivy-leaf\"/> Nerva \u003Cg ref=\"#ivy-leaf\"/> Traianus \u003Cg ref=\"#ivy-leaf\"/> \u003Cexpan>\u003Cabbr>Aug\u003C/abbr>\u003Cex>ustus\u003C/ex>\u003C/expan> \u003Cg ref=\"#ivy-leaf\"/>\n                    \u003Clb n=\"3\"/>Germanicus \u003Cg ref=\"#ivy-leaf\"/> Dacicus \u003Cg ref=\"#ivy-leaf\"/>\n                    \u003Clb n=\"4\"/>\u003CroleName type=\"supracivic.religious\" subtype=\"pontifex.maximus\">pontifex maximus\u003C/roleName> \u003Cg ref=\"#ivy-leaf\"/>\n                    \u003Clb n=\"5\"/>\u003CroleName type=\"supracivic\" subtype=\"tribunicia.potestas\">\u003Cexpan>\u003Cabbr>tr\u003C/abbr>\u003Cex>ibunicia\u003C/ex>\u003C/expan> \u003Cg ref=\"#ivy-leaf\"/> \u003Cexpan>\u003Cabbr>pot\u003C/abbr>\u003Cex>estate\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cg ref=\"#ivy-leaf\"/> \u003Cnum value=\"7\">\u003Chi rend=\"supraline\">VII\u003C/hi>\u003C/num> \u003Cg ref=\"#ivy-leaf\"/> \u003CroleName type=\"supracivic\" subtype=\"imperator\">\u003Cexpan>\u003Cabbr>imp\u003C/abbr>\u003Cex>erator\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cg ref=\"#ivy-leaf\"/> \u003Cnum value=\"4\">\u003Chi rend=\"supraline\">IIII\u003C/hi>\u003C/num> \u003Cg ref=\"#ivy-leaf\"/>\n                    \u003Clb n=\"6\"/>\u003CroleName type=\"supracivic\" subtype=\"consul\">\u003Cexpan>\u003Cabbr>co\u003C/abbr>\u003Cex>n\u003C/ex>\u003Cabbr>s\u003C/abbr>\u003Cex>ul\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cg ref=\"#ivy-leaf\"/> \u003Cnum value=\"5\">V\u003C/num> \u003Cg ref=\"#ivy-leaf\"/> \u003CroleName type=\"supracivic\" subtype=\"pater.patriae\">\u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex>ater\u003C/ex>\u003C/expan> \u003Cg ref=\"#ivy-leaf\"/> \u003Cexpan>\u003Cabbr>p\u003C/abbr>\u003Cex>atriae\u003C/ex>\u003C/expan>\u003C/roleName> \u003Cg ref=\"#ivy-leaf\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text of IMusPalermo\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AT\">\n                \u003Cp>Emperor Caesar, son of the deified Nerva, Nerva Trajan Augustus Germanicus Dacicus, Pontifex Maximus, holding tribunician power for the seventh time, acclaimed imperator for the fourth time, consul for the fifth time, father of the fatherland.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#AT\">\n                \u003Cp>L’imperatore Cesare, figlio del divo Nerva, Nerva Traiano Augusto Germanico Dacico, pontefice massimo, investito della potestà tribunizia per la settima volta, imperatore per la quarta volta, console per la quinta volta, padre della patria.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#AT\">\n                \u003Cp>Roman imperial dedications normally follow a very rigid structure, with the emperor and his full titulature in the dative case at the beginning, followed by the dedicants in the nominative at the end of the text. In this inscription, however, the Emperor appears unusually in the nominative, with no dedicants mentioned. This may indicate that the inscription commemorated an act of imperial euergetism (public benefaction) carried out by the Emperor himself. If this were the case, as the agent rather than the dedicatee, the use of the nominative would be explained.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Maggiore\u003C/author>\n                        \u003Cdate>1829\u003C/date>\n                        \u003CcitedRange>298 no.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/T4NR9UP5\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002795\">https://biblio.inscriptiones.org/epig10002795\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/650805\">7472\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GQN8UZSI\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000589\">https://biblio.inscriptiones.org/epig10000589\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"ILMusPalermo\">\n                         \u003Cauthor>Bivona\u003C/author>\n                         \u003Cdate>1970\u003C/date> \n                        \u003CcitedRange>64\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FZWWPUD6\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002142\">https://biblio.inscriptiones.org/epig10002142\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Raepsaet-Charlier\u003C/author>\n                        \u003Cdate>1974\u003C/date>\n                        \u003CcitedRange>126\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/PZHQV5MN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001648\">https://biblio.inscriptiones.org/epig10001648\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>73\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fasolo\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>71 no.2 fig.32\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/X2SEXMRX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002011\">https://biblio.inscriptiones.org/epig10002011\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
