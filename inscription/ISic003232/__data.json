3C/ex>\u003C/expan>\u003C/supplied> \u003Csupplied reason=\"lost\" cert=\"low\">\u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan>\u003C/supplied>\n                    \u003Clb n=\"2\"/>Epig\u003Csupplied reason=\"lost\" cert=\"low\">onus\u003C/supplied> \u003Csupplied reason=\"lost\">vixit\u003C/supplied>\n                    \u003Clb n=\"3\"/>\u003Cexpan>\u003Cabbr>ann\u003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Cnum value=\"40\">X\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">L\u003C/supplied>\u003C/num> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"4\"/>Epigona \u003Csupplied reason=\"lost\">vixit\u003C/supplied>\n                    \u003Clb n=\"5\"/>\u003Cexpan>\u003Cabbr>mens\u003C/abbr>\u003Cex>ibus\u003C/ex>\u003C/expan> \u003Cg ref=\"#interpunct\">·\u003C/g> \u003Chi rend=\"supraline\">\u003Cnum value=\"6\">VI\u003C/num>\u003C/hi> \u003Cexpan>\u003Cabbr>\u003Csupplied reason=\"undefined\" evidence=\"previouseditor\">d\u003C/supplied>\u003C/abbr>\u003Cex>iebus\u003C/ex>\u003C/expan> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"6\"/>ne uxor b\u003Csupplied reason=\"lost\">ene\u003C/supplied> \u003Csupplied reason=\"lost\">meren\u003C/supplied>\n                    \u003Clb n=\"7\" break=\"no\"/>tibus \u003Cg ref=\"#interpunct\">·\u003C/g> fec\u003Csupplied reason=\"lost\">it\u003C/supplied>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Korhonen 2004\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>Sacred to the shades of the underworld (?). Epigonus lived for 40 years. Epigona lived for 6 months, ? days. [Epigonus'] wife built this for the well-deserving.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--damaged on right side; possible DMS header. Restored by K as belonging to Epigonus, vixit annis XL- - - Also Epigona, his daughter, and erected by his wife (uxor) to them both. Mommsen considered it urban.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Bormann and Henzen\u003C/author>\n                        \u003Cdate>1876\u003C/date>\n                        \u003CcitedRange>1723\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VVHPQFD3\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001134\">https://biblio.inscriptiones.org/epig10001134\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIL\">\n                        \u003Cauthor>Mommsen\u003C/author>\n                        \u003Cdate>1883\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://arachne.uni-koeln.de/item/buch/4004\">1088*.132\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/HSQETNGN\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001137\">https://biblio.inscriptiones.org/epig10001137\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                         \u003Cauthor>Korhonen\u003C/author>\n                         \u003Cdate>2004\u003C/date> \n                        \u003CcitedRange>81\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1930\u003C/date>\n                        \u003CcitedRange>316 no.8\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SKUU2R8X\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001871\">https://biblio.inscriptiones.org/epig10001871\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
