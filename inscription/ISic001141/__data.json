3C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001141.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Ἰοῦϲτοϲ\u003C/w>\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">\u003Cw n=\"10\">Νί\n                    \u003Clb n=\"2\" break=\"no\"/>γρου\u003C/w>\u003C/name>\u003C/persName> \u003Cw n=\"15\">ὑὸϲ\u003C/w>\u003C/persName> \u003Cw n=\"20\">ἔζη\n                    \u003Clb n=\"3\" break=\"no\"/>ϲεν\u003C/w> \u003Cw n=\"25\">ἔτη\u003C/w> \u003Cnum value=\"25\">\u003Cw n=\"30\">κε\u003C/w>\u003C/num>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Ἰοῦϲτος\">Ἰοῦϲτοϲ\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"Νίγρος\">Νίγρου\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ὑιός\">ὑὸϲ\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ζῶ\">ἔζηϲεν\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"κε\">κε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003Cp>Text of IGPalermo\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Ioustos son of Nigros (Niger?); age in years; M-P comments: Il patronomico e qui indicato con l'aggiunta di huios nella forma dialettale huos. E questa una consuetudine ormai abbandonata da tempo nelle iscrizioni di autentico carattere greco ed in uso invece nell'indicazione della filiazione romana. Solo nel V-VI secolo la presenza di filius scritto per esteso e l'abbandono dei tria nomina e, fra i Romani, indizio di cristianesimo.' cf. IGTI no.18 for v. similar stone and comments.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">322\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGMusPalermo\">\n                        \u003Cauthor>Manni Piraino\u003C/author>\n                        \u003Cdate>1973\u003C/date>\n                        \u003CcitedRange>121\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F66S4X3M\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000531\">https://biblio.inscriptiones.org/epig10000531\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl/>\n       