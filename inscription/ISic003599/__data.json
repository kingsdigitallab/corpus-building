C/abbr>\u003Cex>rist\u003C/ex>\u003Cabbr>i\u003C/abbr>\u003C/expan>\u003C/name>\u003C/persName> edificabit\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text after Rizzone and Sammito 2004\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>In the name of our lord Jesus, Cresconius built the sacred work of Christ\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"Rizzone-Sammito\">\n                \u003Cp>Nel nome del Signore nostro Gesù, Crosconius la santa opera di Cristo edificò\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>2007.0677\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Rizzone\u003C/author>\n                        \u003Cauthor>Sammito\u003C/author>\n                        \u003Cdate>2004\u003C/date>\n                        \u003CcitedRange>104-105 fig.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RHXWRC83\"/>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Sammito and Rizzone\u003C/author>\n                        \u003Cdate>2007\u003C/date>\n                        \u003CcitedRange>1623-1624 tav.9