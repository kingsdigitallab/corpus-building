\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"Clodius\">Clodius\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"Atilianus\">Atilianus\u003C/w>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"45\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cw n=\"50\" lemma=\"vivo\">vixit\u003C/w>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\" n=\"55\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                    \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" n=\"60\">\u003Cdesc>[-?-]\u003C/desc>\u003C/gap>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text from Korhonen 2004\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#TG\">\n                \u003Cp>[Sacred] to the spirits of the netherworld. Titus Clod[ius] Atili[anus lived]...\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--D.M.[- - - / Ti.Clod[- - - / Atili[- - -, restored by K as DMS header and of Titus Clodius Atilianus. The text is complete at top and left, the fr. just from the centre of the stone.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1769\u003C/date>\n                        \u003CcitedRange>cl.14, no.35\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SPTB56H3\"/>\n                        \u003Cref target=\"https://biblio.i