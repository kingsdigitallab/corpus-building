/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"10\">χ\u003Csupplied reason=\"lost\">ρ\u003C/supplied>ηστὲ\u003C/w> \u003Cw n=\"15\">καὶ\u003C/w> \u003Cw n=\"20\">ἄ\n                    \u003Clb n=\"3\" break=\"no\"/>μεμπτε\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"25\">χαῖρε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Κούϊντος\">Κουεῖντε\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"χρηστός\">χρηστὲ\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"καί\">καὶ\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ἄμεμπτος\">ἄμεμπτε\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"χαίρω\">χαῖρε\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Pugliese Carratelli 1956\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Koueinte (Quintus?), chrestos kai amemptos; chaire; Ferrua declared this pagan, which P-C accepts; moreover, P-C rejects F's doubts on authenticity.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRan