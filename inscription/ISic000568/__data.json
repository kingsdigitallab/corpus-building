=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marcus · Sicribonius\n                    Marci  libertus ·\n                    Stymphalus\">\u003Cspan data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Marcus\">M(arcus)\u003C/span> · \u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Sicribonius\">S{i}cribonius\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marci\">\u003Cspan data-type=\"name\" data-name-type=\"libertinatio\" data-text=\"Marci\">M(arci)\u003C/span>\u003C/span> l(ibertus) · \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Stymphalus\">Stymphalus\u003C/span>\u003C/span>  \u003Cspan class=\"textpartnumber\" style=\"left: -4em;\">Col. 2\u003Cbr>\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Caecilia\n                    \n                    Attica\">\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Caecilia\">Caecilia\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Attica\">Attica\u003C/span>\u003C/span> · \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Alex Antoniou, Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"la\">\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Cspan class=\"textpartnumber\" style=\"left: -4em;\">Col. 1\u003Cbr>\u003C/span>\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marcus · Sicribonius\n                    Marci  libertus ·\n                    Stymphalus\">\u003Cspan data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Marcus\">M\u003C/span>·\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Sicribonius\">SICRIBONIUS\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marci\">\u003Cspan data-type=\"name\" data-name-type=\"libertinatio\" data-text=\"Marci\">M\u003C/span>\u003C/span>L·\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Stymphalus\">STYMPHALUS\u003C/span>\u003C/span>\u003Cspan class=\"textpartnumber\" style=\"left: -4em;\">Col. 2\u003Cbr>\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Caecilia\n                    \n                    Attica\">\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Caecilia\">CAECILIA\u003C/span>\u003Cbr id=\"al5-diplomatic\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">··\u003C/span>\u003Cbr id=\"al6-diplomatic\">\u003Cspan class=\"linenumber\">6\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Attica\">ATTICA\u003C/span>\u003C/span>·\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text of Salinas; note that Gualtherus (followed by Mommsen) recorded in single column, separating the two sections with a space, rather than in two columns\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"1\">1: \u003Cspan>Gualtherus: SICRIBONIVS, rightly, as per lapidem (and not SICIRIBONIVS as attributed to him by Mommsen).\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"5\">5: \u003Cspan>Gualtherus, Mommsen: vacat; Salinas notes that traces suggest something like 'M.L.'\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"6\">6: \u003Cspan>Gualtherus appears to print a large F to the right of the line, resolved by Mommsen as 'F(ecit)'; Salinas (rightly) suggests this is a typographer's addition, for the next page.\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0001-7077-0703\">Alex Antoniou\u003C/a>\u003C/p>  \u003Cp>Marcus Scribonius Stymphalus, freedman of Marcus. Caecilia Attica.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>Mommsen was constrained to follow Gualtherus' report (second edition only), as Salinas' rediscovery of the piece came too late. The piece is not mentioned in I.L.Palermo and so is seemingly no longer in the museum.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> VIII 697 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002649\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002649\u003C/a>\u003C/li>\u003Cli> Gualtherus 1624 [1625] 238 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001931\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001931\u003C/a>  \u003C/li>\u003Cli> Mommsen 1883 \u003Ca href=\"http://arachne.uni-koeln.de/books/CILv10pII1883\" target=\"_blank\">7318\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10000589\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000589\u003C/a>\u003C/li>\u003Cli> Salinas NSA 1883 567 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001392\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001392\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\"> Line 1    Interlineation line 1 to 2    \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence.  \u003C/div>",[217,220,223,226,229,232,235,238],{"id":218,"html":219},"editions","\u003Cdiv class=\"attribution\">Text encoding: Alex Antoniou, Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"la\">  \u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Cspan class=\"textpartnumber\" style=\"left: -4em;\">Col. 1\u003Cbr>\u003C/span>  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marcus · Sicribonius\n                    Marci  libertus ·\n                    Stymphalus\">\u003Cspan data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Marcus\">M(arcus)\u003C/span> · \u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Sicribonius\">S{i}cribonius\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marci\">\u003Cspan data-type=\"name\" data-name-type=\"libertinatio\" data-text=\"Marci\">M(arci)\u003C/span>\u003C/span> l(ibertus) · \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Stymphalus\">Stymphalus\u003C/span>\u003C/span>  \u003Cspan class=\"textpartnumber\" style=\"left: -4em;\">Col. 2\u003Cbr>\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Caecilia\n                    \n                    Attica\">\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Caecilia\">Caecilia\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Attica\">Attica\u003C/span>\u003C/span> · \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Alex Antoniou, Jonathan Prag\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"la\">\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Cspan class=\"textpartnumber\" style=\"left: -4em;\">Col. 1\u003Cbr>\u003C/span>\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marcus · Sicribonius\n                    Marci  libertus ·\n                    Stymphalus\">\u003Cspan data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Marcus\">M\u003C/span>·\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Sicribonius\">SICRIBONIUS\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marci\">\u003Cspan data-type=\"name\" data-name-type=\"libertinatio\" data-text=\"Marci\">M\u003C/span>\u003C/span>L·\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Stymphalus\">STYMPHALUS\u003C/span>\u003C/span>\u003Cspan class=\"textpartnumber\" style=\"left: -4em;\">Col. 2\u003Cbr>\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\