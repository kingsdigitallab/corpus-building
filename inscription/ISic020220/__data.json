            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>Fragment of foot of a black-glaze lekythos (?).\u003C/p>\n                                    \u003Cmaterial ana=\"#material.clay.fired\" ref=\"https://www.eagle-network.eu/voc/material/lod/131.html\">ceramic\u003C/material>\n                                    \u003CobjectType ana=\"#object.vessel.lekythos\" cert=\"low\" ref=\"http://kerameikos.org/id/lekythos\">lekythos\u003C/objectType>\n                                    \u003Cdimensions>\n                                        \u003Cheight unit=\"cm\">1\u003C/height>\n                                        \u003Cdim type=\"diameter\" unit=\"cm\">6.6\u003C/dim>\n                                        \u003Cwidth unit=\"cm\"/>\n                                        \u003Cdepth unit=\"cm\"/>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.scratched\" ref=\"https://www.eagle-network.eu/voc/writing/lod/9\">scratched\u003C/rs>\n                                    \u003Cp>The text is placed on the underside of the foot. The letters have been highlighted with white painting in modern times to make them more legible.\u003C/p>\n                                    \u003Cdamage ana=\"#text_condition.incomplete text_condition.legible\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003C!--  Based on Glyph table: reverse alpha09 (?unclear) and lambda