003C/abbr>\u003Cex>is\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"10\">·\u003C/g> \u003Cw n=\"15\">\u003Cexpan>\u003Cabbr>m\u003C/abbr>\u003Cex>anibus\u003C/ex>\u003C/expan>\u003C/w> \u003Cg ref=\"#interpunct\" n=\"20\">·\u003C/g> \u003Cw n=\"25\">\u003Cexpan>\u003Cabbr>s\u003C/abbr>\u003Cex>acrum\u003C/ex>\u003C/expan>\u003C/w>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"30\">\u003Cexpan>\u003Cabbr>T\u003C/abbr>\u003Cex>itus\u003C/ex>\u003C/expan>\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"35\">·\u003C/g> \u003Cname>\u003Cw n=\"40\">\u003Cabbr>F\u003C/abbr>\u003C/w>\u003C/name> \u003Cg ref=\"#interpunct\" n=\"45\">·\u003C/g> \u003Cname>\u003Cw n=\"50\">Foen\n                    \u003Clb n=\"3\" break=\"no\"/>ix\u003C/w>\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\" n=\"55\">·\u003C/g> \u003Cw n=\"60\">vixit\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"65\">annis\u003C/w> \u003Cg ref=\"#interpunct\" n=\"70\">·\u003C/g> \u003Cnum value=\"30\">\u003Cw n=\"75\">XXX\u003C/w>\u003C/num>\n                    \u003Clb n=\"5\"/>\u003Corig n=\"80\">ES\u003C/orig>\u003Cg ref=\"#interpunct\" n=\"85\">·\u003C/g> \u003Corig n=\"90\">IS\u003C/orig>\u003Cg ref=\"#interpunct\" n=\"95\">·\u003C/g> \u003Corig n=\"100\">P\u003C/orig>\u003Cg ref=\"#interpunct\" n=\"105\">·\u003C/g> \u003Corig n=\"110\">V\u003C/orig>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#VF\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"dis\">Dis\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"manes\">Manibus\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"sacrum\">Sacrum\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"Titus\">Titus\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"NOLEMMA\">F\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"Foenix\">Foenix\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"vivo\">vixit\u003C/w>\n                    \u003Cw n=\"65\" lemma=\"annus\">annis\u003C/w>\n                    \u003Cw n=\"75\" lemma=\"XXX\">XXX\u003C/w>\n                    \u003Corig n=\"80\">ES\u003C/orig>\n                    \u003Corig n=\"90\">IS\u003C/orig>\n                    \u003Corig n=\"100\">P\u003C/orig>\n                    \u003Corig n=\"110\">V\u003C/orig>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of CIL\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"5\">\n                        \u003Cnote>Mommsen conjectures: MES · II · D · V\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#MH\">\n                \u003Cp>Sacred to the spirits of the dead. Titus F(-?) Foenix lived 30 years. ES. IS. P. V.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#MH\">\n                \u003Cp>F. on line 4 presumed to be a name; possibilties include Faustus, Fabius, Flavius\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/author>\n                        \u003Cdate>1624\u003C/date>\n                        \u003CcitedRange>no. 183\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/GIN6NANU\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002388\">https://biblio.inscriptiones.org/epig10002388\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Gualtherus\u003C/au