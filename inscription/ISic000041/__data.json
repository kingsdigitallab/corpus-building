\">Museo Archeologico Regionale Antonino Salinas\u003C/repository>\n                        \u003Cidno type=\"inventory\">3542\u003C/idno>\n                        \u003C!--Adding location for old id numbers if available-->\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"la\">Latin\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\u003Cp>A plaque in the local red breccia\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.breccia\" ref=\"http://www.eagle-network.eu/voc/material/lod/73.html\">breccia (di San Marco)\u003C/material>\n                                    \u003CobjectType ana=\"#object.plaque\" ref=\"https://www.eagle-network.eu/voc/objtyp/lod/259.html\">plaque\u003C/objectType>\n                                    \u003Cdimensions>\u003C!--ILPalermo-->\n                                        \u003Cheight unit=\"cm\">44.5\u003C/height>\n                                        \u003Cwidth unit=\"cm\">42.5\u003C/width>\n                                        \u003Cdepth unit=\"cm\">4\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.complete\"/>\n\t\t    \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\u003Cp>Text is centred, with almost a full blank line between the name of the deceased and the phrase recording the dedicant.\u00