 xml:id=\"SS\" ref=\"https://orcid.org/0000-0003-3914-9569\">Simona Stoyanova\u003C/name>\n                    \u003Cresp>standardisation of template and tidying up encoding\u003C/resp>\n                \u003C/respStmt>\n            \u003C/titleStmt>\n            \u003CpublicationStmt>\n                \u003Cauthority>I.Sicily\u003C/authority>\n                \u003Cidno type=\"filename\">ISic020709\u003C/idno>\n                \u003Cidno type=\"TM\"/>\n                \u003Cidno type=\"EDR\"/>\n                \u003Cidno type=\"EDH\"/>\n                \u003Cidno type=\"EDCS\"/>\n                \u003Cidno type=\"PHI\"/>\n                \u003Cidno type=\"URI\">http://sicily.classics.ox.ac.uk/inscription/ISic020709\u003C/idno>\n                \u003Cavailability>\n                    \u003Clicence target=\"http://creativecommons.org/licenses/by/4.0/\">Licensed under a Creative Commons-Attribution 4.0 licence.\u003C/licence>\n                \u003C/availability>\n            \u003C/publicationStmt>\n            \u003CsourceDesc>\n                \u003CmsDesc>\n                    \u003CmsIdentifier>\n                        \u003Ccountry>Italy\u003C/country>\n                        \u003Cregion>Sicily\u003C/region>\n                        \u003Csettlement>Aidone\u003C/settlement>\n                        \u003Crepository role=\"museum\" ref=\"http://sicily.classics.ox.ac.uk/museum/001\">Museo Archeologico di Aidone\u003C/repository>\n                        \u003Cidno type=\"inventory\">90-61\u003C/idno>\n                        \u003CaltIdentifier>\n                            \u003Csettlement/>\n                            \u003Crepository/>\n                            \u003Cidno type=\"old\"/>\n                        \u003C/altIdentifier>\n                    \u003C/msIdentifier>\n                    \u003CmsContents>\n                        \u003CtextLang mainLang=\"scx\">Sikel\u003Ccertainty locus=\"value\" match=\"../@mainLang\" assertedValue=\"grc\">\u003Cdesc>Ancient Greek\u003C/desc>\u003C/certainty>\u003C/textLang>\n                    \u003C/msContents>\n                    \u003CphysDesc>\n                        \u003CobjectDesc>\n                            \u003CsupportDesc>\n                                \u003Csupport>\n                                    \u003Cp>Fragment of neck and rim of a black-glazed krater (Laconian type).\u003C/p>\n                                    \u003Cmaterial ana=\"#material.inorganic.ceramic\" type=\"ceramic\" subtype=\"unverified\" ref=\"https://www.eagle-network.eu/voc/material/lod/131.html\">ceramic\u003C/material>\n                                    \u003CobjectType ana=\"#object.vessel.krater\" ref=\"http://kerameikos.org/id/krater\">krater\u003C/objectType>\n                                    \u003Cdimensions>\u003C!-- dimensions of the fragment -->\n                                        \u003Cheight unit=\"cm\">13\u003C/height>\n                                        \u003Cwidth unit=\"cm\">18\u003C/width>\n                                        \u003Cdepth unit=\"cm\">1.6\u003C/depth>\n                                    \u003C/dimensions>\n                                    \u003Cdimensions>\u003C!-- estimated dimensions of the krater -->\n                                        \u003Cheight unit=\"cm\">30 ca.\u003C/height>\n                                        \u003Cdim type=\"diameter\" unit=\"cm\">38\u003C/dim>\u003C!-- estimated diameter of the rim -->\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition ana=\"#condition.fragment\"/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Crs ana=\"#execution.scratched\" ref=\"https://www.eagle-network.eu/voc/writing/lod/9\">scratched\u003C/rs>\n                                    \u003Cp>The text is placed on the neck of the vessel, just below the rim.\u003C/p>\n                                    \u003Cdamage ana=\"#text_condition.complete\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003C!--  Based on Glyph table: -->\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462372\">Morgantina\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2524052/\">Morgantina\u003C/placeName>\n                                \u003Cgeo>37.430596, 14.479485\u003C/geo>\n                            \u003C/origPlace>\n                            \u003C!-- and evidence=\"historical context\"? or sth similar? -->     \u003CorigDate datingMethod=\"#julian\" evidence=\"archaeological-context material-context lettering\" notBefore-custom=\"-0575\" notAfter-custom=\"-0459\">second quarter of the 6th—first half of the 5th century BCE (destruction of the archaic settlement during Douketios' campaigns)\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"discovered\" when=\"1990\">Found during the excavations (1990) in the eastern shoulder of the plateau on which the archaic settlement was placed\u003Cgeo>37.430596, 14.479485\u003C/geo>.\u003C/provenance>\u003C!-- generic coodinates for Morgantina -->\n                        \u003Cprovenance type=\"observed\">no autopsy\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.production-ownership\" ref=\"http://vocab.getty.edu/page/aat/300256090\">production or ownership\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2022-01-30\" who=\"#VM\">Valentina Mignosa added metadata, text\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020709_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020709.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"scx-Grek\"> \n                    \u003Cab>\n                        \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Κυπαρας\u003C/name>\u003C/persName>εμι \u003C!-- we should perhaps discuss if we should use the usual 'Hellenised' (!) edition here Κύπαρας ἐμί \n                        or keep it as a single word without accents (this could be another form of the aphaeretic use of the verb? Ask Robert?) since it is probably Sikel language with Greek interference. -->\n                    \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" subtype=\"transliteration\" xml:lang=\"scx-Latn\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname type=\"idionym\">Kyparas\u003C/name>\u003C/persName>emi\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Antonaccio in Antonaccio, Neils 1995\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#VM\">\n                \u003Cp>I belong to Kypara.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#VM\">\n                \u003Cp>Sono di proprietà di Kypara.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\">\n                \u003Cp>The inscription shows a name that occurs in other documents from eastern Sicily (see in particular the loom weights \n                    from Terravecchia di Cuti \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020569\">ISic020569\u003C/ref>, \n                    \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020570\">ISic020570\u003C/ref>, \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020571\">ISic020571\u003C/ref>). \n                    However, judging from the ductus it appears to be a forgery.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Antonaccio, Shea\u003C/author>\n                        \u003Cdate>2015\u003C/date>\n                        \u003CcitedRange/>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/V88A3D6V\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002358\">https://biblio.inscriptiones.org/epig10002358\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Antonaccio, Neils\u003C/author>\n                        \u003Cdate>1995\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/BFCIDFQA\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002359\">https://biblio.inscriptiones.org/epig10002359\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
