arch_element.architrave",{"_":36,"ana":37,"type":38,"subtype":39,"ref":41}," stone","#material.inorganic.stone","stone.unspecified",[40],"unverified","http://www.eagle-network.eu/voc/material/lod/2.html",{"ana":43},"#condition.fragment",[45,48,50],{"unit":46,"dimension":47},"cm","height",{"unit":46,"dimension":49},"width",{"unit":46,"dimension":51},"depth",{"layout":53},{"p":54,"rs":55,"damage":59},"Gualtherus' presentation implies the text was partly on a moulding or panel, and partly in a section above.",{"_":56,"ana":57,"ref":58},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":60},"#text_condition.incomplete",{"dimensions":62},[63,68],{"type":64,"l":65,"from":66,"to":66,"unit":67},"letterHeight","Line 1","line1","mm",{"type":69,"l":70,"from":66,"to":71,"unit":67},"interlinear","Interlineation line 1 to 2","line2",{"_":73,"notBefore":74,"notAfter":75},"Hellenistic?",-400,-1,[77,82],{"_":78,"type":79,"ref":80,"region":81},"Catina","ancient","http://pleiades.stoa.org/places/462270","Sicilia",{"_":83,"type":84,"ref":85,"region":81},"Catania","modern","http://sws.geonames.org/2525068",[87],[88,89],37.49223,15.07041,{"_":91,"type":92,"subtype":93,"notAfter":94,"geo":95},"Reported by Gualtherus in the Loggia of the city, having been found 'ad S. Spiritum, in villa Octavii Ioenii Equitis'; a church of the Holy Spirit was located in the vicinity of the so-called Temple of Ceres, which, in part on the basis of this inscrption, was identified in the vicinity of the Batione degli Infetti, on the NW side of the city, where a substantial walled structure was identified in the 16th century. Like many inscriptions preserved in the Loggia, it does not seem to have survived the eruption and earthquake of 1669 / 1693.","found","discovered","1624",[96,97],37.5071946,15.0802665,[96,97],{"_":100,"type":101,"subtype":102,"geo":103},"None","observed","autopsied",null,{"_":105,"type":106,"subtype":107,"geo":103},"Lost","not-observed","lost",[],"S