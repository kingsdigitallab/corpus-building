of_inscription/Attribution\">ownership\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-01-22\" who=\"#VM\">Valentina Mignosa added text and further data.\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020704_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020704.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"scx-Grek\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName cert=\"low\">\u003Cname>ϙυπε\u003C/name> \u003CpersName cert=\"low\">\u003Cname>ιπινιγοι\u003C/name>\u003C/persName>\u003C/persName> εμι\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" subtype=\"transliteration\" xml:lang=\"scx-Latn\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName cert=\"low\">\u003Cname>qupe\u003C/name> \u003CpersName cert=\"low\">\u003Cname>ipinigoi\u003C/name>\u003C/persName>\u003C/persName> emi\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Sudano 2015\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\">\n                \u003Cp/>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#VM\">\n                \u003Cp>The text can be interpreted as an Italic bimember onomastic formula \n                    (see e.g. \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020602\">ISic020602\u003C/ref> \n                    and \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020603\">ISic020603\u003C/ref>).\n                    For the apheretic use of -εμι at the end of the onomastic formula see \u003Cref target=\"https://www.zotero.org/groups/382445/items/EIAZ7ZEW\">Agostiniani 1988-1989\u003C/ref>, 195-199; \n                    \u003Cref target=\"https://www.zotero.org/groups/382445/items/RHXSKW4A\">Agostiniani, Cordano 2002\u003C/ref>, 87-89;\n                    Sudano 2015, 702-703; commentary of \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020739\">ISic020739\u003C/ref>-\u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020745\">ISic020745\u003C/ref>,\n                    and \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic020766\">ISic020766\u003C/ref>.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Sudano\u003C/author>\n                        \u003Cdate>2015\u003C/date>\n                        \u003CcitedRange>702, no. 4, fig. 10\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/4HMK3Q8K\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002382\">https://biblio.inscriptiones.org/epig10002382\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>2003\u003C/date>\n                        \u003CcitedRange>150-151\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/HPEPK9TF\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001843\">https://biblio.inscriptiones.org/epig10001843\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Agostiniani, Cordano\u003C/author>\n                        \u003Cdate>2002\u003C/date>\n                        \u003CcitedRange>85-87\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RHXSKW4A\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002381\">https://biblio.inscriptiones.org/epig10002381\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n                        \u003Cauthor>Camera\u003C/author>\n                        \u003Cdate>2020\u003C/date>\n                        \u003CcitedRange>153-154, fig. 7.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/JTQR7KH3\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002379\">https://biblio.inscriptiones.org/epig10002379\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Camera\u003C/author>\n                        \u003Cdate>2010\u003C/date>\n                        \u003CcitedRange>115-116\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/C4TC2D3J\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002377\">https://biblio.inscriptiones.org/epig10002377\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
