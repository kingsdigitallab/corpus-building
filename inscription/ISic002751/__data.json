"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic002751_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic002751.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#FP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Στουδιῶ\n                    \u003Clb n=\"2\" break=\"no\"/>σε\u003C/w>\u003C/name>\u003C/persName> \u003Cg ref=\"#interpunct\" n=\"10\">·\u003C/g> \u003Cw n=\"15\">χρησ\u003Chi rend=\"ligature\">τὲ\u003C/hi>\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"20\">χαῖρε\u003C/w> \u003Cg ref=\"#interpunct\" n=\"25\">·\u003C/g> \u003Cw n=\"30\">ἔζη\n                    \u003Clb n=\"4\" break=\"no\"/>σε\u003C/w> \u003Cg ref=\"#interpunct\" n=\"35\">·\u003C/g> \u003Cw n=\"40\">ἔτη\u003C/w> \u003Cg ref=\"#interpunct\" n=\"45\">·\u003C/g> \u003Cnum value=\"60\">\u003Cw n=\"50\">\u003Chi rend=\"supraline\">ξ\u003C/hi>\u003C/w>\u003C/num> \u003Cg ref=\"#ivy-leaf\" n=\"55\">❦\u003C/g>\n                    \u003Clb n=\"5\"/>\u003Cw n=\"60\">λυδιαστής\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Στουδιῶσος\">Στουδιῶσε\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"χρηστός\">χρηστὲ\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"χαίρω\">χαῖρε\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"ζῶ\">ἔζησε\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"50\" lemma=\"ξ\">ξ\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"λυδιάστης\">λυδιαστής\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Manganaro 1994\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#FP\">\n                \u003Cp>Farewell worthy Studiosos! He lived for 60 years after being a pastoral cantor.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#FP\">\n                \u003Cp>Addio, degno Studiosos. Egli visse 60 anni essendo stato un cantore bucolico.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--'Studiose chreste chaire', age in years, and defined as a ludiastes. I.e. epitaph of Studiosus. Died age 60, not age 7 as some earlier eds. sugg'd. Article by Valentini is on such performers / actors more generally. Manganaro 1963 says lost.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>44.0747\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>38.0925\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1963\u003C/date>\n                        \u003CcitedRange>63\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/M3UEW68D\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001850\">https://biblio.inscriptiones.org/epig10001850\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ansaldi\u003C/author>\n                        \u003Cdate>1981\u003C/date>\n                        \u003CcitedRange>319\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/FD9JT2RS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002181\">https://biblio.inscriptiones.org/epig10002181\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1994\u003C/date>\n                        \u003CcitedRange>103 no 17bis ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/532NF7SV\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001825\">https://biblio.inscriptiones.org/epig10001825\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Orsi\u003C/author>\n                        \u003Cdate>1900\u003C/date>\n                        \u003CcitedRange>48 no.12\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/UE3VRJA7\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001707\">https://biblio.inscriptiones.org/epig10001707\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Prosperi Valentini\u003C/author>\n                        \u003Cdate>1985\u003C/date>\n                        \u003CcitedRange>77-78 no.5\u003C/citedRange>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>59\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
