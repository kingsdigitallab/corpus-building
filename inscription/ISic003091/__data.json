        \u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-23\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2025-11-25\" who=\"#JP\">Jonathan Prag revised from publication\u003C/change>\u003C!-- Giustolisi non vidi-->\n                \u003Cchange when=\"2026-01-19\" who=\"#DD\">Dmitry Dundua's lemmatizations were added from source CoNLL-U files\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc using PyEpiDoc and associated scripts\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003091_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003091.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\" source=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Σιλανός\u003C/w>\u003C/name>\u003C/persName> \u003Cspace unit=\"character\" extent=\"unknown\" n=\"10\"/> \u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"15\">Σιλανός\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"20\">ἥρωες\u003C/w> \u003Cw n=\"25\">ἀγαθοί\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Σιλανός\">Σιλανός\u003C/w>\n                    \u003Cspace unit=\"character\" extent=\"unknown\" n=\"10\"/>\n                    \u003Cw n=\"15\" lemma=\"Σιλανός\">Σιλανός\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ἥρως\">ἥρωες\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"ἀγαθός\">ἀγαθοί\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Giustolisi as reported in SEG\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Giustolisi proposed that it was a dedication to or invovation of the divinity Silenos, but Manganaro, and Moretti (comm in SEG) instead suggest that it is a funerary aedicola for two men called Silenos, perhaps father and son, with the designation as heroes agathoi, as is common in the later Hellenistic period.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>36.0854\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Giustolisi\u003C/author>\n                        \u003Cdate>1981\u003C/date>\n                        \u003CcitedRange>121-122 figs.144-148r\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/3XSSKHFP\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001947\">https://biblio.inscriptiones.org/epig10001947\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1992\u003C/date>\n                        \u003CcitedRange>500-501 no.IX\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/UQRFDXEG\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001830\">https://biblio.inscriptiones.org/epig10001830\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
