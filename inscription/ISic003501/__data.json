{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"slug":1,"metadata":2,"images":104,"html":206,"xml":257},"ISic003501",{"file":1,"uri":1,"title":3,"status":4,"editions":6,"editionAuthor":19,"type":20,"support":25,"objectType":26,"material":30,"condition":36,"dimensions":38,"layoutDesc":49,"handNote":58,"date":74,"places":79,"geo":89,"country":84,"provenance":81,"provenanceFound":93,"provenanceGeo":97,"provenanceObserved":98,"provenanceLost":19,"graphics":104,"region":114,"settlement":86,"repository":115,"textLang":128,"bibliographyEdition":132,"bibliographyDiscussion":156,"citation":159,"tmNumber":8,"facsimile":182,"letterHeights":183,"publications":189,"zotero":192,"keywords":195,"lettering_types":205},"Fragment of a Greek inscription",{"_":5},"edited",[7,10,12,14,16],{"_":8,"type":9},"645369","TM",{"type":11},"EDR",{"type":13},"EDH",{"type":15},"EDCS",{"_":17,"type":18},"336194","PHI",null,{"_":21,"ana":22,"ref":23,"cert":24},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html","low","Fragment of grey-white marble with blue-grey veining. The right edge appears intact, broken on the other three sides. The rear of the piece preserves a double moulding along the lower edge, which is not perpendicular to the text on the obverse. The clear implication is that the stone is a piece of marble veneer that has been subsequently re-used for the inscription.",{"_":27,"ana":28,"ref":29},"plaque","#object.plaque","https://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":31,"ana":32,"type":33,"subtype":34,"ref":35},"marble","#material.inorganic.stone.metamorphic_rock.marble","stone.marble","unverified","http://www.eagle-network.eu/voc/material/lod/48.html",{"ana":37},"#condition.fragment",[39,43,46],{"_":40,"unit":41,"dimension":42},"8.5","cm","height",{"_":44,"unit":41,"dimension":45},"9.3","width",{"_":47,"unit":41,"dimension":48},"1.5","depth",{"layout":50},{"p":51,"rs":52,"damage":56},"Trac