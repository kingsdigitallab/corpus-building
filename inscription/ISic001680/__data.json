pe_of_inscription\">\n                    \u003Cterm ana=\"#function.honorific\" ref=\"https://ontology.inscriptiones.org/type_of_inscription/Honorific\">honorific\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2021-05-21\" who=\"#JP\">Jonathan Prag created initial draft of text and metadata from the ed. pr. of Ampolo/Erdas\u003C/change>\n                \u003Cchange when=\"2025-12-24\" who=\"#ZL\">tagged names and persons\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001680_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001680.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>ὁ δᾶμος τῶν \u003CplaceName type=\"ethnic\">Ἐγεσταίων\u003C/placeName>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Φάωνα\u003C/name> \u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Νύμφωνος\u003C/name>\u003C/persName> \u003Cname>Σωπολιανόν\u003C/name>\u003C/persN