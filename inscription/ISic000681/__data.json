iciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic000681.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"la\" resp=\"#AA\">\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"a\">\n                    \u003Cab>\n                        \u003Ccb n=\"1\"/>\n                        \u003Clb n=\"1\"/>\u003Cname>\u003Cexpan>\u003Cabbr>Sex\u003C/abbr>\u003Cex>to\u003C/ex>\u003C/expan>\u003C/name> \u003Cname>Nonio\u003C/name>\n                        \u003Clb n=\"2\"/>\u003Cname>\u003Cexpan>\u003Cabbr>Sex\u003C/abbr>\u003Cex>ti\u003C/ex>\u003C/expan>\u003C/name> \u003Cexpan>\u003Cabbr>f\u003C/abbr>\u003Cex>ilio\u003C/ex>\u003C/expan> \u003CorgName>\u003Cexpan>\u003Cabbr>Quir\u003C/abbr>\u003Cex>ina\u003C/ex>\u003C/expan>\u003C/orgName>\n                        \u003Clb n=\"3\"/>\u003Cname>Africano\u003C/name>\n                        \u003Clb n=\"4\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\u003Cunclear>NPP\u003C/unclear> \u003Cchoice>\u003Corig>vixsit\u003C/orig>\u003Creg>vixit\u003C/reg>\u003C/choice> \u003Cexpan>\u003Cabbr>a\u003C/abbr>\u003Cex>nnis\u003C/ex>\u003C/expan> \u003Cnum value=\"28\">XXIIX\u003C/num>\n                    \u003C/ab>\n                \u003C/div>\n                \u003Cdiv type=\"textpart\" subtype=\"section\" n=\"b\">\n                    \u003Cab>\n                        \u003Ccb n=\"2\"/>\n                        \u003Clb n=\"1\"/>\u003Cname>Caeciliae\u003C/name> \u003Cname>Zoticae\u003C/name>\n                        \u003Clb n=\"2\"/>\u003Cname>\u003Cexpan>\u003Cabbr>Sex\u003C/abbr>\u003Cex>tus\u003C/ex>\u003C/expan>\u003C/name> \u003Cname>Nonius\u003C/name> \u003Cname>Albanus\u003C/name>\n                        \u003Clb n=\"3\"/>o\u003Csupplied reason=\"lost\">pt\u003C/supplied>ima\u003Cunclear>e\u003C/unclear> uxori fecit\n                        \u003Clb n=\"4\"/>e\u003Csupplied reason=\"lost\">pul\u003C/supplied>um \u003Cexpan>\u003Cabbr>sing\u003C/abbr>\u003Cex cert=\"low\">ulis\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>\u003Cam>IIS\u003C/am>\u003C/abbr>\u003Cex>sestertium\u003C/ex>\u003C/expan> \u003Cexpan>\u003Cabbr>n\u003C/abbr>\u003Cex>ummum\u003C/ex>\u003C/expan> dignum eius\n                    \u003C/ab>\n                \u003C/div>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\u003Capp>\u003Cnote>Text: Manganaro 1989\u003C/note>\u003C/app>\u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AA\">\n                \u003Cp>To Sextus Nonius Africanus, son of Sextus, of tribe Quirina [...] lived for 28 years. To Caecilia Zotica, Sextus Nonius Albanus made this for his excellent wife. One sestertius per person [was provided] for a banquet worthy of her.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--two deceased: Sextus Nonius S. f. Quir. Africanus and Caecilia Zotica (by her husband Sextus Nonius Albanus). Nonius Albanus has donated HS 2.5 to inididual citizens for epulum (last line: e]pul]um sing. IIS.N.dignum eius-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"AE\">\n                        \u003CcitedRange>1989.0338h\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/R46KDTZX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001283\">https://biblio.inscriptiones.org/epig10001283\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>163-164 no.12 fig.12\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/EZMBJ6GN\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001831\">https://biblio.inscriptiones.org/epig10001831\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Fasolo\u003C/author>\n                        \u003Cdate>2013\u003C/date>\n                        \u003CcitedRange>82-83 no.28 fig.54\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/X2SEXMRX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002011\">https://biblio.inscriptiones.org/epig10002011\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
