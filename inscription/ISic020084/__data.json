/items/2H7NP37F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001880\">https://biblio.inscriptiones.org/epig10001880\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Tusa\u003C/author>\n                        \u003Cdate>1967\u003C/date>\n                        \u003CcitedRange>no.7\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VKGKCTWE\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001538\">https://biblio.inscriptiones.org/epig10001538\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n                        \u003Cauthor>Tod\u003C/author>\n                        \u003Cdate>1911-1912\u003C/date>\n                        \u003CcitedRange>109\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/VTE8U5QJ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001559\">https://biblio.inscriptiones.org/epig10001559\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
