orner\u003C/p>\n                                    \u003Cmaterial ana=\"#material.stone.sandstone\" ref=\"http://www.eagle-network.eu/voc/material/lod/75.html\">sandstone\u003C/material>\n                                    \u003CobjectType ana=\"#object.stele\" ref=\"http://www.eagle-network.eu/voc/objtyp/lod/250.html\">stele\u003C/objectType>\n                                    \u003Cdimensions>\u003C!-- from IGPal -->\n                                        \u003Cheight unit=\"cm\">43.5\u003C/height>\n                                        \u003Cwidth unit=\"cm\">30.5\u003C/width>\n                                        \u003Cdepth unit=\"cm\">14\u003C/depth>\n                                    \u003C/dimensions>\n                                \u003C/support>\n                                \u003Ccondition/>\n                            \u003C/supportDesc>\n                            \u003ClayoutDesc>\n                                \u003Clayout>\n                                    \u003Cp>Single line of Greek letters across the middle of the stone\u003C/p>\n                                    \u003Crs ana=\"#execution.chiselled\" ref=\"http://www.eagle-network.eu/voc/writing/lod/1\">chiselled\u003C/rs>\n                                    \u003Cdamage/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>Regular plain letters. Phi is slightly taller than the rest, but with a small circular eye; sigma has horizontal top and bottom bars, with the diagonals joined by a curve; omicron is smaller than the other letters and mid-line.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u0