ssorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cexpan>\u003Cabbr>Θ\u003C/abbr>\u003Cex>εοῖς\u003C/ex>\u003C/expan> \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>κ\u003C/abbr>\u003Cex>αταχθονίοις\u003C/ex>\u003C/expan>\u003C/supplied>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>Κρασσ\u003Cunclear>ι\u003C/unclear>\u003C/name>\u003C/persName>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"3\"/>ἔζησε\u003Csupplied reason=\"lost\">ν\u003C/supplied> \u003Csupplied reason=\"lost\">ἔτη\u003C/supplied> \u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based upon photograph in publication\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#JP\">\n                \u003Cp>To the spirits of the underword. Krassi[--] lived [--] years [---]\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Names in 'Krassi-' are surprisingly rare. Κρασσίκιος, Κρασσίων and the Latin cognomen Crassipes are almost the only forms attested.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Manganelli\u003C/author>\n                        \u003Cdate>2019\u003C/date>\n                        \u003CcitedRange>154 fig.31\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/XED5YVUS\"/>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
