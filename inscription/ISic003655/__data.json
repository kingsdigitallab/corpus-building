n from publication\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#DD\">Dmitry Dundua's lemmatizations were added from source CoNLL-U files\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc using PyEpiDoc and associated scripts\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface/>\u003C!-- \n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003655_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003655.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface> -->\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003Cg ref=\"#cross_greek\" n=\"5\">🞣\u003C/g>\n                    \u003Clb n=\"2\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"10\">Ἀσυλλις\u003C/w>\u003C/name>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"10\" lemma=\"Ἀσυλλις\">Ἀσυλλις\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text of Manganaro 1965\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>Two large letters are observable at right angles to the main text, on the left, which Manganaro reads as either two alphas or delta + alpha, but without any suggestion as to significance. \u003C!-- M takes the name to be a feminine form, unless a variant of Asullios, attested in Syracuse catacombs. Notes coin evidence in the region for C4 AD activity.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1965\u003C/date>\n                        \u003CcitedRange>200 tav.71.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RGTHAFKT\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001841\">https://biblio.inscriptiones.org/epig10001841\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
