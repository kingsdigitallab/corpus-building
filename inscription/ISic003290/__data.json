Δ with serif, lunate Ε and Σ, cursive Ω.\u003C/p>\u003C!--measurements from Korhonen-->\n                                \u003Clocus from=\"line1\" to=\"line4\">Lines 1-4\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"18\" atMost=\"30\">18-30\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line2\">Interlineation line 1 to 2\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\">not recorded\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462270\">Catina\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525068\">Catania\u003C/placeName>\n                                \u003Cgeo>37.49223, 15.07041\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"0301\" notAfter-custom=\"0400\">4th century CE\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\">Original discovery not recorded, according to Korhonen and Noy from Catania.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\">Observed by Libertini in Museo Biscari, later by Korhonen in Magazzino del cortile, Collezione Biscari (formerly sala VII 288) \u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cacquisition/>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n            \u003Cxi:include href=\"../alists/charDecl.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>ISicily glyphs authority list\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>\n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2019-09-02\" who=\"#AA\">Alex Antoniou Epidoc editing and English translation\u003C/change>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n                \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n                \u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-12-22\" who=\"#martaf\">Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#DD\">Dmitry Dundua's lemmatizations were added from source CoNLL-U files\u003C/change>\n                \u003Cchange when=\"2026-01-19\" who=\"#RC\">Robert Crellin integrated lemmatizations into EpiDoc using PyEpiDoc and associated scripts\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic003290_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic003290.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#martaf #AA\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">\u003Csupplied reason=\"lost\">Πρ\u003C/supplied>ῖσκα\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"10\">\u003Csupplied reason=\"lost\">ἔζ\u003C/supplied>ησεν\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"15\">\u003Csupplied reason=\"lost\">ἔτ\u003C/supplied>η\u003C/w> \u003Cnum value=\"18\">\u003Cw n=\"20\">δέκ\n                    \u003Clb n=\"4\" break=\"no\"/>\u003Csupplied reason=\"lost\" cert=\"low\">αοκ\u003C/supplied>τῶ\u003C/w>\u003C/num> \u003Cg ref=\"#menorah\" n=\"25\">🕎\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Πρῖσκα\">Πρῖσκα\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"ζῶ\">ἔζησεν\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"δέκαοκτῶ\">δέκαοκτῶ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#martaf\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text based on photograph\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"line 1\">\n                        \u003Cnote>Ferrua, Noy: [---]ις κα[---]; Korhonen: [Πρ]ῖσκα\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"line 2\">\n                        \u003Cnote>Libertini, Korhonen: [ἔζ]ησεν; Ferrua, Noy: [---]ης εν[---]\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"line 3\">\n                        \u003Cnote>Liberini, Noy: δέκ[α]; Ferrua [---]ηδε κ[---]; Korhonen: [ἔτ]η δέκ[α]\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"line 4\">\n                        \u003Cnote>Ferrua: ἐτω(ν); Korhonen: [ἐν Χρισ]τῷ (the space between τω and the previous letter could be justified if we suppose an abbreviation: ἐν Χρ(ισ)τῷ); Chaniotis: [μήνας ὀκ]τώ\u003C/note>\n                    \u003C/app>\n                    \u003Capp loc=\"line 4\">\n                        \u003Cnote>Ferrua, Noy and Korhonen 2001 interpreted the symbol as a menorah, but later Korhonen as a palm\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#martaf\">\n                \u003Cp>Prisca lived for 18 (?) years.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#martaf\">\n                \u003Cp>Prisca visse per 18 (?) anni.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#martaf\">\n                \u003Cp>The epitaph is Jewish, as revealed by the symbol of a menorah. Korhonen rejects the Judaic provenance of the inscription believing the symbol to be a palm, but the feet of the menorah seems to be present even if not rubricated. Korhonen’s supplement to l. 4 \u003Cforeign xml:lang=\"grc\">ἐν Χρ(ισ)τῷ\u003C/foreign> (the same abbreviation as in RQUA 10 (1896) 38 nr. 67), for this reason, cannot be supported: moreover, the space does not seem sufficient. If one assumes that a few characters are missing on the right, the integration of Chaniotis (ap. SEG) \u003Cforeign xml:lang=\"grc\">[μήνας ὀκ]τώ\u003C/foreign> is also not possible. One possibility would be to integrate the numeral \u003Cforeign xml:lang=\"grc\">δεκαοκτώ\u003C/foreign>. For the name Prisca in another Latin inscription from Catania from the imperial period, see CIL 10.1088*199 = \u003Cref target=\"http://sicily.classics.ox.ac.uk/inscription/ISic003241\">ISic003241\u003C/ref>.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>51.1200\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IMusCatania\">\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2004\u003C/date>\n                        \u003CcitedRange>192\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/2EUC82DH\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000028\">https://biblio.inscriptiones.org/epig10000028\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Libertini\u003C/author>\n                        \u003Cdate>1930\u003C/date>\n                        \u003CcitedRange>318 no.8\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SKUU2R8X\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001871\">https://biblio.inscriptiones.org/epig10001871\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1938\u003C/date>\n                        \u003CcitedRange>72 no.3\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/BPRRV8SB\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002004\">https://biblio.inscriptiones.org/epig10002004\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Noy\u003C/author>\n                        \u003Cdate>1993\u003C/date>\n                        \u003CcitedRange>no.147\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/IBA4JMAN\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000166\">https://biblio.inscriptiones.org/epig10000166\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2001\u003C/date>\n                        \u003CcitedRange>93-94\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/CVTW89H4\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001425\">https://biblio.inscriptiones.org/epig10001425\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
