181,"target":181},"https://biblio.inscriptiones.org/epig10000166","Jewish inscriptions of Western Europe","\u003Cspan>D. Noy, \u003Ci>Jewish Inscriptions of Western Europe\u003C/i>, 2 vols (Cambridge: Cambridge University Press, 1993)\u003C/span>","https://www.zotero.org/groups/isicily/items/IBA4JMAN",{"author":144,"date":186,"citedRange":187,"ptr":188,"ref":190,"title":192,"citation":193,"uri":194},"2001","93-94",{"target":189},"https://www.zotero.org/groups/382445/items/CVTW89H4",{"_":191,"target":191},"https://biblio.inscriptiones.org/epig10001425","Osservazioni sul collezionismo epigrafico siciliano","\u003Cspan>Kalle Korhonen, «Osservazioni sul collezionismo epigrafico siciliano», \u003Ci>Arctos: acta philologica fennica\u003C/i> 35 (2001): 85–102\u003C/span>","https://www.zotero.org/groups/isicily/items/CVTW89H4",{"type":196,"bibl":197},"discussion",[23],{"editor":199,"principal":202,"contributors":203,"change":223},{"_":200,"ref":201},"Jonathan Prag","#JP",{"_":200,"ref":201},[204,207,211,215,219],{"_":200,"xml:id":205,"ref":206},"JP","http://orcid.org/0000-0003-3819-8537",{"_":208,"xml:id":209,"ref":210},"Marta Fogagnolo","martaf","https://orcid.org/0000-0001-5187-5163",{"_":212,"xml:id":213,"ref":214},"James Cummings","JCu","http://orcid.org/0000-0002-6686-3728",{"_":216,"xml:id":217,"ref":218},"Alex Antoniou","AA","http://orcid.org/0000-0001-7077-0703",{"_":220,"xml:id":221,"ref":222},"Simona Stoyanova","SS","https://orcid.org/0000-0003-3914-9569",{"_":224,"when":225,"who":226},"Marta Fogagnolo revised the text encoding, added dimensions, translations and commentary","2022-12-22","#martaf",{"n":99,"url":100,"height":101,"width":102,"desc":103,"surfaceType":104},[],[230,231,232,233,234,235],"Supplementum epigraphicum graecum, 1923-","Korhonen, 2004, IMusCatania","Libertini, 1930, Il Museo Biscari","Ferrua, 1938, Osservazioni sulle iscrizioni cristiane catanesi","Noy, 1993, Jewish inscriptions of Western Europe","Korhonen, 2001, Osservazioni sul collezionismo epigrafico siciliano",[237,238,239,240,241,242],"F2GG87EQ","2EUC82DH","SKUU2R8X","BPRRV8SB","IBA4JMAN","CVTW89H4",[244,245,246,25,30,34,247,248,249,250,248,251,252,124],"isic003290","epitaph for priska(?)",{"_":5},"catina","catania","italy","sicily","museo civico di catania","ancient greek",[],{"title":255,"body":256,"divs":257,"editions":284,"images":294,"handnote":300},"ISic003290. Epitaph for Priska(?)","\u003Cdiv id=\"editions\">\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Πρῖσκα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Πρῖσκα\">[Πρ]ῖσκα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"ἔζησεν\">[ἔζ]ησεν\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">[ἔτ]η\u003C/span> δέκ-\u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[αοκ?]τῶ´ 🕎 \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Πρῖσκα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Πρῖσκα\">[..]ΙΣΚΑ\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"ἔζησεν\">[..]ΗΣΕΝ\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">[..]Η\u003C/span>ΔΕΚ\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[...]ΤΩ🕎\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003290_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003290_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003290.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003290-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 1\">line.1: \u003Cspan>Ferrua, Noy: [---]ις κα[---]; Korhonen: [Πρ]ῖσκα\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Libertini, Korhonen: [ἔζ]ησεν; Ferrua, Noy: [---]ης εν[---]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 3\">line.3: \u003Cspan>Liberini, Noy: δέκ[α]; Ferrua [---]ηδε κ[---]; Korhonen: [ἔτ]η δέκ[α]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 4\">line.4: \u003Cspan>Ferrua: ἐτω(ν); Korhonen: [ἐν Χρισ]τῷ (the space between τω and the previous letter could be justified if we suppose an abbreviation: ἐν Χρ(ισ)τῷ); Chaniotis: [μήνας ὀκ]τώ\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 4\">\u003Cspan>Ferrua, Noy and Korhonen 2001 interpreted the symbol as a menorah, but later Korhonen as a palm\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Prisca lived for 18 (?) years.\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Prisca visse per 18 (?) anni.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>The epitaph is Jewish, as revealed by the symbol of a menorah. Korhonen rejects the Judaic provenance of the inscription believing the symbol to be a palm, but the feet of the menorah seems to be present even if not rubricated. Korhonen’s supplement to l. 4 \u003Cspan class=\"lang\" lang=\"grc\">ἐν Χρ(ισ)τῷ\u003C/span> (the same abbreviation as in RQUA 10 (1896) 38 nr. 67), for this reason, cannot be supported: moreover, the space does not seem sufficient. If one assumes that a few characters are missing on the right, the integration of Chaniotis (ap. SEG) \u003Cspan class=\"lang\" lang=\"grc\">[μήνας ὀκ]τώ\u003C/span> is also not possible. One possibility would be to integrate the numeral \u003Cspan class=\"lang\" lang=\"grc\">δεκαοκτώ\u003C/span>. For the name Prisca in another Latin inscription from Catania from the imperial period, see CIL 10.1088*199 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic003241\" target=\"_blank\">ISic003241\u003C/a>.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 51.1200 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000796\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000796\u003C/a>\u003C/li>\u003Cli> Libertini 1930 318 no.8 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001871\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001871\u003C/a>\u003C/li>\u003Cli> Ferrua 1938 72 no.3 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002004\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002004\u003C/a>\u003C/li>\u003Cli> Noy 1993 no.147 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000166\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000166\u003C/a>\u003C/li>\u003Cli> Korhonen 2001 93-94 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001425\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001425\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 192 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\">\u003Cp>A with broken bar, Δ with serif, lunate Ε and Σ, cursive Ω.\u003C/p> Lines 1-4  18-30  Interlineation line 1 to 2  not recorded  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[258,261,264,267,270,272,275,278,281],{"id":259,"html":260},"editions","\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Πρῖσκα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Πρῖσκα\">[Πρ]ῖσκα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"ἔζησεν\">[ἔζ]ησεν\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">[ἔτ]η\u003C/span> δέκ-\u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[αοκ?]τῶ´ 🕎 \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Πρῖσκα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Πρῖσκα\">[..]ΙΣΚΑ\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"ἔζησεν\">[..]ΗΣΕΝ\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">[..]Η\u003C/span>ΔΕΚ\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[...]ΤΩ🕎\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>",{"id":262,"html":263},"facsimile-images","\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003290_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003290_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003290.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003290-thumb.jpg\">\u003C/a>",{"id":265,"html":266},"apparatus","\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text based on photograph\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 1\">line.1: \u003Cspan>Ferrua, Noy: [---]ις κα[---]; Korhonen: [Πρ]ῖσκα\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>Libertini, Korhonen: [ἔζ]ησεν; Ferrua, Noy: [---]ης εν[---]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 3\">line.3: \u003Cspan>Liberini, Noy: δέκ[α]; Ferrua [---]ηδε κ[---]; Korhonen: [ἔτ]η δέκ[α]\u003C/span>\u003C/span>\u003Cbr>\u003C/li>\u003Cli>\u003Cspan class=\"line 4\">line.4: \u003Cspan>Ferrua: ἐτω(ν); Korhonen: [ἐν Χρισ]τῷ (the space between τω and the previous letter could be justified if we suppose an abbreviation: ἐν Χρ(ισ)τῷ); Chaniotis: [μήνας ὀκ]τώ\u003C/span>\u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 4\">\u003Cspan>Ferrua, Noy and Korhonen 2001 interpreted the symbol as a menorah, but later Korhonen as a palm\u003C/span>\u003C/span>\u003C/li>\u003C/ul>",{"id":268,"html":269},"translation","\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Prisca lived for 18 (?) years.\u003C/p>  ",{"id":268,"html":271},"\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Prisca visse per 18 (?) anni.\u003C/p>  ",{"id":273,"html":274},"commentary","\u003Ch2>commentary\u003C/h2>  \u003Cp>The epitaph is Jewish, as revealed by the symbol of a menorah. Korhonen rejects the Judaic provenance of the inscription believing the symbol to be a palm, but the feet of the menorah seems to be present even if not rubricated. Korhonen’s supplement to l. 4 \u003Cspan class=\"lang\" lang=\"grc\">ἐν Χρ(ισ)τῷ\u003C/span> (the same abbreviation as in RQUA 10 (1896) 38 nr. 67), for this reason, cannot be supported: moreover, the space does not seem sufficient. If one assumes that a few characters are missing on the right, the integration of Chaniotis (ap. SEG) \u003Cspan class=\"lang\" lang=\"grc\">[μήνας ὀκ]τώ\u003C/span> is also not possible. One possibility would be to integrate the numeral \u003Cspan class=\"lang\" lang=\"grc\">δεκαοκτώ\u003C/span>. For the name Prisca in another Latin inscription from Catania from the imperial period, see CIL 10.1088*199 = \u003Ca href=\"http://sicily.classics.ox.ac.uk/inscription/ISic003241\" target=\"_blank\">ISic003241\u003C/a>.\u003C/p>  ",{"id":276,"html":277},"bibliography","\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 51.1200 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000796\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000796\u003C/a>\u003C/li>\u003Cli> Libertini 1930 318 no.8 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001871\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001871\u003C/a>\u003C/li>\u003Cli> Ferrua 1938 72 no.3 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002004\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002004\u003C/a>\u003C/li>\u003Cli> Noy 1993 no.147 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000166\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000166\u003C/a>\u003C/li>\u003Cli> Korhonen 2001 93-94 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001425\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001425\u003C/a>\u003C/li>\u003Cli> Korhonen 2004 192 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  ",{"id":279,"html":280},"handnote","\u003Cp>A with broken bar, Δ with serif, lunate Ε and Σ, cursive Ω.\u003C/p> Lines 1-4  18-30  Interlineation line 1 to 2  not recorded  ",{"id":282,"html":283},"license"," Licensed under a Creative Commons-Attribution 4.0 licence. ",[285,287,290,291],{"html":286},"Text encoding: Marta Fogagnolo, Alex Antoniou",{"id":288,"lang":124,"html":289},"edition-interpretive","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Πρῖσκα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Πρῖσκα\">[Πρ]ῖσκα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"ἔζησεν\">[ἔζ]ησεν\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">[ἔτ]η\u003C/span> δέκ-\u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>[αοκ?]τῶ´ 🕎 \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"html":286},{"id":292,"lang":124,"html":293},"edition-diplomatic","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Πρῖσκα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Πρῖσκα\">[..]ΙΣΚΑ\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"ἔζησεν\">[..]ΗΣΕΝ\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\">[..]Η\u003C/span>ΔΕΚ\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>[...]ΤΩ🕎\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>",[295,297],{"image":100,"thumb":296,"title":103},"ISic003290_tiled-thumb.tif",{"image":298,"thumb":299,"title":103},"ISic003290.jpg","ISic003290-thumb.jpg",[301],{"html":58},"\u003C?xml version='1.0' encoding='UTF-8'?>\n\u003C?xml-model href=\"https://epidoc.stoa.org/schema/latest/tei-epidoc.rng\" type=\"application/xml\" schematypens=\"http://relaxng.org/ns/structure/1.0\"?>\n\u003C?xml-model href=\"../schematron/ircyr-checking.sch\" schematypens=\"http://purl.oclc.org/dsdl/schematron\"?>\n\u003CTEI xmlns=\"http://www.tei-c.org/ns/1.0\" xmlns:xi=\"http://www.w3.org/2001/XIn