            \u003Cp>The text is arranged in a circular pattern on the fragment.\u003C/p>\n                                    \u003Cdamage ana=\"#text_condition.complete\"/>\n                                \u003C/layout>\n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003C!-- Based on Glyph table: -->\n                                \u003Clocus from=\"line1\" to=\"line1\">Line 1\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\"/>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"https://pleiades.stoa.org/places/462214\">Gela\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2524653/\">Gela\u003C/placeName>\n                                \u003Cgeo>37.0630925, 14.2584705\u003C/geo>\n                            \u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" evidence=\"lettering archaeological-context\" notBefore-custom=\"-0475\" notAfter-custom=\"-0451\">475—450 BCE (so Arena on letters)\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\">Found in Bitalemi\u003Cgeo>37.061394, 14.260346\u003C/geo>.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">No Autopsy\u003C/provenance>\n                        \u003Cacquisition>Gela, Museo Archeologico Regionale di Gela\u003C/acquisition>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n            \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n            \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                \u003Cxi:fallback>\n                    \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                \u003C/xi:fallback>\n            \u003C/xi:include>             \n            \u003Cxi:include href=\"../alists/charDecl.xml\">                 \n                \u003Cxi:fallback>                     \n                    \u003Cp>ISicily glyphs authority list\u003C/p>                 \n                \u003C/xi:fallback>             \n            \u003C/xi:include>         \n        \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language> \n                \u003Clanguage ident=\"it\">Italian\u003C/language> \n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language> \n                \u003Clanguage ident=\"la\">Latin\u003C/language> \n                \u003Clanguage ident=\"he\">Hebrew\u003C/language> \n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language> \n                \u003Clanguage ident=\"xly\">Elymian\u003C/language> \n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>  \n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>  \n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"https://ontology.inscriptiones.org/type_of_inscription\">\n                    \u003Cterm ana=\"#function.dedication.votive\" ref=\"https://www.eagle-network.eu/voc/typeins/lod/83\">votive\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"draft\">\n            \u003ClistChange>\n                \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n                \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n                \u003Cchange when=\"2021-04-15\" who=\"#VM\">Valentina Mignosa added metadata, text\u003C/change>\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic020489_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic020489.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>hι\u003Cunclear>αρ\u003C/unclear>ὰ \u003CpersName type=\"divine\">\u003Cname>\u003Cunclear>Θεσ\u003C/unclear>μοφόρο̄\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>ἐκ τᾶς \u003CpersName type=\"attested\">\u003Cname>Δικαιο͂ς\u003C/name>\u003C/persName> σκᾱνᾶς\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Dubois (IGDS 1)\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#VM\">\n                \u003Cp>Dedicated to Thesmophoros by the skana of Dikaiô.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#VM\">\n                \u003Cp>Dedicato a Thesmophoros da parte della skana di Dikaiô.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" xml:lang=\"en\" resp=\"#VM\">\n                \u003Cp>The fragment is part of a pyxis that was a votive offering for Thesmophoros. A Thesmophorion was would be found in Bitalemi \n                    (see Orlandini 1966). Of interest is the term σκανά, variously interpreted by editors. According to Orlandini, the term refers to the wooden \n                    building which served to house the women participating in the Thesmophoria, and whose base was found in mud bricks at Bitalemi. \n                    More plausible is the interpretation of Dubois (IGDS 1, no. 155), according to whom the term designates by metonymy the group of \n                    women, in this case under the direction of Dikaio, who took part in the Thesmoforia. The scholar in fact points out that in the regulation \n                    of Halaesa (no. 196, ll.39-46) the term σκανά designates a landmark in the territory, so it must have been a fairly solid building (however, it should be \n                    noted that even if this skana had been a wooden building, given its importance in the sacred landscape, it would still have been a landmark. \n                    Dubois again notes that in the sacred law of Elatea (LSCG no. 82 \u003Cref>https://www.zotero.org/groups/382445/items/4JJ6UXUV\u003C/ref>), the verb σκᾱνε͂ν has the sense of θοινᾶσθαι \"to take part in a ceremonial meal\". \n                    So the group of women who took part in the Thesmophoria and conducted their ritual functions in this building, which was also used for ceremonial \n                    banquets, were perhaps designated - precisely by metonymy - by the name of the building itself, which would thus serve as a collective name in our text.\n                    The name of a woman Δικαιώ is also well attested: in Thessaly (IG \u003Cref target=\"https://clio.columbia.edu/catalog/1729590\">9.0156\u003C/ref>), Athens (IG \u003Cref target=\"https://clio.columbia.edu/catalog/2155411\">2.9064\u003C/ref>) and in Bouthrôtos in Epirus.\u003C/p>\n            \u003C/div>\n            \u003C!-- Jeffery Archive: J. WC Gela NL p.01a-d. Correspondence between Jeffery and Kilmer on the fragment. -->\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IGASM2[2]\">\n                        \u003Cauthor>Arena\u003C/author>\n                        \u003Cdate>2002\u003C/date>\n                        \u003CcitedRange>46a, pl. XVII.2\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/65P7AM6N\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001373\">https://biblio.inscriptiones.org/epig10001373\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGDS1\">\n                         \u003Cauthor>Dubois\u003C/author>  \n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"http://www.persee.fr/doc/efr_0000-0000_1989_cat_119_1\">155\u003C/ref>\n                            \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RWXNUFEX\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000187\">https://biblio.inscriptiones.org/epig10000187\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"DVA\">\n                        \u003Cauthor>Lazzarini\u003C/author>\n                        \u003Cdate>1976\u003C/date>\n                        \u003CcitedRange>586, p. 125\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/3N7Z6QX5\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002517\">https://biblio.inscriptiones.org/epig10002517\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Orlandini\u003C/author>\n                        \u003Cdate>1966\u003C/date>\n                        \u003CcitedRange>20-21, tab.10.4\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/QI5CKEGR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001464\">https://biblio.inscriptiones.org/epig10001464\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl>\n                        \u003Cauthor>Orlandini\u003C/author>\n                        \u003Cdate>1966\u003C/date>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/QI5CKEGR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001464\">https://biblio.inscriptiones.org/epig10001464\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
