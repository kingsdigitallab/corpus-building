commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--There is some confusion as to whether there are one or two versions of this, in limestone and basalt, both unpublished other than Manganaro 1961b; Compare Manganaro 1961b: 195-196 fig. 19 = IMusCatania 30, funerary for the same man.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1961\u003C/date>\n                        \u003CcitedRange>195 fig.20\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/HXK7DASC\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001852\">https://biblio.inscriptiones.org/epig10001852\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Wilson\u003C/author>\n                        \u003Cdate>1996\u003C/date>\n                        \u003CcitedRange>161 n.35\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/73MBISJ2\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001507\">https://biblio.inscriptiones.org/epig10001507\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Pensabene\u003C/author>\n                        \u003Cdate>1996-1997\u003C/date>\n                        \u003CcitedRange>71\u003C/citedRange>\n                    \u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
