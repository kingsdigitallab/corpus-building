on\u003C/change> \t\n            \u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001058_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001058.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>ἐνθ\u003Csupplied reason=\"lost\">ά\u003C/supplied>δε κῖτε Μαρκι\u003Chi rend=\"ligature\">λίν\u003C/hi>η\n                    \u003Clb n=\"2\"/>\u003Cg ref=\"#staurogram\">𐆠\u003C/g> σεμνὴ \u003Csupplied reason=\"lost\">\u003Cexpan>\u003Cabbr>κ\u003C/abbr>\u003Cex>αὶ\u003C/ex>\u003C/expan>\u003C/supplied> ἄμεμπτος βιώσα\u003Csupplied reason=\"omitted\">σα\u003C/supplied>\n                    \u003Clb n=\"3\"/>ἰς τὸν κόσμον τοῦτον ἀπε\u003Csurplus>κ\u003C/surplus>\n                    \u003Clb n=\"4\" break=\"no\"/>χώρι πρὸς \u003Csupplied reason=\"omitted\">τὸν\u003C/supplied> \u003Csupplied reason=\"omitted\">Κ\u003C/supplied>ύριον ἐτῶν\n                    \u003Clb n=\"5\"/>\u003Cg ref=\"#alpha\">α\u003C/g> \u003Cg ref=\"#staurogram\">𐆠\u003C/g> \u003Cg ref=\"#omega\">ω\u003C/g> \u003Cnum value=\"17\">ιζ\u003C/num> \u003Corig>Α\u003Chi rend=\"supraline\">Ι\u003C/hi>ΧΗΝ\u003C/orig> πράττουσα τῇ\n                    \u003Clb n=\"6\"/>πρὸ \u003Cnum value=\"9\">θ\u003C/num> \u003Cexpan>\u003Cabbr>καλ\u003C/abbr>\u003Cex>ανδῶν\u003C/ex>\u003C/expan> Ἰανουαρί\n                    \u003Clb n=\"7\" break=\"no\"/>ων τὸν δὲ θεόν σε φίλε\n                    \u003Clb n=\"8\"/>μή μου σκύλῃς τὸν \u003Cunclear>β\u003C/unclear>όθ\n                    \u003Clb n=\"9\" break=\"no\"/>ρον μή μοι δίξῃς φῶς\n                    \u003Clb n=\"10\"/>ἂ\u003Csupplied reason=\"omitted\">ν\u003C/supplied> δὲ θελήσῃς φῶς μοι\n                    \u003Clb n=\"11\"/>δῖξε σοὶ τὸ φῶς\n                    \u003Clb n=\"12\"/>ὁ \u003Cexpan>\u003Cabbr>\u003Chi rend=\"ligature\">θ\u003C/hi>\u003C/abbr>\u003Cex>εὸ\u003C/ex>\u003Cabbr>\u003Chi rend=\"ligature\">ς\u003C/hi>\u003C/abbr>\u003C/expan> χόλιον δώση \u003C!-- just for now, but we have to solve the issue with ligature across theta and sigma. -->\n                    \u003Clb n=\"13\"/>\u003Cg ref=\"#staurogram\">𐆠\u003C/g> \u003Cexpan>\u003Cabbr>\u003Chi rend=\"supraline\">ἰ\u003C/hi>\u003C/abbr>\u003Cex>ησοῦς\u003C/ex> \u003Cabbr>\u003Chi rend=\"supraline\">χ\u003C/hi>\u003C/abbr>\u003Cex>ριστὸς\u003C/ex> \u003Cabbr>\u003Chi rend=\"supraline\">θ\u003C/hi>\u003C/abbr>\u003Cex>εοῦ\u003C/ex> \u003Cabbr>\u003Chi rend=\"supraline\">ύ\u003C/hi>\u003C/abbr>\u003Cex>ἱὸς\u003C/ex> \u003Cabbr>\u003Chi rend=\"supraline\">ς\u003C/hi>\u003C/abbr>\u003Cex>ωτήρ\u003C/ex>\u003C/expan>\n                    \u003Clb n=\"14\"/>\u003Cg ref=\"#palm\">⸙\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after Pugliese Carratelli 1956 with changes based on Kaibel's edition.\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!-- (see also BE 1959.0546) NB see also ISic003689; Markiline; enthade keitai; amemptos, semnos; departed to the lord; age in years; date of death; series of imprecations to god; chi-rho symbols, and alpha-omega; also 'ichthus' at foot, an acrostic calling on Christ. A copy on stone is also in the Syracuse Museum, no.6474 (June 1888; but see also no.92), and at least one other ed. of the inscr. seems to be based upon that instead; the one on display at Palazzolo is coll. Iudica no.2269; Ferrua disentangles the set and argues both examples in Syracuse are original ancient texts, while the Iudica copy is a copy of Syracuse no. 92.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">238\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>14.0590\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/F2GG87EQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"BE\">\n                        \u003CcitedRange>1955.0307\u003C/citedRange>\n                        \u003Cptr target=\"http://zotero.org/groups/382445/items/77P5MNIR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001282\">https://biblio.inscriptiones.org/epig10001282\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Kirchhoff\u003C/author>\n                        \u003Cdate>1877\u003C/date>\n                        \u003CcitedRange>9473\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/533T8HNS\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001249\">https://biblio.inscriptiones.org/epig10001249\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Agnello\u003C/author>\n                        \u003Cdate>1953\u003C/date>\n                        \u003CcitedRange>no.65\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/D9BZFDDR\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002211\">https://biblio.inscriptiones.org/epig10002211\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Pugliese Carratelli\u003C/author>\n                        \u003Cdate>1956\u003C/date>\n                        \u003CcitedRange>no.44 ph\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/PJDRZH66\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001394\">https://biblio.inscriptiones.org/epig10001394\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Ferrua\u003C/author>\n                        \u003Cdate>1989\u003C/date>\n                        \u003CcitedRange>no.492\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/759ZXHKQ\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001995\">https://biblio.inscriptiones.org/epig10001995\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
