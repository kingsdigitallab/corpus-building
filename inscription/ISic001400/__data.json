αιδίοις\u003C/w> \u003Cg ref=\"#ivy-leaf\" n=\"15\">❦\u003C/g>\n                    \u003Clb n=\"3\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"20\">Κορνελία\u003C/w>\u003C/name>\u003C/persName> \u003Cg ref=\"#ivy-leaf\" n=\"25\">❦\u003C/g>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"30\">χρηστὴ\u003C/w> \u003Cw n=\"35\">χαῖ\n                    \u003Clb n=\"5\" break=\"no\"/>ρε\u003C/w> \u003Cw n=\"40\">ἔζησες\u003C/w> \u003Cg ref=\"#ivy-leaf\" n=\"45\">❦\u003C/g>\n                    \u003Clb n=\"6\"/>\u003Cg ref=\"#ivy-leaf\" n=\"50\">❦\u003C/g> \u003Cw n=\"55\">ἔτη\u003C/w> \u003Cnum value=\"22\">\u003Cw n=\"60\">κβ\u003C/w>\u003C/num>\n                \u003C/ab>\n                \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"θεός\">Θεοῖς\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"καταγαΐδιοι\">καταγαιδίοις\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"Κορνελία\">Κορνελία\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"χρηστός\">χρηστὴ\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"χαίρω\">χαῖρε\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"ζῶ\">ἔζησες\u003C/w>\n                    \u003Cw n=\"55\" lemma=\"ἔτος\">ἔτη\u003C/w>\n                    \u003Cw n=\"60\" lemma=\"κβ\">κβ\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>text of IG\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"it\" resp=\"#AR\">\n                \u003Cp>Agli dei sotterranei. Addio gentile Cornelia. Sei vissuta 22 anni\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\" xml:lang=\"en\" resp=\"#AR\">\n              