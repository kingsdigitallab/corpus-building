eName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462074\">Adranon\u003C/placeName>\t\t\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2525769\">Adrano\u003C/placeName>\n                            \t\u003Cgeo>37.66358, 14.83283\u003C/geo>\n\t\t\u003C/origPlace>\n                            \u003CorigDate datingMethod=\"#julian\" notBefore-custom=\"-0400\" notAfter-custom=\"-0001\" cert=\"low\">A date in the period 4th — 1st century BCE seems most likely, but it is impossible to be certain in the absence of further information\u003C/origDate>\n                        \u003C/origin>\n                        \u003Cprovenance type=\"found\" subtype=\"first-recorded\">Reported at second-hand by Torremuzza (1769), who was sent the text by Nicolaus Capretti.\u003C/provenance>\n                        \u003Cprovenance type=\"observed\" subtype=\"autopsied\">None\u003C/provenance>\n                        \u003Cprovenance type=\"not-observed\" subtype=\"lost\">Lost.\u003C/provenance>\n                    \u003C/history>\n                \u003C/msDesc>\n            \u003C/sourceDesc>\n        \u003C/fileDesc>\n        \u003CencodingDesc>\n             \u003Cp>Encoded following the latest EpiDoc guidelines\u003C/p>\n             \u003Cxi:include href=\"../alists/ISicily-taxonomies.xml\">\n                 \u003Cxi:fallback>\n                     \u003Cp>Taxonomies for ISicily controlled values\u003C/p>\n                 \u003C/xi:fallback>\n             \u003C/xi:include>\n\t  \u003Cxi:include href=\"../alists/charDecl.xml\">\n\t     \u003Cxi:fallback>\n\t       \u003Cp>ISicily glyphs authority list\u003C/p>\n\t     \u003C/xi:fallback>\n\t   \u003C/xi:include>\n         \u003C/encodingDesc>\n        \u003CprofileDesc>\n            \u003CcalendarDesc>\n                \u003Ccalendar xml:id=\"julian\">\n                    \u003Cp>Julian Calendar\u003C/p>\n                \u003C/calendar>\n            \u003C/calendarDesc>\n            \u003ClangUsage>\n                \u003Clanguage ident=\"en\">English\u003C/language>\n                \u003Clanguage ident=\"it\">Italian\u003C/language>\n                \u003Clanguage ident=\"grc\">Ancient Greek\u003C/language>\n                \u003Clanguage ident=\"la\">Latin\u003C/language>\n                \u003Clanguage ident=\"he\">Hebrew\u003C/language>\n                \u003Clanguage ident=\"phn\">Phoenician\u003C/language>\n                \u003Clanguage ident=\"xpu\">Punic\u003C/language>\n                \u003Clanguage ident=\"osc\">Oscan\u003C/language>\n                \u003Clanguage ident=\"xly\">Elymian\u003C/language>\n                \u003Clanguage ident=\"scx\">Sikel\u003C/language>\n                \u003Clanguage ident=\"sxc\">Sikan\u003C/language>\n            \u003C/langUsage>\n            \u003CtextClass>\n                \u003Ckeywords scheme=\"http://www.eagle-network.eu/voc/typeins.html\">\n                    \u003Cterm ana=\"#function.funerary\" ref=\"http://www.eagle-network.eu/voc/typeins/lod/92.html\" cert=\"low\">funerary\u003C/term>\n                \u003C/keywords>\n            \u003C/textClass>\n        \u003C/profileDesc>\n        \u003CrevisionDesc status=\"edited\">\n            \u003ClistChange>\n                \u003Cchange when=\"2016-12-03\" who=\"#JCu\">James Cummings autogenerated EpiDoc output from database\u003C/change>\n                \u003Cchange when=\"2020-06-14\" who=\"#JP\">Jonathan Prag edited the file in line with edition prepared for Adrano museum catalogue\u003C/change>             \n                \u003Cchange when=\"2020-09-10\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t   \u003Cchange when=\"2020-10-05\" who=\"#SS\">Simona Stoyanova normalised Unicode\u003C/change>\n            \t   \u003Cchange when=\"2020-10-08\" who=\"#SS\">Simona Stoyanova updated list of languages\u003C/change>\n            \t\u003Cchange when=\"2020-11-20\" who=\"#SS\">Simona Stoyanova added EDCS numbers\u003C/change>\n\t\t\u003Cchange when=\"2020-11-26\" who=\"#SS\">Simona Stoyanova restructured bibliography\u003C/change>\n\t    \u003Cchange when=\"2020-12-18\" who=\"#JP\">Updated Zenodo DOI\u003C/change>\n            \t\u003Cchange when=\"2021-01-19\" who=\"#SS\">renumbered files, uris and references\u003C/change>\n                \u003Cchange when=\"2022-02-17\" who=\"#JP\">updated bibliography plus named entities\u003C/change>\n\t\u003C/listChange>\n        \u003C/revisionDesc>\n    \u003C/teiHeader>\n    \u003Cfacsimile>\n        \u003Csurface type=\"front\">\n            \u003Cgraphic n=\"screen\" url=\"ISic001387_tiled.tif\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n            \u003Cgraphic n=\"print\" url=\"ISic001387.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>Ἀρχε\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>\n                    \u003Clb n=\"2\"/>\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"character\"/>ας\u003C/name>\n                    \u003Clb n=\"3\"/>\u003CpersName type=\"attested\">\u003Cname type=\"patronym\">Πολυσ\u003Cgap reason=\"lost\" extent=\"unknown\" unit=\"line\" cert=\"low\"/>\u003C/name>\u003C/persName>\u003C/persName>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\" resp=\"#JP\">\n                \u003ClistApp>\n                    \u003Capp>\u003Cnote>Text derived from Torremuzza 1769\u003C/note>\u003C/app>\n                    \u003Capp loc=\"line 3\">\u003Cnote>Torremuzza gives no indication that anything is missing after the sigma\u003C/note>\u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\" resp=\"#JP\">\n                \u003Cp>The stone is probably a funerary inscription. Franz (\u003Cref target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\">CIG\u003C/ref> III, 5737) proposed expanding the text as Ἀρχε[λαΐδ]ας Πολυσ[τράτου] or  Πολυσ[θένευς] (i.e. “(tombstone) of Archelaidas, son of Polystratos/Polysthenes”). However, the name \u003Cref target=\"http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?name=%E1%BC%88%CF%81%CF%87%CE%B5%CE%BB%CE%B1%CE%90%CE%B4%CE%B1%CF%82\">Ἀρχελαΐδας\u003C/ref> is not attested for Sicily, and the alternatives in Ἀρχε- known for the island mostly do not end in –ας (Ἀρχέδαμος is common; Ἀρχεθάλης, Ἀρχέλας, Ἀρχέστρατος, Ἀρχέτιμος, Ἀρχέτιος are all found). \u003Cref target=\"http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?name=%CE%A0%CE%BF%CE%BB%CF%8D%CF%83%CF%84%CF%81%CE%B1%CF%84%CE%BF%CF%82\">Πολύστρατος\u003C/ref> is attested once on Sicily, \u003Cref target=\"http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?name=%CE%A0%CE%BF%CE%BB%CF%85%CF%83%CE%B8%CE%AD%CE%BD%CE%B7%CF%82\">Πολυσθένης\u003C/ref> is rare and not known in western Greece/Sicily. Torremuzza does not indicate anything was missing after the final letter, and the rare name \u003Cref target=\"http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?name=%CE%A0%CF%8C%CE%BB%CF%85%CF%82\">Πόλυς\u003C/ref> is attested in Sicily, on a vase inscription from Gela of the fifth century BC (Dubois, IGDS 142 c; = Arena, Iscr. Sic. II 23), although one would then expect Πολυος for the genitive patronymic.\u003C/p>\n                    \u003Cp>It is impossible to date this text, in the absence of further information, although it is most likely to belong to the Hellenistic period.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">568\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1769\u003C/date>\n                        \u003CcitedRange>\u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/501560\">268 cl. 18 no. 38\u003C/ref>\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SPTB56H3\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002084\">https://biblio.inscriptiones.org/epig10002084\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Castelli\u003C/author>\n                        \u003Cdate>1784\u003C/date>\n                        \u003CcitedRange>\u003Cref target=\"http://arachne.uni-koeln.de/item/buchseite/501990\">287 cl. 18 no. 38\u003C/ref>\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/7PSFHSUH\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002083\">https://biblio.inscriptiones.org/epig10002083\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"CIG\">\n                        \u003Cauthor>Franz\u003C/author>\n                        \u003Cdate>1853\u003C/date>\n                        \u003CcitedRange>5737\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TQMVHEVL\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001250\">https://biblio.inscriptiones.org/epig10001250\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Russo\u003C/author>\n                        \u003Cdate>1911\u003C/date>\n                        \u003CcitedRange>59-60\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/CRSSWMDV\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001615\">https://biblio.inscriptiones.org/epig10001615\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Prag\u003C/author>\n                        \u003Cdate>2015\u003C/date>\n                        \u003CcitedRange>317-318 no. B\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/SHKXSQLC\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002338\">https://biblio.inscriptiones.org/epig10002338\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
