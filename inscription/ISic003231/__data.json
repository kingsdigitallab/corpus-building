=\"5\" data-lemma=\"Ἐπαφρόδειτος\">Ἐπαφρό&lt;δ&gt;ειτος\u003C/span>\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"ἔζησεν\" data-n=\"10\" data-lemma=\"ζάω\">ἔζησεν\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\" data-n=\"15\" data-lemma=\"ἔτος\">ἔτη\u003C/span> · \u003Cspan data-text=\"ξ\" data-n=\"25\" data-lemma=\"ξ\">ξ\u003C/span>´ · \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Victoria Fendel, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-interpretive-simple-lemmatized\">  \u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Cspan data-text=\"Ἐπαφρόδειτος\" data-n=\"5\" data-lemma=\"Ἐπαφρόδειτος\">Ἐπαφρόδειτος\u003C/span>  \u003Cspan data-text=\"ἔζησεν\" data-n=\"10\" data-lemma=\"ζάω\">ἔζησεν\u003C/span>  \u003Cspan data-text=\"ἔτη\" data-n=\"15\" data-lemma=\"ἔτος\">ἔτη\u003C/span>  \u003Cspan data-text=\"ξ\" data-n=\"25\" data-lemma=\"ξ\">ξ\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"grc\">\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἐπαφρόδειτος\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἐπαφρόδειτος\">\u003Cspan data-text=\"Ἐπαφρόδειτος\" data-n=\"5\" data-lemma=\"Ἐπαφρόδειτος\">ΕΠΑΦΡΟΕΙΤΟΣ\u003C/span>\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"ἔζησεν\" data-n=\"10\" data-lemma=\"ζάω\">ΕΖΗΣΕΝ\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\" data-n=\"15\" data-lemma=\"ἔτος\">ΕΤΗ\u003C/span>·\u003Cspan data-text=\"ξ\" data-n=\"25\" data-lemma=\"ξ\">Ξ\u003C/span>·\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Victoria Fendel, Robert Crellin\u003C/div>\u003Cdiv id=\"edition-diplomatic-simple-lemmatized\">\u003Cdiv class=\"textpart\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Cspan data-text=\"Ἐπαφρόδειτος\" data-n=\"5\" data-lemma=\"Ἐπαφρόδειτος\">ΕΠΑΦΡΟΔΕΙΤΟΣ\u003C/span>\u003Cspan data-text=\"ἔζησεν\" data-n=\"10\" data-lemma=\"ζάω\">ΕΖΗΣΕΝ\u003C/span>\u003Cspan data-text=\"ἔτη\" data-n=\"15\" data-lemma=\"ἔτος\">ΕΤΗ\u003C/span>\u003Cspan data-text=\"ξ\" data-n=\"25\" data-lemma=\"ξ\">Ξ\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic003231_tiled.tif\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003231_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic003231.jpg\">\u003Cimg title=\"I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\" src=\"ISic003231-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>  \u003Cspan>Text based on photograph\u003C/span>  \u003C/span>; \u003C/li>\u003Cli>\u003Cspan class=\"line 2\">line.2: \u003Cspan>lapis: Ἐπαφροειτος\u003C/span>  \u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">  \u003C/p>\u003Cp>Epaphrodeitos lived for 60 years.\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"https://orcid.org/0000-0001-5187-5163\">Marta Fogagnolo\u003C/a>\u003C/p>  \u003Cp>Epaphrodeitos visse 60 anni.\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>Korhonen considers the inscription not urban because of the structure of the epitaph and the palaeography. Moreover, the name of the deceased, \u003Cspan class=\"lang\" lang=\"grc\">Ἐπαφρόδιτος\u003C/span>, is highly attested in Sicily (see LGPN 3A: 145) and in another inscription from Catania (Libertini 1937: 78).\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli> 2004.0646 \u003Ca href=\"https://biblio.inscriptiones.org/epig10001283\" target=\"_blank\">https://biblio.inscriptiones.org/epig10001283\u003C/a>  \u003C/li>\u003Cli> 54.0901 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000796\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000796\u003C/a>  \u003C/li>\u003Cli>\u003C/li>\u003Cli> Korhonen 2004 80 \u003Ca href=\"https://biblio.inscriptiones.org/epig10000028\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000028\u003C/a>  \u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\u003C/ul>  \u003C/div>  \u003Cdiv id=\"handnote\"> \u003Cp>E like a standard Σ with a middle bar, rhomboid Ο, Φ with circular bowl and extended upright.\u003C/p> Lines 1-3  23-30  Interlineation line 1 to 2  not recorded  \u003C/div>\u003Cdiv id=\"license\"> Licensed under a Creative Commons-Attribution 4.0 licence. \u003C/div>",[237,240,243,246,249,251,254,257,260],{"id":238,"html":239},"editions","\u003Cdiv class=\"attribution\">Text encoding: Marta Fogagnolo, Alex Antoniou\u003C/div>\u003Cdiv id=\"edition-interpretive\" lang=\"grc\">  \u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenu