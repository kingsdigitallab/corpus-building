n                            \u003C/layoutDesc>\n                        \u003C/objectDesc>\n                        \u003ChandDesc>\n                            \u003ChandNote>\n                                \u003Cp>Regular deeply v-cut letters with some curvature on longer strokes. Lunate sigma and epsilon; kappa has short arms. Elegant hedera at end of line 1. Phi in line 1 and Iota in line 3 are extended.\u003C/p>\n                                \u003Clocus from=\"line1\" to=\"line2\">Line 1-2\u003C/locus>\u003C!-- Bitto -->\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"45\" atMost=\"45\">45\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line3\" to=\"line3\">Line 3\u003C/locus>\n                                \u003Cdimensions type=\"letterHeight\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"40\" atMost=\"40\">40\u003C/height>\n                                \u003C/dimensions>\n                                \u003Clocus from=\"line1\" to=\"line3\">Interlineation line 1 to 3\u003C/locus>\n                                \u003Cdimensions type=\"interlinear\">\n                                    \u003Cheight unit=\"mm\" atLeast=\"14\" atMost=\"15\">14-15\u003C/height>\n                                \u003C/dimensions>\n                            \u003C/handNote>\n                        \u003C/handDesc>\n                    \u003C/physDesc>\n                    \u003Chistory>\n                        \u003Corigin>\n                            \u003CorigPlace>\u003Cregion>Sicilia\u003C/region>\n                                \u003CplaceName type=\"ancient\" ref=\"http://pleiades.stoa.org/places/462538\">Messana\u003C/placeName>\n                                \u003CplaceName type=\"modern\" ref=\"http://sws.geonames.org/2524170\">Messina\u003C/placeName>\n     