=\"name\" data-name-type=\"cognomen\" data-text=\"Rogata\">Rogata\u003C/span>\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"vixit\">vixit\u003C/span> · \u003Cspan data-text=\"annos\">ann(os)\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003Cdiv class=\"attribution\">Text encoding: Jonathan Prag; edition source: #JP\u003C/div>\u003Cdiv id=\"edition-diplomatic\" lang=\"la\">\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-diplomatic\">\u003Ca id=\"al1-diplomatic\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Caius · Iulius · Felix\">\u003Cspan data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Caius\">C\u003C/span>·\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Iulius\">IULIUS\u003C/span>·\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Felix\">FELIX\u003C/span>\u003C/span>\u003Cbr id=\"al2-diplomatic\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"vixit\">VIXIT\u003C/span>·\u003Cspan data-text=\"annos\">ANN\u003C/span>\u003Cbr id=\"al3-diplomatic\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Appuleia · Rogata\">\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Appuleia\">APPULEIA\u003C/span>·\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Rogata\">ROGATA\u003C/span>\u003C/span>\u003Cbr id=\"al4-diplomatic\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"vixit\">VIXIT\u003C/span>·\u003Cspan data-text=\"annos\">ANN\u003C/span>\u003C/span>\u003C/div>\u003Cp class=\"miniapp\">\u003C/p>\u003C/div>\u003C/div>  \u003Cdiv id=\"facsimile-images\">\u003Ch2>Facsimile Images\u003C/h2>\u003Ca href=\"ISic000006_tiled.tif\">\u003Cimg title=\"Photo J. Prag, courtesy  Museo Archeologico Regionale Antonino Salinas\" src=\"ISic000006_tiled-thumb.tif\">\u003C/a>\u003Ca href=\"ISic000006.jpg\">\u003Cimg title=\"Photo J. Prag, courtesy  Museo Archeologico Regionale Antonino Salinas\" src=\"ISic000006-thumb.jpg\">\u003C/a>\u003C/div>  \u003Cdiv id=\"apparatus\">\u003Ch4>Apparatus criticus\u003C/h4>\u003Cul>\u003Cli>\u003Cspan>\u003Cspan>Text checked against photograph\u003C/span>\u003C/span>\u003C/li>\u003C/ul>\u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>English translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/a>\u003C/p>  \u003Cp>Gaius Iulis Felix lived for [--] years. Appuleia Rogata lived for [--] years\u003C/p>  \u003C/div>  \u003Cdiv id=\"translation\">\u003Ch2>Italian translation\u003C/h2>\u003Cp class=\"translation-author\">\u003Ca href=\"http://orcid.org/0000-0003-3819-8537\">Jonathan Prag\u003C/a>\u003C/p>  \u003Cp>Gaio Giulio Felice visse anni [--]. Appuleia Rogata visse anni [--]\u003C/p>  \u003C/div>  \u003Cdiv id=\"commentary\">\u003Ch2>commentary\u003C/h2>  \u003Cp>The absence of the ages for both individuals is unusual, and the best explanation is that the inscription was engraved before the death of the two and was never completed with their age of death. Theoretically, the age might have been added using paint, which has since been lost.\u003C/p>  \u003C/div>  \u003Cdiv id=\"bibliography\">\u003Ch2>bibliography\u003C/h2>  \u003Cul>\u003Cli>\u003C/li>\u003Cli> Mommsen 1883 \u003Ca href=\"http://arachne.uni-koeln.de/item/buchseite/650810\" target=\"_blank\">7512\u003C/a>  \u003Ca href=\"https://biblio.inscriptiones.org/epig10000589\" target=\"_blank\">https://biblio.inscriptiones.org/epig10000589\u003C/a>\u003C/li>\u003Cli> Bivona 1970 6 \u003Ca href=\"https://biblio.inscriptiones.org/epig10002142\" target=\"_blank\">https://biblio.inscriptiones.org/epig10002142\u003C/a>\u003C/li>\u003C/ul>  \u003Cul>\u003Cli>\u003C/li>\