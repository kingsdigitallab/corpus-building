554.jpg\" height=\"3680px\" width=\"5520px\">\n                \u003Cdesc>I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n        \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#JP\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>\u003CpersName type=\"attested\">\u003Cname>\u003Cw n=\"5\">Σκρειβωνία\u003C/w>\u003C/name>\u003C/persName>\n                    \u003Clb n=\"2\"/>\u003Cw n=\"10\">ζῶσα\u003C/w> \u003Cw n=\"15\">ἑαυτῇ\u003C/w>\n                    \u003Clb n=\"3\"/>\u003Cw n=\"20\">ἐποίησεν\u003C/w>\n                    \u003Clb n=\"4\"/>\u003Cw n=\"25\">καὶ\u003C/w> \u003Cw n=\"30\">τοῖς\u003C/w> \u003Cw n=\"35\">ἰδίοις\u003C/w>\n                    \u003Clb n=\"5\"/>\u003Cw n=\"40\">πᾶσιν\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"edition\" subtype=\"simple-lemmatized\" resp=\"#DD #RC\">\n                \u003Cab>\n                    \u003Cw n=\"5\" lemma=\"Σκριβωνία\">Σκρειβωνία\u003C/w>\n                    \u003Cw n=\"10\" lemma=\"ζῶ\">ζῶσα\u003C/w>\n                    \u003Cw n=\"15\" lemma=\"ἑαυτοῦ\">ἑαυτῇ\u003C/w>\n                    \u003Cw n=\"20\" lemma=\"ποιέω\">ἐποίησεν\u003C/w>\n                    \u003Cw n=\"25\" lemma=\"καί\">καὶ\u003C/w>\n                    \u003Cw n=\"30\" lemma=\"ὁ\">τοῖς\u003C/w>\n                    \u003Cw n=\"35\" lemma=\"ἴδιος\">ἰδίοις\u003C/w>\n                    \u003Cw n=\"40\" lemma=\"πᾶς\">πᾶσιν\u003C/w>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003ClistApp>\n                    \u003Capp>\n                        \u003Cnote>Text after comparison of Kaibel, Filippi and SEG, prioritising Kaibel's transcription of the manuscript tradition\u003C/note>\n                    \u003C/app>\n                \u003C/listApp>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>As Korhonen lucidly details, the inscription is one of a series of late 18th century local antiquarian forgeries, constructed on the basis of existing texts, principally those to be found in the 1769 first edition of the corpus of Torremuzza. Kaibel classed the entire series already as forgeries in IG XIV.\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">21*\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl type=\"bulletin\" n=\"SEG\">\n                        \u003CcitedRange>52.0899\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F2GG87EQ\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10000796\">https://biblio.inscriptiones.org/epig10000796\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Filippi\u003C/author>\n                        \u003Cdate>2002\u003C/date>\n                        \u003CcitedRange>74-75 no. 5/15\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/PIPP325H\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001991\">https://biblio.inscriptiones.org/epig10001991\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Filippi\u003C/author>\n                        \u003Cdate>2005\u003C/date>\n                        \u003CcitedRange>65 no.5/14\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/WBLZEBQ8\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10002296\">https://biblio.inscriptiones.org/epig10002296\u003C/ref>\n                    \u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Korhonen\u003C/author>\n                        \u003Cdate>2017\u003C/date>\n                        \u003CcitedRange>198\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/92ITYJC6\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001484\">https://biblio.inscriptiones.org/epig10001484\u003C/ref>\n                    \u003C/bibl>\n                \u003C/listBibl>\n                \u003ClistBibl type=\"discussion\">\n                    \u003Cbibl/>\n                \u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>"],"uses":{"params":["slug"]}}]}
