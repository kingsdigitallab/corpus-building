’Identità Siciliana\u003C/desc>\n            \u003C/graphic>\n         \u003C/surface>\n    \u003C/facsimile>\n    \u003Ctext>\n        \u003Cbody>\n            \u003Cdiv type=\"edition\" subtype=\"primary\" xml:space=\"preserve\" xml:lang=\"grc\" resp=\"#VM\">\n                \u003Cab>\n                    \u003Clb n=\"1\"/>ἐνθάδε κῖτε \u003CpersName type=\"attested\">\u003Cname>Κωσστ\n                    \u003Clb n=\"2\" break=\"no\"/>αντία\u003C/name>\u003C/persName> ἐτῶν \u003Cnum value=\"20\">εἴκοσι\u003C/num>\n                    \u003Clb n=\"3\"/>μηνὶ Φ\u003Csurplus>ρ\u003C/surplus>εβρουαρίῳ τ\n                    \u003Clb n=\"4\" break=\"no\"/>ε͂ς \u003Cnum value=\"24\">εἴκοσι τεσάροις\u003C/num> ἡμέ\n                    \u003Clb n=\"5\" break=\"no\"/>ρᾳ Ἡλίου· ἤδιος τόπος\n                    \u003Clb n=\"6\"/>ἀγορασθέντος ὁλοκοτ\n                    \u003Clb n=\"7\" break=\"no\"/>ίνου\n                    \u003Clb n=\"7a\"/>\u003Cg ref=\"#christogram\">☧\u003C/g>\n                \u003C/ab>\n            \u003C/div>\n            \u003Cdiv type=\"apparatus\">\n                \u003Cp>Text of IGPalermo\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"translation\">\n                \u003Cp>\u003C!--translation(s) - add @xml:lang for 'en' or 'it' to div-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"commentary\">\n                \u003Cp>\u003C!--commented out pending revision-->\n                    \u003C!--Kosstantia (Konstantia); age in years; date of death (NB, recorded as 24th of the month, not by the normal Roman system; cf. IG 14.0239; 0105; 0152; several letters are cursive; purchase of the locus recorded, with price (rare) (also in Agnello, Sill. 21, for the same price!); also, Sunday referred to as hermera heliou, rare - cf. IG 14.0165; 0235; 0525.-->\u003C/p>\n            \u003C/div>\n            \u003Cdiv type=\"bibliography\">\n                \u003ClistBibl type=\"edition\">\n                    \u003Cbibl type=\"corpus\" n=\"IG\">\n                        \u003Cauthor>Kaibel\u003C/author>\n                        \u003Cdate>1890\u003C/date>\n                        \u003CcitedRange>\n                            \u003Cref target=\"https://clio.columbia.edu/catalog/6873760\">142\u003C/ref>\n                        \u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/Q2SBPG9F\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001072\">https://biblio.inscriptiones.org/epig10001072\u003C/ref>\u003C/bibl>\n                    \u003Cbibl type=\"corpus\" n=\"IGMusPalermo\">\n                         \u003Cauthor>Manni Piraino\u003C/author>\n                         \u003Cdate>1973\u003C/date> \n                        \u003CcitedRange>112\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/F66S4X3M\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10000531\">https://biblio.inscriptiones.org/epig10000531\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Carini\u003C/author>\n                        \u003Cdate>1875\u003C/date>\n                        \u003CcitedRange>124 no.30\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/H7KWCRG9\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10002090\">https://biblio.inscriptiones.org/epig10002090\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Strazzulla\u003C/author>\n                        \u003Cdate>1897\u003C/date>\n                        \u003CcitedRange>no.82\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/TUA8RN5S\"/>\n                    \u003Cref target=\"https://biblio.inscriptiones.org/epig10001390\">https://biblio.inscriptiones.org/epig10001390\u003C/ref>\u003C/bibl>\n                    \u003Cbibl>\n                        \u003Cauthor>Manganaro\u003C/author>\n                        \u003Cdate>1988\u003C/date>\n                        \u003CcitedRange>85 n.475\u003C/citedRange>\n                        \u003Cptr target=\"https://www.zotero.org/groups/382445/items/RZSFKACR\"/>\n                        \u003Cref target=\"https://biblio.inscriptiones.org/epig10001427\">https://biblio.inscriptiones.org/epig10001427\u003C/ref>\u003C/bibl>\n                \u003C/listBibl>\n\t   \u003ClistBibl type=\"discussion\">\u003Cbibl/>\u003C/listBibl>\n            \u003C/div>\n        \u003C/body>\n    \u003C/text>\n\u003C/TEI>\n"],"uses":{"params":["slug"]}}]}
