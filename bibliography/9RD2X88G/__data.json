 equal length horizontals; rho has small closed eiey; sigma has horizaontal top and bottom; phi has ovoid eye, with tall vertical; omega varies from circular to tear-drop, always closed on a horizontal foot.",[39,46],{"type":40,"l":41,"from":42,"to":43,"h":44,"unit":45},"letterHeight","Line 1-16","line1","line16","11-16","mm",{"type":47,"l":48,"from":42,"to":49,"unit":45},"interlinear","Interlineation line 1 to 2","line2",{"_":51,"notBefore":52,"notAfter":53,"evidence":54},"2nd century BCE",-200,-101,"lettering",[56,60],{"_":57,"type":58,"ref":59},"Acrae","ancient","http://pleiades.stoa.org/places/462068",{"_":61,"type":62,"ref":63},"Palazzolo Acreide","modern","http://sws.geonames.org/2523922",[65],[66,67],37.0578,14.89346,"Italy","Sicily","Siracusa",{"_":72,"role":73,"ref":74},"Soprintendenza Beni Culturali e Ambientali di Siracusa","museum","http://sicily.classics.ox.ac.uk/museum/201",{"type":76},"inventory",{"_":78,"mainLang":79,"languages":80},"Ancient Greek","grc",[78],{"n":82,"url":83,"height":84,"width":85,"desc":86,"surfaceType":87},"screen","ISic001950_tiled.tif","3652px","2776px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[90],"Vinci, 2022, Onomastica e suddivisioni civiche ad Akrai alla luce di nuovi frammenti epigrafici",[92],"9RD2X88G",[94,95,96,14,18,22,97,98,99,100,101,102,103,79],"isic001950","fragmentary list of names",{"_":10},"acrae","palazzolo acreide","italy","sicily","siracusa","soprintendenza beni culturali e ambientali di siracusa","ancient greek","Text encoding: Jonathan Prag; edition source: \u003Ca href=\"https://www.zotero.org/groups/382445/items/9RD2X88G\">https://www.zotero.org/groups/382445/items/9RD2X88G\u003C/a>",{"file":106,"uri":106,"title":107,"status":108,"editionAuthor":109,"type":110,"objectType":111,"material":112,"condition":113,"layoutDesc":114,"handNote":119,"date":126,"places":129,"geo":132,