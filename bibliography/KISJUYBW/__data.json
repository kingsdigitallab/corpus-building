rig. ligem | l.14 p\u003C/p>",{"author":3,"date":4,"citedRange":146,"ptr":147,"ref":149,"title":2,"citation":5,"uri":6},"75-80",{"target":148},"http://zotero.org/groups/382445/items/KISJUYBW",{"_":150,"target":150},"https://biblio.inscriptiones.org/epig10002323",{"file":152,"uri":152,"title":153,"status":154,"editionAuthor":13,"type":155,"objectType":156,"material":158,"condition":160,"layoutDesc":161,"handNote":167,"date":177,"places":181,"geo":188,"provenance":183,"provenanceGeo":192,"country":79,"region":80,"settlement":195,"repository":196,"idno":199,"textLang":201,"tmNumber":205,"facsimile":206,"letterHeights":211,"publications":215,"zotero":219,"keywords":223,"html":232,"bibl":233},"ISic000794","Funerary inscription for Kale",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":157},"http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":159,"ana":24,"ref":25},"marble",{"ana":27},{"layout":162},{"p":163,"rs":164,"damage":165},"Four lines of ancient Greek filling the upper portion of the face of the stone, with a consistent left margin, the right side more cramped and irregular. The lower part of the stone is blank.",{"_":32,"ana":33,"ref":34},{"ana":166},"#text_condition.complete #text_condition.legible",{"lettering":168,"dimensions":169},"Letters are somewhat irregular in size, with simple straight line serifs terminating most strokes. Alpha with both broken bar and straight bar; beta both open and closed with rounded eyes; epsilon quadrate with equal length strokes; theta and omicron are rhomboid; kappa has short arms; mu has vertical first and last, short middle strokes; pi has overhanging horizontal; sigma is quadrate lunate; omega is inverted cursive form, having the appearance of mu; the pi-rho ligature is used twice; staurogram at the end of the text.",[170,176],{"type":41,"l":171,"from":43,"to":172,"h":173,"unit":45,"atLeast":174,"atMost":175},"Line 1-4","line4","30-45","30","45",{"type":56,"l":57,"from":43,"to":50,"unit":45},{"_":178,"notBefore":1