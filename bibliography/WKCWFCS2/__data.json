C/span>] \u003Cbr id=\"al11-interpretive\">\u003Cspan class=\"linenumber\">11\u003C/span>ΠΑΣΙΦΑΝ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al12-interpretive\">\u003Cspan class=\"linenumber\">12\u003C/span>Τ̣Α̣ΙΧΑΡΙ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al13-interpretive\">\u003Cspan class=\"linenumber\">13\u003C/span>ΤΟΔΕΔ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al14-interpretive\">\u003Cspan class=\"linenumber\">14\u003C/span>ΑΝΑΘΕ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al15-interpretive\">\u003Cspan class=\"linenumber\">15\u003C/span>ΑΥΤΩΝ̣[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al16-interpretive\">\u003Cspan class=\"linenumber\">16\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">...\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":279,"ptr":280,"ref":281,"title":2,"citation":5,"uri":6},"247-248 fig.1",{"target":126},{"_":128,"target":128},{"file":283,"uri":283,"title":284,"status":285,"editionAuthor":13,"type":286,"objectType":290,"material":294,"condition":26,"layoutDesc":298,"handNote":302,"date":340,"places":344,"geo":347,"provenance":50,"provenanceGeo":349,"country":64,"region":65,"settlement":54,"repository":352,"idno":353,"textLang":356,"tmNumber":360,"facsimile":361,"letterHeights":364,"publications":365,"zotero":372,"keywords":379,"html":385,"bibl":386},"ISic003324","Two dedications to a Caesar by the Annii",{"_":12},{"_":287,"ana":288,"ref":289},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html",{"_":291,"ana":292,"ref":293},"base","#object.base","http://www.eagle-network.eu/voc/objtyp/lod/57.html",{"_":295,"ana":296,"ref":297},"marble\n                                    ","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":299