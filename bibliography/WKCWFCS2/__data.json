ttested\" data-text=\"Σέξτου Ἐγνατίου Σέξτου υἱοῦ Ῥούφου\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Σέξτου\">Σέξτου\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἐγνατίου\">Ἐ[γν]ατί̣ου̣\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σέξτου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Σέξτου\">Σ[έ]ξ[τ]ο[υ\u003C/span>\u003C/span> υἱοῦ \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ῥούφου\">Ῥ]ούφου\u003C/span>\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Λούκιος ς Λουκίου υἱὸς ο\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Λούκιος\">Λούκιος\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"ς\">[\u003Cspan dir=\"ltr\" class=\"gap\">. 5.\u003C/span>]ς\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Λουκίου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Λουκίου\">Λουκίου\u003C/span>\u003C/span> υἱὸ[ς \u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"ο\">\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>]ο[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>\u003C/span>\u003C/span> γυμνασίαρχος τῶν τε ἐφήβων καὶ νε]ωτέρων τοὺς ἀν[κ]λίτας ἐκ τῶν ἰδίων \u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"Ἑρμᾶι\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἑρμᾶι\">Ἑρμᾶι\u003C/span>\u003C/span> καὶ \u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"Ἡρακλεῖ\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἡρακλεῖ\">Ἡρακλε[ῖ]\u003C/span>\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":297,"ptr":298,"ref":299,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"248-249",{"target":218},{"_":220,"target":220},{"file":301,"uri":301,"title":302,"status":303,"editionAuthor":13,"type":304,"objectType":308,"material":312,"condition":31,"layoutDesc":318,"handNote":322,"date":368,"places":372,"geo":375,"country":158,"provenance":155,"provenanceGeo":377,"region":170,"settlement":160,"repository":380,"idno":381,"textLang":384,"tmNumber":388,"facsimile":389,"letterHeights":392,"publications":415,"zotero":422,"keywords":429,"html":435,"bibl":436,"bulletinDateSort":221,"citedRangeSort":437,"languageSort":385,"materialSort":313,"typeSort":305},"ISic003324","Two dedications to a Caesar by the Annii",{"_":12},{"_":305,"ana":306,"ref":307},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html",{"_":309,"ana":310,"ref":311},"base","#object.base","http://www.eagle-network.eu/voc/objtyp/lod/57.html",{"_":313,"ana":314,"type":315,"subtype":316,"resp":29,"ref":317},"marble\n                                    ","#material.inorganic.stone.metamorphic_rock.marble","stone.marble",[28],"http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":319},{"p":320,"rs":321,"damage":31},"Three lines of Latin letters centred on each of front and rear face, first line larger in both cases",{"_":36,"ana":37,"ref":38},{"lettering":323,"dimensions":324},"The letters are neatly cut, with short serifs. P is open on both texts, R is closed. Text A has tall I in line three. The primary difference between Text A and Text B is in the technique, with the letters in A having a flat cut, whereas B is engraved with a more elegant 'v-cut' and more elegant interpuncts. It is likely that the two were carved by different stone-masons.",[325,331,337,343,346,350,355,358,363,366],{"type":134,"l":326,"from":327,"to":327,"h":328,"unit":139,"atLeast":329,"atMost":330},"Line A 1","lineA1","37-39","37","39",{"type":134,"l":332,"from":333,"to":333,"h":334,"unit":139,"atLeast":335,"atMost":336},"Line A 2","lineA2","32-35","32","35",{"type":134,"l":338,"from":