 and rear face, first line larger in both cases",{"_":28,"ana":29,"ref":30},{"lettering":302,"dimensions":303},"The letters are neatly cut, with short serifs. P is open on both texts, R is closed. Text A has tall I in line three. The primary difference between Text A and Text B is in the technique, with the letters in A having a flat cut, whereas B is engraved with a more elegant 'v-cut' and more elegant interpuncts. It is likely that the two were carved by different stone-masons.",[304,308,312,316,320,324,328,331,334,337],{"type":34,"l":305,"from":306,"to":306,"h":307,"unit":37},"Line A 1","lineA1","37-39",{"type":34,"l":309,"from":310,"to":310,"h":311,"unit":37},"Line A 2","lineA2","32-35",{"type":34,"l":313,"from":314,"to":314,"h":315,"unit":37},"Line A 3","lineA3","27-33",{"type":34,"l":317,"from":318,"to":318,"h":319,"unit":37},"Line B 1","lineB1","35",{"type":34,"l":321,"from":322,"to":322,"h":323,"unit":37},"Line B 2","lineB2","30",{"type":34,"l":325,"from":326,"to":326,"h":327,"unit":37},"Line B 3","lineB3","27-29",{"type":39,"l":329,"from":306,"to":310,"h":330,"unit":37},"Interlineation line A1 to A2","12",{"type":39,"l":332,"from":310,"to":314,"h":333,"unit":37},"Interlineation line A2 to A3","11-13",{"type":39,"l":335,"from":318,"to":322,"h":336,"unit":37},"Interlineation line B1-B2","10",{"type":39,"l":338,"from":322,"to":326,"h":336,"unit":37},"Interlineation line B2-B3",{"_":340,"notBefore":341,"notAfter":342},"Perhaps between 16 BCE and 4 CE",-16,4,[344,345],{"_":48,"type":49,"ref":50},{"_":52,"type":53,"ref":54},[347],[57,58],[349,350],37.297479,13.589125,{"_":65,"role":66,"ref":67},{"_":353,"type":354},"22522","inventory",{"_":356,"mainLang":357,"languages":358},"Latin","la",[356],"645577",{"n":74,"url":361,"height":76,"width":77,"desc":362,"surfaceType":79},"ISic003324A_tiled.tif","Photo J. Prag, courtesy Museo Regionale Archeologico Pietro Griffo, Agrigento",[],[365,366,367,368,369,94,370],"De Miro, 1984-1985, L'attivita della soprintendenza arche