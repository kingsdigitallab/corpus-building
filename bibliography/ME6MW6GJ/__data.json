ing O is small and mid-line. A large diagonal upward stroke is visible above the first letter of each of the civic ethnics; and a horizontal above the Q at the end of line 6. The letters all show traces of dark paint (modern?).",[39,45,49,53,57,61,65,69,73,76,78,81,84],{"type":40,"l":41,"from":42,"to":42,"h":43,"unit":44},"letterHeight","Line 1","line1","65-71","mm",{"type":40,"l":46,"from":47,"to":47,"h":48,"unit":44},"Line 2","line2","68-74",{"type":40,"l":50,"from":51,"to":51,"h":52,"unit":44},"Line 3","line3","70-74",{"type":40,"l":54,"from":55,"to":55,"h":56,"unit":44},"Line 4","line4","72-75",{"type":40,"l":58,"from":59,"to":59,"h":60,"unit":44},"Line 5","line5","67-72",{"type":40,"l":62,"from":63,"to":63,"h":64,"unit":44},"Line 6","line6","67-74",{"type":40,"l":66,"from":67,"to":67,"h":68,"unit":44},"Line 7","line7","74-78",{"type":70,"l":71,"from":42,"to":47,"h":72,"unit":44},"interlinear","Interlineation line 1 to 2","50-52",{"type":70,"l":74,"from":47,"to":51,"h":75,"unit":44},"Interlineation line 2 to 3","47-51",{"type":70,"l":77,"from":51,"to":55,"h":72,"unit":44},"Interlineation line 3 to 4",{"type":70,"l":79,"from":55,"to":59,"h":80,"unit":44},"Interlineation line 4 to 5","50-53",{"type":70,"l":82,"from":59,"to":63,"h":83,"unit":44},"Interlineation line 5 to 6","52-55",{"type":70,"l":85,"from":63,"to":67,"h":86,"unit":44},"Interlineation line 6 to 7","45-52",{"_":88,"notBefore":89,"notAfter":90,"precision":91},"Mid-1st century CE",1,100,"low",[93,97],{"_":94,"type":95,"ref":96},"Agrigentum","ancient","http://pleiades.stoa.org/places/462086",{"_":98,"type":99,"ref":100},"Agrigento","modern","http://sws.geonames.org/6541860",[102],[103,104],37.32084,13.58876,[106,107],37.28967,13.592091,"Italy","Sicily",{"_":111,"role":112,"ref":113},"Museo Regionale Archeologico Pietro Griffo","museum","http://sicily.classics.ox.ac.uk/museum/130",{"_":115,"type":116},"C1970 (?)","inventory",{"_":118,"mainLang":119,"languages":120},"Latin","la",[118],"491698",{"n":123,"u