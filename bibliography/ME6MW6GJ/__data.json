ing strokes. In line 5 the O and C of 'procos' are intelinked, and the following O is small and mid-line. A large diagonal upward stroke is visible above the first letter of each of the civic ethnics; and a horizontal above the Q at the end of line 6. The letters all show traces of dark paint (modern?).",[41,47,51,55,59,63,67,71,75,78,80,83,86],{"type":42,"l":43,"from":44,"to":44,"h":45,"unit":46},"letterHeight","Line 1","line1","65-71","mm",{"type":42,"l":48,"from":49,"to":49,"h":50,"unit":46},"Line 2","line2","68-74",{"type":42,"l":52,"from":53,"to":53,"h":54,"unit":46},"Line 3","line3","70-74",{"type":42,"l":56,"from":57,"to":57,"h":58,"unit":46},"Line 4","line4","72-75",{"type":42,"l":60,"from":61,"to":61,"h":62,"unit":46},"Line 5","line5","67-72",{"type":42,"l":64,"from":65,"to":65,"h":66,"unit":46},"Line 6","line6","67-74",{"type":42,"l":68,"from":69,"to":69,"h":70,"unit":46},"Line 7","line7","74-78",{"type":72,"l":73,"from":44,"to":49,"h":74,"unit":46},"interlinear","Interlineation line 1 to 2","50-52",{"type":72,"l":76,"from":49,"to":53,"h":77,"unit":46},"Interlineation line 2 to 3","47-51",{"type":72,"l":79,"from":53,"to":57,"h":74,"unit":46},"Interlineation line 3 to 4",{"type":72,"l":81,"from":57,"to":61,"h":82,"unit":46},"Interlineation line 4 to 5","50-53",{"type":72,"l":84,"from":61,"to":65,"h":85,"unit":46},"Interlineation line 5 to 6","52-55",{"type":72,"l":87,"from":65,"to":69,"h":88,"unit":46},"Interlineation line 6 to 7","45-52",{"_":90,"notBefore":91,"notAfter":92,"precision":93},"Mid-1st century CE",1,100,"low",[95,99],{"_":96,"type":97,"ref":98},"Agrigentum","ancient","http://pleiades.stoa.org/places/462086",{"_":100,"type":101,"ref":102},"Agrigento","modern","http://sws.geonames.org/6541860",[104],[105,106],37.32084,13.58876,[108,109],37.28967,13.592091,"Italy","Sicily",{"_":113,"role":114,"ref":115},"Museo Regionale Archeologico Pietro Griffo","museum","http://sicily.classics.ox.ac.uk/museum/130",{"_":117,"type":118},"C1970 (?)","inventory",{