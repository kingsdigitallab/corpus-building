s":43},"Tall, slightly curved letters, mostly with minimal serifs. P is open; R is closed with long tail; E has short horizontals of equal length, slightly upward curving; M is four equal slanting strokes. In line 5 the O and C of 'procos' are intelinked, and the following O is small and mid-line. A large diagonal upward stroke is visible above the first letter of each of the civic ethnics; and a horizontal above the Q at the end of line 6. The letters all show traces of dark paint (modern?).",[44,52,58,63,69,74,78,83,89,94,96,100,104],{"type":45,"l":46,"from":47,"to":47,"h":48,"unit":49,"atLeast":50,"atMost":51},"letterHeight","Line 1","line1","65-71","mm","65","71",{"type":45,"l":53,"from":54,"to":54,"h":55,"unit":49,"atLeast":56,"atMost":57},"Line 2","line2","68-74","68","74",{"type":45,"l":59,"from":60,"to":60,"h":61,"unit":49,"atLeast":62,"atMost":57},"Line 3","line3","70-74","70",{"type":45,"l":64,"from":65,"to":65,"h":66,"unit":49,"atLeast":67,"atMost":68},"Line 4","line4","72-75","72","75",{"type":45,"l":70,"from":71,"to":71,"h":72,"unit":49,"atLeast":73,"atMost":67},"Line 5","line5","67-72","67",{"type":45,"l":75,"from":76,"to":76,"h":77,"unit":49,"atLeast":73,"atMost":57},"Line 6","line6","67-74",{"type":45,"l":79,"from":80,"to":80,"h":81,"unit":49,"atLeast":57,"atMost":82},"Line 7","line7","74-78","78",{"type":84,"l":85,"from":47,"to":54,"h":86,"unit":49,"atLeast":87,"atMost":88},"interlinear","Interlineation line 1 to 2","50-52","50","52",{"type":84,"l":90,"from":54,"to":60,"h":91,"unit":49,"atLeast":92,"atMost":93},"Interlineation line 2 to 3","47-51","47","51",{"type":84,"l":95,"from":60,"to":65,"h":86,"unit":49,"atLeast":87,"atMost":88},"Interlineation line 3 to 4",{"type":84,"l":97,"from":65,"to":71,"h":98,"unit":49,"atLeast":87,"atMost":99},"Interlineation line 4 to 5","50-53","53",{"type":84,"l":101,"from":71,"to":76,"h":102,"unit":49,"atLeast":88,"atMost":103},"Interlineation line 5 to 6","52-55","55",{"type":84,"l":105,"from":76,"to":80,"h":106,"