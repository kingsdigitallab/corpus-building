s.stoa.org/places/462270",{"_":52,"type":53,"ref":54},"Catania","modern","http://sws.geonames.org/2525068",[56],[57,58],37.49223,15.07041,"Italy","Sicily",{"_":62,"mainLang":63,"languages":64},"Ancient Greek","grc",[62],{"n":66,"url":67,"height":68,"width":69,"desc":70,"surfaceType":71},"screen","ISic001338_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[74,75,76,77,78],"Gualtherus, 1624 [1625], Siciliæ obiacentium insular. et Bruttiorum antiquæ tabulæ, cum animadversionib","Kaibel, 1890, IG","Supplementum epigraphicum graecum, 1923-","Franz, 1853, CIG","Manganaro, 1994, Per una storia della 'chora Katanaia'",[80,81,82,83,84],"ZP8DE8KS","Q2SBPG9F","F2GG87EQ","TQMVHEVL","ZHFSM94Z",[86,87,88,13,17,21,89,90,91,92,90,93,63],"isic001338","boundary stone (?)",{"_":10},"catina","catania","italy","sicily","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan class=\"supraline\" title=\"line above\">ΕΚL\u003C/span>\u003Cspan dir=\"ltr\">(vac.)\u003C/span>ΚΑΤ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":96,"date":3,"citedRange":97,"ptr":98,"ref":100,"title":2,"citation":4},"Manganaro","173-174",{"target":99},"https://www.zotero.org/groups/382445/items/ZHFSM94Z",{"_":101,"target":101},"https://biblio.inscriptiones.org/epig10001823",{"file":103,"uri":103,"title":104,"status":105,"editionAuthor":11,"type":106,"objectType":107,"material":111,"condition":24,"layoutDesc":115,"handNote":119,"date":136,"places":141,"geo":148,"country":59,"region":60,"settlement":152,"repository":153,"idno":157,"textLang":160,"facsimile":166,"provenance":143,"letterHeights":169,"publications":170,"zotero":178,"keywords":186,"html":195,"bibl":196},"ISic001404