line separates lines 1 and 2.",{"_":29,"ana":30,"ref":31},{"lettering":113,"dimensions":114},"The letters are engraved in broad, rounded strokes (partly the result of weathering) and have a regular form. K has arms that do not quite reach to the top and bottom of the letter; E has strokes of equal length; A has broken bar. The text is either Latin or a mixture or Latin and Greek, given the presence of L in the second line.",[115,117,120,124,126],{"type":36,"l":37,"from":38,"to":38,"h":116,"unit":39},"120-130",{"type":36,"l":118,"from":43,"to":43,"h":119,"unit":39},"Line 2","100-110",{"type":36,"l":121,"from":122,"to":122,"h":123,"unit":39},"Line 3","line3","100",{"type":41,"l":42,"from":38,"to":43,"h":125,"unit":39},"30-40",{"type":41,"l":127,"from":43,"to":122,"h":128,"unit":39},"Interlineation line 2 to 3","10-30",{"_":130,"notBefore":131,"notAfter":132,"precision":133},"5th century CE or later (?)",401,700,"low",[135,138],{"_":136,"type":49,"ref":137},"Centuripae","http://pleiades.stoa.org/places/462153",{"_":139,"type":53,"ref":140},"Centuripe","http://sws.geonames.org/2525032",[142],[143,144],37.62336,14.74049,"Adrano",{"_":147,"role":148,"ref":149},"Museo Archeologico Regionale di Adrano","museum","http://sicily.classics.ox.ac.uk/museum/021",{"_":151,"type":152},"480","inventory",{"_":154,"mainLang":63,"otherLangs":155,"ana":156,"languages":157},"Ancient Greek and Latin","la","#bilingualism.biscriptal-phenomena.graphic-interference",[62,158],"Latin",{"n":66,"url":160,"height":69,"width":68,"desc":161,"surfaceType":71},"ISic001404_tiled.tif","Photo J. Prag, courtesy Museo Archeologico Regionale di Adrano",[],[75,76,77,78,164,165,74,166,167,168,169,170],"Biondi, 2002, Per una carta archeologica del territorio di Centuripe","Biondi, 2010, Centuripe (EN). Indagini su un territorio della Sicilia centro-orientale","Castelli, 1769, Siciliae et objacentium insularum veterum inscriptionum nova collectio","Castelli, 1784, Siciliae et objacentium insularum veterum inscri