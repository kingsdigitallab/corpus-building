{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":5},{"title":2,"date":3,"citation":4},"Le epigrafi","2017","\u003Cspan>G. Zavettieri, «Le epigrafi», in \u003Ci>Da Zancle a Messina 2016. Nuovi dati di archeologia urbana\u003C/i>, a c. di G. Tigano (Palermo: Regione Siciliana, 2017), 167–71\u003C/span>",[6,95,143,182,220],{"file":7,"uri":7,"title":8,"status":9,"editionAuthor":11,"type":12,"objectType":16,"material":20,"condition":24,"layoutDesc":25,"handNote":32,"date":46,"places":51,"geo":60,"country":64,"region":65,"settlement":57,"repository":66,"idno":67,"textLang":70,"facsimile":74,"provenance":53,"letterHeights":80,"publications":81,"zotero":83,"keywords":85,"html":94},"ISic004377","Epitaph for Likinis Isauros",{"_":10},"draft",null,{"_":13,"ana":14,"ref":15},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":17,"ana":18,"ref":19},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":21,"ana":22,"ref":23},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html","",{"layout":26},{"p":27,"rs":28,"damage":24},"Four lines of simply incised Greek letters engraved between guidelines. The letters become steadily smaller and more compressed",{"_":29,"ana":30,"ref":31},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":33,"dimensions":34},"Simple lunate letters: epsilon has an extended middle bar, upsilon is variable either almost a V or with very curved upper arms",[35,42],{"type":36,"l":37,"from":38,"to":39,"h":40,"unit":41},"letterHeight","Lines 1-4","line1","line4","32","mm",{"type":43,"l":44,"from":38,"to":45,"unit":41},"interlinear","Interlineation line 1 to 2","line2",{"_":47,"notBefore":48,"notAfter":49,"precision":50},"1st — 2nd century CE",1,200,"low",[52,56],{"_":53,"ref":54,"type":55},"Messana","http://pleiades.stoa.org/places/462538","ancient",{"_":57,"ref":58,"type":59},"Messina","http://sws.geonames.org/2524170","modern",[61],[62,63],38.19394,15.55256,"Italy","Sicily","Soprintendenza stores",{"_":68,"type":69},"ME 22797","inventory",{"_":71,"mainLang":72,"languages":73},"Ancient Greek","grc",[71],{"n":75,"url":76,"height":77,"width":77,"desc":78,"surfaceType":79},"screen","ISic004377_tiled.tif","2126px","Photo courtesy of archivio fotografico della soprintendenza di Messina","front",[],[82],"Zavettieri, 2017, Le epigrafi",[84],"R9M3U4WX",[86,87,88,13,17,21,89,90,91,92,90,93,72],"isic004377","epitaph for likinis isauros",{"_":10},"messana","messina","italy","sicily","ancient greek","Text encoding: Jonathan Prag, edition source:",{"file":96,"uri":96,"title":97,"status":98,"editionAuthor":11,"type":99,"objectType":100,"material":101,"condition":24,"layoutDesc":105,"handNote":109,"date":117,"places":118,"geo":121,"country":64,"region":65,"settlement":57,"repository":123,"idno":127,"textLang":129,"facsimile":131,"provenance":53,"letterHeights":135,"publications":136,"zotero":137,"keywords":138,"html":94},"ISic004378","Epitaph for Daphne Lykeia",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":102,"ana":103,"ref":104},"marble","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":106},{"p":107,"rs":108,"damage":24},"Five lines of  Greek letters, neatly centred on the stone.",{"_":29,"ana":30,"ref":31},{"lettering":110,"dimensions":111},"Somewhat elegant lunate letters: delta, alpha, lambda all have elongated upper strokes; alpha with downard left sloping cross-bar; zeta tall, curved and elegant; upsilon has curved upper arms.",[112,116],{"type":36,"l":113,"from":38,"to":114,"h":115,"unit":41},"Lines 1-5","line5","20",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":47,"notBefore":48,"notAfter":49,"precision":50},[119,120],{"_":53,"ref":54,"type":55},{"_":57,"ref":58,"type":59},[122],[62,63],{"_":124,"role":125,"ref":126},"Soprintendenza Beni Culturali e Ambientali di Messina","museum","http://sicily.classics.ox.ac.uk/museum/197",{"_":128,"type":69},"ME 22798",{"_":71,"mainLang":72,"languages":130},[71],{"n":75,"url":132,"height":133,"width":134,"desc":78,"surfaceType":79},"ISic004378_tiled.tif","1890px","2480px",[],[82],[84],[139,140,141,13,17,102,89,90,91,92,90,142,93,72],"isic004378","epitaph for daphne lykeia",{"_":10},"soprintendenza beni culturali e ambientali di messina",{"file":144,"uri":144,"title":145,"status":146,"editionAuthor":11,"type":147,"objectType":148,"material":150,"condition":24,"layoutDesc":151,"handNote":155,"date":161,"places":162,"geo":165,"country":64,"region":65,"settlement":57,"repository":66,"idno":167,"textLang":169,"facsimile":171,"provenance":53,"letterHeights":175,"publications":176,"zotero":177,"keywords":178,"html":94},"ISic004380","Fragmentary Greek epitaph",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":149},"https://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":21,"ana":22,"ref":23},{"layout":152},{"p":153,"rs":154,"damage":24},"Remains of five lines of Greek letters, apparently cnetered on the stone, with incised guidelines. The final line is significantly smaller. The outline of a human hand is incised on the lower right below the text.",{"_":29,"ana":30,"ref":31},{"lettering":156,"dimensions":157},"Lunate letters, with the later minuscule style of mu. Letters are regular and neatly v-cut, with minimal serifs. Heart-shaped hedera at end of line 4 after the age.",[158,160],{"type":36,"l":113,"from":38,"to":114,"h":159,"unit":41},"35",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":47,"notBefore":48,"notAfter":49,"precision":50},[163,164],{"_":53,"ref":54,"type":55},{"_":57,"ref":58,"type":59},[166],[62,63],{"_":168,"type":69},"ME 22799",{"_":71,"mainLang":72,"languages":170},[71],{"n":75,"url":172,"height":173,"width":174,"desc":78,"surfaceType":79},"ISic004380_tiled.tif","1762px","1422px",[],[82],[84],[179,180,181,13,17,21,89,90,91,92,90,93,72],"isic004380","fragmentary greek epitaph",{"_":10},{"file":183,"uri":183,"title":145,"status":184,"editionAuthor":11,"type":185,"objectType":186,"material":187,"condition":24,"layoutDesc":188,"handNote":192,"date":198,"places":199,"geo":202,"country":64,"region":65,"settlement":57,"repository":66,"idno":204,"textLang":206,"facsimile":208,"provenance":53,"letterHeights":212,"publications":213,"zotero":215,"keywords":217,"html":94},"ISic004381",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":149},{"_":102,"ana":103,"ref":104},{"layout":189},{"p":190,"rs":191,"damage":24},"Remains of four lines of Greek letters, approximately centred on the stone. The beginning of lines 1 and 2 is lost, and the end of line 4 is damaged.",{"_":29,"ana":30,"ref":31},{"lettering":193,"dimensions":194},"Somewhat irregular quadrate letters, with a rhomboid omicron and regular sigma; epsilon has bars of equal length. Vertical strokes appear to serve as interpuncts in line 1 and to demarcate the number in line 4.",[195,197],{"type":36,"l":37,"from":38,"to":39,"h":196,"unit":41},"21",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":47,"notBefore":48,"notAfter":49,"precision":50},[200,201],{"_":53,"ref":54,"type":55},{"_":57,"ref":58,"type":59},[203],[62,63],{"_":205,"type":69},"ME 10771",{"_":71,"mainLang":72,"languages":207},[71],{"n":75,"url":209,"height":210,"width":211,"desc":78,"surfaceType":79},"ISic004381_tiled.tif","2008px","2717px",[],[82,214],"Bacci and Tigano, 2001, Da Zancle a Messina, un percorso archeologico attraverso gli scavi",[84,216],"H338MD7C",[218,180,219,13,17,102,89,90,91,92,90,93,72],"isic004381",{"_":10},{"file":221,"uri":221,"title":222,"status":223,"editionAuthor":11,"type":224,"objectType":225,"material":226,"condition":24,"layoutDesc":227,"handNote":231,"date":237,"places":241,"geo":244,"country":64,"region":65,"settlement":57,"repository":66,"idno":246,"textLang":248,"facsimile":250,"provenance":53,"letterHeights":253,"publications":254,"zotero":255,"keywords":256,"html":94},"ISic004382","Epitaph erected by Sossis for his wife Rufina Marcia",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":149},{"_":102,"ana":103,"ref":104},{"layout":228},{"p":229,"rs":230,"damage":24},"Five lines of Greek letters, unevenly set out and unevenly spaced (the first line is set apart by a larger gap from the remaining lines); a left margin is more or less observed.",{"_":29,"ana":30,"ref":31},{"lettering":232,"dimensions":233},"Lunate Greek letters, tending towards cursive in some cases, and reducing in size in the final lines. Moderately regularly and quite deeply incised with terminal serifs to the strokes. Alpha and Lambda extend the top of the right hasta. Alpha is closed lower left in the cursive style. Epsilon and sigma are lunate. Eta and pi have the same form (standard pi). Mu is cursive. Phi is significantly taller than other letters. Numerals are marked by supraline.",[234,236],{"type":36,"l":113,"from":38,"to":114,"h":235,"unit":41},"17",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":238,"notBefore":239,"notAfter":240,"precision":50},"2nd — 3rd century CE",201,300,[242,243],{"_":53,"ref":54,"type":55},{"_":57,"ref":58,"type":59},[245],[62,63],{"_":247,"type":69},"ME 22800",{"_":71,"mainLang":72,"languages":249},[71],{"n":75,"url":251,"height":252,"width":211,"desc":78,"surfaceType":79},"ISic004382_tiled.tif","2016px",[],[82],[84],[257,258,259,13,17,102,89,90,91,92,90,93,72],"isic004382","epitaph erected by sossis for his wife rufina marcia",{"_":10}],"uses":{"params":["slug"]}}]}
