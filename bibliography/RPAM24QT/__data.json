a (in symbols below) is lunate.",[39,44],{"type":40,"l":41,"from":42,"to":42,"unit":43},"letterHeight","Line 1","line1","mm",{"type":45,"l":46,"from":42,"to":47,"unit":43},"interlinear","Interlineation line 1 to 2","line2",{"_":49,"notBefore":50,"notAfter":51,"precision":52},"4th — 5th century CE",301,500,"low",[54,58],{"_":55,"type":56,"ref":57},"Syracusae","ancient","http://pleiades.stoa.org/places/462503",{"_":59,"type":60,"ref":61},"Siracusa","modern","http://sws.geonames.org/2523083",[63],[64,65],37.08415,15.27628,[67,68],37.0767995,15.2848558,"Italy","Sicily",{"_":72,"role":73,"ref":74},"Museo Archeologico Regionale Paolo Orsi","museum","http://sicily.classics.ox.ac.uk/museum/097",{"_":76,"type":77},"47","inventory",{"_":79,"mainLang":80,"languages":81},"Ancient Greek","grc",[79],"492539",{"n":84,"url":85,"height":86,"width":87,"desc":88,"surfaceType":89},"screen","ISic000909_tiled.tif","3721px","4724px","Photo Museo Arch. Reg. P. Orsi (2012), Aut. Assessorato Beni Culturali Regione Siciliana n.10681 del 06/05/2014","front",[],[92,93,94,95],"IG, 1890","Annotazioni sul sarcofago rinvenuto in Siracusa, 1872","I Taccuini. I. Riproduzione anastatica e trascrizione dei Taccuini 1-4, 2018","IGCVO, 1989",[97,98,99,100],"Q2SBPG9F","RPAM24QT","RGRSRUHK","9CT5ZWIK",[102,103,104,14,18,22,105,106,107,108,106,109,110,80],"isic000909","epitaph of daphros",{"_":11},"syracusae","siracusa","italy","sicily","museo archeologico regionale paolo orsi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>ἐνθάδε κεῖτε \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δάφρος\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Δάφρος\">Δάφρος\u003C/span>\u003C/span> 𐆠 \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"l