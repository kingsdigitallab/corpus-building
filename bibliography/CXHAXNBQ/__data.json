of the cursive form; omicron is circular in lines 1 and 3, angular (made up of straight lines) in lines 3 and 4; sigma is and open four bar sigma in lines 1-2, a quadrate lunate sigma in lines 3-4; phi has a small elongated eye; omega is open in lines 1-2, lunate in line 4. It is therefore likely that lines 1-2 were incised by a different hand from lines 3-4.",[185,187,190,194,198,200,203],{"type":85,"l":86,"from":87,"to":87,"h":186,"unit":89},"6-15",{"type":85,"l":188,"from":93,"to":93,"h":189,"unit":89},"Line 2","9-16",{"type":85,"l":191,"from":192,"to":192,"h":193,"unit":89},"Line 3","line3","5-8",{"type":85,"l":195,"from":196,"to":196,"h":197,"unit":89},"Line 4","line4","6-14",{"type":91,"l":92,"from":87,"to":93,"h":199,"unit":89},"9-12",{"type":91,"l":201,"from":93,"to":192,"h":202,"unit":89},"Interlineation line 2 to 3","5-9",{"type":91,"l":204,"from":192,"to":196,"h":205,"unit":89},"Interlineation line 3 to 4","2-5",{"_":207,"notBefore":208,"notAfter":209,"evidence":210},"Potentially lines 1-2 (Hellenistic) predate lines 3-4 (late Hellenistic or Roman) by a century or two.",-200,200,"lettering",[212,213],{"_":101,"type":102,"ref":103},{"_":105,"type":106,"ref":107},[215],[110,111],{"_":115,"role":116,"ref":117},{"_":218,"type":219},"C311","inventory",{"_":119,"mainLang":120,"languages":221},[119],{"n":123,"url":223,"height":224,"width":225,"desc":226,"surfaceType":128},"ISic001082_tiled.tif","3680px","5520px","Photo J. Prag, courtesy Museo Archeologico Regionale P. Griffo, Agrigento",[],[229,230,231,133],"Kaibel, 1890, IG","Supplementum epigraphicum graecum, 1923-","Bulletin épigraphique, 1888-",[233,234,235,143],"Q2SBPG9F","F2GG87EQ","77P5MNIR",[237,238,239,167,171,175,155,156,157,158,156,159,160,120],"isic001082","i.sicily inscription 001082",{"_":10},{"file":241,"uri":241,"title":242,"status":243,"editionAuthor":11,"type":244,"objectType":245,"material":249,"condition":24,"layoutDesc":250,"handNote":253,"date":257,"places":261,"geo":264,"country":112,"regi