retive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"Ἑρμᾶι\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἑρμᾶι\">\u003Cspan data-text=\"Ἑρμᾶι\" data-n=\"20\" data-lemma=\"\">Ἑρμᾶι\u003C/span>\u003C/span>\u003C/span> #triple-colon \u003Cspan data-text=\"ἀνέθηκε\" data-n=\"30\" data-lemma=\"\">ἀνέθηκε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":334,"ptr":335,"ref":336,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"32-33 no.3 pl.4",{"target":176},{"_":178,"target":178},{"file":338,"uri":338,"title":339,"status":340,"editionAuthor":13,"type":341,"objectType":342,"material":346,"condition":30,"layoutDesc":348,"handNote":352,"date":384,"places":389,"geo":392,"country":108,"provenance":105,"provenanceGeo":394,"region":118,"settlement":110,"repository":397,"idno":398,"textLang":400,"tmNumber":402,"facsimile":403,"letterHeights":405,"publications":422,"zotero":425,"keywords":428,"html":432,"bibl":433,"bulletinDateSort":179,"citedRangeSort":434,"languageSort":127,"materialSort":165,"typeSort":185},"ISic001082","I.Sicily inscription 001082",{"_":12},{"_":185,"ana":186,"ref":187},{"_":343,"ana":344,"ref":345},"altar","#object.altar","http://www.eagle-network.eu/voc/objtyp/lod/29.html",{"_":165,"ana":24,"type":25,"subtype":347,"resp":28,"ref":29},[27],{"layout":349},{"p":350,"rs":351,"damage":30},"Four lines of Greek letters, all crudely incised in the epigraphic field on the front face.",{"_":34,"ana":35,"ref":36},{"lettering":353,"dimensions":354},"The first two lines are deeply incised, the second two very lightly incised. Alpha has straight bar, with an apex; epsilon has equal length horizontals; mu in line 3 has extended apices, in anticipation of the cursive form; omicron is circular in lines 1 and 3, angular (made up of straight lines) in lines 3 and 4; sigma is and open four bar sigma in lines 1-2, a quadrate lunate sigma in lines 3-4; phi has a small elongated eye; omega is open in lines 1-2, lunate in line 4. It is therefore likely that lines 1-2 were incised by a different hand from lines 3-4.",[355,359,363,369,374,377,380],{"type":91,"l":92,"from":93,"to":93,"h":356,"unit":94,"atLeast":357,"atMost":358},"6-15","6","15",{"type":91,"l":285,"from":98,"to":98,"h":360,"unit":94,"atLeast":361,"atMost":362},"9-16","9","16",{"type":91,"l":364,"from":365,"to":365,"h":366,"unit":94,"atLeast":367,"atMost":368},"Line 3","line3","5-8","5","8",{"type":91,"l":370,"from":371,"to":371,"h":372,"unit":94,"atLeast":357,"atMost":373},"Line 4","line4","6-14","14",{"type":96,"l":97,"from":93,"to":98,"h":375,"unit":94,"atLeast":361,"atMost":376},"9-12","12",{"type":96,"l":378,"from":98,"to":365,"h":379,"unit":94,"atLeast":367,"atMost":361},"Interlineation line 2 to 3","5-9",{"type":96,"l":381,"from":365,"to":371,"h":382,"unit":94,"atLeast":383,"atMost":367},"Interlineation line 3 to 4","2-5","2",{"_":385,"notBefore":386,"notAfter":387,"evidence":388},"Potentially lines 1-2 (Hellenistic) predate lines 3-4 (late Hellenistic or Roman) by a century or two.",-200,200,"lettering",[390,391],{"_":105,"type":106,"ref":107,"region":108},{"_":110,"type":111,"ref":112,"region":108},[393],[115,116],[395,396],37.2966681,13.5882617,{"_":120,"role":121,"ref":122},{"_":399,"type":125},"C311",{"_":127,"mainLang":128,"languages":401},[127],"492710",{"n":132,"url":404,"height":134,"width":135,"desc":136,"surfaceType":137},"ISic001082_tiled.tif",[406,409,412,415,417,419,420],{"atLeast":407,"atMost":408},6,15,{"atLeast":410,"atMost":411},9,16,{"atLeast":413,"atMost":414},5,8,{"atLeast":407,"atMost":416},14,{"atLeast":410,"atMost":418},12,{"atLeast":413,"atMost":410},{"atLeast":421,"atMost":413},2,[423,140,424,146],"Kaibel, 1890, IG","Bulletin épigraphique, 1888-",[426,151,427,157],"Q2SBPG9F","77P5MNIR",[429,430,431,185,343,165,166,167,168,169,167,170,171,128],"isic001082","i.sicily inscription 001082",{"_