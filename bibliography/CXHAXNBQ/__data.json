03Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"Ἑρμᾶι\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἑρμᾶι\">\u003Cspan data-text=\"Ἑρμᾶι\" data-n=\"20\" data-lemma=\"\">Ἑρμᾶι\u003C/span>\u003C/span>\u003C/span> #triple-colon \u003Cspan data-text=\"ἀνέθηκε\" data-n=\"30\" data-lemma=\"\">ἀνέθηκε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":332,"ptr":333,"ref":334,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"32-33 no.3 pl.4",{"target":175},{"_":177,"target":177},{"file":336,"uri":336,"title":337,"status":338,"editionAuthor":13,"type":339,"objectType":340,"material":344,"condition":29,"layoutDesc":345,"handNote":349,"date":381,"places":386,"geo":389,"country":107,"provenance":104,"provenanceGeo":391,"region":117,"settlement":109,"repository":394,"idno":395,"textLang":397,"tmNumber":399,"facsimile":400,"letterHeights":402,"publications":419,"zotero":422,"keywords":425,"html":429,"bibl":430,"bulletinDateSort":178,"citedRangeSort":431,"languageSort":126,"materialSort":164,"typeSort":184},"ISic001082","I.Sicily inscription 001082",{"_":12},{"_":184,"ana":185,"ref":186},{"_":341,"ana":342,"ref":343},"altar","#object.altar","http://www.eagle-network.eu/voc/objtyp/lod/29.html",{"_":164,"ana":24,"type":25,"subtype":26,"resp":27,"ref":28},{"layout":346},{"p":347,"rs":348,"damage":29},"Four lines of Greek letters, all crudely incised in the epigraphic field on the front face.",{"_":33,"ana":34,"ref":35},{"lettering":350,"dimensions":351},"The first two lines are deeply incised, the second two very lightly incised. Alpha has straight bar, with an apex; epsilon has equal length horizontals; mu in line 3 has extended apices, in anticipation of the cursive form; omicron is circular in lines 1 and 3, angular (made up of straight lines) in lines 3 and 4; sigma is and open four bar sigma in lines 1-2, a quadrate lunate sigma in lines 3-4; phi has a small elongated eye; omega is open in lines 1-2, lunate in line 4. It is therefore likely that lines 1-2 were incised by a different hand from lines 3-4.",[352,356,360,366,371,374,377],{"type":90,"l":91,"from":92,"to":92,"h":353,"unit":93,"atLeast":354,"atMost":355},"6-15","6","15",{"type":90,"l":283,"from":97,"to":97,"h":357,"unit":93,"atLeast":358,"atMost":359},"9-16","9","16",{"type":90,"l":361,"from":362,"to":362,"h":363,"unit":93,"atLeast":364,"atMost":365},"Line 3","line3","5-8","5","8",{"type":90,"l":367,"from":368,"to":368,"h":369,"unit":93,"atLeast":354,"atMost":370},"Line 4","line4","6-14","14",{"type":95,"l":96,"from":92,"to":97,"h":372,"unit":93,"atLeast":358,"atMost":373},"9-12","12",{"type":95,"l":375,"from":97,"to":362,"h":376,"unit":93,"atLeast":364,"atMost":358},"Interlineation line 2 to 3","5-9",{"type":95,"l":378,"from":362,"to":368,"h":379,"unit":93,"atLeast":380,"atMost":364},"Interlineation line 3 to 4","2-5","2",{"_":382,"notBefore":383,"notAfter":384,"evidence":385},"Potentially lines 1-2 (Hellenistic) predate lines 3-4 (late Hellenistic or Roman) by a century or two.",-200,200,"lettering",[387,388],{"_":104,"type":105,"ref":106,"region":107},{"_":109,"type":110,"ref":111,"region":107},[390],[114,115],[392,393],37.2966681,13.5882617,{"_":119,"role":120,"ref":121},{"_":396,"type":124},"C311",{"_":126,"mainLang":127,"languages":398},[126],"492710",{"n":131,"url":401,"height":133,"width":134,"desc":135,"surfaceType":136},"ISic001082_tiled.tif",[403,406,409,412,414,416,417],{"atLeast":404,"atMost":405},6,15,{"atLeast":407,"atMost":408},9,16,{"atLeast":410,"atMost":411},5,8,{"atLeast":404,"atMost":413},14,{"atLeast":407,"atMost":415},12,{"atLeast":410,"atMost":407},{"atLeast":418,"atMost":410},2,[420,139,421,145],"Kaibel, 1890, IG","Bulletin épigraphique, 1888-",[423,150,424,156],"Q2SBPG9F","77P5MNIR",[426,427,428,184,341,164,165,166,167,168,166,169,170,127],"isic001082","i.sicily inscription 001082",{"_":12},"\u003Cdiv c