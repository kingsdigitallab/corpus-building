mber\">12\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Πασίωνος\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Πασίωνος\">Πασίωνος\u003C/span>\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κότητος\">\u003Cspan data-type=\"name\" data-name-type=\"papponym\" data-text=\"Κότητος\">Κότητος\u003C/span>\u003C/span>\u003C/span> καὶ \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Θεόδωρος Θεοδώρου Ξηνιάδα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Θεόδωρος\">Θεόδωρος\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Θεοδώρου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Θεοδώρου\">Θεοδώρου\u003C/span>\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ξηνιάδα\">\u003Cspan data-type=\"name\" data-name-type=\"papponym\" data-text=\"Ξηνιάδα\">Ξηνιάδα\u003C/span>\u003C/span>\u003C/span>, \u003Cbr id=\"al13-interpretive\">\u003Cspan class=\"linenumber\">13\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Δημήτριον Διοδότου Συρακόσιον\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Δημήτριον\">Δημήτριον\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Διοδότου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Διοδότου\">Διοδότου\u003C/span>\u003C/span> Συρακόσιον\u003C/span> πολλὰς καὶ μεγάλας χρείας \u003Cbr id=\"al14-interpretive\">\u003Cspan class=\"linenumber\">14\u003C/span>παρεισχῆσθαι τῶι ἁμῶι δάμωι καὶ μεγάλων ἀγαθῶν παραίτιο&lt;ν&gt; \u003Cbr id=\"al15-interpretive\">\u003Cspan class=\"linenumber\">15\u003C/span>γεγόνειν, τοῖς δὲ Ἀκραγαντίνοις πάτριόν ἐστι καὶ ἐκ προγόνων \u003Cbr id=\"al16-interpretive\">\u003Cspan class=\"linenumber\">16\u003C/span>παραδεδομένον τιμεῖν τοὺς ἀγαθοὺς ἄνδρας καὶ προισταμέ-\u003Cb