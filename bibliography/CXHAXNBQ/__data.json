76,"places":381,"geo":384,"provenance":101,"provenanceGeo":386,"country":113,"region":114,"settlement":105,"repository":389,"idno":390,"textLang":392,"tmNumber":394,"facsimile":395,"letterHeights":397,"publications":414,"zotero":417,"keywords":420,"html":424,"bibl":425,"citedRangeSort":426,"languageSort":123,"materialSort":161,"typeSort":180},"ISic001082","I.Sicily inscription 001082",{"_":12},{"_":180,"ana":181,"ref":182},{"_":336,"ana":337,"ref":338},"altar","#object.altar","http://www.eagle-network.eu/voc/objtyp/lod/29.html",{"_":161,"ana":24,"ref":25},{"layout":341},{"p":342,"rs":343,"damage":26},"Four lines of Greek letters, all crudely incised in the epigraphic field on the front face.",{"_":30,"ana":31,"ref":32},{"lettering":345,"dimensions":346},"The first two lines are deeply incised, the second two very lightly incised. Alpha has straight bar, with an apex; epsilon has equal length horizontals; mu in line 3 has extended apices, in anticipation of the cursive form; omicron is circular in lines 1 and 3, angular (made up of straight lines) in lines 3 and 4; sigma is and open four bar sigma in lines 1-2, a quadrate lunate sigma in lines 3-4; phi has a small elongated eye; omega is open in lines 1-2, lunate in line 4. It is therefore likely that lines 1-2 were incised by a different hand from lines 3-4.",[347,351,355,361,366,369,372],{"type":87,"l":88,"from":89,"to":89,"h":348,"unit":90,"atLeast":349,"atMost":350},"6-15","6","15",{"type":87,"l":278,"from":94,"to":94,"h":352,"unit":90,"atLeast":353,"atMost":354},"9-16","9","16",{"type":87,"l":356,"from":357,"to":357,"h":358,"unit":90,"atLeast":359,"atMost":360},"Line 3","line3","5-8","5","8",{"type":87,"l":362,"from":363,"to":363,"h":364,"unit":90,"atLeast":349,"atMost":365},"Line 4","line4","6-14","14",{"type":92,"l":93,"from":89,"to":94,"h":367,"unit":90,"atLeast":353,"atMost":368},"9-12","12",{"type":92,"l":370,"from":94,"to":357,"h":371,"unit":90,"atLeast":359,"atMost":353},"Interlineation line 2 to 3","5-9",{"type":92,"l":373,"from":357,"to":363,"h":374,"unit":90,"atLeast":375,"atMost":359},"Interlineation line 3 to 4","2-5","2",{"_":377,"notBefore":378,"notAfter":379,"evidence":380},"Potentially lines 1-2 (Hellenistic) predate lines 3-4 (late Hellenistic or Roman) by a century or two.",-200,200,"lettering",[382,383],{"_":101,"type":102,"ref":103},{"_":105,"type":106,"ref":107},[385],[110,111],[387,388],37.2966681,13.5882617,{"_":116,"role":117,"ref":118},{"_":391,"type":121},"C311",{"_":123,"mainLang":124,"languages":393},[123],"492710",{"n":128,"url":396,"height":130,"width":131,"desc":132,"surfaceType":133},"ISic001082_tiled.tif",[398,401,404,407,409,411,412],{"atLeast":399,"atMost":400},6,15,{"atLeast":402,"atMost":403},9,16,{"atLeast":405,"atMost":406},5,8,{"atLeast":399,"atMost":408},14,{"atLeast":402,"atMost":410},12,{"atLeast":405,"atMost":402},{"atLeast":413,"atMost":405},2,[415,136,416,142],"Kaibel, 1890, IG","Bulletin épigraphique, 1888-",[418,147,419,153],"Q2SBPG9F","77P5MNIR",[421,422,423,180,336,161,162,163,164,165,163,166,167,124],"isic001082","i.sicily inscription 001082",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"Πολυστεφάνῳ\n                    Σωτείρᾳ\">\u003Cspan data-type=\"name\" data-name-type=\"epithet\" data-text=\"Πολυστεφάνῳ\">Πολυστεφάνῳ\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Σωτείρᾳ\">Σωτείρᾳ\u003C/span>\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"\" data-text=\"Νικομήδης ὁ καὶ\n                    Ὄνυς\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Νικομήδης\">Νικομήδης\u003C/span> ὁ καὶ 