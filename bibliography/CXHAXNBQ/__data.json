ta-text=\"Ἑρμᾶι\" data-n=\"20\" data-lemma=\"\">Ἑρμᾶι\u003C/span>\u003C/span>\u003C/span> #triple-colon \u003Cspan data-text=\"ἀνέθηκε\" data-n=\"30\" data-lemma=\"\">ἀνέθηκε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":328,"ptr":329,"ref":330,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"32-33 no.3 pl.4",{"target":172},{"_":174,"target":174},{"file":332,"uri":332,"title":333,"status":334,"editionAuthor":13,"type":335,"objectType":336,"material":340,"condition":26,"layoutDesc":341,"handNote":345,"date":377,"places":382,"geo":385,"country":104,"provenance":101,"provenanceGeo":387,"region":114,"settlement":106,"repository":390,"idno":391,"textLang":393,"tmNumber":395,"facsimile":396,"letterHeights":398,"publications":415,"zotero":418,"keywords":421,"html":425,"bibl":426,"bulletinDateSort":175,"citedRangeSort":427,"languageSort":123,"materialSort":161,"typeSort":181},"ISic001082","I.Sicily inscription 001082",{"_":12},{"_":181,"ana":182,"ref":183},{"_":337,"ana":338,"ref":339},"altar","#object.altar","http://www.eagle-network.eu/voc/objtyp/lod/29.html",{"_":161,"ana":24,"ref":25},{"layout":342},{"p":343,"rs":344,"damage":26},"Four lines of Greek letters, all crudely incised in the epigraphic field on the front face.",{"_":30,"ana":31,"ref":32},{"lettering":346,"dimensions":347},"The first two lines are deeply incised, the second two very lightly incised. Alpha has straight bar, with an apex; epsilon has equal length horizontals; mu in line 3 has extended apices, in anticipation of the cursive form; omicron is circular in lines 1 and 3, angular (made up of straight lines) in lines 3 and 4; sigma is and open four bar sigma in lines 1-2, a quadrate lunate sigma in lines 3-4; phi has a small elongated eye; omega is open in lines 1-2, lunate in line 4. It is therefore likely that lines 1-2 were incised by a different hand from lines 3-4.",[348,352,356,362,367,370,373],{"type":87,"l":88,"from":89,"to":89,"h":349,"unit":90,"atLeast":350,"atMost":351},"6-15","6","15",{"type":87,"l":279,"from":94,"to":94,"h":353,"unit":90,"atLeast":354,"atMost":355},"9-16","9","16",{"type":87,"l":357,"from":358,"to":358,"h":359,"unit":90,"atLeast":360,"atMost":361},"Line 3","line3","5-8","5","8",{"type":87,"l":363,"from":364,"to":364,"h":365,"unit":90,"atLeast":350,"atMost":366},"Line 4","line4","6-14","14",{"type":92,"l":93,"from":89,"to":94,"h":368,"unit":90,"atLeast":354,"atMost":369},"9-12","12",{"type":92,"l":371,"from":94,"to":358,"h":372,"unit":90,"atLeast":360,"atMost":354},"Interlineation line 2 to 3","5-9",{"type":92,"l":374,"from":358,"to":364,"h":375,"unit":90,"atLeast":376,"atMost":360},"Interlineation line 3 to 4","2-5","2",{"_":378,"notBefore":379,"notAfter":380,"evidence":381},"Potentially lines 1-2 (Hellenistic) predate lines 3-4 (late Hellenistic or Roman) by a century or two.",-200,200,"lettering",[383,384],{"_":101,"type":102,"ref":103,"region":104},{"_":106,"type":107,"ref":108,"region":104},[386],[111,112],[388,389],37.2966681,13.5882617,{"_":116,"role":117,"ref":118},{"_":392,"type":121},"C311",{"_":123,"mainLang":124,"languages":394},[123],"492710",{"n":128,"url":397,"height":130,"width":131,"desc":132,"surfaceType":133},"ISic001082_tiled.tif",[399,402,405,408,410,412,413],{"atLeast":400,"atMost":401},6,15,{"atLeast":403,"atMost":404},9,16,{"atLeast":406,"atMost":407},5,8,{"atLeast":400,"atMost":409},14,{"atLeast":403,"atMost":411},12,{"atLeast":406,"atMost":403},{"atLeast":414,"atMost":406},2,[416,136,417,142],"Kaibel, 1890, IG","Bulletin épigraphique, 1888-",[419,147,420,153],"Q2SBPG9F","77P5MNIR",[422,423,424,181,337,161,162,163,164,165,163,166,167,124],"isic001082","i.sicily inscription 001082",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-te