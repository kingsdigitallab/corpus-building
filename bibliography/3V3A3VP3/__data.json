gant 'v-cut' and more elegant interpuncts. It is likely that the two were carved by different stone-masons.",[37,45,51,57,60,64,69,73,78,81],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42,"atLeast":43,"atMost":44},"letterHeight","Line A 1","lineA1","37-39","mm","37","39",{"type":38,"l":46,"from":47,"to":47,"h":48,"unit":42,"atLeast":49,"atMost":50},"Line A 2","lineA2","32-35","32","35",{"type":38,"l":52,"from":53,"to":53,"h":54,"unit":42,"atLeast":55,"atMost":56},"Line A 3","lineA3","27-33","27","33",{"type":38,"l":58,"from":59,"to":59,"h":50,"unit":42,"atLeast":50,"atMost":50},"Line B 1","lineB1",{"type":38,"l":61,"from":62,"to":62,"h":63,"unit":42,"atLeast":63,"atMost":63},"Line B 2","lineB2","30",{"type":38,"l":65,"from":66,"to":66,"h":67,"unit":42,"atLeast":55,"atMost":68},"Line B 3","lineB3","27-29","29",{"type":70,"l":71,"from":40,"to":47,"h":72,"unit":42,"atLeast":72,"atMost":72},"interlinear","Interlineation line A1 to A2","12",{"type":70,"l":74,"from":47,"to":53,"h":75,"unit":42,"atLeast":76,"atMost":77},"Interlineation line A2 to A3","11-13","11","13",{"type":70,"l":79,"from":59,"to":62,"h":80,"unit":42,"atLeast":80,"atMost":80},"Interlineation line B1-B2","10",{"type":70,"l":82,"from":62,"to":66,"h":80,"unit":42,"atLeast":80,"atMost":80},"Interlineation line B2-B3",{"_":84,"notBefore":85,"notAfter":86},"Perhaps between 16 BCE and 4 CE",-16,4,[88,92],{"_":89,"type":90,"ref":91},"Agrigentum","ancient","http://pleiades.stoa.org/places/462086",{"_":93,"type":94,"ref":95},"Agrigento","modern","http://sws.geonames.org/6541860",[97],[98,99],37.32084,13.58876,[101,102],37.297479,13.589125,"Italy","Sicily",{"_":106,"role":107,"ref":108},"Museo Regionale Archeologico Pietro Griffo","museum","http://sicily.classics.ox.ac.uk/museum/130",{"_":110,"type":111},"22522","inventory",{"_":113,"mainLang":114,"languages":115},"Latin","la",[113],"645577",{"n":118,"url":119,"height":120,"width":121,"desc":122,"surfaceType":123},"screen","ISic003324A_tiled.tif","3680px","5