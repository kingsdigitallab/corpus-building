cations":223,"zotero":225,"keywords":227,"html":233},"ISic003479","Sikel inscription on wall of a tomb",{"_":10},{"_":13,"ana":14,"ref":15},{"_":184,"ana":185,"ref":186},"rock face","#object.rock-face","http://www.eagle-network.eu/voc/objtyp/lod/211",{"_":188,"ana":189,"ref":190},"stone","#material.stone","http://www.eagle-network.eu/voc/material/lod/2.html",{"layout":192},{"p":193,"rs":194,"damage":24},"The text is laid out on the right hand wall (as one enters) of the roughly rectangular chamber. Two sequences of letters run in the upper line from left to right and in the lower line from right to left, with a final letter below.",{"_":28,"ana":29,"ref":30},{"dimensions":196},[197,200],{"type":34,"l":198,"from":36,"to":41,"h":199,"unit":37},"Line 1-2","60-85",{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":202,"notBefore":203,"notAfter":204,"evidence":205,"precision":123},"Archaic (the tomb is dated by typology only to the 7th century or early 6th century BCE)",-650,-501,"archaeological-context",[207],{"_":208,"type":54,"ref":209,"corresp":210},"Palagonia","http://sws.geonames.org/2523927","#findspot",[212],[213,214],37.32955,14.74474,{"role":64},{"_":217,"mainLang":218,"languages":219},"Sikel","scx",[217],{"n":74,"url":221,"height":76,"width":77,"desc":78,"surfaceType":79},"ISic003479_tiled.tif",[],[82,82,84,83,224],"Cordano, 2012, Iscrizioni monumentali dei Siculi",[88,88,90,89,226],"C7FV3MUG",[228,229,230,13,184,188,231,99,100,231,232,218],"isic003479","sikel inscription on wall of a tomb",{"_":10},"palagonia","sikel","Text encoding: Jonathan Prag",{"file":235,"uri":235,"title":180,"status":236,"editionAuthor":11,"type":237,"objectType":238,"material":239,"condition":24,"layoutDesc":240,"handNote":244,"date":253,"places":254,"geo":256,"country":60,"region":61,"settlement":208,"repository":258,"textLang":259,"facsimile":261,"provenance":208,"letterHeights":263,"publications":264,"zotero":265,"keywords":266,"html":233},"ISic003480",{"_":10},{"_":13,"ana":14,"ref":15},{"_":184,"ana":185,"ref":186},{"_":188,"ana":189,"ref":190},{"layout":241},{"p":242,"rs":243,"damage":24},"The text is engraved on the left-hand wall as one enters the tomb, in a single line, from right to left, with two further large letters separated from the main text",{"_":28,"ana":29,"ref":30},{"lettering":245,"dimensions":246},"Letters of the archaic Greek alphabet: sigma rendered with a single wavy line; of the two alphas, one is regular, the other the arrow-head form 'alpha siculum'. Of the main group, qoppa is the tallest at 130 mm; of the two alphas, the regular is 170 mm, the sikel form 110 mm",[247,249,252],{"type":34,"l":35,"from":36,"to":36,"h":248,"unit":37},"up to 130",{"type":34,"l":250,"from":41,"to":41,"h":251,"unit":37},"Line 2","110-170",{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":202,"notBefore":203,"notAfter":204,"evidence":205,"precision":123},[255],{"_":208,"type":54,"ref":209,"corresp":210},[257],[213,214],{"role":64},{"_":217,"mainLang":218,"languages":260},[217],{"n":74,"url":262,"height":76,"width":77,"desc":78,"surfaceType":79},"ISic003480_tiled.tif",[],[82,82,84,83,224],[88,88,90,89,226],[267,229,268,13,184,188,231,99,100,231,232,218],"isic003480",{"_":10}],"uses":{"params":["slug"]}}]}
