ref":250},"marble",{"layout":688},{"p":689,"rs":690,"damage":26},"Parts of three lines of Latin letters are preserved",{"_":31,"ana":32,"ref":33},{"lettering":692,"dimensions":693},"The letters are neatly V-cut and well-proportioned, with modest serifs. Neither lines 1 nor 3 are completely preserved, but line 1 is taller than line 2, and line 3 is shorter",[694,696],{"type":132,"l":329,"from":139,"to":139,"h":695,"unit":136,"atLeast":695,"atMost":695},"70",{"type":143,"l":144,"from":134,"to":139,"h":145,"unit":136},{"_":698,"notBefore":645,"notAfter":646,"evidence":150},"1st century CE",[700,701],{"_":153,"type":154,"ref":155},{"_":157,"type":158,"ref":159,"offset":160},[703],[163,164],[],{"_":171,"role":172,"ref":173},{"_":707,"type":176},"ME 20225",{"_":279,"mainLang":280,"languages":709},[279],"175720",{"n":183,"url":712,"height":662,"width":713,"desc":663,"surfaceType":188},"ISic000802_tiled.tif","5982px",[715],{"atLeast":716,"atMost":716},70,[195,197,291,201,203],[207,209,295,213,215],[720,721,722,15,314,686,222,223,224,225,222,226,302,280],"isic000802","latin fragment mentioning a basilica",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]equọ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]basilic̣[a\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ọp̣ẹṛị[bus\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":725,"ptr":726,"ref":727,"title":2,"citation":5,"uri":6},"15 no.5 fig.3",{"target":232},{"_":234,"target":234},{"file":729,"uri":729,"title":730,"status":731,"editionAuthor":13,"type":732,"objectType":733,"material":734,"condition":26,"layoutDesc":738,"handNote":742,"date":751,"places":754,"geo":757,"provenance":153,"provenanceGeo":759,"country":168,"region":169,"settlement":153,"repository":760,"textLang":761,"tmNumber":763,"facsimile":764,"letterHeights":768,"publications":772,"zotero":774,"keywords":776,"html":780,"bibl":781},"ISic000803","Dedication by a pair of seviri",{"_":12},{"_":15,"ana":16,"ref":17},{"_":244,"ana":245,"ref":246},{"_":735,"ana":736,"ref":737},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":739},{"p":740,"rs":741,"damage":26},"Two lines of Latin letters in the field below the moulding (17.5 cm high and\n                                        originally 160 cm wide)",{"_":31,"ana":32,"ref":33},{"lettering":743,"dimensions":744},"The letters are crudely cut (but the stone is too coarse to allow of better): P is\n                                    open, but R is closed; Q has a long tail; long I is taller than the other letters\n                                    (63mm); E is tall and narrow; words are separated by simple interpuncts.",[745,748,750],{"type":132,"l":133,"from":134,"to":134,"h":746,"unit":136,"atLeast":747,"atMost":330},"45-55","45",{"type":132,"l":329,"from":139,"to":139,"h":749,"unit":136,"atLeast":640,"atMost":747},"40-45",{"type":143,"l":642,"from":134,"to":139,"unit":136},{"_":752,"notBefore":265,"notAfter":753},"End 1st century CE, beginning 2nd century CE",150,[755,756],{"_":153,"type":154,"ref":155},{"_":157,"type":158,"ref":159,"offset":160},[758],[163,164],[],{"_":171,"role":172,"ref":173},{"_":279,"mainLang":280,"languages":762},[279],"175721",{"n":183,"url":765,"height":766,"width":767,"desc":663,"surfaceType":188},"ISic000803a_tiled.tif","1672px","3072px",[769,771],{"atLeast":770,"atMost":380},45,{"atLeast":667,"atMost":770},[195,197,291,203,773],"Burgio, 2013, Architetture onorarie dell’agorà di Alesa, 1. Il monumento dei Seviri Augustales: analisi e proposta ricostruttiva",[207,209,295,215,775],"5ETXJGSF",[777,778,779,15,244,735,222,223,224,225,222,226,302,280],"isic000803","dedication by a pair of seviri",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span> Q (uintus) · Caecilius · Q (uinti) · l (ibertus) · Hime[raeus \u003Cspan dir=\"ltr\" class=\"gap\">.. ? ..\u003C/span>]s · \u003Cspan class=\"reversed\" title=\"reversed: Ↄ\">(())\u003C/span>(mulieris) · l (ibertus) · Sabinus · \u003Cspan dir=\"ltr\">(vac.2)\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>  \u003Cspan dir=\"ltr\">(vac.5)\u003C/span> sẹṿiri · \u003Cspan dir=\"ltr\">(vac.)\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">.. ? ..\u003C/span>] ḍ (e) · s (ua) · p (ecunia) · \u003Cspan dir=\"ltr\">(vac.7)\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":782,"ptr":783,"ref":784,"title":2,"citation":5,"uri":6},"16 no.6 tav.4.1",{"target":232},{"_":234,"target":234},{"file":786,"uri":786,"title":787,"status":788,"editionAuthor":13,"type":789,"objectType":790,"material":793,"condition":26,"layoutDesc":794,"handNote":798,"date":811,"places":815,"geo":818,"provenance":153,"provenanceGeo":820,"country":168,"region":169,"settlement":153,"repository":823,"idno":824,"textLang":826,"tmNumber":828,"facsimile":829,"letterHeights":833,"publications":841,"zotero":843,"keywords":845,"html":849,"bibl":850},"ISic000804","Dedication of a statue to Ceres, by Iulius Acilius Hermes, sevir",{"_":12},{"_":240,"ana":241,"ref":242},{"_":791,"ana":792,"ref":246},"statue base","#object.statue_base",{"_":248,"ana":249,"ref":250},{"layout":795},{"p":796,"rs":797,"damage":26},"The Latin text is engraved over two lines (letters c.20 mm high, but of uneven height), to a maximum length of 52 cm.",{"_":31,"ana":32,"ref":33},{"lettering":799,"dimensions":800}," The letters show some irregularity, with fairly pronounced serifs, and lengthy tails to the letter R. The first two words are separated from the rest by a space; an interpunct is visible at the end of the dedicant’s name, and the final abbreviated phrase is separated from the rest by a large hedera (ivy leaf). The letter I in line 1 is frequently taller than the rest (but so too is the first L in line 1); the final I of line 1 is somewhat irregularly carved.",[801,804,808],{"type":132,"l":133,"from":134,"to":134,"h":802,"unit":136,"atLeast":803,"atMost":141},"18-25","18",{"type":132,"l":329,"from":139,"to":139,"h":805,"unit":136,"atLeast":806,"atMost":807},"19-23","19","23",{"type":143,"l":340,"from":134,"to":139,"h":809,"unit":136,"atLeast":810,"atMost":455},"7-15","7",{"_":812,"notBefore":813,"notAfter":814,"evidence":586},"Statue can be dated stylistically to the late Antonine period (i.e. the 180s or 190s CE), and the text is compatible with such a date.",180,199,[816,817],{"_":153,"type":154,"ref":155},{"_":157,"type":158,"ref":159,"offset":160},[819],[163,164],[821,822],37.998037,14.262643,{"_":171,"role":172,"ref":173},{"_":825,"type":176},"ME 20194",{"_":279,"mainLang":280,"languages":827},[279],"175724",{"n":183,"url":830,"height":831,"width":832,"desc":375,"surfaceType":188},"ISic000804_tiled.tif","1949px","4512px",[834,836,839],{"atLeast":835,"atMost":193},18,{"atLeast":837,"atMost":838},19,23,{"atLeast":840,"atMost":481},7,[195,197,291,842,293,203,205],"Scibona, 2008, Statuary",[207,209,295,844,297,215,217],"EQC3W4UU",[846,847,848,240,791,248,222,223,224,225,222,226,302,280],"isic000804","dedication of a statue to ceres, by iulius acilius hermes, sevir",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Cereri sacr(um) \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> Iulius Acilius Her-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>mes · pro honor(e) seviratus ❦ d(eae) d(onum) d(edit) \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":851,"ptr":852,"ref":853,"title":2,"citation":5,"uri":6},"19 no.9 fig.1-2",{"target":232},{"_":234,"target":234},{"file":855,"uri":855,"title":856,"status":857,"editionAuthor":13,"type":858,"objectType":859,"material":860,"condition":26,"layoutDesc":862,"handNote":865,"date":872,"places":876,"geo":879,"provenance":153,"provenanceGeo":881,"country":168,"region":169,"settlement":153,"repository":884,"idno":885,"textLang":887,"tmNumber":889,"facsimile":890,"letterHeights":893,"publications":896,"zotero":897,"keywords":898,"html":902,"bibl":903},"ISic000805","Fragmentary latin inscription mentioning a proconsul",{"_":12},{"_":15,"ana":16,"ref":17},{"_":314,"ana":315,"ref":316},{"_":861,"ana":249,"ref":250},"marble (pink)",{"layout":863},{"rs":864,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":866,"dimensions":867},"Letters are 50mm high, tall, thin, serifed. P and R are open; the hastae of M join early and extend upwards; a hedera like interpunct (tail top and bottom to a hollow element) appears once between C and V of line 2.",[868,871],{"type":132,"l":869,"from":134,"to":333,"h":870,"unit":136,"atLeast":870,"atMost":870},"Line 1-3","50",{"type":143,"l":261,"from":134,"to":139,"unit":136},{"_":873,"notBefore":874,"notAfter":875},"3rd century CE",201,300,[877,878],{"_":153,"type":154,"ref":155},{"_":157,"type":158,"ref":159,"offset":160},[880],[163,164],[882,883],37.998054,14.262639,{"_":171,"role":172,"ref":173},{"_":886,"type":176},"ME 20228",{"_":279,"mainLang":280,"languages":888},[279],"175725",{"n":183,"url":891,"height":892,"width":662,"desc":663,"surfaceType":188},"ISic000805_tiled.tif","5256px",[894],{"atLeast":895