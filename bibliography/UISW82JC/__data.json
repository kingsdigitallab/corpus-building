rom":134,"to":139,"h":664,"unit":136},"Interlineation line 1 to 2","?",{"_":666,"notBefore":611,"notAfter":667},"Late 1st century CE, or 2nd century CE",200,[669,670],{"_":153,"type":154,"ref":155,"region":156},{"_":158,"type":159,"ref":160,"offset":161,"region":156},[672],[164,165],[674,675],37.998047,14.262635,{"_":171,"role":172,"ref":173},{"_":678,"type":176},"ME 20226",{"_":507,"mainLang":508,"languages":680},[507],"175722",{"n":183,"url":683,"height":684,"width":685,"desc":686,"surfaceType":188},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[688],{"atLeast":191,"atMost":191},[195,197,443,444,200,201,690,203,205],"Portale, 2009, Le sculture da Alesa",[207,209,449,450,212,213,692,215,217],"BCIMMIKZ",[694,695,696,366,588,652,222,223,224,225,222,226,526,508],"isic000768","dedication by a sevir to concordia",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":699,"ptr":700,"ref":701,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"17 no.7 fig.1",{"target":232},{"_":234,"target":234},{"file":703,"uri":703,"title":704,"status":705,"editionAuthor":13,"type":706,"objectType":707,"material":708,"condition":26,"layoutDesc":710,"handNote":714,"date":742,"places":746,"geo":749,"country":156,"provenance":153,"provenanceGeo":751,"region":169,"settlement":153,"repository":754,"idno":755,"textLang":757,"tmNumber":759,"facsimile":760,"letterHeights":764,"publicati