 is open; S\n                                    has a larger upper half, leaning slightly to the right. Words are separated by a\n                                    comma-like three pointed serif.",[611,614],{"type":132,"l":612,"from":134,"to":139,"h":613,"unit":136},"Lines 1-2","38-40",{"type":143,"l":615,"from":134,"to":139,"unit":136},"Not measured",{"_":617,"notBefore":618,"notAfter":619,"precision":151},"Mid 1st century CE",1,100,[621,622],{"_":154,"type":155,"ref":156},{"_":158,"type":159,"ref":160,"offset":161},[624],[164,165],[],{"_":172,"role":173,"ref":174},{"_":628,"type":177},"ME 20224",{"_":277,"mainLang":278,"languages":630},[277],"175719",{"n":184,"url":633,"height":634,"width":635,"desc":636,"surfaceType":189},"ISic000801_tiled.tif","6190px","4912px","Photo J. Prag",[],[192,194,288,198,200,202],[204,206,292,210,212,214],[641,642,643,599,311,246,220,221,222,223,220,224,299,278],"isic000801","fragment of a public latin inscription",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]CILIV[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]R · S · P · INỌ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":646,"ptr":647,"ref":648,"title":2,"citation":5,"uri":6},"15 no.4 fig.2",{"target":230},{"_":232,"target":232},{"file":650,"uri":650,"title":651,"status":652,"editionAuthor":13,"type":653,"objectType":654,"material":655,"condition":26,"layoutDesc":657,"handNote":661,"date":667,"places":669,"geo":672,"provenance":154,"provenanceGeo":674,"country":169,"region":170,"settlement":154,"repository":675,"idno":676,"textLang":678