27",{"_":507,"mainLang":508,"languages":758},[507],"175723",{"n":183,"url":761,"height":762,"width":763,"desc":437,"surfaceType":188},"ISic000769_tiled.tif","3704px","7048px",[765,767,768,770,773,776],{"atLeast":766,"atMost":766},65,{"atLeast":630,"atMost":630},{"atLeast":769,"atMost":769},43,{"atLeast":771,"atMost":772},17,20,{"atLeast":774,"atMost":775},11,14,{"atLeast":777,"atMost":775},12,[195,197,443,444,200,201,203,205],[207,209,449,450,212,213,215,217],[781,782,783,15,370,784,222,223,224,225,222,226,526,508],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":12},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":787,"ptr":788,"ref":789,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"17 no.8 fig.2-3\n                        ",{"target":232},{"_":234,"target":234},{"file":791,"uri":791,"title":792,"status":793,"editionAuthor":13,"type":794,"objectType":795,"material":798,"condition":26,"layoutDesc":799,"handNote":803,"date":816,"places":820,"geo":823,"country":156,"provenance":153,"provenanceGeo":825,"region":169,"settlement":153,"repository":828,"idno":829,"textLang":831,"tmNumber":833,"facsimile":834,"letterHeights":838,"publications":846,"zotero":848,"keywords":850,"html":854,"bibl":855,"bulletinDateSort":235,"citedRangeSort":856,"languageSort":507,"materialSort":652,"typeSort":366},"ISic000804","Dedication of a statue to Ceres, by Iulius Acilius Hermes, sevir",{"_":12},{"_":366,"ana":367,"ref":368},{"_":796,"ana":797,"ref":590},"statue base","#object.statue_base",{"_":652,"ana":475,"ref":476},{"layout":800},{"p":801,"rs":802,"damage":26},"The Latin text is engraved over two lines (letters c.20 mm high, but of uneven height), to a maximum length of 52 cm.",{"_":31,"ana":32,"ref":33},{"lettering":804,"dimensions":805}," The letters show some irregularity, with fairly pronounced serifs, and lengthy tails to the letter R. The first two words are separated from the rest by a space; an interpunct is visible at the end of the dedicant’s name, and the final abbreviated phrase is separated from the rest by a large hedera (ivy leaf). The letter I in line 1 is frequently taller than the rest (but so too is the first L in line 1); the final I of line 1 is somewhat irregularly carved.",[806,809,813],{"type":132,"l":133,"from":134,"to":134,"h":807,"unit":136,"atLeast":808,"atMost":141},"18-25","18",{"type":132,"l":548,"from":139,"to":139,"h":810,"unit":136,"atLeast":811,"atMost":812},"19-23","19","23",{"type":143,"l":729,"from":134,"to":139,"h":814,"unit":136,"atLeast":815,"atMost":413},"7-15","7",{"_":817,"notBefore":818,"notAfter":819,"evidence":326},"Statue can be dated stylistically to the late Antonine period (i.e. the 180s or 190s CE), and the text is compatible with such a date.",180,199,[821,822],{"_":153,"type":154,"ref":155,"region":156},{"_":158,"type":159,"ref":160,"offset":161,"region":156},[824],[164,165],[826,827],37.998037,14.262643,{"_":171,"role":172,"ref":173},{"_":830,"type":176},"ME 20194",{"_":507,"mainLang":508,"languages":832},[507],"175724",{"n":183,"url":835,"height":836,"width":837,"desc":437,"surfaceType":188},"ISic000804_tiled.tif","1949px","4512px",[839,841,844],{"atLeast":840,"atMost":193},18,{"atLeast":842,"atMost":843},19,23,{"atLeast":845,"atMost":440},7,[195,197,443,847,690,203,205],"Scibona, 2008, Statuary",[207