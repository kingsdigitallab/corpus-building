ype=\"attested\" data-text=\"Μάρκος · Αἰμίλιος · Ῥόδων \n                    Κίπου · υἱὸς\">\u003Cspan data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Μάρκος\">Μ(άρκος)\u003C/span> · \u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Αἰμίλιος\">Αἰμίλιος\u003C/span> · \u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Ῥόδων\">Ῥό[δων]\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κίπου\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Κίπου\">Κίπου\u003C/span>\u003C/span> · \u003Cspan data-text=\"υἱὸς\">υἱὸς\u003C/span>\u003C/span> · \u003Cspan data-text=\"ὑπὲρ τῆς\">ὑπ̣[ὲρ τῆς]\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"ἀγορανο\">ἀγορανο\u003C/span>  \u003Cspan data-text=\"μ\">μ̣\u003C/span>  \u003Cspan data-text=\"ίας\">[ίας]\u003C/span>  \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan data-text=\"ἀνέθηκεν\">ἀνέθ[ηκεν]\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>\u003Cspan data-text=\"ἐκ\">ἐκ\u003C/span>  \u003Cspan data-text=\"τῶν ἰδίων\">τῶ̣[ν ἰδίων]\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":222,"date":3,"citedRange":458,"ptr":459,"ref":460,"title":2,"citation":4},"13 no.3 fig.2",{"target":225},{"_":227,"target":227},{"file":462,"uri":462,"title":463,"status":464,"editionAuthor":11,"type":465,"objectType":466,"material":467,"condition":24,"layoutDesc":469,"handNote":472,"date":542,"places":547,"geo":550,"country":164,"region":165,"settlement":152,"repository":552,"idno":553,"textLang":555,"facsimile":557,"provenance":152,"letterHeights":561,"publications":562,"zotero":563,"keywords":564,"html":568,"bibl":569},"ISic000800","Honorific for [---] Lapiron Sal., son of Apollodoros",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":468,"ana":376,"ref":377},"limestone\n                                    ",{"layout":470},{"rs":471,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":473,"dimensions":538},[474,475],"The text is regularly cut and well spaced; the terminations to the main strokes are pronounced, but not yet developed into full serifs. There is no space between words. Epsilon has a short middle bar; theta has an unattached middle bar; omicron is full size; alpha consistently has a broken bar; omega is closed and ellipsoid.",{"_":476,"ref":477},"\n                                    Types list:\n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                ",[478,481,484,487,490,491,492,495,498,499,500,501,502,505,508,511,512,513,514,515,516,517,518,519,520,