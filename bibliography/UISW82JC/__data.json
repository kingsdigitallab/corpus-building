s are separated by comma-like interpuncts.",[326,328,331,335,339,344,349],{"type":132,"l":133,"from":134,"to":134,"h":327,"unit":136,"atLeast":327,"atMost":327},"65",{"type":132,"l":329,"from":139,"to":139,"h":330,"unit":136,"atLeast":330,"atMost":330},"Line 2","55",{"type":132,"l":332,"from":333,"to":333,"h":334,"unit":136,"atLeast":334,"atMost":334},"Line 3","line3","43",{"type":132,"l":336,"from":337,"to":337,"h":338,"unit":136},"Line 4","line4","incomplete",{"type":143,"l":340,"from":134,"to":139,"h":341,"unit":136,"atLeast":342,"atMost":343},"Interlineation lines 1-2","17-20","17","20",{"type":143,"l":345,"from":139,"to":333,"h":346,"unit":136,"atLeast":347,"atMost":348},"Interlineation lines 2-3","11-14","11","14",{"type":143,"l":350,"from":333,"to":337,"h":351,"unit":136,"atLeast":352,"atMost":348},"Interlineation lines 3-4","12-14","12",{"_":354,"notBefore":355,"notAfter":356},"2nd century CE or early 3rd century CE",101,250,[358,359],{"_":153,"type":154,"ref":155},{"_":157,"type":158,"ref":159,"offset":160},[361],[163,164],[363,364],37.997854,14.262475,{"_":171,"role":172,"ref":173},{"_":367,"type":176},"ME 20227",{"_":279,"mainLang":280,"languages":369},[279],"175723",{"n":183,"url":372,"height":373,"width":374,"desc":375,"surfaceType":188},"ISic000769_tiled.tif","3704px","7048px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina",[377,379,381,383,386,389],{"atLeast":378,"atMost":378},65,{"atLeast":380,"atMost":380},55,{"atLeast":382,"atMost":382},43,{"atLeast":384,"atMost":385},17,20,{"atLeast":387,"atMost":388},11,14,{"atLeast":390,"atMost":388},12,[195,197,291,292,200,201,203,205],[207,209,295,296,212,213,215,217],[394,395,396,15,314,397,222,223,224,225,222,226,302,280],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":12},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":400,"ptr":401,"ref":402,"title":2,"citation":5,"uri":6},"17 no.8 fig.2-3\n                        ",{"target":232},{"_":234,"target":234},{"file":404,"uri":404,"title":405,"status":406,"editionAuthor":13,"type":407,"objectType":408,"material":409,"condition":412,"layoutDesc":414,"handNote":420,"date":457,"places":461,"geo":464,"provenance":153,"provenanceGeo":466,"country":168,"region":169,"settlement":153,"repository":469,"idno":470,"textLang":472,"tmNumber":474,"facsimile":475,"letterHeights":479,"publications":482,"zotero":487,"keywords":492,"html":496,"bibl":497},"ISic000770","Dedication by Marcus Aimilius Rho[--]",{"_":12},{"_":240,"ana":241,"ref":242},{"_":314,"ana":315,"ref":316},{"_":410,"ana":24,"ref":411},"limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":413},"#condition.damaged",{"layout":415},{"p":416,"rs":417,"damage":418},"The first part of all six lines of the Greek text are preserved, but none are complete.",{"_":31,"ana":32,"ref":33},{"ana":419},"#text_condition.incomplete #text_condition.legible",{"lettering":421,"dimensions":451},[422,423],"The letters are uniform and well cut, with pronounced serifs. A hollow triangular interpunct is used between all the onomastic elements (but apparently not elsewhere in the text; spaces are however observed between words, with or without interpunct). Theta has a detached middle bar; omicron is full size; epsilon has a detached short middle bar; mu reaches almost to the lower line in the middle, and the outer strokes are vertical.",{"_":424,"ref":425},"\n                                    Types list:\n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                ",[426,427,428,429,430,431,432,433,434,435,436,439,440,441,442,443,444,447,448,449,450],{"_":41,"target":42},{"_":44,"target":45},{"_":53,"target":54},{"_":56,"target":57},{"_":59,"target":60},{"_":68,"target":69},{"_":71,"target":72},{"_":74,"target":75},{"_":77,"target":78},{"_":83,"target":84},{"_":437,"target":438},"Μ type3.2","https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Μ-type3.2.html",{"_":95,"target":96},{"_":98,"target":99},{"_":101,"target":102},{"_":104,"target":105},{"_":107,"target":108},{"_":445,"target":446},"Ρ type1.1","https://kingsdigitallab.github.io/crossreads/data/allographs/types/greek-Ρ-type1.1.html",{"_":113,"target":114},{"_":116,"target":117},{"_":125,"target":126},{"_":128,"target":129},[452,456],{"type":132,"l":453,"from":134,"to":454,"h":455,"unit":136,"atLeast":455,"atMost":455},"Lines 1-6","line6","15",{"type":143,"l":144,"from":134,"to":139,"h":145,"unit":136},{"_":458,"notBefore":459,"notAfter":460},"1st century BCE (pre-Augustan?)",-100,-21,[462,463],{"_":153,"type":15