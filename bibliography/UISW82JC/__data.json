ht c.30mm), and words are separated by simple triangular interpuncts. The letters are lightly serifed. E is tall and narrow, T has a curved cross-bar, rising to the right.",[253,255],{"type":130,"l":254,"from":132,"to":137,"h":133,"unit":134},"Line 1-2",{"type":141,"l":256,"from":132,"to":137,"h":257,"unit":134},"Interlineation line 1 to 2","?",{"_":259,"notBefore":260,"notAfter":261,"precision":149},"Late 1st century CE, or 2nd century CE",51,200,[263,264],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[266],[162,163],[268,269],37.998047,14.262635,{"_":170,"role":171,"ref":172},{"_":272,"type":175},"ME 20226",{"_":274,"mainLang":275,"languages":276},"Latin","la",[274],"175722",{"n":182,"url":279,"height":280,"width":281,"desc":282,"surfaceType":187},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[],[12,191,285,286,194,195,287,197,199],"La Sicilia da Sesto Pompeo a Diocleziano, 1988","Iscrizioni Latine nuove e vecchie della Sicilia, 1989","Le sculture da Alesa, 2009",[201,203,289,290,206,207,291,209,211],"RZSFKACR","EZMBJ6GN","BCIMMIKZ",[293,294,295,235,239,243,217,218,219,220,217,221,296,275],"isic000768","dedication by a sevir to concordia",{"_":11},"latin","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":299,"ptr":300,"ref":301,"title":2,"citation":5},"17 no.7 fig.1",{"target":227},{"_":229,"target":229},{"file":303,"uri":303,"title":304,"status":305,"editionAuthor":12,"type":306,"objectType":307,"material":311,"condition":3,"layoutDesc":313,"handNote":317,"date":342,"places":346,"geo":349,"provenance":152,"provenanceGeo":351,"country":167,"region":168,"settlement":152,"repository":354,"idno":355,"textLang":357,"tmNumber":359,"facsimile":360,"letterHeights":365,"publications":366,"zotero":367,"keywords":368,"html":373,"bibl":374},"ISic000769","Honours for L. Naevius(?) Firminus Manilianus",{"_":11},{"_":14,"ana":15,"ref":16},{"_":308,"ana":309,"ref":310},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":312,"ana":244,"ref":245},"marble (blue)\n                                    ",{"layout":314},{"p":315,"rs":316,"damage":3},"Remains of four lines of latin text are preserved: only the lower part of the first line survives, and only traces of the tops of letters remain from the beginning of line four.",{"_":29,"ana":30,"ref":31},{"lettering":318,"dimensions":319},"The letters are V-cut and generously (and sometimes unevenly) spaced, with moderate serifs. R is closed, and both A and R have lightly cut horizontals; all the strokes of M are off-vertical. Words are separated by comma-like interpuncts.",[320,322,325,329,333,336,339],{"type":130,"l":131,"from":132,"to":132,"h":321,"unit":134},"65",{"type":130,"l":323,"from":137,"to":137,"h":324,"unit":134},"Line 2","55",{"type":130,"l":326,"from":327,"to":327,"h":328,"unit":134},"Line 3","line3","43",{"type":130,"l":330,"from":331,"to":331,"h":332,"unit":134},"Line 4","line4","incomplete",{"type":141,"l":334,"from":132,"to":137,"h":335,"unit":134},"Interlineation lines 1-2","17-20",{"type":141,"l":337,"from":137,"to":327,"h":338,"unit":134},"Interlineation lines 2-3","11-14",{"type":141,"l":340,"from":327,"to":331,"h":341,"unit":134},"Interlineation lines 3-4","12-14",{"_":343,"notBefore":344,"notAfter":345,"precision":149},"2nd century CE or early 3rd century CE",101,250,[347,348],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[350],[162,163],[352,353],37.997854,14.262475,{"_":170,"role":171,"ref":172},{"_":356,"type":175},"ME 20227",{"_":274,"mainLang":275,"languages":358},[274],"175723",{"n":182,"url":361,"height":362,"width":363,"desc":364,"surfaceType":187},"ISic000769_tiled.tif","3704px","7048px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina",[],[12,191,285,286,194,195,197,199],[201,203,289,290,206,207,209,211],[369,370,371,14,308,372,217,218,219,220,217,221,296,275],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":11},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":375,"ptr":376,"ref":377,"title":2,"citation":5},"17 no.8 fig.2-3\n                        ",{"target":227},{"_":229,"target":229},{"file":379,"uri":379,"title":380,"status":381,"editionAuthor":12,"type":382,"objectType":383,"material":384,"condition":388,"layoutDesc":390,"handNote":396,"date":433,"places":437,"geo":440,"provenance":152,"provenanceGeo":442,"country":167,"region":168,"settlement":152,"repository":445,"idno":446,"textLang":448,"tmNumber":450,"facsimile":451,"letterHeights":455,"publications":456,"zotero":461,"keywords":466,"html":470,"bibl":471},"ISic000770","Dedication by Marcus Aimilius Rho[--]",{"_":11},{"_":235,"ana":236,"ref":237},{"_":308,"ana":309,"ref":310},{"_":385,"ana":386,"ref":387},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":389},"#condition.damaged",{"layout":391},{"p":392,"rs":393,"damage":394},"The first part of all six lines of the Greek text are preserved, but none are complete.",{"_":29,"ana":30,"ref":31},{"ana":395},"#text_condition.incomplete #text_condition.legible",{"lettering":397,"dimensions":427},[398,399],"The letters are uniform and well cut, with pronounced serifs. A hollow triangular interpunct is used between all the onomastic elements (but apparently not elsewhere in the text; spaces are however observed between words, with or without interpunct). Theta has a detached middle bar; omicron is full size; epsilon has a detached short middle bar; mu reaches almost to the lower line in the middle, and the outer strokes are vertical.",{"_":400,"ref":401},"\n                                    Types list:\n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                ",[402,403,404,405,406,407,408,409,410,411,412,415,416,417,418,419,420,423,424,425,426],{"_":39,"target":40},{"_":42,"target":43},{"_":51,"target":52},{"_":54,"target":55},{"_":57,"target":58},{"_":66,"target":67},{"_":69,"target":70},{"_":72