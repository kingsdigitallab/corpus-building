:294,"keywords":298,"html":303,"bibl":304},"ISic000768","Dedication by a sevir to Concordia",{"_":12},{"_":240,"ana":241,"ref":242},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":244,"ana":245,"ref":246},"base","#object.base","http://www.eagle-network.eu/voc/objtyp/lod/57.html",{"_":248,"ana":249,"ref":250},"marble (white)","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":252},{"p":253,"rs":254,"damage":26},"The epigraphic face is preserved for a width of 12.5 cm, with two lines of Latin letters filling the available field.",{"_":31,"ana":32,"ref":33},{"lettering":256,"dimensions":257},"The letters are tall, neatly cut and closely spaced (height c.30mm), and words are separated by simple triangular interpuncts. The letters are lightly serifed. E is tall and narrow, T has a curved cross-bar, rising to the right.",[258,260],{"type":132,"l":259,"from":134,"to":139,"h":135,"unit":136,"atLeast":135,"atMost":135},"Line 1-2",{"type":143,"l":261,"from":134,"to":139,"h":262,"unit":136},"Interlineation line 1 to 2","?",{"_":264,"notBefore":265,"notAfter":266},"Late 1st century CE, or 2nd century CE",51,200,[268,269],{"_":153,"type":154,"ref":155},{"_":157,"type":158,"ref":159,"offset":160},[271],[163,164],[273,274],37.998047,14.262635,{"_":171,"role":172,"ref":173},{"_":277,"type":176},"ME 20226",{"_":279,"mainLang":280,"languages":281},"Latin","la",[279],"175722",{"n":183,"url":284,"height":285,"width":286,"desc":287,"surfaceType":188},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[289],{"atLeast":191,"atMost":191},[195,197,291,292,200,201,293,203,205],"Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano","Manganaro, 1989, Iscrizioni Latine nuove e vecchie della Sicilia","Portale, 2009, Le sculture da Alesa",[207,209,295,296,212,213,297,215,217],"RZSFKACR","EZMBJ6GN","BCIMMIKZ",[299,300,301,240,244,248,222,223,224,225,222,226,302,280],