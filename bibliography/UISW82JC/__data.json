g","#function.honorific #function.building",{"_":290,"ana":291,"ref":292},{"_":555,"ana":235,"ref":236},"marble (white)\n                                    ",{"layout":557},{"rs":558,"p":559,"damage":24},{"_":29,"ana":30,"ref":31},"Parts of two lines of latin letters are preserved. Substantial vacat below line 2.",{"lettering":561,"dimensions":562},"The letters are neatly V-cut, of wide proportions, with minimal serifs. P is open; S\n                                    has a larger upper half, leaning slightly to the right. Words are separated by a\n                                    comma-like three pointed serif.",[563,566],{"type":130,"l":564,"from":132,"to":137,"h":565,"unit":134},"Lines 1-2","38-40",{"type":141,"l":567,"from":132,"to":137,"unit":134},"Not measured",{"_":569,"notBefore":570,"notAfter":571,"precision":149},"Mid 1st century CE",1,100,[573,574],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[576],[162,163],{"_":167,"role":168,"ref":169},{"_":579,"type":172},"ME 20224",{"_":262,"mainLang":263,"languages":581},[262],{"n":178,"url":583,"height":584,"width":585,"desc":586,"surfaceType":183},"ISic000801_tiled.tif","6190px","4912px","Photo J. Prag",[],[186,188,272,192,194,196],[198,200,276,204,206,208],[591,592,593,551,290,234,214,215,216,217,214,218,283,263],"isic000801","fragment of a public latin inscription",{"_":10},{"file":595,"uri":595,"title":596,"status":597,"editionAuthor":11,"type":598,"objectType":599,"material":600,"condition":24,"layoutDesc":602,"handNote":606,"date":612,"places":614,"geo":617,"country":164,"region":165,"settlement":152,"repository":619,"idno":620,"textLang":622,"facsimile":624,"provenance":152,"letterHeights":627,"publications":628,"zotero":629,"keywords":630,"html":220},"ISic000802","Latin fragment mentioning a basilica",{"_":10},{"_":13,"ana":14,"ref":15,"cert":149},{"_":290,"ana":291,"ref":292},{"_":601,"ana":235,"ref":236},"marble",{"layout":603},{"p":604,"rs":605,"damage":24},"Parts of three lines of Latin letters are preserved",{"_":29,"ana":30,"ref":31},{"lettering":607,"dimensions":608},"The letters are neatly V-cut and well-proportioned, with modest serifs. Neither lines 1 nor 3 are completely preserved, but line 1 is taller than line 2, and line 3 is shorter",[609,611],{"type":130,"l":305,"from":137,"to":137,"h":610,"unit":134},"70",{"type":141,"l":142,"from":132,"to":137,"h":143,"unit":134},{"_":613,"notBefore":570,"notAfter":571,"evidence":148,"precision":149},"1st century CE",[615,616],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[618],[162,163],{"_":167,"role":168,"ref":169},{"_":621,"type":172},"ME 20225",{"_":262,"mainLang":263,"languages":623},[262],{"n":178,"url":625,"height":585,"width":626,"desc":586,"surfaceType":183},"ISic000802_tiled.tif","5982px",[],[186,188,272,192,194],[198,200,276,204,206],[631,632,633,13,290,601,214,215,216,217,214,218,283,263],"isic000802","latin fragment mentioning a basilica",{"_":10},{"file":635,"uri":635,"title":636,"status":637,"editionAuthor":11,"type":638,"objectType":639,"material":640,"condition":24,"layoutDesc":644,"handNote":648,"date":656,"places":659,"geo":662,"country":164,"region":165,"settlement":152,"repository":664,"textLang":665,"facsimile":667,"provenance":152,"letterHeights":671,"publications":672,"zotero":674,"keywords":676,"html":220},"ISic000803","Dedication by a pair of seviri",{"_":10},{"_":13,"ana":14,"ref":15},{"_":230,"ana":231,"ref":232},{"_":641,"ana":642,"ref":643},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":645},{"p":646,"rs":647,"damage":24},"Two lines of Latin letters in the field below the moulding (17.5 cm high and\n                                        originally 160 cm wide)",{"_":29,"ana":30,"ref":31},{"lettering":649,"dimensions":650},"The letters are crudely cut (but the stone is too coarse to allow of better): P is\n                                    open, but R is closed; Q has a long tail; long I is taller than the other letters\n                                    (63mm); E is tall and narrow; words are separated by simple interpuncts.",[651,653,655],{"type":130,"l":131,"from":132,"to":132,"h":652,"unit":134},"45-55",{"type":130,"l":305,"from":137,"to":137,"h":654,"unit":134},"40-45",{"type":141,"l":567,"from":132,"to":137,"unit":134},{"_":657,"notBefore":251,"notAfter":658,"precision":149},"End 1st century CE, beginning 2nd century CE",150,[660,661],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[663],[162,163],{"_":167,"role":168,"ref":169},{"_":262,"mainLang":263,"languages":666},[262],{"n":178,"url":668,"height":669,"width":670,"desc":586,"surfaceType":183},"ISic000803a_tiled.tif","1672px","3072px",[],[186,188,272,194,673],"Burgio, 2013, Architetture onorarie dell’agorà di Alesa, 1. Il monumento dei Seviri Augustales: analisi e proposta ricostruttiva",[198,200,276,206,675],"5ETXJGSF",[677,678,679,13,230,641,214,215,216,217,214,218,283,263],"isic000803","dedication by a pair of seviri",{"_":10},{"file":681,"uri":681,"title":682,"status":683,"editionAuthor":11,"type":684,"objectType":685,"material":688,"condition":24,"layoutDesc":689,"handNote":693,"date":702,"places":706,"geo":709,"country":164,"region":165,"settlement":152,"repository":711,"idno":712,"textLang":714,"facsimile":716,"provenance":152,"letterHeights":720,"publications":721,"zotero":723,"keywords":725,"html":220},"ISic000804","Dedication of a statue to Ceres, by Iulius Acilius Hermes, sevir",{"_":10},{"_":226,"ana":227,"ref":228},{"_":686,"ana":687,"ref":232},"statue base","#object.statue_base",{"_":234,"ana":235,"ref":236},{"layout":690},{"p":691,"rs":692,"damage":24},"The Latin text is engraved over two lines (letters c.20 mm high, but of uneven height), to a maximum length of 52 cm.",{"_":29,"ana":30,"ref":31},{"lettering":694,"dimensions":695}," The letters show some irregularity, with fairly pronounced serifs, and lengthy tails to the letter R. The first two words are separated from the rest by a space; an interpunct is visible at the end of the dedicant’s name, and the final abbreviated phrase is separated from the rest by a large hedera (ivy leaf). The letter I in line 1 is frequently taller than the rest (but so too is the first L in line 1); the final I of line 1 is somewhat irregularly carved.",[696,698,700],{"type":130,"l":131,"from":132,"to":132,"h":697,"unit":134},"18-25",{"type":130,"l":305,"from":137,"to":137,"h":699,"unit":134},"19-23",{"type":141,"l":316,"from":132,"to":137,"h":701,"unit":134},"7-15",{"_":703,"notBefore":704,"notAfter":705,"evidence":524},"Statue can be dated stylistically to the late Antonine period (i.e. the 180s or 190s CE), and the text is compatible with such a date.",180,199,[707,708],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[710],[162,163],{"_":167,"role":168,"ref":169},{"_":713,"type":172},"ME 20194",{"_":262,"mainLang":263,"languages":715},[262],{"n":178,"url":717,"height":718,"width":719,"desc":342,"surfaceType":183},"ISic000804_tiled.tif","1949px","4512px",[],[186,188,272,722,274,194,196],"Scibona, 2008, Statuary",[198,200,276,724,278,206,208],"EQC3W4UU",[726,727,728,226,686,234,214,215,216,217,214,218,283,263],"isic000804","dedication of a statue to ceres, by iulius acilius hermes, sevir",{"_":10},{"file":730,"uri":730,"title":731,"status":732,"editionAuthor":11,"type":733,"objectType":734,"material":735,"condition":24,"layoutDesc":737,"handNote":740,"date":747,"places":751,"geo":754,"country":164,"region":165,"settlement":152,"repository":756,"idno":757,"textLang":759,"facsimile":761,"provenance":152,"letterHeights":764,"publications":765,"zotero":766,"keywords":767,"html":220},"ISic000805","Fragmentary latin inscription mentioning a proconsul",{"_":10},{"_":13,"ana":14,"ref":15},{"_":290,"ana":291,"ref":292},{"_":736,"ana":235,"ref":236},"marble (pink)",{"layout":738},{"rs":739,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":741,"dimensions":742},"Letters are 50mm high, tall, thin, serifed. P and R are open; the hastae of M join early and extend upwards; a hedera like interpunct (tail top and bottom to a hollow element) appears once between C and V of line 2.",[743,746],{"type":130,"l":744,"from":132,"to":309,"h":745,"unit":134},"Line 1-3","50",{"type":141,"l":247,"from":132,"to":137,"unit":134},{"_":748,"notBefore":749,"notAfter":750,"precision":149},"3rd century CE",201,300,[752,753],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[755],[162,163],{"_":167,"role":168,"ref":169},{"_":758,"type":172},"ME 20228",{"_":262,"mainLang":263,"languages":760},[262],{"n":178,"url":762,"height":763,"width":585,"desc":586,"surfaceType":183},"ISic000805_tiled.tif","5256px",[],[186,188,272,191,192,194,196],[198,200,276,203,204,206,208],[768,769,770,13,290,736,214,215,216,217,214,218,283,263],"isic000805","fragmentary latin inscription mentioning a proconsul",{"_":10}],"uses":{"params":["slug"]}}]}
