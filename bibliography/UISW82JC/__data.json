o 2","?",{"_":549,"notBefore":494,"notAfter":550},"Late 1st century CE, or 2nd century CE",200,[552,553],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[555],[165,166],[557,558],37.998047,14.262635,{"_":173,"role":174,"ref":175},{"_":561,"type":178},"ME 20226",{"_":388,"mainLang":389,"languages":563},[388],"175722",{"n":185,"url":566,"height":567,"width":568,"desc":569,"surfaceType":190},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[571],{"atLeast":193,"atMost":193},[195,198,320,321,323,199,573,200,325],"Portale, 2009, Le sculture da Alesa",[203,206,328,329,331,207,575,208,333],"BCIMMIKZ",[577,578,579,234,470,535,215,216,217,218,215,219,407,389],"isic000768","dedication by a sevir to concordia",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":582,"ptr":583,"ref":584,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"17 no.7 fig.1",{"target":225},{"_":227,"target":227},{"file":586,"uri":586,"title":587,"status":588,"editionAuthor":13,"type":589,"objectType":590,"material":591,"condition":26,"layoutDesc":593,"handNote":597,"date":625,"places":629,"geo":632,"provenance":155,"provenanceGeo":634,"country":170,"region":171,"settlement":155,"repository":637,"idno":638,"textLang":640,"tmNumber":642,"facsimile":643,"letterHeights":647,"publications":661,"zotero":662,"keywords":663,"html":668,"bibl":669,"bulletinDateSort":228,"citedRangeSort":670,"languageSort":388,"materialSort":592,"typeSort":15},"ISic000769","Honours for L. Naevius(?) Firminus Manilianus",{"_":12},{"_":15,"ana":16,"ref":17},{"_":238,"ana":239,"ref":240},{"_":592,"ana":356,"ref":357},"marble (blue)\n                                    ",{"layout":594},{"p":595,"rs":596,"damage":26},"Remains of four lines of latin text are preserved: only the lower part of the first line survives, and only traces of the tops of letters remain from the beginning of line four.",{"_":30,"ana":31,"ref":32},{"lettering":598,"dimensions":599},"The letters are V-cut and generously (and sometimes unevenly) spaced, with moderate serifs. R is closed, and both A and R have lightly cut horizontals; all the strokes of M are off-vertical. Words are separated by comma-like interpuncts.",[600,602,603,607,611,616,621],{"type":137,"l":485,"from":139,"to":139,"h":601,"unit":142,"atLeast":601,"atMost":601},"65",{"type":137,"l":429,"from":146,"to":146,"h":488,"unit":142,"atLeast":488,"atMost":488},{"type":137,"l":604,"from":605,"to":605,"h":606,"unit":142,"atLeast":606,"atMost":606},"Line 3","line3","43",{"type":137,"l":608,"from":609,"to":609,"h":610,"unit":142},"Line 4","line4","incomplete",{"type":144,"l":612,"from":139,"to":146,"h":613,"unit":142,"atLeast":614,"atMost":615},"Interlineation lines 1-2","17-20","17","20",{"type":144,"l":617,"from":146,"to":605,"h":618,"unit":142,"atLeast":619,"atMost":620},"Interlineation lines 2-3","11-14","11","14",{"type":144,"l":622,"from":605,"to":609,"h":623,"unit":142,"atLeast":624,"atMost":620},"Interlineation lines 3-4","12-14","12",{"_":626,"notBefore":627,"notAfter":628},"2nd century CE or early 3rd century CE",101,250,[630,631],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[633],[165,166],[635,636],37.997854,14.262475,{"_":173,"role":174,"ref":175},{"_":639,"type":178},"ME 20227",{"_":388,"mainLang":389,"languages":641},[388],"175723",{"n":185,"url":644,"height":645,"width":646,"desc":314,"surfaceType":190},"ISic000769_tiled.tif","3704px","7048px",[648,650,651,653,656,659],{"atLeast":649,"atMost":649},65,{"atLeast":513,"atMost":513},{"atLeast":652,"atMost":652},43,{"atLeast":654,"atMost":655},17,20,{"atLeast":657,"atMost":658},11,14,{"atLeast":660,"atMost":658},12,[195,198,320,321,323,199,200,325],[203,206,328,329,331,207,208,333],[664,665,666,15,238,667,215,216,217,218,215,219,407,389],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":12},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":670,"ptr":671,"ref":672,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"17 no.8 fig.2-3\n                        ",{"target":225},{"_":227,"target":227},{"file":674,"uri":674,"title":675,"status":676,"editionAuthor":13,"type":677,"objectType":678,"material":681,"condition":26,"layoutDesc":682,"handNote":686,"date":700,"places":704,"geo":707,"provenance":155,"provenanceGeo":709,"country":170,"region":171,"settlement":155,"repository":712,"idno":713,"textLang":715,"tmNumber":717,"facsimile":718,"letterHeights":722,"publications":731,"zotero":733,"keywords":735,"html":739,"bibl":740,"bulletinDateSort":228,"citedRangeSort":741,"languageSort":388,"materialSort":535,"typeSort":234},"ISic000804","Dedication of a statue to Ceres, by Iulius Acilius Hermes, sevir",{"_":12},{"_":234,"ana":235,"ref":236},{"_":679,"ana":680,"ref":472},"statue base","#object.statue_base",{"_":535,"ana":356,"ref":357},{"layout":683},{"p":684,"rs":685,"damage":26},"The Latin text is engraved over two lines (letters c.20 mm high, but of uneven height), to a maximum length of 52 cm.",{"_":30,"ana":31,"ref":32},{"lettering":687,"dimensions":688}," The letters show some irregularity, with fairly pronounced serifs, and lengthy tails to the letter R. The first two words are separated from the rest by a space; an interpunct is visible at the end of the dedicant’s name, and the final abbreviated phrase is separated from the rest by a large hedera (ivy leaf). The letter I in line 1 is frequently taller than the rest (but so too is the first L in line 1); the final I of line 1 is somewhat irregularly carved.",[689,693,697],{"type":137,"l":485,"from":139,"to":139,"h":690,"unit":142,"atLeast":691,"atMost":692},"18-25","18","25",{"type":137,"l":429,"from":146,"to":146,"h":694,"unit":142,"atLeast":695,"atMost":696},"19-23","19","23",{"type":144,"l":612,"from":139,"to":146,"h":698,"unit":142,"atLeast":699,"atMost":289},"7-15","7",{"_":701,"notBefore":702,"notAfter":703,"evidence":152},"Statue can be dated stylistically to the late Antonine period (i.e. the 180s or 190s CE), and the text is compatible with such a date.",180,199,[705,706],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[708],[165,166],[710,711],37.998037,14.262643,{"_":173,"role":174,"ref":175},{"_":714,"type":178},"ME 20194",{"_":388,"mainLang":389,"languages":716},[388],"175724",{"n":185,"url":719,"height":720,"width":721,"desc":314,"surfaceType":190},"ISic000804_tiled.tif","1949px","4512px",[723,726,729],{"atLeast":724,"atMost":725},18,25,{"atLeast":727,"atMost":728},19,23,{"atLeast":730,"atMost":317},7,[195,198,320,732,573,200,325],"Scibona, 2008, Statuary",[203,206,328,734,575,208,333],"EQC3W4UU",[736,737,738,234,679,535,215,216,217,218,215,219,407,389],"isic000804","dedication of a statue 