:31},{"lettering":249,"dimensions":250},"The letters are tall, neatly cut and closely spaced (height c.30mm), and words are separated by simple triangular interpuncts. The letters are lightly serifed. E is tall and narrow, T has a curved cross-bar, rising to the right.",[251,253],{"type":130,"l":252,"from":132,"to":137,"h":133,"unit":134},"Line 1-2",{"type":141,"l":254,"from":132,"to":137,"h":255,"unit":134},"Interlineation line 1 to 2","?",{"_":257,"notBefore":258,"notAfter":259,"precision":149},"Late 1st century CE, or 2nd century CE",51,200,[261,262],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[264],[162,163],{"_":167,"role":168,"ref":169},{"_":267,"type":172},"ME 20226",{"_":269,"mainLang":270,"languages":271},"Latin","la",[269],{"n":178,"url":273,"height":274,"width":275,"desc":276,"surfaceType":183},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[],[186,188,279,280,191,192,281,194,196],"Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano","Manganaro, 1989, Iscrizioni Latine nuove e vecchie della Sicilia","Portale, 2009, Le sculture da Alesa",[198,200,283,284,203,204,285,206,208],"RZSFKACR","EZMBJ6GN","BCIMMIKZ",[287,288,289,233,237,241,214,215,216,217,214,218,290,270],"isic000768","dedication by a sevir to concordia",{"_":10},"latin","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":222,"date":3,"citedRange":293,"ptr":294,"ref":295,"title":2,"citation":4},"17 no.7 fig.1",{"target":225},{"_":227,"target":227},{"file":297,"uri":297,"title":298,"status":299,"editionAuthor":11,"type":300,"objectType":301,"material":305,"condition":24,"layoutDesc":307,"handNote":311,"date":336,"places":340,"geo":343,"country":164,"region":165,"settlement":152,"repository":345,"idno":346,"textLang":348,"facsimile":350,"provenance":152,"letterHeights":355,"publications":356,"zotero":357,"keywords":358,"html":363,"bibl":364},"ISic000769","Honours for L. Naevius(?) Firminus Manilianus",{"_":10},{"_":13,"ana":14,"ref":15},{"_":302,"ana":303,"ref":304},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":306,"ana":242,"ref":243},"marble (blue)\n                                    ",{"layout":308},{"p":309,"rs":310,"damage":24},"Remains of four lines of latin text are preserved: only the lower part of the first line survives, and only traces of the tops of letters remain from the beginning of line four.",{"_":29,"ana":30,"ref":31},{"lettering":312,"dimensions":313},"The letters are V-cut and generously (and sometimes unevenly) spaced, with moderate serifs. R is closed, and both A and R have lightly cut horizontals; all the strokes of M are off-vertical. Words are separated by comma-like interpuncts.",[314,316,319,323,327,330,333],{"type":130,"l":131,"from":132,"to":132,"h":315,"unit":134},"65",{"type":130,"l":317,"from":137,"to":137,"h":318,"unit":134},"Line 2","55",{"type":130,"l":320,"from":321,"to":321,"h":322,"unit":134},"Line 3","line3","43",{"type":130,"l":324,"from":325,"to":325,"h":326,"unit":134},"Line 4","line4","incomplete",{"type":141,"l":328,"from":132,"to":137,"h":329,"unit":134},"Interlineation lines 1-2","17-20",{"type":141,"l":331,"from":137,"to":321,"h":332,"unit":134},"Interlineation lines 2-3","11-14",{"type":141,"l":334,"from":321,"to":325,"h":335,"unit":134},"Interlineation lines 3-4","12-14",{"_":337,"notBefore":338,"notAfter":339,"precision":149},"2nd century CE or early 3rd century CE",101,250,[341,342],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[344],[162,163],{"_":167,"role":168,"ref":169},{"_":347,"type":172},"ME 20227",{"_":269,"mainLang":270,"languages":349},[269],{"n":178,"url":351,"height":352,"width":353,"desc":354,"surfaceType":183},"ISic000769_tiled.tif","3704px","7048px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina",[],[186,188,279,280,191,192,194,196],[198,200,283,284,203,204,206,208],[359,360,361,13,302,362,214,215,216,217,214,218,290,270],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":10},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":222,"date":3,"citedRange":365,"ptr":366,"ref":367,"title":2,"citation":4},"17 no.8 fig.2-3\n                        ",{"target":225},{"_":227,"target":227},{"file":369,"uri":369,"title":370,"status":371,"editionAuthor":11,"type":372,"objectType":373,"material":374,"condition":378,"layoutDesc":380,"handNote":386,"date":423,"places":427,"geo":430,"country":164,"region":165,"settlement":152,"repository":432,"idno":433,"textLang":435,"facsimile":437,"provenance":152,"letterHeights":441,"publications":442,"zotero":447,"keywords":452,"html":456,"bibl":457},"ISic000770","Dedication by Marcus Aimilius Rho[--]",{"_":10},{"_":233,"ana":234,"ref":235},{"_":302,"ana":303,"ref":304},{"_":375,"ana":376,"ref":377},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":379},"#condition.damaged",{"layout":381},{"p":382,"rs":383,"damage":384},"The first part of all six lines of the Greek text are preserved, but none are complete.",{"_":29,"ana":30,"ref":31},{"ana":385},"#text_condition.incomplete #text_condition.legible",{"lettering":387,"dimensions":417},[388,389],"The letters are uniform and well cut, with pronounced serifs. A hollow triangular interpunct is used between all the onomastic elements (but apparently not elsewhere in the text; spaces are however observed between words, with or without interpunct). Theta has a detached middle bar; omicron is full size; epsilon has a detached short middle bar; mu reaches almost to the lower line in the middle, and the outer strokes are vertical.",{"_":390,"ref":391},"\n                                    Types list:\n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                ",[392,393,394,395,396,397,398,399,400,401,402,405,406,407,408,409,410,413,414,415,416],{"_":39,"target":40},{"_":42,"target":43},{"_":51,"target":52},{"_":54,"target":55},{"_":57,"target":58},{"_":66,"target":67},{"_":69,"target":70},{"_":72,"target":7