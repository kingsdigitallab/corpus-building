author":226,"date":3,"citedRange":692,"ptr":693,"ref":694,"title":2,"citation":4},"15 no.5 fig.3",{"target":229},{"_":231,"target":231},{"file":696,"uri":696,"title":697,"status":698,"editionAuthor":11,"type":699,"objectType":700,"material":701,"condition":24,"layoutDesc":705,"handNote":709,"date":717,"places":720,"geo":723,"provenance":152,"provenanceGeo":725,"country":167,"region":168,"settlement":152,"repository":726,"textLang":727,"tmNumber":729,"facsimile":730,"letterHeights":734,"publications":735,"zotero":737,"keywords":739,"html":743,"bibl":744},"ISic000803","Dedication by a pair of seviri",{"_":10},{"_":13,"ana":14,"ref":15},{"_":241,"ana":242,"ref":243},{"_":702,"ana":703,"ref":704},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":706},{"p":707,"rs":708,"damage":24},"Two lines of Latin letters in the field below the moulding (17.5 cm high and\n                                        originally 160 cm wide)",{"_":29,"ana":30,"ref":31},{"lettering":710,"dimensions":711},"The letters are crudely cut (but the stone is too coarse to allow of better): P is\n                                    open, but R is closed; Q has a long tail; long I is taller than the other letters\n                                    (63mm); E is tall and narrow; words are separated by simple interpuncts.",[712,714,716],{"type":130,"l":131,"from":132,"to":132,"h":713,"unit":134},"45-55",{"type":130,"l":325,"from":137,"to":137,"h":715,"unit":134},"40-45",{"type":141,"l":614,"from":132,"to":137,"unit":134},{"_":718,"notBefore":262,"notAfter":719,"precision":149},"End 1st century CE, beginning 2nd century CE",150,[721,722],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[724],[162,163],[],{"_":170,"role":171,"ref":172},{"_":276,"mainLang":277,"languages":728},[276],"175721",{"n":182,"url":731,"height":732,"width":733,"desc":635,"surfaceType":187},"ISic000803a_tiled.tif","1672px","3072px",[],[190,192,287,198,