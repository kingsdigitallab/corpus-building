 below the moulding (17.5 cm high and\n                                        originally 160 cm wide)",{"_":30,"ana":31,"ref":32},{"lettering":481,"dimensions":482},"The letters are crudely cut (but the stone is too coarse to allow of better): P is\n                                    open, but R is closed; Q has a long tail; long I is taller than the other letters\n                                    (63mm); E is tall and narrow; words are separated by simple interpuncts.",[483,488,490],{"type":137,"l":484,"from":139,"to":139,"h":485,"unit":142,"atLeast":486,"atMost":487},"Line 1","45-55","45","55",{"type":137,"l":428,"from":146,"to":146,"h":489,"unit":142,"atLeast":368,"atMost":486},"40-45",{"type":144,"l":370,"from":139,"to":146,"unit":142},{"_":492,"notBefore":493,"notAfter":494},"End 1st century CE, beginning 2nd century CE",51,150,[496,497],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[499],[165,166],[],{"_":173,"role":174,"ref":175},{"_":387,"mainLang":388,"languages":503},[387],"175721",{"n":185,"url":506,"height":507,"width":508,"desc":448,"surfaceType":190},"ISic000803a_tiled.tif","1672px","3072px",[510,513],{"atLeast":511,"atMost":512},45,55,{"atLeast":399,"atMost":511},[195,198,319,200,515],"Burgio, 2013, Architetture onorarie dell’agorà di Alesa, 1. Il monumento dei Seviri Augustales: analisi e proposta ricostruttiva",[203,206,327,208,517],"5ETXJGSF",[519,520,521,15,469,473,215,216,217,218,215,219,406,388],"isic000803","dedication by a pair of seviri",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span> Q (uintus) · Caecilius · Q (uinti) · l (ibertus) · Hime[raeus \u003Cspan dir=\"ltr\" class=\"gap\">.. ? ..\u003C/span>]s · \u003Cspan class=\"reversed\" title=\"reversed: Ↄ\">(())\u003C/span>(mulieris) · l (ibertus) · Sabinus · \u003Cspan dir=\"ltr\">(vac.2)\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>  \u003Cspan dir=\"ltr\">(vac.5)\u003C/span> sẹṿiri · \u003Cspan dir=\"ltr\">(vac.)\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">.. ? ..\u003C/span>] ḍ (e) · s (ua) · p (ecunia) · \u003Cspan dir=\"ltr\">(vac.7)\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":524,"ptr":525,"ref":526,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"16 no.6 tav.4.1",{"target":225},{"_":227,"target":227},{"file":528,"uri":528,"title":529,"status":530,"editionAuthor":13,"type":531,"objectType":532,"material":533,"condition":26,"layoutDesc":535,"handNote":539,"date":547,"places":550,"geo":553,"provenance":155,"provenanceGeo":555,"country":170,"region":171,"settlement":155,"repository":558,"idno":559,"textLang":561,"tmNumber":563,"facsimile":564,"letterHeights":569,"publications":571,"zotero":573,"keywords":575,"html":579,"bibl":580,"citedRangeSort":581,"languageSort":387,"materialSort":534,"typeSort":233},"ISic000768","Dedication by a sevir to Concordia",{"_":12},{"_":233,"ana":234,"ref":235},{"_":469,"ana":470,"ref":471},{"_":534,"ana":355,"ref":356},"marble (white)",{"layout":536},{"p":537,"rs":538,"damage":26},"The epigraphic face is preserved for a width of 12.5 cm, with two lines of Latin letters filling the available field.",{"_":30,"ana":31,"ref":32},{"lettering":540,"dimensions":541},"The letters are tall, neatly cut and closely spaced (height c.30mm), and words are separated by simple triangular interpuncts. The letters are lightly serifed. E is tall and narrow, T has a curved cross-bar, rising to the right.",[542,544],{"type":137,"l":543,"from":139,"to":146,"h":141,"unit":142,"atLeast":141,"atMost":141},"Line 1-2",{"type":144,"l":545,"from":139,"to":146,"h":546,"unit":142},"Interlineation line 1 to 2","?",{"_":548,"notBefore":493,"notAfter":549},"Late 1st century CE, or 2nd century CE",200,[551,552],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[554],[165,166],[556,557],37.998047,14.262635,{"_":173,"role":174,"ref":175},{"_":560,"type":178},"ME 20226",{"_":387,"mainLang":388,"languages":562},[387],"175722",{"n":185,"url":565,"height":566,"width":567,"desc":568,"surfaceType":190},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[570],{"atLeast":193,"atMost":193},[195,198,319,320,322,199,572,200,324],"Portale, 2009, Le sculture da Alesa",[203,206,327,328,330,207,574,208,332],"BCIMMIKZ",[576,577,578,233,469,534,215,216,217,218,215,219,406,388],"isic000768","dedication by a sevir to concordia",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":581,"ptr":582,"ref":583,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"17 no.7 fig.1",{"target":225},{"_":227,"target":227},{"file":585,"uri":585,"title":586,"status":587,"editionAuthor":13,"type":588,"objectType":589,"material":590,"condition":26,"layoutDesc":592,"handNote":596,"date":624,"places":628,"geo":631,"provenance":155,"provenanceGeo":633,"country":170,"region":171,"settlement":155,"repository":636,"idno":637,"textLang":639,"tmNumber":641,"facsimile":642,"letterHeights":646,"publications":660,"zotero":661,"keywords":662,"html":667,"bibl":668,"citedRangeSort":669,"languageSort":387,"materialSort":591,"typeSort":15},"ISic000769","Honours for L. Naevius(?) Firminus Manilianus",{"_":12},{"_":15,"ana":16,"ref":17},{"_":237,"ana":238,"ref":239},{"_":591,"ana":355,"ref":356},"marble (blue)\n                                    ",{"layout":593},{"p":594,"rs":595,"damage":26},"Remains of four lines of latin text are preserved: only the lower part of the first line survives, and only traces of the tops of letters remain from the beginning of line four.",{"_":30,"ana":31,"ref":32},{"lettering":597,"dimensions":598},"The letters are V-cut and generously (and sometimes unevenly) spaced, with moderate serifs. R is closed, and both A and R have lightly cut horizontals; all the strokes of M are off-vertical. Words are separated by comma-like interpuncts.",[599,601,602,606,610,615,620],{"type":137,"l":484,"from":139,"to":139,"h":600,"unit":142,"atLeast":600,"atMost":600},"65",{"type":137,"l":428,"from":146,"to":146,"h":487,"unit":142,"atLeast":487,"atMost":487},{"type":137,"l":603,"from":604,"to":604,"h":605,"unit":142,"atLeast":605,"atMost":605},"Line 3","line3","43",{"type":137,"l":607,"from":608,"to":608,"h":609,"unit":142},"Line 4","line4","incomplete",{"type":144,"l":611,"from":139,"to":146,"h":612,"unit":142,"atLeast":613,"atMost":614},"Interlineation lines 1-2","17-20","17","20",{"type":144,"l":616,"from":146,"to":604,"h":617,"unit":142,"atLeast":618,"atMost":619},"Interlineation lines 2-3","11-14","11","14",{"type":144,"l":621,"from":604,"to":608,"h":622,"unit":142,"atLeast":623,"atMost":619},"Interlineation lines 3-4","12-14","12",{"_":625,"notBefore":626,"notAfter":627},"2nd century CE or early 3rd century CE",101,250,[629,630],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[632],[165,166],[634,635],37.997854,14.262475,{"_":173,"role":174,"ref":175},{"_":638,"type":178},"ME 20227",{"_":387,"mainLang":388,"languages":640},[387],"175723",{"n":185,"url":643,"height":644,"width":645,"desc":313,"surfaceType":190},"ISic000769_tiled.tif","3704px","7048px",[647,649,650,652,655,658],{"atLeast":648,"atMost":648},65,{"atLeast":512,"atMost":512},{"atLeast":651,"atMost":651},43,{"atLeast":653,"atMost":654},17,20,{"atLeast":656,"atMost":657},11,14,{"atLeast":659,"atMost":657},12,[195,198,319,320,322,199,200,324],[203,206,327,328,330,207,208,332],[663,664,665,15,237,666,215,216,217,218,215,219,406,388],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":12},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":669,"ptr":670,"ref":671,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"17 no.8 fig.2-3\n                        ",{"target":225},{"_":227,"target":227},{"file":673,"uri":673,"title":674,"status":675,"editionAuthor":13,"type":676,"objectType":677,"material":680,"condition":26,"layoutDesc":681,"handNote":685,"date":699,"places":703,"geo":706,"provenance":155,"provenanceGeo":708,"country":170,"region":171,"settlement":155,"repository":711,"idno":712,"textLang":714,"tmNumber":716,"facsimile":717,"letterHeights":721,"publications":730,"zotero":732,"keywords":734,"html":738,"bibl":739,"citedRangeSort":740,"languageSort":387,"materialSort":534,"typeSort":233},"ISic000804","Dedication of a statue to Ceres, by Iulius Acilius Hermes, sevir",{"_":12},{"_":233,"ana":234,"ref":235},{"_":678,"ana":679,"ref":471},"statue base","#object.statue_base",{"_":534,"ana":355,"ref":356},{"layout":682},{"p":683,"rs":684,"damage":26},"The Latin text is engraved over two lines (letters c.20 mm high, but of uneven height), to a maximum length of 52 cm.",{"_":30,"ana":31,"ref":32},{"lettering":686,"dimensions":687}," The letters show some irregularity, with fairly pronounced serifs, and lengthy tails to the letter R. The first two words are separated from the rest by a space; an interpunct is visible at the end of the dedicant’s name, and the final abbreviated phrase is separated from the rest by a large hedera (ivy leaf). The letter I in line 1 is frequently taller than the rest (but so too is the first L in line 1); the final I of line 1 is somewhat irregularly carved.",[688,692,696],{"type":137,"l":484,"from":139,"to":139,"h":689,"unit":142,"atLeast":690,"atMost":691},"18-25","18","25",{"type":137,"l":428,"from":146,"to":146,"h":693,"unit":142,"atLeast":694,"atMost":695},"19-23","19","23",{"type":144,"l":611,"from":139,"to":146,"h":697,"unit":142,"atLeast":698,"atMost":288},"7-15","7",{"_":700,"notBefore":701,"notAfter":702,"evidence":152},"Statue can be dated stylistically to the late Antonine period (i.e. the 180s or 190s CE), and the text is compatible with such a date.",180,199,[704,705],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[707],[165,166],[709,710],37.998037,14.262643,{"_":173,"role":174,"ref":175},{"_":713,"type":178},"ME 20194",{"_":387,"mainLang":388,"languages":715},[387],"175724",{"n":185,"url":718,"height":719,"width":720,"desc":313,"surfaceType":190},"ISic000804_tiled.tif","1949px","4512px",[722,725,728],{"atLeast":723,"atMost":724},18,25,{"atLeast":726,"atMost":727},19,23,{"atLeast":729,"atMost":316},7,[195,198,319,731,572,200,324],"Scibona, 2008, Statuary",[203,206,327,733,574,208,332],"EQC3W4UU",[735,736,737,233,678,534,215,216,217,218,215,219,406,388],"isic000804","dedication of a statue to ceres, by iulius acilius hermes, sevir",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->