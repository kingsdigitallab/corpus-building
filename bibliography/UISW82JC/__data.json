,{"layout":250},{"p":251,"rs":252,"damage":26},"The epigraphic face is preserved for a width of 12.5 cm, with two lines of Latin letters filling the available field.",{"_":31,"ana":32,"ref":33},{"lettering":254,"dimensions":255},"The letters are tall, neatly cut and closely spaced (height c.30mm), and words are separated by simple triangular interpuncts. The letters are lightly serifed. E is tall and narrow, T has a curved cross-bar, rising to the right.",[256,258],{"type":132,"l":257,"from":134,"to":139,"h":135,"unit":136},"Line 1-2",{"type":143,"l":259,"from":134,"to":139,"h":260,"unit":136},"Interlineation line 1 to 2","?",{"_":262,"notBefore":263,"notAfter":264,"precision":151},"Late 1st century CE, or 2nd century CE",51,200,[266,267],{"_":154,"type":155,"ref":156},{"_":158,"type":159,"ref":160,"offset":161},[269],[164,165],[271,272],37.998047,14.262635,{"_":172,"role":173,"ref":174},{"_":275,"type":177},"ME 20226",{"_":277,"mainLang":278,"languages":279},"Latin","la",[277],"175722",{"n":184,"url":282,"height":283,"width":284,"desc":285,"surfaceType":189},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[],[192,194,288,289,197,198,290,200,202],"Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano","Manganaro, 1989, Iscrizioni Latine nuove e vecchie della Sicilia","Portale, 2009, Le sculture da Alesa",[204,206,292,293,209,210,294,212,214],"RZSFKACR","EZMBJ6GN","BCIMMIKZ",[296,297,298,238,242,246,220,221,222,223,220,224,299,278],"isic000768","dedication by a sevir to concordia",{"_":12},"latin","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":302,"ptr":303,"ref":304,"title":2,"citation":5,"uri":6},"17 no.7 fig.1",{"target":230},{"_":232,"target":232},{"file":306,"uri":306,"title":307,"status":308,"editionAuthor":13,"type":309,"objectType":310,"material":314,"condition":26,"layoutDesc":316,"handNote":320,"date":345,"places":349,"geo":352,"provenance":154,"provenanceGeo":354,"country":169,"region":170,"settlement":154,"repository":357,"idno":358,"textLang":360,"tmNumber":362,"facsimile":363,"letterHeights":368,"publications":369,"zotero":370,"keywords":371,"html":376,"bibl":377},"ISic000769","Honours for L. Naevius(?) Firminus Manilianus",{"_":12},{"_":15,"ana":16,"ref":17},{"_":311,"ana":312,"ref":313},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":315,"ana":247,"ref":248},"marble (blue)\n                                    ",{"layout":317},{"p":318,"rs":319,"damage":26},"Remains of four lines of latin text are preserved: only the lower part of the first line survives, and only traces of the tops of letters remain from the beginning of line four.",{"_":31,"ana":32,"ref":33},{"lettering":321,"dimensions":322},"The letters are V-cut and generously (and sometimes unevenly) spaced, with moderate serifs. R is closed, and both A and R have lightly cut horizontals; all the strokes of M are off-vertical. Words are separated by comma-like interpuncts.",[323,325,328,332,336,339,342],{"type":132,"l":133,"from":134,"to":134,"h":324,"unit":136},"65",{"type":132,"l":326,"from":139,"to":139,"h":327,"unit":136},"Line 2","55",{"type":132,"l":329,"from":330,"to":330,"h":331,"unit":136},"Line 3","line3","43",{"type":132,"l":333,"from":334,"to":334,"h":335,"unit":136},"Line 4","line4","incomplete",{"type":143,"l":337,"from":134,"to":139,"h":338,"unit":136},"Interlineation lines 1-2","17-20",{"type":143,"l":340,"from":139,"to":330,"h":341,"unit":136},"Interlineation lines 2-3","11-14",{"type":143,"l":343,"from":330,"to":334,"h":344,"unit":136},"Interlineation lines 3-4","12-14",{"_":346,"notBefore":347,"notAfter":348,"precision":151},"2nd century CE or early 3rd century CE",101,250,[350,351],{"_":154,"type":155,"ref":156},{"_":158,"type":159,"ref":160,"offset":161},[353],[164,165],[355,356],37.997854,14.262475,{"_":172,"role":173,"ref":174},{"_":359,"type":177},"ME 20227",{"_":277,"mainLang":278,"languages":361},[277],"175723",{"n":184,"url":364,"height":365,"width":366,"desc":367,"surfaceType":189},"ISic000769_tiled.tif","3704px","7048px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina",[],[192,194,288,289,197,198,200,202],[204,206,292,293,209,210,212,214],[372,373,374,15,311,375,220,221,222,223,220,224,299,278],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":12},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":378,"ptr":379,"ref":380,"title":2,"citation":5,"uri":6},"17 no.8 fig.2-3\n                        ",{"target":230},{"_":232,"target":232},{"file":382,"uri":382,"title":383,"status":384,"editionAuthor":13,"type":385,"objectType":386,"material":387,"condition":391,"layoutDesc":393,"handNote":399,"date":436,"places":440,"geo":443,"provenance":154,"provenanceGeo":445,"cou