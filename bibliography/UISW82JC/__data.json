work.eu/voc/material/lod/75.html",{"layout":478},{"p":479,"rs":480,"damage":26},"Two lines of Latin letters in the field below the moulding (17.5 cm high and\n                                        originally 160 cm wide)",{"_":30,"ana":31,"ref":32},{"lettering":482,"dimensions":483},"The letters are crudely cut (but the stone is too coarse to allow of better): P is\n                                    open, but R is closed; Q has a long tail; long I is taller than the other letters\n                                    (63mm); E is tall and narrow; words are separated by simple interpuncts.",[484,489,491],{"type":137,"l":485,"from":139,"to":139,"h":486,"unit":142,"atLeast":487,"atMost":488},"Line 1","45-55","45","55",{"type":137,"l":429,"from":146,"to":146,"h":490,"unit":142,"atLeast":369,"atMost":487},"40-45",{"type":144,"l":371,"from":139,"to":146,"unit":142},{"_":493,"notBefore":494,"notAfter":495},"End 1st century CE, beginning 2nd century CE",51,150,[497,498],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[500],[165,166],[],{"_":173,"role":174,"ref":175},{"_":388,"mainLang":389,"languages":504},[388],"175721",{"n":185,"url":507,"height":508,"width":509,"desc":449,"surfaceType":190},"ISic000803a_tiled.tif","1672px","3072px",[511,514],{"atLeast":512,"atMost":513},45,55,{"atLeast":400,"atMost":512},[195,198,320,200,516],"Burgio, 2013, Architetture onorarie dell’agorà di Alesa, 1. Il monumento dei Seviri Augustales: analisi e proposta ricostruttiva",[203,206,328,208,518],"5ETXJGSF",[520,521,522,15,470,474,215,216,217,218,215,219,407,389],"isic000803","dedication by a pair of seviri",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span> Q (uintus) · Caecilius · Q (uinti) · l (ibertus) · Hime[raeus \u003Cspan dir=\"ltr\" class=\"gap\">.. ? ..\u003C/span>]s · \u003Cspan class=\"reversed\" title=