tin letters filling the available field.",{"_":29,"ana":30,"ref":31},{"lettering":242,"dimensions":243},"The letters are tall, neatly cut and closely spaced (height c.30mm), and words are separated by simple triangular interpuncts. The letters are lightly serifed. E is tall and narrow, T has a curved cross-bar, rising to the right.",[244,246],{"type":130,"l":245,"from":132,"to":137,"h":133,"unit":134},"Line 1-2",{"type":141,"l":247,"from":132,"to":137,"h":248,"unit":134},"Interlineation line 1 to 2","?",{"_":250,"notBefore":251,"notAfter":252,"precision":149},"Late 1st century CE, or 2nd century CE",51,200,[254,255],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[257],[162,163],{"_":167,"role":168,"ref":169},{"_":260,"type":172},"ME 20226",{"_":262,"mainLang":263,"languages":264},"Latin","la",[262],{"n":178,"url":266,"height":267,"width":268,"desc":269,"surfaceType":183},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[],[186,188,272,273,191,192,274,194,196],"Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano","Manganaro, 1989, Iscrizioni Latine nuove e vecchie della Sicilia","Portale, 2009, Le sculture da Alesa",[198,200,276,277,203,204,278,206,208],"RZSFKACR","EZMBJ6GN","BCIMMIKZ",[280,281,282,226,230,234,214,215,216,217,214,218,283,263],"isic000768","dedication by a sevir to concordia",{"_":10},"latin",{"file":285,"uri":285,"title":286,"status":287,"editionAuthor":11,"type":288,"objectType":289,"material":293,"condition":24,"layoutDesc":295,"handNote":299,"date":324,"places":328,"geo":331,"country":164,"region":165,"settlement":152,"repository":333,"idno":334,"textLang":336,"facsimile":338,"provenance":152,"letterHeights":343,"publications":344,"zotero":345,"keywords":346,"html":220},"ISic000769","Honours for L. Naevius(?) Firminus Manilianus",{"_":10},{"_":13,"ana":14,"ref":15},{"_":290,"ana":291,"ref":292},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":294,"ana":235,"ref":236},"marble (blue)\n                                    ",{"layout":296},{"p":297,"rs":298,"damage":24},"Remains of four lines of latin text are preserved: only the lower part of the first line survives, and only traces of the tops of letters remain from the beginning of line four.",{"_":29,"ana":30,"ref":31},{"lettering":300,"dimensions":301},"The letters are V-cut and generously (and sometimes unevenly) spaced, with moderate serifs. R is closed, and both A and R have lightly cut horizontals; all the strokes of M are off-vertical. Words are separated by comma-like interpuncts.",[302,304,307,311,315,318,321],{"type":130,"l":131,"from":132,"to":132,"h":303,"unit":134},"65",{"type":130,"l":305,"from":137,"to":137,"h":306,"unit":134},"Line 2","55",{"type":130,"l":308,"from":309,"to":309,"h":310,"unit":134},"Line 3","line3","43",{"type":130,"l":312,"from":313,"to":313,"h":314,"unit":134},"Line 4","line4","incomplete",{"type":141,"l":316,"from":132,"to":137,"h":317,"unit":134},"Interlineation lines 1-2","17-20",{"type":141,"l":319,"from":137,"to":309,"h":320,"unit":134},"Interlineation lines 2-3","11-14",{"type":141,"l":322,"from":309,"to":313,"h":323,"unit":134},"Interlineation lines 3-4","12-14",{"_":325,"notBefore":326,"notAfter":327,"precision":149},"2nd century CE or early 3rd century CE",101,250,[329,330],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[332],[162,163],{"_":167,"role":168,"ref":169},{"_":335,"type":172},"ME 20227",{"_":262,"mainLang":263,"languages":337},[262],{"n":178,"url":339,"height":340,"width":341,"desc":342,"surfaceType":183},"ISic000769_tiled.tif","3704px","7048px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina",[],[186,188,272,273,191,192,194,196],[198,200,276,277,203,204,206,208],[347,348,349,13,290,350,214,215,216,217,214,218,283,263],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":10},"marble (blue)",{"file":352,"uri":352,"title":353,"status":354,"editionAuthor":11,"type":355,"objectType":356,"material":357,"condition":361,"layoutDesc":363,"handNote":369,"date":406,"places":410,"geo":413,"country":164,"region":165,"settlement":152,"repository":415,"idno":416,"textLang":418,"facsimile":420,"provenance":152,"letterHeights":424,"publications":425,"zotero":430,"keywords":435,"html":220},"ISic000770","Dedication by Marcus Aimilius Rho[--]",{"_":10},{"_":226,"ana":227,"ref":228},{"_":290,"ana":291,"ref":292},{"_":358,"ana":359,"ref":360},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":362},"#condition.damaged",{"layout":364},{"p":365,"rs":366,"damage":367},"The first part of all six lines of the Greek text are preserved, but none are complete.",{"_":29,"ana":30,"ref":31},{"ana":368},"#text_condition.incomplete #text_condition.legible",{"lettering":370,"dimensions":400},[371,372],"The letters are uniform and well cut, with pronounced serifs. A hollow triangular interpunct is used between all the onomastic elements (but apparently not elsewhere in the text; spaces are however observed between words, with or without interpunct). Theta has a detached middle bar; omicron is full size; epsilon has a detached short middle bar; mu reaches almost to the lower line in the middle, and the outer strokes are vertical.",{"_":373,"ref":374},"\n                                    Types list:\n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n