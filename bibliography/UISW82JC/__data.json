,{"file":230,"uri":230,"title":231,"status":232,"editionAuthor":13,"type":233,"objectType":237,"material":241,"condition":242,"layoutDesc":244,"handNote":250,"date":292,"places":296,"geo":299,"provenance":155,"provenanceGeo":301,"country":170,"region":171,"settlement":155,"repository":304,"idno":305,"textLang":307,"tmNumber":309,"facsimile":310,"letterHeights":315,"publications":318,"zotero":326,"keywords":334,"html":338,"bibl":339,"bulletinDateSort":228,"citedRangeSort":340,"languageSort":180,"materialSort":214,"typeSort":234},"ISic000770","Dedication by Marcus Aimilius Rho[--]",{"_":12},{"_":234,"ana":235,"ref":236},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":238,"ana":239,"ref":240},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":214,"ana":24,"ref":25},{"ana":243},"#condition.damaged",{"layout":245},{"p":246,"rs":247,"damage":248},"The first part of all six lines of the Greek text are preserved, but none are complete.",{"_":30,"ana":31,"ref":32},{"ana":249},"#text_condition.incomplete #text_condition.legible",{"lettering":251,"dimensions":287},[252,253],"The letters are uniform and well cut, with pronounced serifs. A hollow triangular interpunct is used between all the onomastic elements (but apparently not elsewhere in the text; spaces are however observed between words, with or without interpunct). Theta has a detached middle bar; omicron is full size; epsilon has a detached short middle bar; mu reaches almost to the lower line in the middle, and the outer strokes are vertical.",{"_":254,"ref":255},"\n                                    Types list:\n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                