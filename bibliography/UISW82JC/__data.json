for a width of 12.5 cm, with two lines of Latin letters filling the available field.",{"_":29,"ana":30,"ref":31},{"lettering":253,"dimensions":254},"The letters are tall, neatly cut and closely spaced (height c.30mm), and words are separated by simple triangular interpuncts. The letters are lightly serifed. E is tall and narrow, T has a curved cross-bar, rising to the right.",[255,257],{"type":130,"l":256,"from":132,"to":137,"h":133,"unit":134},"Line 1-2",{"type":141,"l":258,"from":132,"to":137,"h":259,"unit":134},"Interlineation line 1 to 2","?",{"_":261,"notBefore":262,"notAfter":263,"precision":149},"Late 1st century CE, or 2nd century CE",51,200,[265,266],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[268],[162,163],[270,271],37.998047,14.262635,{"_":170,"role":171,"ref":172},{"_":274,"type":175},"ME 20226",{"_":276,"mainLang":277,"languages":278},"Latin","la",[276],"175722",{"n":182,"url":281,"height":282,"width":283,"desc":284,"surfaceType":187},"ISic000768_tiled.tif","3395px","7360px","Photo J. Prag, courtesy Soprintendenza di Messina",[],[190,192,287,288,195,196,289,198,200],"Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano","Manganaro, 1989, Iscrizioni Latine nuove e vecchie della Sicilia","Portale, 2009, Le sculture da Alesa",[202,204,291,292,207,208,293,210,212],"RZSFKACR","EZMBJ6GN","BCIMMIKZ",[295,296,297,237,241,245,218,219,220,221,218,222,298,277],"isic000768","dedication by a sevir to concordia",{"_":10},"latin","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":226,"date":3,"citedRange":301,"ptr":302,"ref":303,"title":2,"citation":4},"17 no.7 fig.1",{"target":229},{"_":231,"target":231},{"file":305,"uri":305,"title":306,"status":307,"editionAuthor":11,"type":308,"objectType":309,"material":313,"condition":24,"layoutDesc":315,"handNote":319,"date":344,"places":348,"geo":351,"provenance":152,"provenanceGeo":353,"country":167,"region":168,"settlement":152,"repository":356,"idno":357,"textLang":359,"tmNumber":361,"facsimile":362,"letterHeights":367,"publications":368,"zotero":369,"keywords":370,"html":375,"bibl":376},"ISic000769","Honours for L. Naevius(?) Firminus Manilianus",{"_":10},{"_":13,"ana":14,"ref":15},{"_":310,"ana":311,"ref":312},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":314,"ana":246,"ref":247},"marble (blue)\n                                    ",{"layout":316},{"p":317,"rs":318,"damage":24},"Remains of four lines of latin text are preserved: only the lower part of the first line survives, and only traces of the tops of letters remain from the beginning of line four.",{"_":29,"ana":30,"ref":31},{"lettering":320,"dimensions":321},"The letters are V-cut and generously (and sometimes unevenly) spaced, with moderate serifs. R is closed, and both A and R have lightly cut horizontals; all the strokes of M are off-vertical. Words are separated by comma-like interpuncts.",[322,324,327,331,335,338,341],{"type":130,"l":131,"from":132,"to":132,"h":323,"unit":134},"65",{"type":130,"l":325,"from":137,"to":137,"h":326,"unit":134},"Line 2","55",{"type":130,"l":328,"from":329,"to":329,"h":330,"unit":134},"Line 3","line3","43",{"type":130,"l":332,"from":333,"to":333,"h":334,"unit":134},"Line 4","line4","incomplete",{"type":141,"l":336,"from":132,"to":137,"h":337,"unit":134},"Interlineation lines 1-2","17-20",{"type":141,"l":339,"from":137,"to":329,"h":340,"unit":134},"Interlineation lines 2-3","11-14",{"type":141,"l":342,"from":329,"to":333,"h":343,"unit":134},"Interlineation lines 3-4","12-14",{"_":345,"notBefore":346,"notAfter":347,"precision":149},"2nd century CE or early 3rd century CE",101,250,[349,350],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[352],[162,163],[354,355],37.997854,14.262475,{"_":170,"role":171,"ref":172},{"_":358,"type":175},"ME 20227",{"_":276,"mainLang":277,"languages":360},[276],"175723",{"n":182,"url":363,"height":364,"width":365,"desc":366,"surfaceType":187},"ISic000769_tiled.tif","3704px","7048px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina",[],[190,192,287,288,195,196,198,200],[202,204,291,292,207,208,210,212],[371,372,373,13,310,374,218,219,220,221,218,222,298,277],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":10},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":226,"date":3,"citedRange":377,"ptr":378,"ref":379,"title":2,"citation":4},"17 no.8 fig.2-3\n                        ",{"target":229},{"_":231,"target":231},{"file":381,"uri":381,"title":382,"status":383,"editionAuthor":11,"type":384,"objectType":385,"material":386,"condition":390,"layoutDesc":392,"handNote":398,"date":435,"places":439,"geo":442,"provenance":152,"provenanceGeo":444,"country":167,"region":168,"settlement":152,"repository":447,"idno":448,"textLang":450,"tmNumber"