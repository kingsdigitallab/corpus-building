rds are separated by a\n                                    comma-like three pointed serif.",[610,613],{"type":130,"l":611,"from":132,"to":137,"h":612,"unit":134},"Lines 1-2","38-40",{"type":141,"l":614,"from":132,"to":137,"unit":134},"Not measured",{"_":616,"notBefore":617,"notAfter":618,"precision":149},"Mid 1st century CE",1,100,[620,621],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[623],[162,163],[],{"_":170,"role":171,"ref":172},{"_":627,"type":175},"ME 20224",{"_":276,"mainLang":277,"languages":629},[276],"175719",{"n":182,"url":632,"height":633,"width":634,"desc":635,"surfaceType":187},"ISic000801_tiled.tif","6190px","4912px","Photo J. Prag",[],[190,192,287,196,198,200],[202,204,291,208,210,212],[640,641,642,598,310,245,218,219,220,221,218,222,298,277],"isic000801","fragment of a public latin inscription",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]CILIV[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]R · S · P · INỌ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":226,"date":3,"citedRange":645,"ptr":646,"ref":647,"title":2,"citation":4},"15 no.4 fig.2",{"target":229},{"_":231,"target":231},{"file":649,"uri":649,"title":650,"status":651,"editionAuthor":11,"type":652,"objectType":653,"material":654,"condition":24,"layoutDesc":656,"handNote":660,"date":666,"places":668,"geo":671,"provenance":152,"provenanceGeo":673,"country":167,"region":168,"settlement":152,"repository":674,"idno":675,"textLang":677,"tmNumber":679,"facsimile":680,"letterHeights":683,"publications":684,"zotero":685,"keywords":686,"html":690,"bi