reserved, but line 1 is taller than line 2, and line 3 is shorter",[641,643],{"type":130,"l":317,"from":137,"to":137,"h":642,"unit":134},"70",{"type":141,"l":142,"from":132,"to":137,"h":143,"unit":134},{"_":645,"notBefore":597,"notAfter":598,"evidence":148,"precision":149},"1st century CE",[647,648],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[650],[162,163],{"_":167,"role":168,"ref":169},{"_":653,"type":172},"ME 20225",{"_":269,"mainLang":270,"languages":655},[269],{"n":178,"url":657,"height":612,"width":658,"desc":613,"surfaceType":183},"ISic000802_tiled.tif","5982px",[],[186,188,279,192,194],[198,200,283,204,206],[663,664,665,13,302,633,214,215,216,217,214,218,290,270],"isic000802","latin fragment mentioning a basilica",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]equọ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]basilic̣[a\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ọp̣ẹṛị[bus\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":222,"date":3,"citedRange":668,"ptr":669,"ref":670,"title":2,"citation":4},"15 no.5 fig.3",{"target":225},{"_":227,"target":227},{"file":672,"uri":672,"title":673,"status":674,"editionAuthor":11,"type":675,"objectType":676,"material":677,"condition":24,"layoutDesc":681,"handNote":685,"date":693,"places":696,"geo":699,"country":164,"region":165,"settlement":152,"repository":701,"textLang":702,"facsimile":704,"provenance":152,"letterHeights":708,"publications":709,"zotero":711,"keywords":713,"html":717,"bibl":718},"ISic000803","Dedication by a pair of seviri",{"_":10},{"_":13,"ana":14,"ref":15},{"_":237,"ana":238,"ref":239},{"_":678,"ana":679,"ref":680},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":682},{"p":683,"rs":684,"damage":24},"Two lines of Latin letters in the field below the moulding (17.5 cm high and\n                                        originally 160 cm wide)",{"_":29,"ana":30,"ref":31},{"lettering":686,"dimensions":687},"The letters are crudely cut (but the stone is too coarse to allow of better): P is\n                                    open, but R is closed; Q has a long tail; long I is taller than the other letters\n                                    (63mm); E is tall and narrow; words are separated by simple interpuncts.",[688,690,692],{"type":130,"l":131,"from":132,"to":132,"h":689,"unit":134},"45-55",{"type":130,"l":317,"from":137,"to":137,"h":691,"unit":134},"40-45",{"type":141,"l":594,"from":132,"to":137,"unit":134},{"_":694,"notBefore":258,"notAfter":695,"precision":149},"End 1st century CE, beginning 2nd century CE",150,[697,698],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[700],[162,163],{"_":167,"role":168,"ref":169},{"_":269,"mainLang":270,"languages":703},[269],{"n":178,"url":705,"height":706,"width":707,"desc":613,"surfaceType":183},"ISic000803a_tiled.tif","1672px","3072px",[],[186,188,279,194,710],"Burgio, 2013, Architetture onorarie dell’agorà di Alesa, 1. Il monumento dei Seviri Augustales: analisi e proposta ricostruttiva",[198,200,283,206,712],"5ETXJGSF",[714,715,716,13,237,678,214,215,216,217,214,218,290,270],"isic000803","dedication by a pair of seviri",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span> Q (uintus) · Caecilius · Q (uinti) · l (ibertus) · Hime[raeus \u003Cspan dir=\"ltr\" class=\"gap\">.. ? ..\u003C/span>]s · \u003Cspan class=\"reversed\" title=\"reversed: Ↄ\">(())\u003C/span>(mulieris) · l (ibertus) · Sabinus · \u003Cspan dir=\"ltr\">(vac.2)\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>  \u003Cspan dir=\"ltr\">(vac.5)\u003C/span> sẹṿiri · \u003Cspan dir=\"ltr\">(vac.)\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">.. ? ..\u003C/span>] ḍ (e) · s (ua) · p (ecunia) · \u003Cspan dir=\"ltr\">(vac.7)\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":222,"date":3,"citedRange":719,"ptr":720,"ref":721,"title":2,"citation":4},"16 no.6 tav.4.1",{"target":225},{"_":227,"target":227},{"file":723,"uri":723,"title":724,"status":725,"editionAuthor":11,"type":726,"objectType":727,"material":730,"condition":24,"layoutDesc":731,"handNote":735,"date":744,"places":748,"geo":751,"country":164,"region":165,"settlement":152,"repository":753,"idno":754,"textLang":756,"facsimile":758,"provenance":152,"letterHeights":762,"publications":763,"zotero":765,"keywords":767,"html":771,"bibl":772},"ISic000804","Dedication of a statue to Ceres, by Iulius Acilius Hermes, sevir",{"_":10},{"_":233,"ana":234,"ref":235},{"_":728,"ana":729,"ref":239},"statue base","#object.statue_base",{"_":241,"ana":242,"ref":243},{"layout":732},{"p":733,"rs":734,"damage":24},"The Latin text is engraved over two lines (letters c.20 mm high, but of uneven height), to a maximum length of 52 cm.",{"_":29,"ana":30,"ref":31},{"lettering":736,"dimensions":737}," The letters show some irregularity, with fairly pronounced serifs, and lengthy tails to the letter R. The first two words are separated from the rest by a space; an interpunct is visible at the end of the dedicant’s name, and the final abbreviated phrase is separated from the rest by a large hedera (ivy leaf). The letter I in line 1 is frequently taller than the rest (but so too is the first L in line 1); the final I of line 1 is somewhat irregularly carved.",[738,740,742],{"type":130,"l":131,"from":132,"to":132,"h":739,"unit":134},"18-25",{"type":130,"l":317,"from":137,"to":137,"h":741,"unit":134},"19-23",{"type":141,"l":328,"from":132,"to":137,"h":743,"unit":134},"7-15",{"_":745,"notBefore":746,"notAfter":747,"evidence":546},"Statue can be dated stylistically to the late Antonine period (i.e. the 180s or 190s CE), and the text is compatible with such a date.",180,199,[749,750],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[752],[162,163],{"_":167,"role":168,"ref":169},{"_":755,"type":172},"ME 20194",{"_":269,"mainLang":270,"languages":757},[269],{"n":178,"url":759,"height":760,"width":761,"desc":354,"surfaceType":183},"ISic000804_tiled.tif","1949px","4512px",[],[186,188,279,764,281,194,196],"Scibona, 2008, Statuary",[198,200,283,766,285,206,208],"EQC3W4UU",[768,769,770,233,728,241,214,215,216,217,214,218,290,270],"isic000804","dedication of a statue to ceres, by iulius acilius hermes, sevir",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Cereri sacr(um) \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> Iulius Acilius Her-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>mes · pro honor(e) seviratus ❦ d(eae) d(onum) d(edit) \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":222,"date":3,"citedRange":773,"ptr":774,"ref":775,"title":2,"citation":4},"19 no.9 fig.1-2",{"target":225},{"_":227,"target":227},{"file":777,"uri":777,"title":778,"status":779,"editionAuthor":11,"type":780,"objectType":781,"material":782,"condition":24,"layoutDesc":784,"handNote":787,"date":794,"places":798,"geo":801,"country":164,"region":165,"settlement":152,"repository":803,"idno":804,"textLang":806,"facsimile":808,"provenance":152,"letterHeights":811,"publications":812,"zotero":813,"keywords":814,"html":818,"bibl":819},"ISic000805","Fragmentary latin inscription mentioning a proconsul",{"_":10},{"_":13,"ana":14,"ref":15},{"_":302,"ana":303,"ref":304},{"_":783,"ana":242,"ref":243},"marble (pink)",{"layout":785},{"rs":786,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":788,"dimensions":789},"Letters are 50mm high, tall, thin, serifed. P and R are open; the hastae of M join early and extend upwards; a hedera like interpunct (tail top and bottom to a hollow element) appears once between C and V of line 2.",[790,793],{"type":130,"l":791,"from":132,"to":321,"h":792,"unit":134},"Line 1-3","50",{"type":141,"l":254,"from":132,"to":137,"unit":134},{"_":795,"notBefore":796,"notAfter":797,"precision":149},"3rd century CE",201,300,[799,800],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[802],[162,163],{"_":167,"role":168,"ref":169},{"_":805,"type":172},"ME 20228",{"_":269,"mainLang":270,"languages":807},[269],{"n":178,"url":809,"height":810,"width":612,"desc":613,"surfaceType":183},"ISic000805_tiled.tif","5256px",[],[186,188,279,191,192,194,196],[198,200,283,203,204,206,208],[815,816,817,13,302,783,214,215,216,217,214,218,290,270],"isic000805","fragmentary latin inscription mentioning a proconsul",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]idi ọ [\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] ọ proco (n) s (uli) c (larissimo) · v (iro) \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span> [\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span> ị optimo \u003C/span>\u003C/div>  \u003Cp cla