--\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":577,"ptr":578,"ref":579,"title":2,"citation":5,"uri":6},"17 no.7 fig.1",{"target":225},{"_":227,"target":227},{"file":581,"uri":581,"title":582,"status":583,"editionAuthor":13,"type":584,"objectType":585,"material":586,"condition":26,"layoutDesc":588,"handNote":592,"date":620,"places":624,"geo":627,"provenance":155,"provenanceGeo":629,"country":170,"region":171,"settlement":155,"repository":632,"idno":633,"textLang":635,"tmNumber":637,"facsimile":638,"letterHeights":642,"publications":656,"zotero":657,"keywords":658,"html":663,"bibl":664,"citedRangeSort":665,"languageSort":383,"materialSort":587,"typeSort":15},"ISic000769","Honours for L. Naevius(?) Firminus Manilianus",{"_":12},{"_":15,"ana":16,"ref":17},{"_":237,"ana":238,"ref":239},{"_":587,"ana":353,"ref":354},"marble (blue)\n                                    ",{"layout":589},{"p":590,"rs":591,"damage":26},"Remains of four lines of latin text are preserved: only the lower part of the first line survives, and only traces of the tops of letters remain from the beginning of line four.",{"_":30,"ana":31,"ref":32},{"lettering":593,"dimensions":594},"The letters are V-cut and generously (and sometimes unevenly) spaced, with moderate serifs. R is closed, and both A and R have lightly cut horizontals; all the strokes of M are off-vertical. Words are separated by comma-like interpuncts.",[595,597,598,602,606,611,616],{"type":137,"l":481,"from":139,"to":139,"h":596,"unit":142,"atLeast":596,"atMost":596},"65",{"type":137,"l":425,"from":146,"to":146,"h":484,"unit":142,"atLeast":484,"atMost":484},{"type":137,"l":599,"from":600,"to":600,"h":601,"unit":142,"atLeast":601,"atMost":601},"Line 3","line3","43",{"type":137,"l":603,"from":604,"to":604,"h":605,"unit":142},"Line 4","line4","incomplete",{"type":144,"l":607,"from":139,"to":146,"h":608,"unit":142,"atLeast":609,"atMost":610},"Interlineation lines 1-2","17-20","17","20",{"type":144,"l":612,"from":146,"to":600,"h":613,"unit":142,"atLeast":614,"atMost":615},"Interlineation lines 2-3","11-14","11","14",{"type":144,"l":617,"from":600,"to":604,"h":618,"unit":142,"atLeast":619,"atMost":615},"Interlineation lines 3-4","12-14","12",{"_":621,"notBefore":622,"notAfter":623},"2nd century CE or early 3rd century CE",101,250,[625,626],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[628],[165,166],[630,631],37.997854,14.262475,{"_":173,"role":174,"ref":175},{"_":634,"type":178},"ME 20227",{"_":383,"mainLang":384,"languages":636},[383],"175723",{"n":185,"url":639,"height":640,"width":641,"desc":313,"surfaceType":190},"ISic000769_tiled.tif","3704px","7048px",[643,645,646,648,651,654],{"atLeast":644,"atMost":644},65,{"atLeast":509,"atMost":509},{"atLeast":647,"atMost":647},43,{"atLeast":649,"atMost":650},17,20,{"atLeast":652,"atMost":653},11,14,{"atLeast":655,"atMost":653},12,[195,198,319,320,322,199,200,324],[203,206,327,328,330,207,208,332],[659,660,661,15,237,662,215,216,217,218,215,219,403,384],"isic000769","honours for l. naevius(?) firminus manilianus",{"_":12},"marble (blue)","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ḷ(ucio) · Na[ev]ịo · Ḷ(uci) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>f(ilio) · Rom(ilia tribu) · Firmi-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>no · M[a]niḷiano \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan dir=\"ltr\" class=\"gap\">..\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":665,"ptr":666,"ref":667,"title":2,"citation":5,"uri":6},"17 no.8 fig.2-3\n                        ",{"target":225},{"_":227,"target":227},{"file":669,"uri":669,"title":670,"status":671,"editionAuthor":13,"type":672,"objectType":673,"material":676,"condition":26,"layoutDesc":677,"handNote":681,"date":695,"places":699,"geo":702,"provenance":155,"provenanceGeo":704,"country":170,"region":171,"settlement":155,"repository":707,"idno":708,"textLang":710,"tmNumber":712,"facsimile":713,"letterHeights":717,"publications":726,"zotero":728,"keywords":730,"html":734,"bibl":735,"citedRangeSort":736,"languageSort":383,"materialSort":402,"typeSort":233},"ISic000804","Dedication of a statue to Ceres, by Iulius Acilius Hermes, sevir",{"_":12},{"_":233,"ana":234,"ref":235},{"_":674,"ana":675,"ref":468},"statue base","#object.statue_base",{"_":402,"ana":353,"ref":354},{"layout":678},{"p":679,"rs":680,"damage":26},"The Latin text is engraved over two lines (letters c.20 mm high, but of uneven height), to a maximum length of 52 cm.",{"_":30,"ana":31,"ref":32},{"lettering":682,"dimensions":683}," The letters show some irregularity, with fairly pronounced serifs, and lengthy tails to the letter R. The first two words are separated from the rest by a space; an interpunct is visible at the end of the dedicant’s name, and the final abbreviated phrase is separated from the rest by a large hedera (ivy leaf). The letter I in line 1 is frequently taller than the rest (but so too is the first L in line 1); the final I of line 1 is somewhat irregularly carved.",[684,688,692],{"type":137,"l":481,"from":139,"to":139,"h":685,"unit":142,"atLeast":686,"atMost":687},"18-25","18","25",{"type":137,"l":425,"from":146,"to":146,"h":689,"unit":142,"atLeast":690,"atMost":691},"19-23","19","23",{"type":144,"l":607,"from":139,"to":146,"h":693,"unit":142,"atLeast":694,"atMost":288},"7-15","7",{"_":696,"notBefore":697,"notAfter":698,"evidence":152},"Statue can be dated stylistically to the late Antonine period (i.e. the 180s or 190s CE), and the text is compatible with such a date.",180,199,[700,701],{"_":155,"type":156,"ref":157},{"_":159,"type":160,"ref":161,"offset":162},[703],[165,166],[705,706],37.998037,14.262643,{"_":173,"role":174,"ref":175},{"_":709,"type":178},"ME 20194",{"_":383,"mainLang":384,"languages":711},[383],"175724",{"n":185,"url":714,"height":715,"width":716,"desc":313,"surfaceType":190},"ISic000804_tiled.tif","1949px","4512px",[718,721,724],{"atLeast":719,"atMost":720},18,25,{"atLeast":722,"atMost":723},19,23,{"atLeast":725,"atMost":316},7,[195,198,319,727,568,200,324],"Scibona, 2008, Statuary",[203,206,327,729,570,208,332],"EQC3W4UU",[731,732,733,233,674,402,215,216,217,218,215,219,403,384],"isic000804","dedication of a statue to ceres, by iulius acilius hermes, sevir",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Cereri sacr(um) \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> Iulius Acilius Her-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>mes · pro honor(e) seviratus ❦ d(eae) d(onum) d(edit) \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":736,"ptr":737,"ref":738,"title":2,"citation":5,"uri":6},"19 no.9 fig.1-2",{"target":225},{"_":227,"target":227},{"file":740,"uri":740,"title":741,"status":742,"editionAuthor":13,"type":743,"objectType":744,"material":745,"condition":26,"layoutDesc":747,"handNote":750,"date":757,"places":761,"geo":764,"provenance":155,"provenanceGeo":766,"country":170,"region":171,"settlement":155,"repository":769,"idno":770,"textLang":772,"tmNumber":774,"facsimile":775,"letterHeights":778,"publications":781,"zotero":782,"keywords":783,"html":787,"bibl":788,"citedRang