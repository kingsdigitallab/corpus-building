(near) Tripi","Current location unknown",{"_":70,"mainLang":71,"languages":72},"Latin","la",[70],{"n":74,"url":75,"height":76,"width":77,"desc":78,"surfaceType":79},"screen","ISic000623_tiled.tif","1644px","1715px","Scan of NSA 1954 p.49 fig.4","front",[],[82,83,84,85,86],"L'année épigraphique: revue des publications épigraphiques relatives a l'antiquité romaine., 1888-","Wilson, 1990, Sicily under the Roman Empire: the archaeology of a Roman province, 36 B.C. - A.D. 535","Villard, 1876-, Notizie degli scavi di antichità","Bacci and Coppolino, 2009, La Necropoli di Abakainon: primi dati","Sofia, 2015, Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi",[88,89,90,91,92],"R46KDTZX","VF9MMBI9","4MCP2PVV","DX8AWC9Q","9QTE4E3Z",[94,95,96,13,18,22,97,98,99,100,101,102,71],"isic000623","fragmentary latin inscription",{"_":10},"abacaenum","tripi","italy","sicily","(near) tripi","latin","Text encoding: Jonathan Prag",{"file":105,"uri":105,"title":106,"status":107,"editionAuthor":11,"type":109,"objectType":113,"material":117,"condition":34,"layoutDesc":121,"handNote":125,"date":133,"places":138,"geo":141,"country":65,"region":66,"settlement":57,"repository":143,"idno":147,"textLang":150,"facsimile":154,"provenance":53,"letterHeights":159,"publications":160,"zotero":163,"keywords":166,"html":172},"ISic004411","Epitaph for Kratisstos",{"_":108},"edited",{"_":110,"ana":111,"ref":112},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":114,"ana":115,"ref":116},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":118,"ana":119,"ref":120},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":122},{"p":123,"rs":124,"damage":34},"Single line of Greek letters filling the width of the stone",{"_":31,"ana":32,"ref":33},{"lettering":126,"dimensions":127},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[128,131],{"type":39,"l":129,"from":41,"to":41,"h":130,"unit":43},"Line 1","30",{"type":45,"l":46,"from":41,"to":42,"h":132,"unit":43},"NA",{"_":134,"notBefore":135,"notAfter":136,"evidence":137,"precision":16},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[139,140],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[142],[63,64],{"_":144,"role":145,"ref":146},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":148,"type":149},"ME23435","inventory",{"_":151,"mainLang":152,"languages":153},"Ancient Greek","grc",[151],{"n":74,"url":155,"height":156,"width":157,"desc":158,"surfaceType":79},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[],[85,161,86,162],"Bacci et al., 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[91,164,92,165],"ILQ4RQGU","JQQKI6JP",[167,168,169,110,114,118,97,98,99,100,98,170,171,152],"isic004411","epitaph for kratisstos",{"_":108},"museo archeologico santi furnari di tripi","ancient greek","Unknown",{"file":174,"uri":174,"title":175,"status":176,"editionAuthor":11,"type":177,"objectType":178,"material":179,"condition":34,"layoutDesc":180,"handNote":183,"date":188,"places":192,"geo":195,"country":65,"region":66,"settlement":57,"repository":197,"idno":198,"textLang":200,"facsimile":202,"provenance":53,"letterHeights":204,"publications":205,"zotero":206,"keywords":207,"html":103},"ISic004414","Epitaph for Eupolemos",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":116},{"_":118,"ana":119,"ref":120},{"layout":181},{"p":123,"rs":182,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":184,"dimensions":185},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[186,187],{"type":39,"l":129,"from":41,"to":41,"h":130,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":132,"unit":43},{"_":189,"notBefore":190,"notAfter":191,"evidence":137,"precision":16},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[193,194],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[196],[63,64],{"_":144,"role":145,"ref":146},{"_":199,"type":149},"ME23438",{"_":151,"mainLang":152,"languages":201},[151],{"n":74,"url":203,"height":156,"width":157,"desc":158,"surfaceType":79},"ISic004414_tiled.tif",[],[85,161,86,162],[91,164,92,165],[208,209,210,110,114,118,97,98,99,100,98,170,171,152],"isic004414","epitaph for eupolemos",{"_":108},{"file":212,"uri":212,"title":213,"status":214,"editionAuthor":11,"type":215,"objectType":216,"material":220,"condition":34,"layoutDesc":221,"handNote":225,"date":230,"places":233,"geo":237,"country":65,"region":66,"settlement":57,"repository":239,"idno":243,"textLang":244,"facsimile":246,"provenance":53,"letterHeights":248,"publications":249,"zotero":250,"keywords":251,"html":103},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":108},{"_":110,"ana":111,"ref":112},{"_":217,"ana":218,"ref":219},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":118,"ana":119,"ref":120},{"layout":222},{"p":223,"rs":224,"damage":34},"Single line of greek letters approximately centred on the face of the plinth",{"_":31,"ana":32,"ref":33},{"lettering":226,"dimensions":227},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[228,229],{"type":39,"l":129,"from":41,"to":41,"h":130,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":132,"unit":43},{"_":231,"notBefore":232,"notAfter":191,"evidence":137,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,[234,236],{"_":53,"type":54,"ref":55,"corresp":235},"#findspot",{"_":57,"type":58,"ref":59,"offset":60},[238],[63,64],{"_":240,"role":241,"ref":242},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":149},{"_":151,"mainLang":152,"languages":245},[151],{"n":74,"url":247,"height":156,"width":157,"desc":158,"surfaceType":79},"ISic004415_tiled.tif",[],[85,162],[91,165],[252,253,254,110,217,118,97,98,99,100,98,255,171,152],"isic004415","epitaph for krimma, child of aunakos",{"_":108},"necropoli di abakainon",{"file":257,"uri":257,"title":258,"status":259,"editionAuthor":11,"type":260,"objectType":261,"material":262,"condition":34,"layoutDesc":263,"handNote":267,"date":273,"places":274,"geo":277,"country":65,"region":66,"settlement":57,"repository":279,"idno":280,"textLang":281,"facsimile":283,"provenance":53,"letterHeights":285,"publications":286,"zotero":287,"keywords":288,"html":103},"ISic004416","Epitaph for Philon, son Aunakos",{"_":108},{"_":110,"ana":111,"ref":112},{"_":217,"ana":218,"ref":219},{"_":118,"ana":119,"ref":120},{"layout":264},{"p":265,"rs":266,"damage":34},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":31,"ana":32,"ref":33},{"lettering":268,"dimensions":269},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[270,272],{"type":39,"l":129,"from":41,"to":41,"h":271,"unit":43},"59",{"type":45,"l":46,"from":41,"to":42,"h":132,"unit":43},{"_":231,"notBefore":232,"notAfter":191,"evidence":137,"precision":16},[275,276],{"_":53,"type":54,"ref":55,"corresp":235},{"_":57,"type":58,"ref":59,"offset":60},[278],[63,64],{"_":240,"role":241,"ref":242},{"type":149},{"_":151,"mainLang":152,"languages":282},[151],{"n":74,"url":284,"height":156,"width":157,"desc":158,"surfaceType":79},"ISic004416_tiled.tif",[],[85,162],[91,165],[289,290,291,110,217,118,97,98,99,100,98,255,171,152],"isic004416","epitaph for philon, son aunakos",{"_":108},{"file":293,"uri":293,"title":294,"status":295,"editionAuthor":11,"type":296,"objectType":297,"material":298,"condition":34,"layoutDesc":299,"handNote":303,"date":309,"places":310,"geo":313,"country":65,"region":66,"settlement":57,"repository":315,"idno":316,"textLang":317,"facsimile":319,"provenance":53,"letterHeights":321,"publications":322,"zotero":323,"keywords":324,"html":103},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":108},{"_":110,"ana":111,"ref":112},{"_":217,"ana":218,"ref":219},{"_":118,"ana":119,"ref":120},{"layout":300},{"p":301,"rs":302,"damage":34},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":31,"ana":32,"ref":33},{"lettering":304,"dimensions":305},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[306,308],{"type":39,"l":307,"from":41,"to":42,"h":130,"unit":43},"Line 1-2",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":231,"notBefore":232,"notAfter":191,"evidence":137,"precision":16},[311,312],{"_":53,"type":54,"ref":55,"corresp":235},{"_":57,"type":58,"ref":59,"offset":60},[314],[63,64],{"_":240,"role":241,"ref":242},{"type":149},{"_":151,"mainLang":152,"languages":318},[151],{"n":74,"url":320,"height":156,"width":157,"desc":158,"surfaceType":79},"ISic004417_tiled.tif",[],[85,86,162],[91,92,165],[325,326,327,110,217,118,97,98,99,100,98,255,171,152],"isic004417","epitaph for [-?-], child of gerontios",{"_":108},{"file":329,"uri":329,"title":294,"status":330,"editionAuthor":11,"type":331,"objectType":332,"material":333,"condition":34,"layoutDesc":334,"handNote":338,"date":343,"places":345,"geo":348,"country":65,"region":66,"settlement":57,"repository":350,"idno":351,"textLang":352,"facsimile":354,"provenance":53,"letterHeights":356,"publications":357,"zotero":358,"keywords":359,"html":103},"ISic004418",{"_":108},{"_":110,"ana":111,"ref":112},{"_":217,"ana":218,"ref":219},{"_":118,"ana":119,"ref":120},{"layout":335},{"p":336,"rs":337,"damage":34},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":339,"dimensions":340},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[341,342],{"type":39,"l":307,"from":41,"to":42,"h":271,"unit":43},{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":344,"notBefore":232,"notAfter":191,"evidence":137,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[346,347],{"_":53,"type":54,"ref":55,"corresp":235},{"_":57,"type":58,"ref":59,"offset":60},[349],[63,64],{"_":240,"role":241,"ref":242},{"type":149},{"_":151,"mainLang":152,"languages":353},[151],{"n":74,"url":355,"height":156,"width":157,"desc":158,"surfaceType":79},"ISic004418_tiled.tif",[],[85,86,162],[91,92,165],[360,326,361,110,217,118,97,98,99,100,98,255,171,152],"isic004418",{"_":108}],"uses":{"params":["slug"]}}]}
