uthor":13,"type":121,"objectType":125,"material":129,"condition":36,"layoutDesc":133,"handNote":137,"date":145,"places":150,"geo":153,"provenance":55,"provenanceGeo":155,"country":70,"region":71,"settlement":59,"repository":158,"idno":162,"textLang":165,"tmNumber":36,"facsimile":169,"letterHeights":174,"publications":175,"zotero":178,"keywords":181,"html":187,"bibl":188},"ISic004411","Epitaph for Kratisstos",{"_":120},"edited",{"_":122,"ana":123,"ref":124},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":126,"ana":127,"ref":128},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":130,"ana":131,"ref":132},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":134},{"p":135,"rs":136,"damage":36},"Single line of Greek letters filling the width of the stone",{"_":33,"ana":34,"ref":35},{"lettering":138,"dimensions":139},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[140,143],{"type":41,"l":141,"from":43,"to":43,"h":142,"unit":45},"Line 1","30",{"type":47,"l":48,"from":43,"to":44,"h":144,"unit":45},"NA",{"_":146,"notBefore":147,"notAfter":148,"evidence":149,"precision":18},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[151,152],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[154],[65,66],[156,157],38.06519,15.11438,{"_":159,"role":160,"ref":161},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":163,"type":164},"ME23435","inventory",{"_":166,"mainLang":167,"languages":168},"Ancient Greek","grc",[166],{"n":80,"url":170,"height":171,"width":172,"desc":173,"surfaceTyp