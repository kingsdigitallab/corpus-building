5,"date":143,"places":148,"geo":151,"provenance":54,"provenanceGeo":153,"country":69,"region":70,"settlement":58,"repository":156,"idno":160,"textLang":163,"tmNumber":35,"facsimile":167,"letterHeights":172,"publications":173,"zotero":176,"keywords":179,"html":185,"bibl":186},"ISic004411","Epitaph for Kratisstos",{"_":118},"edited",{"_":120,"ana":121,"ref":122},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":124,"ana":125,"ref":126},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":128,"ana":129,"ref":130},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":132},{"p":133,"rs":134,"damage":35},"Single line of Greek letters filling the width of the stone",{"_":32,"ana":33,"ref":34},{"lettering":136,"dimensions":137},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[138,141],{"type":40,"l":139,"from":42,"to":42,"h":140,"unit":44},"Line 1","30",{"type":46,"l":47,"from":42,"to":43,"h":142,"unit":44},"NA",{"_":144,"notBefore":145,"notAfter":146,"evidence":147,"precision":17},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[149,150],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[152],[64,65],[154,155],38.06519,15.11438,{"_":157,"role":158,"ref":159},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":161,"type":162},"ME23435","inventory",{"_":164,"mainLang":165,"languages":166},"Ancient Greek","grc",[164],{"n":79,"url":168,"height":169,"width":170,"desc":171,"surfaceType":84},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato R