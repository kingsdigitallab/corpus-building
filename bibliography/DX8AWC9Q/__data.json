erpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":407,"ptr":408,"ref":409,"title":2,"citation":4},"113 and 166 tav.XXXIVa",{"target":190},{"_":114,"target":114}],"uses":{"params":["slug"]}}]}
