",[157,158],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[160],[69,70],[162,163],38.06519,15.11438,{"_":165,"role":166,"ref":167},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":169,"type":170},"ME23435","inventory",{"_":172,"mainLang":173,"languages":174},"Ancient Greek","grc",[172],{"n":83,"url":176,"height":177,"width":178,"desc":179,"surfaceType":88},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[181],{"atLeast":182,"atMost":182},30,[94,184,95,185],"Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[100,187,101,188],"ILQ4RQGU","JQQKI6JP",[190,191,192,126,130,134,106,107,108,109,107,193,194,173],"isic004411","epitaph for kratisstos",{"_":124},"museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":197,"ptr":198,"ref":199,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"27 fig.14",{"target":116},{"_":118,"target":118},{"file":201,"uri":201,"title":202,"status":203,"editionAuthor":13,"type":204,"objectType":205,"material":209,"condition":39,"layoutDesc":211,"handNote":215,"date":220,"places":224,"geo":228,"country":61,"provenance":58,"provenanceGeo":230,"region":74,"settlement":63,"repository":231,"idno":235,"textLang":236,"tmNumber":39,"facsimile":238,"letterHeights":240,"publications":242,"zotero":243,"keywords":244,"html":249,"bibl":250,"bulletinDateSort":119,"citedRangeSort":251,"languageSort":172,"materialSort":134,"typeSort":126},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":124},{"_":126,"ana":127,"ref":128},{"_":206,"ana":207,"ref":208},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":134,"ana":135,"type":136,"subtype":210,"ref":138},[28],{"layout":212},{"p":213,"rs":214,"damage":39},"Single line of greek letters approximately centred on the face of the plinth",{"_":36,"ana":37,"ref":38},{"lettering":216,"dimensions":217},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[218,219],{"type":44,"l":147,"from":46,"to":46,"h":148,"unit":48,"atLeast":148,"atMost":148},{"type":50,"l":51,"from":46,"to":47,"h":150,"unit":48},{"_":221,"notBefore":222,"notAfter":223,"evidence":155},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,[225,227],{"_":58,"type":59,"ref":60,"corresp":226,"region":61},"#findspot",{"_":63,"type":64,"ref":65,"offset":66,"region":61},[229],[69,70],[162,163],{"_":232,"role":233,"ref":234},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":170},{"_":172,"mainLang":173,"languages":237},[172],{"n":83,"url":239,"height":177,"width":178,"desc":179,"surfaceType":88},"ISic004415_tiled.tif",[241],{"atLeast":182,"atMost":182},[94,185],[100,188],[245,246,247,126,206,134,106,107,108,109,107,248,194,173],"isic004415","epitaph for krimma, child of aunakos",{"_":124},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":251,"ptr":252,"ref":253,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"28 fig.15 (and ref on p.113)",{"target":116},{"_":118,"target":118},{"file":255,"uri":255,"title":256,"status":257,"editionAuthor":13,"type":258,"objectType":259,"material":260,"condition":39,"layoutDesc":262,"handNote":266,"date":272,"places":273,"geo":276,"country":61,"provenance":58,"provenanceGeo":278,"region":74,"settlement":63,"repository":279,"idno":280,"textLang":281,"tmNumber":39,"facsimile":283,"letterHeights":285,"publications":288,"zotero":289,"keywords":290,"html":294,"bibl":295,"bulletinDateSort":119,"citedRangeSort":251,"languageSort":172,"materialSort":134,"typeSort":126},"ISic004416","Epitaph for Philon, son Aunakos",{"_":124},{"_":126,"ana":127,"ref":128},{"_":206,"ana":207,"ref":208},{"_":134,"ana":135,"type":136,"subtype":261,"ref":138},[28],{"layout":263},{"p":264,"rs":265,"damage":39},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":36,"ana":37,"ref":38},{"lettering":267,"dimensions":268},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[269,271],{"type":44,"l":147,"from":46,"to":46,"h":270,"unit":48,"atLeast":270,"atMost":270},"59",{"type":50,"l":51,"from":46,"to":47,"h":150,"unit":48},{"_":221,"notBefore":222,"notAfter":223,"evidence":155},[274,275],{"_":58,"type":59,"ref":60,"corresp":226,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[277],[69,70],[162,163],{"_":232,"role":233,"ref":234},{"type":170},{"_":172,"mainLang":173,"languages":282},[172],{"n":83,"url":284,"height":177,"width":178,"desc":179,"surfaceType":88},"ISic004416_tiled.tif",[286],{"atLeast":287,"atMost":287},59,[94,185],[100,188],[291,292,293,126,206,134,106,107,108,109,107,248,194,173],"isic004416","epitaph for philon, son aunakos",{"_":124},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":251,"ptr":296,"ref":297,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":116},{"_":118,"target":118},{"file":299,"uri":299,"title":300,"status":301,"editionAuthor":13,"type":302,"objectType":303,"material":304,"condition":39,"layoutDesc":306,"handNote":309,"date":314,"places":317,"geo":320,"country":61,"provenance":58,"provenanceGeo":322,"region":74,"settlement":63,"repository":323,"idno":324,"textLang":326,"tmNumber":39,"facsimile":328,"letterHeights":330,"publications":332,"zotero":333,"keywords":334,"html":338,"bibl":339,"bulletinDateSort":119,"citedRangeSort":340,"languageSort":172,"materialSort":134,"typeSort":126},"ISic004414","Epitaph for Eupolemos",{"_":124},{"_":126,"ana":127,"ref":128},{"_":130,"ana":131,"ref":132},{"_":134,"ana":135,"type":136,"subtype":305,"ref":138},[28],{"layout":307},{"p":141,"rs":308,"damage":39},{"_":36,"ana":37,"ref":38},{"lettering":310,"dimensions":311},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[312,313],{"type":44,"l":147,"from":46,"to":46,"h":148,"unit":48,"atLeast":148,"atMost":148},{"type":50,"l":51,"from":46,"to":47,"h":150,"unit":48},{"_":315,"notBefore":316,"notAfter":223,"evidence":155},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,[318,319],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[321],[69,70],[162,163],{"_":165,"role":166,"ref":167},{"_":325,"type":170},"ME23438",{"_":172,"mainLang":173,"languages":327},[172],{"n":83,"url":329,"height":177,"width":178,"desc":179,"surfaceType":88},"ISic004414_tiled.tif",[331],{"atLeast":182,"atMost":182},[94,184,95,185],[100,187,101,188],[335,336,337,126,130,134,106,107,108,109,107,193,194,173],"isic004414","epitaph for eupolemos",{"_":124},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":340,"ptr":341,"ref":342,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"41 fig.23",{"target":116},{"_":118,"target":118},{"file":344,"uri":344,"title":345,"status":346,"editionAuthor":13,"type":347,"objectType":348,"material":349,"condition":39,"layoutDesc":351,"handNote":355,"date":361,"places":363,"geo":366,"country":61,"provenance":58,"provenanceGeo":368,"region":74,"settlement":63,"repository":369,"idno":370,"textLang":371,"tmNumber":39,"facsimile":373,"letterHeights":375,"publications":377,"zotero":378,"keywords":379,"html":383,"bibl":384,"bulletinDateSort":119,"citedRangeSort":385,"languageSort":172,"materialSort":134,"typeSort":126},"ISic004418","Epitaph for [-?-], child of Gerontios",{"_":124},{"_":126,"ana":127,"ref":128},{"_":206,"ana":207,"ref":208},{"_":134,"ana":135,"type":136,"subtype":350,"ref":138},[28],{"layout":352},{"p":353,"rs":354,"damage":39},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":36,"ana":37,"ref":38},{"lettering":356,"dimensions":357},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[358,360],{"type":44,"l":359,"from":46,"to":47,"h":270,"unit":48,"atLeast":270,"atMost":270},"Line 1-2",{"type":50,"l":51,"from":46,"to":47,"unit":48},{"_":362,"notBefore":222,"notAfter":223,"evidence":155},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[364,365],{"_":58,"type":59,"ref":60,"corresp":226,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[367],[69,70],[162,163],{"_":232,"role":233,"ref":234},{"type":170},{"_":172,"mainLang":173,"languages":372},[172],{"n":83,"url":374,"height":177,"width":178,"desc":179,"surfaceType":88},"ISic004418_tiled.tif",[376],{"atLeast":287,"atMost":287},[94,95,185],[100,101,188],[380,381,382,126,206,134,106,107,108,109,107,248,194,173],"isic004418","epitaph for [-?-], child of gerontios",{"_":124},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":385,"ptr":386,"ref":387,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"113 and 166 tav.XXXIVa",{"target":116},{"_":118,"target":118},{"file":389,"uri":389,"title":345,"status":390,"editionAuthor":13,"type":391,"objectType":392,"material":393,"condition":39,"layoutDesc":395,"handNote":399,"date":404,"places":405,"geo":408,"country":61,"provenance":58,"provenanceGeo":410,"region":74,"settlement":63,"repository":411,"idno":412,"textLang"