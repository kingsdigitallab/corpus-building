":46,"l":47,"from":42,"to":43,"h":142,"unit":44},{"_":207,"notBefore":208,"notAfter":209,"evidence":147,"precision":17},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[211,212],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[214],[64,65],[154,155],{"_":157,"role":158,"ref":159},{"_":218,"type":162},"ME23438",{"_":164,"mainLang":165,"languages":220},[164],{"n":79,"url":222,"height":169,"width":170,"desc":171,"surfaceType":84},"ISic004414_tiled.tif",[],[89,174,90,175],[95,177,96,178],[227,228,229,120,124,128,101,102,103,104,102,183,184,165],"isic004414","epitaph for eupolemos",{"_":118},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":232,"ptr":233,"ref":234,"title":2,"citation":5},"41 fig.23",{"target":189},{"_":113,"target":113},{"file":236,"uri":236,"title":237,"status":238,"editionAuthor":12,"type":239,"objectType":240,"material":244,"condition":35,"layoutDesc":245,"handNote":249,"date":254,"places":257,"geo":261,"provenance":54,"provenanceGeo":263,"country":69,"region":70,"settlement":58,"repository":264,"idno":268,"textLang":269,"tmNumber":35,"facsimile":271,"letterHeights":273,"publications":274,"zotero":275,"keywords":276,"html":281,"bibl":282},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":118},{"_":120,"ana":121,"ref":122},{"_":241,"ana":242,"ref":243},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":128,"ana":129,"ref":130},{"layout":246},{"p":247,"rs":248,"damage":35},"Single line of greek letters approximately centred on the face of the plinth",{"_":32,"ana":33,"ref":34},{"lettering":250,"dimensions":251},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[252,253],{"type":40,"l":139,"from":42,"to":42,"h":140,"unit":44},{"type":46,"l":47,"from":42,"to":43,"h":142,"unit":44},{"_":255,"notBefore":256,"notAfter":209,"evidence":147,"precision":17},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,[258,260],{"_":54,"type":55,"ref":56,"corresp":259},"#findspot",{"_":58,"type":59,"ref":60,"offset":61},[262],[64,65],[154,155],{"_":265,"role":266,"ref":267},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":162},{"_":164,"mainLang":165,"languages":270},[164],{"n":79,"url":272,"height":169,"width":170,"desc":171,"surfaceType":84},"ISic004415_tiled.tif",[],[89,175],[95,178],[277,278,279,120,241,128,101,102,103,104,102,280,184,165],"isic004415","epitaph for krimma, child of aunakos",{"_":118},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":283,"ptr":284,"ref":285,"title":2,"citation":5},"28 fig.15 (and ref on p.113)",{"target":189},{"_":113,"target":113},{"file":287,"uri":287,"title":288,"status":289,"editionAuthor":12,"type":290,"objectType":291,"material":292,"condition":35,"layoutDesc":293,"handNote":297,"date":303,"places":304,"geo":307,"provenance":54,"provenanceGeo":309,"country":69,"region":70,"settlement":58,"repository":310,"idno":311,"textLang":312,"tmNumber":35,"facsimile":314,"letterHeights":316,"publications":317,"zotero":318,"keywords":319,"html":323,"bibl":324},"ISic004416","Epitaph for Philon, son Aunakos",{"_":118},{"_":120,"ana":121,"ref":122},{"_":241,"ana":242,"ref":243},{"_":128,"ana":129,"ref":130},{"layout":294},{"p":295,"rs":296,"damage":35},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":32,"ana":33,"ref":34},{"lettering":298,"dimensions":299},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[300,302],{"type":40,"l":139,"from":42,"to":42,"h":301,"unit":44},"59",{"type":46,"l":47,"from":42,"to":43,"h":142,"unit":44},{"_":255,"notBefore":256,"notAfter":209,"evidence":147,"precision":17},[305,306],{"_":54,"type":55,"ref":56,"corresp":259},{"_":58,"type":59,"ref":60,"offset":61},[308],[64,65],[154,155],{"_":265,"role":266,"ref":267},{"type":162},{"_":164,"mainLang":165,"languages":313},[164],{"n":79,"url":315,"height":169,"width":170,"desc":171,"surfaceType":84},"ISic004416_tiled.tif",[],[89,175],[95,178],[320,321,322,120,241,128,101,102,103,104,102,280,184,165],"isic004416","epitaph for philon, son aunakos",{"_":118},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":283,"ptr":325,"ref":326,"title":2,"citation":5},{"target":189},{"_":113,"target":113},{"file":328,"uri":328,"title":329,"status":330,"editionAuthor":12,"type":331,"objectType":332,"material":333,"condition":35,"layoutDesc":334,"handNote":338,"date":344,"places":345,"geo":348,"prov