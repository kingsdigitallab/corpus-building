"handNote":249,"date":256,"places":260,"geo":263,"provenance":54,"provenanceGeo":265,"country":70,"region":71,"settlement":59,"repository":266,"idno":270,"textLang":272,"tmNumber":26,"facsimile":274,"letterHeights":276,"publications":278,"zotero":280,"keywords":282,"html":287,"bibl":288,"citedRangeSort":289,"languageSort":79,"materialSort":23,"typeSort":15},"ISic004411","Epitaph for Kratisstos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":241,"ana":242,"ref":243},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":23,"ana":24,"ref":25},{"layout":246},{"p":247,"rs":248,"damage":26},"Single line of Greek letters filling the width of the stone",{"_":31,"ana":32,"ref":33},{"lettering":250,"dimensions":251},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[252,254],{"type":38,"l":253,"from":40,"to":40,"h":131,"unit":43,"atLeast":131,"atMost":131},"Line 1",{"type":45,"l":46,"from":40,"to":41,"h":255,"unit":43},"NA",{"_":257,"notBefore":258,"notAfter":259,"evidence":51},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,[261,262],{"_":54,"type":55,"ref":56},{"_":59,"type":60,"ref":61,"offset":62},[264],[65,66],[68,69],{"_":267,"role":268,"ref":269},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":271,"type":77},"ME23435",{"_":79,"mainLang":80,"languages":273},[79],{"n":83,"url":275,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004411_tiled.tif",[277],{"atLeast":149,"atMost":149},[93,279,94,95],"Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione",[97,281,98,99],"ILQ4RQGU",[283,284,285,15,241,23,104,105,106,107,105,286,109,80],"isic004411","epitaph for kratisstos",{"_":12},"museo archeologico santi furnari di tripi","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":289,"ptr":290,"ref":291,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"27 fig.14",{"target":114},{"_":116,"target":116},{"file":293,"uri":293,"title":294,"status":295,"editionAuthor":13,"type":296,"objectType":297,"material":298,"condition":26,"layoutDesc":299,"handNote":303,"date":308,"places":309,"geo":312,"provenance":54,"provenanceGeo":314,"country":70,"region":71,"settlement":59,"repository":315,"idno":316,"textLang":317,"tmNumber":26,"facsimile":319,"letterHeights":321,"publications":323,"zotero":324,"keywords":325,"html":329,"bibl":330,"citedRangeSort":331,"languageSort":79,"materialSort":23,"typeSort":15},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":300},{"p":301,"rs":302,"damage":26},"Single line of greek letters approximately centred on the face of the plinth",{"_":31,"ana":32,"ref":33},{"lettering":304,"dimensions":305},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[306,307],{"type":38,"l":253,"from":40,"to":40,"h":131,"unit":43,"atLeast":131,"atMost":131},{"type":45,"l":46,"from":40,"to":41,"h":255,"unit":43},{"_":134,"notBefore":49,"notAfter":50,"evidence":51},[310,311],{"_":54,"type":55,"ref":56,"corresp":57},{"_":59,"type":60,"ref":61,"offset":62},[313],[65,66],[68,69],{"_":73,"role":74,"ref":75},{"type":77},{"_":79,"mainLang":80,"languages":318},[79],{"n":83,"url":320,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004415_tiled.tif",[322],{"atLeast":149,"atMost":149},[93,95],[97,99],[326,327,328,15,19,23,104,105,106,107,105,108,109,80],"isic004415","epitaph for krimma, child of aunakos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":331,"ptr":332,"ref":333,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"28 fig.15 (and ref on p.113)",{"target":114},{"_":116,"target":116},{"file":335,"uri":335,"title":336,"status":337,"editionAuthor":13,"type":338,"objectType":339,"material":340,"condition":26,"layoutDesc":341,"handNote":345,"date":350,"places":351,"geo":354,"provenance":54,"provenanceGeo":356,"country":70,"region":71,"settlement":59,"repository":357,"idno":358,"textLang":359,"tmNumber":26,"facsimile":361,"letterHeights":363,"publications":365,"zotero":366,"keywords":367,"html":371,"bibl":372,"citedRangeSort":331,"languageSort":79,"materialSort":23,"typeSort":15},"ISic004416","Epitaph for Philon, son Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":342},{"p":343,"rs":344,"damage":26},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":31,"ana":32,"ref":33},{"lettering":346,"dimensions":347},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[348,349],{"type":38,"l":253,"from":40,"to":40,"h":42,"unit":43,"atLeast":42,"atMost":42},{"type":45,"l":46,"from":40,"to":41,"h":255,"unit":43},{"_":134,"notBefore":49,"notAfter":50,"evidence":51},[352,353],{"_":54,"type":55,"ref":56,"corresp":57},{"_":59,"type":60,"ref":61,"offset":62},[355],[65,66],[68,69],{"_":73,"role":74,"ref":75},{"type":77},{"_":79,"mainLang":80,"languages":360},[79],{"n":83,"url":362,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004416_tiled.tif",[364],{"atLeast":91,"atMost":91},[93,95],[97,99],[368,369,370,15,19,23,104,105,106,107,105,108,109,80],"isic004416","epitaph for philon, son aunakos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":331,"ptr":373,"ref":374,"inscriptionDate":4,"title":2,"citation":5,"uri":6},{"target":114},{"_":116,"target":116},{"file":376,"uri":376,"title":377,"status":378,"editionAuthor":13,"type":379,"objectType":380,"material":381,"condition":26,"layoutDesc":382,"handNote":385,"date":390,"places":393,"geo":396,"provenance":54,"provenanceGeo":398,"country":70,"region":71,"settlement":59,"repository":399,"idno":400,"textLang":402,"tmNumber":26,"facsimile":404,"letterHeights":406,"publications":408,"zotero":409,"keywords":410,"html":414,"bibl":415,"citedRangeSort":416,"languageSort":79,"materialSort":23,"typeSort":15},"ISic004414","Epitaph for Eupolemos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":241,"ana":242,"ref":243},{"_":23,"ana":24,"ref":25},{"layout":383},{"p":247,"rs":384,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":386,"dimensions":387},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[388,389],{"type":38,"l":253,"from":40,"to":40,"h":131,"unit":43,"atLeast":131,"atMost":131},{"type":45,"l":46,"from":40,"to":41,"h":255,"unit":43},{"_":391,"notBefore":392,"notAfter":50,"evidence":51},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,[394,395],{"_":54,"type":55,"ref":56},{"_":59,"type":60,"ref":61,"offset":62},[397],[65,66],[68,69],{"_":267,"role":268,"ref":269},{"_":401,"type":77},"ME23438",{"_":79,"mainLang":80,"languages":403},[79],{"n":83,"url":405,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004414_tiled.tif",[407],{"atLeast":149,"atMost":149},[93,279,94,95],[97,281,98,99],[411,412,413,15,241,23,104,105,106,107,105,286,109,80],"isic004414","epitaph for eupolemos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":416,"ptr":417,"ref":418,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"41 fig.23",{"target":114},{"_":116,"target":116},false],"uses":{"params":["slug"]}}]}
