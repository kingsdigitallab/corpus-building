{"_":57,"type":58,"ref":59,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[158],[68,69],[160,161],38.06519,15.11438,{"_":163,"role":164,"ref":165},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":167,"type":168},"ME23435","inventory",{"_":170,"mainLang":171,"languages":172},"Ancient Greek","grc",[170],{"n":82,"url":174,"height":175,"width":176,"desc":177,"surfaceType":87},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[179],{"atLeast":180,"atMost":180},30,[93,182,94,183],"Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[99,185,100,186],"ILQ4RQGU","JQQKI6JP",[188,189,190,125,129,133,105,106,107,108,106,191,192,171],"isic004411","epitaph for kratisstos",{"_":123},"museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":195,"ptr":196,"ref":197,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"27 fig.14",{"target":115},{"_":117,"target":117},{"file":199,"uri":199,"title":200,"status":201,"editionAuthor":13,"type":202,"objectType":203,"material":207,"condition":38,"layoutDesc":208,"handNote":212,"date":217,"places":221,"geo":225,"country":60,"provenance":57,"provenanceGeo":227,"region":73,"settlement":62,"repository":228,"idno":232,"textLang":233,"tmNumber":38,"facsimile":235,"letterHeights":237,"publications":239,"zotero":240,"keywords":241,"html":246,"bibl":247,"bulletinDateSort":118,"citedRangeSort":248,"languageSort":170,"materialSort":133,"typeSort":125},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":123},{"_":125,"ana":126,"ref":127},{"_":204,"ana":205,"ref":206},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":133,"ana":134,"type":135,"subtype":27,"ref":136},{"layout":209},{"p":210,"rs":211,"damage":38},"Single line of greek letters approximately centred on the face of the plinth",{"_":35,"ana":36,"ref":37},{"lettering":213,"dimensions":214},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[215,216],{"type":43,"l":145,"from":45,"to":45,"h":146,"unit":47,"atLeast":146,"atMost":146},{"type":49,"l":50,"from":45,"to":46,"h":148,"unit":47},{"_":218,"notBefore":219,"notAfter":220,"evidence":153},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,[222,224],{"_":57,"type":58,"ref":59,"corresp":223,"region":60},"#findspot",{"_":62,"type":63,"ref":64,"offset":65,"region":60},[226],[68,69],[160,161],{"_":229,"role":230,"ref":231},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":168},{"_":170,"mainLang":171,"languages":234},[170],{"n":82,"url":236,"height":175,"width":176,"desc":177,"surfaceType":87},"ISic004415_tiled.tif",[238],{"atLeast":180,"atMost":180},[93,183],[99,186],[242,243,244,125,204,133,105,106,107,108,106,245,192,171],"isic004415","epitaph for krimma, child of aunakos",{"_":123},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":248,"ptr":249,"ref":250,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"28 fig.15 (and ref on p.113)",{"target":115},{"_":117,"target":117},{"file":252,"uri":252,"title":253,"status":254,"editionAuthor":13,"type":255,"objectType":256,"material":257,"condition":38,"layoutDesc":258,"handNote":262,"date":268,"places":269,"geo":272,"country":60,"provenance":57,"provenanceGeo":274,"region":73,"settlement":62,"repository":275,"idno":276,"textLang":277,"tmNumber":38,"facsimile":279,"letterHeights":281,"publications":284,"zotero":285,"keywords":286,"html":290,"bibl":291,"bulletinDateSort":118,"citedRangeSort":248,"languageSort":170,"materialSort":133,"typeSort":125},"ISic004416","Epitaph for Philon, son Aunakos",{"_":123},{"_":125,"ana":126,"ref":127},{"_":204,"ana":205,"ref":206},{"_":133,"ana":134,"type":135,"subtype":27,"ref":136},{"layout":259},{"p":260,"rs":261,"damage":38},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":35,"ana":36,"ref":37},{"lettering":263,"dimensions":264},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[265,267],{"type":43,"l":145,"from":45,"to":45,"h":266,"unit":47,"atLeast":266,"atMost":266},"59",{"type":49,"l":50,"from":45,"to":46,"h":148,"unit":47},{"_":218,"notBefore":219,"notAfter":220,"evidence":153},[270,271],{"_":57,"type":58,"ref":59,"corresp":223,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[273],[68,69],[160,161],{"_":229,"role":230,"ref":231},{"type":168},{"_":170,"mainLang":171,"languages":278},[170],{"n":82,"url":280,"height":175,"width":176,"desc":177,"surfaceType":87},"ISic004416_tiled.tif",[282],{"atLeast":283,"atMost":283},59,[93,183],[99,186],[287,288,289,125,204,133,105,106,107,108,106,245,192,171],"isic004416","epitaph for philon, son aunakos",{"_":123},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":248,"ptr":292,"ref":293,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":115},{"_":117,"target":117},{"file":295,"uri":295,"title":296,"status":297,"editionAuthor":13,"type":298,"objectType":299,"material":300,"condition":38,"layoutDesc":301,"handNote":304,"date":309,"places":312,"geo":315,"country":60,"provenance":57,"provenanceGeo":317,"region":73,"settlement":62,"repository":318,"idno":319,"textLang":321,"tmNumber":38,"facsimile":323,"letterHeights":325,"publications":327,"zotero":328,"keywords":329,"html":333,"bibl":334,"bulletinDateSort":118,"citedRangeSort":335,"languageSort":170,"materialSort":133,"typeSort":125},"ISic004414","Epitaph for Eupolemos",{"_":123},{"_":125,"ana":126,"ref":127},{"_":129,"ana":130,"ref":131},{"_":133,"ana":134,"type":135,"subtype":27,"ref":136},{"layout":302},{"p":139,"rs":303,"damage":38},{"_":35,"ana":36,"ref":37},{"lettering":305,"dimensions":306},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[307,308],{"type":43,"l":145,"from":45,"to":45,"h":146,"unit":47,"atLeast":146,"atMost":146},{"type":49,"l":50,"from":45,"to":46,"h":148,"unit":47},{"_":310,"notBefore":311,"notAfter":220,"evidence":153},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,[313,314],{"_":57,"type":58,"ref":59,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[316],[68,69],[160,161],{"_":163,"role":164,"ref":165},{"_":320,"type":168},"ME23438",{"_":170,"mainLang":171,"languages":322},[170],{"n":82,"url":324,"height":175,"width":176,"desc":177,"surfaceType":87},"ISic004414_tiled.tif",[326],{"atLeast":180,"atMost":180},[93,182,94,183],[99,185,100,186],[330,331,332,125,129,133,105,106,107,108,106,191,192,171],"isic004414","epitaph for eupolemos",{"_":123},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":335,"ptr":336,"ref":337,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"41 fig.23",{"target":115},{"_":117,"target":117},{"file":339,"uri":339,"title":340,"status":341,"editionAuthor":13,"type":342,"objectType":343,"material":344,"condition":38,"layoutDesc":345,"handNote":349,"date":355,"places":357,"geo":360,"country":60,"provenance":57,"provenanceGeo":362,"region":73,"settlement":62,"repository":363,"idno":364,"textLang":365,"tmNumber":38,"facsimile":367,"letterHeights":369,"publications":371,"zotero":372,"keywords":373,"html":377,"bibl":378,"bulletinDateSort":118,"citedRangeSort":379,"languageSort":170,"materialSort":133,"typeSort":125},"ISic004418","Epitaph for [-?-], child of Gerontios",{"_":123},{"_":125,"ana":126,"ref":127},{"_":204,"ana":205,"ref":206},{"_":133,"ana":134,"type":135,"subtype":27,"ref":136},{"layout":346},{"p":347,"rs":348,"damage":38},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":35,"ana":36,"ref":37},{"lettering":350,"dimensions":351},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[352,354],{"type":43,"l":353,"from":45,"to":46,"h":266,"unit":47,"atLeast":266,"atMost":266},"Line 1-2",{"type":49,"l":50,"from":45,"to":46,"unit":47},{"_":356,"notBefore":219,"notAfter":220,"evidence":153},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[358,359],{"_":57,"type":58,"ref":59,"corresp":223,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[361],[68,69],[160,161],{"_":229,"role":230,"ref":231},{"type":168},{"_":170,"mainLang":171,"languages":366},[170],{"n":82,"url":368,"height":175,"width":176,"desc":177,"surfaceType":87},"ISic004418_tiled.tif",[370],{"atLeast":283,"atMost":283},[93,94,183],[99,100,186],[374,375,376,125,204,133,105,106,107,108,106,245,192,171],"isic004418","epitaph for [-?-], child of gerontios",{"_":123},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":379,"ptr":380,"ref":381,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"113 and 166 tav.XXXIVa",{"target":115},{"_":117,"target":117},{"file":383,"uri":383,"title":340,"status":384,"editionAuthor":13,"type":385,"objectType":386,"material":387,"condition":38,"layoutDesc":388,"handNote":392,"date":397,"places":398,"geo":401,"country":60,"provenance":57,"provenanceGeo":403,"region":73,"settlement":62,"repository":404,"idno":405,"textLang":406,"tmNumber":38,"facsimile":408,"lette