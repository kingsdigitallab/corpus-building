gion":61},[158],[69,70],[160,161],38.06519,15.11438,{"_":163,"role":164,"ref":165},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":167,"type":168},"ME23435","inventory",{"_":170,"mainLang":171,"languages":172},"Ancient Greek","grc",[170],{"n":83,"url":174,"height":175,"width":176,"desc":177,"surfaceType":88},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[179],{"atLeast":180,"atMost":180},30,[94,182,95,183],"Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[100,185,101,186],"ILQ4RQGU","JQQKI6JP",[188,189,190,126,130,134,106,107,108,109,107,191,192,171],"isic004411","epitaph for kratisstos",{"_":124},"museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":195,"ptr":196,"ref":197,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"27 fig.14",{"target":116},{"_":118,"target":118},{"file":199,"uri":199,"title":200,"status":201,"editionAuthor":13,"type":202,"objectType":203,"material":207,"condition":39,"layoutDesc":209,"handNote":213,"date":218,"places":222,"geo":226,"country":61,"provenance":58,"provenanceGeo":228,"region":74,"settlement":63,"repository":229,"idno":233,"textLang":234,"tmNumber":39,"facsimile":236,"letterHeights":238,"publications":240,"zotero":241,"keywords":242,"html":247,"bibl":248,"bulletinDateSort":119,"citedRangeSort":249,"languageSort":170,"materialSort":134,"typeSort":126},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":124},{"_":126,"ana":127,"ref":128},{"_":204,"ana":205,"ref":206},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":134,"ana":25,"type":26,"subtype":208,"ref":136},[28],{"layout":210},{"p":211,"rs":212,"damage":39},"Single line of greek letters approximately centred on the face of the plinth",{"_":36,"ana":37,"ref":38},{"lettering":214,"dimensions":215},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[216,217],{"type":44,"l":145,"from":46,"to":46,"h":146,"unit":48,"atLeast":146,"atMost":146},{"type":50,"l":51,"from":46,"to":47,"h":148,"unit":48},{"_":219,"notBefore":220,"notAfter":221,"evidence":153},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,[223,225],{"_":58,"type":59,"ref":60,"corresp":224,"region":61},"#findspot",{"_":63,"type":64,"ref":65,"offset":66,"region":61},[227],[69,70],[160,161],{"_":230,"role":231,"ref":232},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":168},{"_":170,"mainLang":171,"languages":235},[170],{"n":83,"url":237,"height":175,"width":176,"desc":177,"surfaceType":88},"ISic004415_tiled.tif",[239],{"atLeast":180,"atMost":180},[94,183],[100,186],[243,244,245,126,204,134,106,107,108,109,107,246,192,171],"isic004415","epitaph for krimma, child of aunakos",{"_":124},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":249,"ptr":250,"ref":251,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"28 fig.15 (and ref on p.113)",{"target":116},{"_":118,"target":118},{"file":253,"uri":253,"title":254,"status":255,"editionAuthor":13,"type":256,"objectType":257,"material":258,"condition":39,"layoutDesc":260,"handNote":264,"date":270,"places":271,"geo":274,"country":61,"provenance":58,"provenanceGeo":276,"region":74,"settlement":63,"repository":277,"idno":278,"textLang":279,"tmNumber":39,"facsimile":281,"letterHeights":283,"publications":286,"zotero":287,"keywords":288,"html":292,"bibl":293,"bulletinDateSort":119,"citedRangeSort":249,"languageSort":170,"materialSort":134,"typeSort":126},"ISic004416","Epitaph for Philon, son Aunakos",{"_":124},{"_":126,"ana":127,"ref":128},{"_":204,"ana":205,"ref":206},{"_":134,"ana":25,"type":26,"subtype":259,"ref":136},[28],{"layout":261},{"p":262,"rs":263,"damage":39},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":36,"ana":37,"ref":38},{"lettering":265,"dimensions":266},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[267,269],{"type":44,"l":145,"from":46,"to":46,"h":268,"unit":48,"atLeast":268,"atMost":268},"59",{"type":50,"l":51,"from":46,"to":47,"h":148,"unit":48},{"_":219,"notBefore":220,"notAfter":221,"evidence":153},[272,273],{"_":58,"type":59,"ref":60,"corresp":224,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[275],[69,70],[160,161],{"_":230,"role":231,"ref":232},{"type":168},{"_":170,"mainLang":171,"languages":280},[170],{"n":83,"url":282,"height":175,"width":176,"desc":177,"surfaceType":88},"ISic004416_tiled.tif",[284],{"atLeast":285,"atMost":285},59,[94,183],[100,186],[289,290,291,126,204,134,106,107,108,109,107,246,192,171],"isic004416","epitaph for philon, son aunakos",{"_":124},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":249,"ptr":294,"ref":295,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":116},{"_":118,"target":118},{"file":297,"uri":297,"title":298,"status":299,"editionAuthor":13,"type":300,"objectType":301,"material":302,"condition":39,"layoutDesc":304,"handNote":307,"date":312,"places":315,"geo":318,"country":61,"provenance":58,"provenanceGeo":320,"region":74,"settlement":63,"repository":321,"idno":322,"textLang":324,"tmNumber":39,"facsimile":326,"letterHeights":328,"publications":330,"zotero":331,"keywords":332,"html":336,"bibl":337,"bulletinDateSort":119,"citedRangeSort":338,"languageSort":170,"materialSort":134,"typeSort":126},"ISic004414","Epitaph for Eupolemos",{"_":124},{"_":126,"ana":127,"ref":128},{"_":130,"ana":131,"ref":132},{"_":134,"ana":25,"type":26,"subtype":303,"ref":136},[28],{"layout":305},{"p":139,"rs":306,"damage":39},{"_":36,"ana":37,"ref":38},{"lettering":308,"dimensions":309},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[310,311],{"type":44,"l":145,"from":46,"to":46,"h":146,"unit":48,"atLeast":146,"atMost":146},{"type":50,"l":51,"from":46,"to":47,"h":148,"unit":48},{"_":313,"notBefore":314,"notAfter":221,"evidence":153},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,[316,317],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[319],[69,70],[160,161],{"_":163,"role":164,"ref":165},{"_":323,"type":168},"ME23438",{"_":170,"mainLang":171,"languages":325},[170],{"n":83,"url":327,"height":175,"width":176,"desc":177,"surfaceType":88},"ISic004414_tiled.tif",[329],{"atLeast":180,"atMost":180},[94,182,95,183],[100,185,101,186],[333,334,335,126,130,134,106,107,108,109,107,191,192,171],"isic004414","epitaph for eupolemos",{"_":124},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":338,"ptr":339,"ref":340,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"41 fig.23",{"target":116},{"_":118,"target":118},{"file":342,"uri":342,"title":343,"status":344,"editionAuthor":13,"type":345,"objectType":346,"material":347,"condition":39,"layoutDesc":349,"handNote":353,"date":359,"places":361,"geo":364,"country":61,"provenance":58,"provenanceGeo":366,"region":74,"settlement":63,"repository":367,"idno":368,"textLang":369,"tmNumber":39,"facsimile":371,"letterHeights":373,"publications":375,"zotero":376,"keywords":377,"html":381,"bibl":382,"bulletinDateSort":119,"citedRangeSort":383,"languageSort":170,"materialSort":134,"typeSort":126},"ISic004418","Epitaph for [-?-], child of Gerontios",{"_":124},{"_":126,"ana":127,"ref":128},{"_":204,"ana":205,"ref":206},{"_":134,"ana":25,"type":26,"subtype":348,"ref":136},[28],{"layout":350},{"p":351,"rs":352,"damage":39},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":36,"ana":37,"ref":38},{"lettering":354,"dimensions":355},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[356,358],{"type":44,"l":357,"from":46,"to":47,"h":268,"unit":48,"atLeast":268,"atMost":268},"Line 1-2",{"type":50,"l":51,"from":46,"to":47,"unit":48},{"_":360,"notBefore":220,"notAfter":221,"evidence":153},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[362,363],{"_":58,"type":59,"ref":60,"corresp":224,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[365],[69,70],[160,161],{"_":230,"role":231,"ref":232},{"type":168},{"_":170,"mainLang":171,"languages":370},[170],{"n":83,"url":372,"height":175,"width":176,"desc":177,"surfaceType":88},"ISic004418_tiled.tif",[374],{"atLeast":285,"atMost":285},[94,95,183],[100,101,186],[378,379,380,126,204,134,106,107,108,109,107,246,192,171],"isic004418","epitaph for [-?-], child of gerontios",{"_":124},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":383,"ptr":384,"ref":385,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"113 and 166 tav.XXXIVa",{"target":116},{"_":118,"target":118},{"file":387,"uri":387,"title":343,"status":388,"editionAuthor":13,"type":389,"objectType":390,"material":391,"condition":39,"layoutDesc":393,"handNote":397,"date":402,"places":403,"geo":406,"country":61,"provenance":58,"provenanceGeo":408,"region":74,"settlement":63,"repository":409,"idno":410,"textLang":411,"tmNumber":39,"facsimile":413,"letterHeights":415,"publications":417,"zotero":418,"keywords":419,