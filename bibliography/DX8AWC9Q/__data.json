Siciliana",[],[85,168,86,169],"Bacci et al., 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[91,171,92,172],"ILQ4RQGU","JQQKI6JP",[174,175,176,117,121,125,97,98,99,100,98,177,178,159],"isic004411","epitaph for kratisstos",{"_":115},"museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":181,"ptr":182,"ref":184,"title":2,"citation":4},"27 fig.14",{"target":183},"http://zotero.org/groups/382445/items/DX8AWC9Q",{"_":110,"target":110},{"file":186,"uri":186,"title":187,"status":188,"editionAuthor":11,"type":189,"objectType":190,"material":191,"condition":34,"layoutDesc":192,"handNote":195,"date":200,"places":204,"geo":207,"country":65,"region":66,"settlement":57,"repository":209,"idno":210,"textLang":212,"facsimile":214,"provenance":53,"letterHeights":216,"publications":217,"zotero":218,"keywords":219,"html":223,"bibl":224},"ISic004414","Epitaph for Eupolemos",{"_":115},{"_":117,"ana":118,"ref":119},{"_":121,"ana":122,"ref":123},{"_":125,"ana":126,"ref":127},{"layout":193},{"p":130,"rs":194,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":196,"dimensions":197},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[198,199],{"type":39,"l":136,"from":41,"to":41,"h":137,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":139,"unit":43},{"_":201,"notBefore":202,"notAfter":203,"evidence":144,"precision":16},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[205,206],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[208],[63,64],{"_":151,"role":152,"ref":153},{"_":211,"type":156},"ME23438",{"_":158,"mainLang":159,"languages":213},[158],{"n":74,"url":215,"height":163,"width":164,"desc":165,"surfaceType":79},"ISic004414_tiled.tif",[],[85,168,86,169],[91,171,92,172],[220,221,222,117,121,125,97,98,99,100,98,177,178,159],"isic004414","epitaph for eupolemos",{"_":115},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":225,"ptr":226,"ref":227,"title":2,"citation":4},"41 fig.23",{"target":183},{"_":110,"target":110},{"file":229,"uri":229,"title":230,"status":231,"editionAuthor":11,"type":232,"objectType":233,"material":237,"condition":34,"layoutDesc":238,"handNote":242,"date":247,"places":250,"geo":254,"country":65,"region":66,"settlement":57,"repository":256,"idno":260,"textLang":261,"facsimile":263,"provenance":53,"letterHeights":265,"publications":266,"zotero":267,"keywords":268,"html":273,"bibl":274},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":115},{"_":117,"ana":118,"ref":119},{"_":234,"ana":235,"ref":236},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":125,"ana":126,"ref":127},{"layout":239},{"p":240,"rs":241,"damage":34},"Single line of greek letters approximately centred on the face of the plinth",{"_":31,"ana":32,"ref":33},{"lettering":243,"dimensions":244},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[245,246],{"type":39,"l":136,"from":41,"to":41,"h":137,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":139,"unit":43},{"_":248,"notBefore":249,"notAfter":203,"evidence":144,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,[251,253],{"_":53,"type":54,"ref":55,"corresp":252},"#findspot",{"_":57,"type":58,"ref":59,"offset":60},[255],[63,64],{"_":257,"role":258,"ref":259},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":156},{"_":158,"mainLang":159,"languages":262},[158],{"n":74,"url":264,"height":163,"width":164,"desc":165,"surfaceType":79},"ISic004415_tiled.tif",[],[85,169],[91,172],[269,270,271,117,234,125,97,98,99,100,98,272,178,159],"isic004415","epitaph for krimma, child of aunakos",{"_":115},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":275,"ptr":276,"ref":277,"title":2,"citation":4},"28 fig.15 (and ref on p.113)",{"target":183},{"_":110,"target":110},{"file":279,"uri":279,"title":280,"status":281,"editionAuthor":11,"type":282,"objectType":283,"material":284,"condition":34,"layoutDesc":285,"handNote":289,"date":295,"places":296,"geo":299,"country":65,"region":66,"settlement":57,"repository":301,"idno":302,"textLang":303,"facsimile":305,"provenance":53,"letterHeights":307,"publications":308,"zotero":309,"keywords":310,"html":314,"bibl":315},"ISic004416","Epitaph for Philon, son Aunakos",{"_":115},{"_":117,"ana":118,"ref":119},{"_":234,"ana":235,"ref":236},{"_":125,"ana":126,"ref":127},{"layout":286},{"p":287,"rs":288,"damage":34},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":31,"ana":32,"ref":33},{"lettering":290,"dimensions":291},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[292,294],{"type":39,"l":136,"from":41,"to":41,"h":293,"unit":43},"59",{"type":45,"l":46,"from":41,"to":42,"h":139,"unit":43},{"_":248,"notBefore":249,"notAfter":203,"evidence":144,"precision":16},[297,298],{"_":53,"type":54,"ref":55,"corresp":252},{"_":57,"type":58,"ref":59,"offset":60},[300],[63,64],{"_":257,"role":258,"ref":259},{"type":156},{"_":158,"mainLang":159,"languages":304},[158],{"n":74,"url":306,"height":163,"width":164,"desc":165,"surfaceType":79},"ISic004416_tiled.tif",[],[85,169],[91,172],[311,312,313,117,234,125,97,98,99,100,98,272,178,159],"isic004416","epitaph for philon, son aunakos",{"_":115},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":275,"ptr":316,"ref":317,"title":2,"citation":4},{"target":183},{"_":110,"target":110},{"file":319,"uri":319,"title":320,"status":321,"editionAuthor":11,"type":322,"objectType":323,"material":324,"condition":34,"layoutDesc":325,"handNote":329,"date":335,"places":336,"geo":339,"country":65,"region":66,"settlement":57,"repository":341,"idno":342,"textLang":343,"facsimile":345,"provenance":53,"letterHeights":347,"publications":348,"zotero":349,"keywords":350,"html":354,"bibl":355},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":115},{"_":117,"ana":118,"ref":119},{"_":234,"ana":235,"ref":236},{"_":125,"ana":126,"ref":127},{"layout":326},{"p":327,"rs":328,"damage":34},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":31,"ana":32,"ref":33},{"lettering":330,"dimensions":331},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[332,334],{"type":39,"l":333,"from":41,"to":42,"h":137,"unit":43},"Line 1-2",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":248,"notBefore":249,"notAfter":203,"evidence":144,"precision":16},[337,338],{"_":53,"type":54,"ref":55,"corresp":252},{"_":57,"type":58,"ref":59,"offset":60},[340],[63,64],{"_":257,"role":258,"ref":259},{"type":156},{"_":158,"mainLang":159,"languages":344},[158],{"n":74,"url":346,"height":163,"width":164,"desc":165,"surfaceType":79},"ISic004417_tiled.tif",[],[85,86,169],[91,92,172],[351,352,353,117,234,125,97,98,99,100,98,272,178,159],"isic004417","epitaph for [-?-], child of gerontios",{"_":115},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":356,"ptr":357,"ref":358,"title":2,"citation":4},"113 and 166 tav.XXXIVa-b",{"target":183},{"_":110,"target":110},{"file":360,"uri":360,"title":320,"status":361,"editionAuthor":11,"type":362,"objectType":363,"material":364,"condition":34,"layoutDesc":365,"handNote":369,"date":374,"places":376,"geo":379,"country":65,"region":66,"settlement":57,"repository":381,"idno":382,"textLang":383,"facsimile":385,"provenance":53,"letterHeights":387,"publications":388,"zotero":389,"keywords":390,"html":393,"bibl":394},"ISic004418",{"_":115},{"_":117,"ana":118,"ref":119},{"_":234,"ana":235,"ref":236},{"_":125,"ana":126,"ref":127},{"layout":366},{"p":367,"rs":368,"damage":34},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":370,"dimensions":371},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[372,373],{"type":39,"l":333,"from":41,"to":42,"h":293,"unit":43},{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":375,"notBefore":249,"notAfter":203,"evidence":144,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[377,378],{"_":53,"type":54,"ref":55,"corresp":252},{"_":57,"type":58,"ref":59,"offset":60},[380],[63,64],{"_":257,"role":258,"ref":259},{"type":156},{"_":158,"mainLang":159,"languages":384},[158],{"n":74,"url":386,"height":163,"width":164,"desc":165,"surfaceType":79},"ISic004418_tiled.tif",[],[85,86,169],[91,92,172],[391,352,392,117,234,125,97,98,99,100,98,272,178,159],"isic004418",{"_":115},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":395,"ptr":396,"ref":397,"title":2,"citation":4},"113 a