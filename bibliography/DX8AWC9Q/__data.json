"dimensions":187},"thinly incised regular letters with minimal serifs",[188,190],{"type":38,"l":189,"from":40,"to":41,"unit":43},"Lines 1-2",{"type":45,"l":46,"from":40,"to":41,"unit":43},{"_":192,"notBefore":193,"notAfter":194},"Presumably 1st or 2nd century CE",1,200,[196,197],{"_":54,"type":55,"ref":56},{"_":59,"type":60,"ref":61,"offset":62},[199],[65,66],[201,202],38.0572,15.10404,"(near) Tripi","Current location unknown",{"_":206,"mainLang":207,"languages":208},"Latin","la",[206],"175831",{"n":83,"url":211,"height":212,"width":213,"desc":214,"surfaceType":88},"ISic000623_tiled.tif","1644px","1715px","Scan of NSA 1954 p.49 fig.4",[],[217,218,219,93,94],"L'année épigraphique: revue des publications épigraphiques relatives a l'antiquité romaine., 1888-","Wilson, 1990, Sicily under the Roman Empire: the archaeology of a Roman province, 36 B.C. - A.D. 535","Notizie degli scavi di antichità, 1876-",[221,222,223,97,98],"R46KDTZX","VF9MMBI9","4MCP2PVV",[225,226,227,167,172,176,104,105,106,107,228,229,207],"isic000623","fragmentary latin inscription",{"_":165},"(near) tripi","latin","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]nius[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan class=\"supraline\" title=\"line above\">II\u003C/span>viṛ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":232,"ptr":233,"ref":235,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"13 fig.2",{"target":234},"https://www.zotero.org/groups/382445/items/DX8AWC9Q",{"_":116,"target":116},{"file":237,"uri":237,"title":238,"status":239,"editionAuthor":13,"type":240,"objectType":241,"material":245,"condition":26,"layoutDesc":246,"handNote":250,"date":257,"places":261,"geo":264,"provenance":54,"provenanceGeo":266,"country":70,"region":71,"settlement":59,"repository":267,"idno":271,"textLang":273,"tmNumber":26,"facsimile":275,"letterHeights":277,"publications":279,"zotero":281,"keywords":283,"html":288,"bibl":289,"bulletinDateSort":117,"citedRangeSort":290,"languageSort":79,"materialSort":23,"typeSort":15},"ISic004411","Epitaph for Kratisstos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":242,"ana":243,"ref":244},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":23,"ana":24,"ref":25},{"layout":247},{"p":248,"rs":249,"damage":26},"Single line of Greek letters filling the width of the stone",{"_":31,"ana":32,"ref":33},{"lettering":251,"dimensions":252},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[253,255],{"type":38,"l":254,"from":40,"to":40,"h":132,"unit":43,"atLeast":132,"atMost":132},"Line 1",{"type":45,"l":46,"from":40,"to":41,"h":256,"unit":43},"NA",{"_":258,"notBefore":259,"notAfter":260,"evidence":51},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,[262,263],{"_":54,"type":55,"ref":56},{"_":59,"type":60,"ref":61,"offset":62},[265],[65,66],[68,69],{"_":268,"role":269,"ref":270},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":272,"type":77},"ME23435",{"_":79,"mainLang":80,"languages":274},[79],{"n":83,"url":276,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004411_tiled.tif",[278],{"atLeast":150,"atMost":150},[93,280,94,95],"Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione",[97,282,98,99],"ILQ4RQGU",[284,285,286,15,242,23,104,105,106,107,105,287,109,80],"isic004411","epitaph for kratisstos",{"_":12},"museo archeologico santi furnari di tripi","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":290,"ptr":291,"ref":292,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"27 fig.14",{"target":114},{"_":116,"target":116},{"file":294,"uri":294,"title":295,"status":296,"editionAuthor":13,"type":297,"objectType":298,"material":299,"condition":26,"layoutDesc":300,"handNote":304,"date":309,"places":310,"geo":313,"provenance":54,"provenanceGeo":315,"country":70,"region":71,"settlement":59,"repository":316,"idno":317,"textLang":318,"tmNumber":26,"facsimile":320,"letterHeights":322,"publications":324,"zotero":325,"keywords":326,"html":330,"bibl":331,"bulletinDateSort":117,"citedRangeSort":332,"languageSort":79,"materialSort":23,"typeSort":15},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":301},{"p":302,"rs":303,"damage":26},"Single line of greek letters approximately centred on the face of the plinth",{"_":31,"ana":32,"ref":33},{"lettering":305,"dimensions":306},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[307,308],{"type":38,"l":254,"from":40,"to":40,"h":132,"unit":43,"atLeast":132,"atMost":132},{"type":45,"l":46,"from":40,"to":41,"h":256,"unit":43},{"_":135,"notBefore":49,"notAfter":50,"evidence":51},[311,312],{"_":54,"type":55,"ref":56,"corresp":57},{"_":59,"type":60,"ref":61,"offset":62},[314],[65,66],[68,69],{"_":73,"role":74,"ref":75},{"type":77},{"_":79,"mainLang":80,"languages":319},[79],{"n":83,"url":321,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004415_tiled.tif",[323],{"atLeast":150,"atMost":150},[93,95],[97,99],[327,328,329,15,19,23,104,105,106,107,105,108,109,80],"isic004415","epitaph for krimma, child of aunakos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":332,"ptr":333,"ref":334,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"28 fig.15 (and ref on p.113)",{"target":114},{"_":116,"target":116},{"file":336,"uri":336,"title":337,"status":338,"editionAuthor":13,"type":339,"objectType":340,"material":341,"condition":26,"layoutDesc":342,"handNote":346,"date":351,"places":352,"geo":355,"provenance":54,"provenanceGeo":357,"country":70,"region":71,"settlement":59,"repository":358,"idno":359,"textLang":360,"tmNumber":26,"facsimile":362,"letterHeights":364,"publications":366,"zotero":367,"keywords":368,"html":372,"bibl":373,"bulletinDateSort":117,"citedRangeSort":332,"languageSort":79,"materialSort":23,"typeSort":15},"ISic004416","Epitaph for Philon, son Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":343},{"p":344,"rs":345,"damage":26},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":31,"ana":32,"ref":33},{"lettering":347,"dimensions":348},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[349,350],{"type":38,"l":254,"from":40,"to":40,"h":42,"unit":43,"atLeast":42,"atMost":42},{"type":45,"l":46,"from":40,"to":41,"h":256,"unit":43},{"_":135,"notBefore":49,"notAfter":50,"evidence":51},[353,354],{"_":54,"type":55,"ref":56,"corresp":57},{"_":59,"type":60,"ref":61,"offset":62},[356],[65,66],[68,69],{"_":73,"role":74,"ref":75},{"type":77},{"_":79,"mainLang":80,"languages":361},[79],{"n":83,"url":363,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004416_tiled.tif",[365],{"atLeast":91,"atMost":91},[93,95],[97,99],[369,370,371,15,19,23,104,105,106,107,105,108,109,80],"isic004416","epitaph for philon, son aunakos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":332,"ptr":374,"ref":375,"inscriptionDate":4,"title":2,"citation":5,"uri":6},{"target":114},{"_":116,"target":116},{"file":377,"uri":377,"title":378,"status":379,"editionAuthor":13,"type":380,"objectType":381,"material":382,"condition":26,"layoutDesc":383,"handNote":386,"date":391,"places":394,"geo":397,"provenance":54,"provenanceGeo":399,"country":70,"region":71,"settlement":59,"repository":400,"idno":401,"textLang":403,"tmNumber":26,"facsimile":405,"letterHeights":407,"publications":409,"zotero":410,"keywords":411,"html":415,"bibl":416,"bulletinDateSort":117,"citedRangeSort":417,"languageSort":79,"materialSort":23,"typeSort":15},"ISic004414","Epitaph for Eupolemos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":242,"ana":243,"ref":244},{"_":23,"ana":24,"ref":25},{"layout":384},{"p":248,"rs":385,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":387,"dimensions":388},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[389,390],{"type":38,"l":254,"from":40,"to":40,"h":132,"unit":43,"atLeast":132,"atMost":132},{"type":45,"l":46,"from":40,"to":41,"h":256,"unit":43},{"_":392,"notBefore":393,"notAfter":50,"evidence":51},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,[395,396],{"_":54,"type":55,"ref":56},{"_":59,"type":60,"ref":61,"offset":62},[398],[65,66],[68,69],{"_":268,"role":269,"ref":270},{"_":402,"type":77},"ME23438",{"_":79,"mainLang":80,"languages":404},[79],{"n":83,"url":406,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004414_tiled.tif",[408],{"atLeast":150,"atMost":150},[93,280,94,95],[97,282,98,99],[412,413,414,15,242,23,104,105,106,107,105,287,109,80],"isic004414","epitaph for eupolemos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":417,"ptr":418,"ref":419,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"41 fig.23",{"target":114},{"_":116,"target":116},false],"uses":{"params":["slug"]}}]}
