/items/DX8AWC9Q",{"_":115,"target":115},"https://biblio.inscriptiones.org/epig10002171",2009,{"file":118,"uri":118,"title":119,"status":120,"editionAuthor":13,"type":122,"objectType":126,"material":130,"condition":36,"layoutDesc":134,"handNote":138,"date":146,"places":151,"geo":154,"country":58,"provenance":55,"provenanceGeo":156,"region":71,"settlement":60,"repository":159,"idno":163,"textLang":166,"tmNumber":36,"facsimile":170,"letterHeights":175,"publications":178,"zotero":181,"keywords":184,"html":190,"bibl":191,"bulletinDateSort":116,"citedRangeSort":192,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004411","Epitaph for Kratisstos",{"_":121},"edited",{"_":123,"ana":124,"ref":125},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":127,"ana":128,"ref":129},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":131,"ana":132,"ref":133},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":135},{"p":136,"rs":137,"damage":36},"Single line of Greek letters filling the width of the stone",{"_":33,"ana":34,"ref":35},{"lettering":139,"dimensions":140},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[141,144],{"type":41,"l":142,"from":43,"to":43,"h":143,"unit":45,"atLeast":143,"atMost":143},"Line 1","30",{"type":47,"l":48,"from":43,"to":44,"h":145,"unit":45},"NA",{"_":147,"notBefore":148,"notAfter":149,"evidence":150},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[152,153],{"_":55,"type":56,"ref":57,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[155],[66,67],[157,158],38.06519,15.11438,{"_":160,"role":161,"ref":162},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":164,"type":165},"ME23435","inventory",{"_":167,"mainLang":168,"languages":169},"Ancient Greek","grc",[167],{"n":80,"url":171,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[176],{"atLeast":177,"atMost":177},30,[91,179,92,180],"Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[97,182,98,183],"ILQ4RQGU","JQQKI6JP",[185,186,187,123,127,131,103,104,105,106,104,188,189,168],"isic004411","epitaph for kratisstos",{"_":121},"museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":192,"ptr":193,"ref":195,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"27 fig.14",{"target":194},"http://zotero.org/groups/382445/items/DX8AWC9Q",{"_":115,"target":115},{"file":197,"uri":197,"title":198,"status":199,"editionAuthor":13,"type":200,"objectType":201,"material":205,"condition":36,"layoutDesc":206,"handNote":210,"date":215,"places":219,"geo":223,"country":58,"provenance":55,"provenanceGeo":225,"region":71,"settlement":60,"repository":226,"idno":230,"textLang":231,"tmNumber":36,"facsimile":233,"letterHeights":235,"publications":237,"zotero":238,"keywords":239,"html":244,"bibl":245,"bulletinDateSort":116,"citedRangeSort":246,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":121},{"_":123,"ana":124,"ref":125},{"_":202,"ana":203,"ref":204},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":131,"ana":132,"ref":133},{"layout":207},{"p":208,"rs":209,"damage":36},"Single line of greek letters approximately centred on the face of the plinth",{"_":33,"ana":34,"ref":35},{"lettering":211,"dimensions":212},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[213,214],{"type":41,"l":142,"from":43,"to":43,"h":143,"unit":45,"atLeast":143,"atMost":143},{"type":47,"l":48,"from":43,"to":44,"h":145,"unit":45},{"_":216,"notBefore":217,"notAfter":218,"evidence":150},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,[220,222],{"_":55,"type":56,"ref":57,"corresp":221,"region":58},"#findspot",{"_":60,"type":61,"ref":62,"offset":63,"region":58},[224],[66,67],[157,158],{"_":227,"role":228,"ref":229},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":165},{"_":167,"mainLang":168,"languages":232},[167],{"n":80,"url":234,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004415_tiled.tif",[236],{"atLeast":177,"atMost":177},[91,180],[97,183],[240,241,242,123,202,131,103,104,105,106,104,243,189,168],"isic004415","epitaph for krimma, child of aunakos",{"_":121},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":246,"ptr":247,"ref":248,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"28 fig.15 (and ref on p.113)",{"target":194},{"_":115,"target":115},{"file":250,"uri":250,"title":251,"status":252,"editionAuthor":13,"type":253,"objectType":254,"material":255,"condition":36,"layoutDesc":256,"handNote":260,"date":266,"places":267,"geo":270,"country":58,"provenance":55,"provenanceGeo":272,"region":71,"settlement":60,"repository":273,"idno":274,"textLang":275,"tmNumber":36,"facsimile":277,"letterHeights":279,"publications":282,"zotero":283,"keywords":284,"html":288,"bibl":289,"bulletinDateSort":116,"citedRangeSort":246,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004416","Epitaph for Philon, son Aunakos",{"_":121},{"_":123,"ana":124,"ref":125},{"_":202,"ana":203,"ref":204},{"_":131,"ana":132,"ref":133},{"layout":257},{"p":258,"rs":259,"damage":36},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":33,"ana":34,"ref":35},{"lettering":261,"dimensions":262},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[263,265],{"type":41,"l":142,"from":43,"to":43,"h":264,"unit":45,"atLeast":264,"atMost":264},"59",{"type":47,"l":48,"from":43,"to":44,"h":145,"unit":45},{"_":216,"notBefore":217,"notAfter":218,"evidence":150},[268,269],{"_":55,"type":56,"ref":57,"corresp":221,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[271],[66,67],[157,158],{"_":227,"role":228,"ref":229},{"type":165},{"_":167,"mainLang":168,"languages":276},[167],{"n":80,"url":278,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004416_tiled.tif",[280],{"atLeast":281,"atMost":281},59,[91,180],[97,183],[285,286,287,123,202,131,103,104,105,106,104,243,189,168],"isic004416","epitaph for philon, son aunakos",{"_":121},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":246,"ptr":290,"ref":291,"inscriptionDate":4,"title":2,"citation":5,"uri":6},{"target":194},{"_":115,"target":115},{"file":293,"uri":293,"title":294,"status":295,"editionAuthor":13,"type":296,"objectType":297,"material":298,"condition":36,"layoutDesc":299,"handNote":302,"date":307,"places":310,"geo":313,"country":58,"provenance":55,"provenanceGeo":315,"region":71,"settlement":60,"repository":316,"idno":317,"textLang":319,"tmNumber":36,"facsimile":321,"letterHeights":323,"publications":325,"zotero":326,"keywords":327,"html":331,"bibl":332,"bulletinDateSort":116,"citedRangeSort":333,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004414","Epitaph for Eupolemos",{"_":121},{"_":123,"ana":124,"ref":125},{"_":127,"ana":128,"ref":129},{"_":131,"ana":132,"ref":133},{"layout":300},{"p":136,"rs":301,"damage":36},{"_":33,"ana":34,"ref":35},{"lettering":303,"dimensions":304},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[305,306],{"type":41,"l":142,"from":43,"to":43,"h":143,"unit":45,"atLeast":143,"atMost":143},{"type":47,"l":48,"from":43,"to":44,"h":145,"unit":45},{"_":308,"notBefore":309,"notAfter":218,"evidence":150},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,[311,312],{"_":55,"type":56,"ref":57,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[314],[66,67],[157,158],{"_":160,"role":161,"ref":162},{"_":318,"type":165},"ME23438",{"_":167,"mainLang":168,"languages":320},[167],{"n":80,"url":322,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004414_tiled.tif",[324],{"atLeast":177,"atMost":177},[91,179,92,180],[97,182,98,183],[328,329,330,123,127,131,103,104,105,106,104,188,189,168],"isic004414","epitaph for eupolemos",{"_":121},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":333,"ptr":334,"ref":335,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"41 fig.23",{"target":194},{"_":115,"target":115},{"file":337,"uri":337,"title":338,"status":339,"editionAuthor":13,"type":340,"objectType":341,"material":342,"condition":36,"layoutDesc":343,"handNote":347,"date":353,"places":355,"geo":358,"country":58,"provenance":55,"provenanceGeo":360,"region":71,"settlement":60,"repository":361,"idno":362,"textLang":363,"tmNumber":36,"facsimile":365,"letterHeights":367,"publications":369,"zotero":370,"keywords":371,"html":375,"bibl":376,"bulletinDateSort":116,"citedRangeSort":377,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004418","Epitaph for [-?-], child of Gerontios",{"_":121},{"_":123,"ana":124,"ref":125},{"_":202,"ana":203,"ref":204},{"_":131,"ana":132,"ref":133},{"layout":344},{"p":345,"rs":346,"damage":36},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":33,"ana":34,"ref":35},{"lettering":348,"dimensions":349},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[350,352],{"type":41,"l":351,"from":43,"to":44,"h":264,"unit":45,"atLeast":264,"atMost":264},"Line 1-2",{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":354,"notBefore":217,"notAfter":218,"evidence":150},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[356,357],{"_":55,"type":56,"ref":57,"corresp":221,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[359],[66,67],[157,158],{"_":227,"role":228,"ref":229},{"type":165},{"_":167,"mainLang":168,"languages":364},[167],{"n":80,"url":366,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004418_tiled.tif",[368],{"atLeast":281,"atMost":281},[91,92,180],[97,98,183],[372,373,374,123,202,131,103,104,105,106,104,243,189,168],"isic004418","epitaph for [-?-], child of gerontios",{"_":121},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":377,"ptr":378,"ref":379,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"113 and 166 tav.XXXIVa",{"target":194},{"_":115,"target":115},{"file":381,"uri":381,"title":338,"status":382,"editionAuthor":13,"type":383,"objectType":384,"material":385,"condition":36,"layoutDesc":386,"handNote":390,"date":395,"places":396,"geo":399,"country":58,"provenance":55,"provenanceGeo":401,"region":71,"settlement":60,"repository":402,"idno":403,"textLang":404,"tmNumber":36,"facsimile":406,"letterHeights":408,"publications":410,"zotero":411,"keywords":412,"html":415,"bibl":416,"bulletinDateSort":116,"citedRangeSort":417,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004417",{"_":121},{"_":123,"ana":124,"ref":125},{"_":202,"ana":203,"ref":204},{"_":131,"ana":132,"ref":133},{"layout":387},{"p":388,"rs":389,"damage":36},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":33,"ana":34,"ref":35},{"lettering":391,"dimensions":392},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[393,394],{"type":41,"l":351,"from":43,"to":44,"h":143,"unit":45,"atLeast":143,"atMost":143},{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":216,"notBefore":217,"notAfter":218,"evidence":150},[397,398],{"_":55,"type":56,"ref":57,"corresp":221,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[400],[66,67],[157,158],{"_":227,"role":228,"ref":229},{"type":165},{"_":167,"mainLang":168,"languages":405},[167],{"n":80,"url":407,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004417_tiled.tif",[409],{"atLeast":177,"atMost":177},[91,92,180],[97,98,183],[413,373,414,123,202,131,103,104,105,106,104,243,189,168],"isic004417",{"_":121},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":417,"ptr":418,"ref":419,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"113 and 166 tav.XXXIVa-b",{"target":194},{"_":115,"target":115},false],"uses":{"params":["slug"]}}]}
