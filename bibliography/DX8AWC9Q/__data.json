,"from":41,"to":41,"h":141,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":143,"unit":43},{"_":208,"notBefore":209,"notAfter":210,"evidence":148,"precision":16},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[212,213],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[215],[63,64],[155,156],{"_":158,"role":159,"ref":160},{"_":219,"type":163},"ME23438",{"_":165,"mainLang":166,"languages":221},[165],{"n":78,"url":223,"height":170,"width":171,"desc":172,"surfaceType":83},"ISic004414_tiled.tif",[],[89,175,90,176],[95,178,96,179],[228,229,230,121,125,129,101,102,103,104,102,184,185,166],"isic004414","epitaph for eupolemos",{"_":119},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":233,"ptr":234,"ref":235,"title":2,"citation":4},"41 fig.23",{"target":190},{"_":114,"target":114},{"file":237,"uri":237,"title":238,"status":239,"editionAuthor":11,"type":240,"objectType":241,"material":245,"condition":34,"layoutDesc":246,"handNote":250,"date":255,"places":258,"geo":262,"provenance":53,"provenanceGeo":264,"country":68,"region":69,"settlement":57,"repository":265,"idno":269,"textLang":270,"tmNumber":34,"facsimile":272,"letterHeights":274,"publications":275,"zotero":276,"keywords":277,"html":282,"bibl":283},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":119},{"_":121,"ana":122,"ref":123},{"_":242,"ana":243,"ref":244},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":129,"ana":130,"ref":131},{"layout":247},{"p":248,"rs":249,"damage":34},"Single line of greek letters approximately centred on the face of the plinth",{"_":31,"ana":32,"ref":33},{"lettering":251,"dimensions":252},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[253,254],{"type":39,"l":140,"from":41,"to":41,"h":141,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":143,"unit":43},{"_":256,"notBefore":257,"notAfter":210,"evidence":148,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,[259,261],{"_":53,"type":54,"ref":55,"corresp":260},"#findspot",{"_":57,"type":58,"ref":59,"offset":60},[263],[63,64],[155,156],{"_":266,"role":267,"ref":268},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":163},{"_":165,"mainLang":166,"languages":271},[165],{"n":78,"url":273,"height":170,"width":171,"desc":172,"surfaceType":83},"ISic004415_tiled.tif",[],[89,176],[95,179],[278,279,280,121,242,129,101,102,103,104,102,281,185,166],"isic004415","epitaph for krimma, child of aunakos",{"_":119},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":284,"ptr":285,"ref":286,"title":2,"citation":4},"28 fig.15 (and ref on p.113)",{"target":190},{"_":114,"target":114},{"file":288,"uri":288,"title":289,"status":290,"editionAuthor":11,"type":291,"objectType":292,"material":293,"condition":34,"layoutDesc":294,"handNote":298,"date":304,"places":305,"geo":308,"provenance":53,"provenanceGeo":310,"country":68,"region":69,"settlement":57,"repository":311,"idno":312,"textLang":313,"tmNumber":34,"facsimile":315,"letterHeights":317,"publications":318,"zotero":319,"keywords":320,"html":324,"bibl":325},"ISic004416","Epitaph for Philon, son Aunakos",{"_":119},{"_":121,"ana":122,"ref":123},{"_":242,"ana":243,"ref":244},{"_":129,"ana":130,"ref":131},{"layout":295},{"p":296,"rs":297,"damage":34},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":31,"ana":32,"ref":33},{"lettering":299,"dimensions":300},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[301,303],{"type":39,"l":140,"from":41,"to":41,"h":302,"unit":43},"59",{"type":45,"l":46,"from":41,"to":42,"h":143,"unit":43},{"_":256,"notBefore":257,"notAfter":210,"evidence":148,"precision":16},[306,307],{"_":53,"type":54,"ref":55,"corresp":260},{"_":57,"type":58,"ref":59,"offset":60},[309],[63,64],[155,156],{"_":266,"role":267,"ref":268},{"type":163},{"_":165,"mainLang":166,"languages":314},[165],{"n":78,"url":316,"height":170,"width":171,"desc":172,"surfaceType":83},"ISic004416_tiled.tif",[],[89,176],[95,179],[321,322,323,121,242,129,101,102,103,104,102,281,185,166],"isic004416","epitaph for philon, son aunakos",{"_":119},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":284,"ptr":326,"ref":327,"title":2,"citation":4},{"target":190},{"_":114,"target":114},{"file":329,"uri":329,"title":330,"status":331,"editionAuthor":11,"type":332,"objectType":333,"material":334,"condition":34,"layoutDesc":335,"han