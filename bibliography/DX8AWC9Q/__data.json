":121,"objectType":125,"material":129,"condition":36,"layoutDesc":133,"handNote":137,"date":145,"places":150,"geo":153,"provenance":55,"provenanceGeo":155,"country":70,"region":71,"settlement":59,"repository":158,"idno":162,"textLang":165,"tmNumber":36,"facsimile":169,"letterHeights":174,"publications":177,"zotero":180,"keywords":183,"html":189,"bibl":190},"ISic004411","Epitaph for Kratisstos",{"_":120},"edited",{"_":122,"ana":123,"ref":124},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":126,"ana":127,"ref":128},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":130,"ana":131,"ref":132},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":134},{"p":135,"rs":136,"damage":36},"Single line of Greek letters filling the width of the stone",{"_":33,"ana":34,"ref":35},{"lettering":138,"dimensions":139},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[140,143],{"type":41,"l":141,"from":43,"to":43,"h":142,"unit":45,"atLeast":142,"atMost":142},"Line 1","30",{"type":47,"l":48,"from":43,"to":44,"h":144,"unit":45},"NA",{"_":146,"notBefore":147,"notAfter":148,"evidence":149},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[151,152],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[154],[65,66],[156,157],38.06519,15.11438,{"_":159,"role":160,"ref":161},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":163,"type":164},"ME23435","inventory",{"_":166,"mainLang":167,"languages":168},"Ancient Greek","grc",[166],{"n":80,"url":170,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[175],{"atLeast":176,"atMost":176},30,[91,178,92,179],"Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[97,181,98,182],"ILQ4RQGU","JQQKI6JP",[184,185,186,122,126,130,103,104,105,106,104,187,188,167],"isic004411","epitaph for kratisstos",{"_":120},"museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":191,"ptr":192,"ref":194,"title":2,"citation":5,"uri":6},"27 fig.14",{"target":193},"http://zotero.org/groups/382445/items/DX8AWC9Q",{"_":115,"target":115},{"file":196,"uri":196,"title":197,"status":198,"editionAuthor":13,"type":199,"objectType":200,"material":201,"condition":36,"layoutDesc":202,"handNote":205,"date":210,"places":214,"geo":217,"provenance":55,"provenanceGeo":219,"country":70,"region":71,"settlement":59,"repository":220,"idno":221,"textLang":223,"tmNumber":36,"facsimile":225,"letterHeights":227,"publications":229,"zotero":230,"keywords":231,"html":235,"bibl":236},"ISic004414","Epitaph for Eupolemos",{"_":120},{"_":122,"ana":123,"ref":124},{"_":126,"ana":127,"ref":128},{"_":130,"ana":131,"ref":132},{"layout":203},{"p":135,"rs":204,"damage":36},{"_":33,"ana":34,"ref":35},{"lettering":206,"dimensions":207},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[208,209],{"type":41,"l":141,"from":43,"to":43,"h":142,"unit":45,"atLeast":142,"atMost":142},{"type":47,"l":48,"from":43,"to":44,"h":144,"unit":45},{"_":211,"notBefore":212,"notAfter":213,"evidence":149},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[215,216],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[218],[65,66],[156,157],{"_":159,"role":160,"ref":161},{"_":222,"type":164},"ME23438",{"_":166,"mainLang":167,"languages":224},[166],{"n":80,"url":226,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004414_tiled.tif",[228],{"atLeast":176,"atMost":176},[91,178,92,179],[97,181,98,182],[232,233,234,122,126,130,103,104,105,106,104,187,188,167],"isic004414","epitaph for eupolemos",{"_":120},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":237,"ptr":238,"ref":239,"title":2,"citation":5,"uri":6},"41 fig.23",{"target":193},{"_":115,"target":115},{"file":241,"uri":241,"title":242,"status":243,"editionAuthor":13,"type":244,"objectType":245,"material":249,"condition":36,"layoutDesc":250,"handNote":254,"date":259,"places":262,"geo":266,"provenance":55,"provenanceGeo":268,"country":70,"region":71,"settlement":59,"repository":269,"idno":273,"textLang":274,"tmNumber":36,"facsimile":276,"letterHeights":278,"publications":280,"zotero":281,"keywords":282,"html":287,"bibl":288},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":120},{"_":122,"ana":123,"ref":124},{"_":246,"ana":247,"ref":248},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":130,"ana":131,"ref":132},{"layout":251},{"p":252,"rs":253,"damage":36},"Single line of greek letters approximately centred on the face of the plinth",{"_":33,"ana":34,"ref":35},{"lettering":255,"dimensions":256},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[257,258],{"type":41,"l":141,"from":43,"to":43,"h":142,"unit":45,"atLeast":142,"atMost":142},{"type":47,"l":48,"from":43,"to":44,"h":144,"unit":45},{"_":260,"notBefore":261,"notAfter":213,"evidence":149},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,[263,265],{"_":55,"type":56,"ref":57,"corresp":264},"#findspot",{"_":59,"type":60,"ref":61,"offset":62},[267],[65,66],[156,157],{"_":270,"role":271,"ref":272},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":164},{"_":166,"mainLang":167,"languages":275},[166],{"n":80,"url":277,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004415_tiled.tif",[279],{"atLeast":176,"atMost":176},[91,179],[97,182],[283,284,285,122,246,130,103,104,105,106,104,286,188,167],"isic004415","epitaph for krimma, child of aunakos",{"_":120},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":289,"ptr":290,"ref":291,"title":2,"citation":5,"uri":6},"28 fig.15 (and ref on p.113)",{"target":193},{"_":115,"target":115},{"file":293,"uri":293,"title":294,"status":295,"editionAuthor":13,"type":296,"objectType":297,"material":298,"condition":36,"layoutDesc":299,"handNote":303,"date":309,"places":310,"geo":313,"provenance":55,"provenanceGeo":315,"country":70,"region":71,"settlement":59,"repository":316,"idno":317,"textLang":318,"tmNumber":36,"facsimile":320,"letterHeights":322,"publications":325,"zotero":326,"keywords":327,"html":331,"bibl":332},"ISic004416","Epitaph for Philon, son Aunakos",{"_":120},{"_":122,"ana":123,"ref":124},{"_":246,"ana":247,"ref":248},{"_":130,"ana":131,"ref":132},{"layout":300},{"p":301,"rs":302,"damage":36},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":33,"ana":34,"ref":35},{"lettering":304,"dimensions":305},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[306,308],{"type":41,"l":141,"from":43,"to":43,"h":307,"unit":45,"atLeast":307,"atMost":307},"59",{"type":47,"l":48,"from":43,"to":44,"h":144,"unit":45},{"_":260,"notBefore":261,"notAfter":213,"evidence":149},[311,312],{"_":55,"type":56,"ref":57,"corresp":264},{"_":59,"type":60,"ref":61,"offset":62},[314],[65,66],[156,157],{"_":270,"role":271,"ref":272},{"type":164},{"_":166,"mainLang":167,"languages":319},[166],{"n":80,"url":321,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004416_tiled.tif",[323],{"atLeast":324,"atMost":324},59,[91,179],[97,182],[328,329,330,122,246,130,103,104,105,106,104,286,188,167],"isic004416","epitaph for philon, son aunakos",{"_":120},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":289,"ptr":333,"ref":334,"title":2,"citation":5,"uri":6},{"target":193},{"_":115,"target":115},{"file":336,"uri":336,"title":337,"status":338,"editionAuthor":13,"type":339,"objectType":340,"material":341,"condition":36,"layoutDesc":342,"handNote":346,"date":352,"places":353,"geo":356,"provenance":55,"provenanceGeo":358,"country":70,"region":71,"settlement":59,"repository":359,"idno":360,"textLang":361,"tmNumber":36,"facsimile":363,"letterHeights":365,"publications":367,"zotero":368,"keywords":369,"html":373,"bibl":374},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":120},{"_":122,"ana":123,"ref":124},{"_":246,"ana":247,"ref":248},{"_":130,"ana":131,"ref":132},{"layout":343},{"p":344,"rs":345,"damage":36},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":33,"ana":34,"ref":35},{"lettering":347,"dimensions":348},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[349,351],{"type":41,"l":350,"from":43,"to":44,"h":142,"unit":45,"atLeast":142,"atMost":142},"Line 1-2",{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":260,"notBefore":261,"notAfter":213,"evidence":149},[354,355],{"_":55,"type":56,"ref":57,"corresp":264},{"_":59,"type":60,"ref":61,"offset":62},[357],[65,66],[156,157],{"_":270,"role":271,"ref":272},{"type":164},{"_":166,"mainLang":167,"languages":362},[166],{"n":80,"url":364,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004417_tiled.tif",[366],{"atLeast":176,"atMost":176},[91,92,179],[97,98,182],[370,371,372,122,246,130,103,104,105,106,104,286,188,167],"isic004417","epitaph for [-?-], child of gerontios",{"_":120},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":375,"ptr":376,"ref":377,"title":2,"citation":5,"uri":6},"113 and 166 tav.XXXIVa-b",{"target":193},{"_":115,"target":115},{"file":379,"uri":379,"title":337,"status":380,"editionAuthor":13,"type":381,"objectType":382,"material":383,"condition":36,"layoutDesc":384,"handNote":388,"date":393,"places":395,"geo":398,"provenance":55,"provenanceGeo":400,"country":70,"region":71,"settlement":59,"repository":401,"idno":402,"textLang":403,"tmNumber":36,"facsimile":405,"letterHeights":407,"publications":409,"zotero":410,"keywords":411,"html":414,"bibl":415},"ISic004418",{"_":120},{"_":122,"ana":123,"ref":124},{"_":246,"ana":247,"ref":248},{"_":130,"ana":131,"ref":132},{"layout":385},{"p":386,"rs":387,"damage":36},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":33,"ana":34,"ref":35},{"lettering":389,"dimensions":390},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[391,392],{"type":41,"l":350,"from":43,"to":44,"h":307,"unit":45,"atLeast":307,"atMost":307},{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":394,"notBefore":261,"notAfter":213,"evidence":149},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[396,397],{"_":55,"type":56,"ref":57,"corresp":264},{"_":59,"type":60,"ref":61,"offset":62},[399],[65,66],[156,157],{"_":270,"role":271,"ref":272},{"type":164},{"_":166,"mainLang":167,"languages":404},[166],{"n":80,"url":406,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004418_tiled.tif",[408],{"atLeast":324,"atMost":324},[91,92,179],[97,98,182],[412,371,413,122,246,130,103,104,105,106,104,286,188,167],"isic004418",{"_":120},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":416,"ptr":417,"ref":418,"title":2,"citation":5,"uri":6},"113 and 166 tav.XXXIVa",{"target":193},{"_":115,"target":115}],"uses":{"params":["slug"]}}]}
