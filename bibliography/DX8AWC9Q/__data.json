/items/DX8AWC9Q",{"_":115,"target":115},"https://biblio.inscriptiones.org/epig10002171",2009,{"file":118,"uri":118,"title":119,"status":120,"editionAuthor":13,"type":122,"objectType":126,"material":130,"condition":36,"layoutDesc":134,"handNote":138,"date":146,"places":151,"geo":154,"country":58,"provenance":55,"provenanceGeo":156,"region":71,"settlement":60,"repository":159,"idno":163,"textLang":166,"tmNumber":36,"facsimile":170,"letterHeights":175,"publications":178,"zotero":181,"keywords":184,"html":190,"bibl":191,"bulletinDateSort":116,"citedRangeSort":192,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004411","Epitaph for Kratisstos",{"_":121},"edited",{"_":123,"ana":124,"ref":125},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":127,"ana":128,"ref":129},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":131,"ana":132,"ref":133},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":135},{"p":136,"rs":137,"damage":36},"Single line of Greek letters filling the width of the stone",{"_":33,"ana":34,"ref":35},{"lettering":139,"dimensions":140},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[141,144],{"type":41,"l":142,"from":43,"to":43,"h":143,"unit":45,"atLeast":143,"atMost":143},"Line 1","30",{"type":47,"l":48,"from":43,"to":44,"h":145,"unit":45},"NA",{"_":147,"notBefore":148,"notAfter":149,"evidence":150},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[152,153],{"_":55,"type":56,"ref":57,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[155],[66,67],[157,158],38.06519,15.11438,{"_":160,"role":161,"ref":162},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":164,"type":165},"ME23435","inventory",{"_":167,"mainLang":168,"languages":169},"Ancient Greek","grc",[167],{"n":80,"url":171,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[176],{"atLeast":177,"atMost":177},30,[91,179,92,180],"Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[97,182,98,183],"ILQ4RQGU","JQQKI6JP",[185,186,187,123,127,131,103,104,105,106,104,188,189,168],"isic004411","epitaph for kratisstos",{"_":121},"museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":192,"ptr":193,"ref":194,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"27 fig.14",{"target":113},{"_":115,"target":115},{"file":196,"uri":196,"title":197,"status":198,"editionAuthor":13,"type":199,"objectType":200,"material":204,"condition":36,"layoutDesc":205,"handNote":209,"date":214,"places":218,"geo":222,"country":58,"provenance":55,"provenanceGeo":224,"region":71,"settlement":60,"repository":225,"idno":229,"textLang":230,"tmNumber":36,"facsimile":232,"letterHeights":234,"publications":236,"zotero":237,"keywords":238,"html":243,"bibl":244,"bulletinDateSort":116,"citedRangeSort":245,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":121},{"_":123,"ana":124,"ref":125},{"_":201,"ana":202,"ref":203},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":131,"ana":132,"ref":133},{"layout":206},{"p":207,"rs":208,"damage":36},"Single line of greek letters approximately centred on the face of the plinth",{"_":33,"ana":34,"ref":35},{"lettering":210,"dimensions":211},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[212,213],{"type":41,"l":142,"from":43,"to":43,"h":143,"unit":45,"atLeast":143,"atMost":143},{"type":47,"l":48,"from":43,"to":44,"h":145,"unit":45},{"_":215,"notBefore":216,"notAfter":217,"evidence":150},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,[219,221],{"_":55,"type":56,"ref":57,"corresp":220,"region":58},"#findspot",{"_":60,"type":61,"ref":62,"offset":63,"region":58},[223],[66,67],[157,158],{"_":226,"role":227,"ref":228},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":165},{"_":167,"mainLang":168,"languages":231},[167],{"n":80,"url":233,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004415_tiled.tif",[235],{"atLeast":177,"atMost":177},[91,180],[97,183],[239,240,241,123,201,131,103,104,105,106,104,242,189,168],"isic004415","epitaph for krimma, child of aunakos",{"_":121},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":245,"ptr":246,"ref":247,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"28 fig.15 (and ref on p.113)",{"target":113},{"_":115,"target":115},{"file":249,"uri":249,"title":250,"status":251,"editionAuthor":13,"type":252,"objectType":253,"material":254,"condition":36,"layoutDesc":255,"handNote":259,"date":265,"places":266,"geo":269,"country":58,"provenance":55,"provenanceGeo":271,"region":71,"settlement":60,"repository":272,"idno":273,"textLang":274,"tmNumber":36,"facsimile":276,"letterHeights":278,"publications":281,"zotero":282,"keywords":283,"html":287,"bibl":288,"bulletinDateSort":116,"citedRangeSort":245,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004416","Epitaph for Philon, son Aunakos",{"_":121},{"_":123,"ana":124,"ref":125},{"_":201,"ana":202,"ref":203},{"_":131,"ana":132,"ref":133},{"layout":256},{"p":257,"rs":258,"damage":36},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":33,"ana":34,"ref":35},{"lettering":260,"dimensions":261},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[262,264],{"type":41,"l":142,"from":43,"to":43,"h":263,"unit":45,"atLeast":263,"atMost":263},"59",{"type":47,"l":48,"from":43,"to":44,"h":145,"unit":45},{"_":215,"notBefore":216,"notAfter":217,"evidence":150},[267,268],{"_":55,"type":56,"ref":57,"corresp":220,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[270],[66,67],[157,158],{"_":226,"role":227,"ref":228},{"type":165},{"_":167,"mainLang":168,"languages":275},[167],{"n":80,"url":277,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004416_tiled.tif",[279],{"atLeast":280,"atMost":280},59,[91,180],[97,183],[284,285,286,123,201,131,103,104,105,106,104,242,189,168],"isic004416","epitaph for philon, son aunakos",{"_":121},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":245,"ptr":289,"ref":290,"inscriptionDate":4,"title":2,"citation":5,"uri":6},{"target":113},{"_":115,"target":115},{"file":292,"uri":292,"title":293,"status":294,"editionAuthor":13,"type":295,"objectType":296,"material":297,"condition":36,"layoutDesc":298,"handNote":301,"date":306,"places":309,"geo":312,"country":58,"provenance":55,"provenanceGeo":314,"region":71,"settlement":60,"repository":315,"idno":316,"textLang":318,"tmNumber":36,"facsimile":320,"letterHeights":322,"publications":324,"zotero":325,"keywords":326,"html":330,"bibl":331,"bulletinDateSort":116,"citedRangeSort":332,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004414","Epitaph for Eupolemos",{"_":121},{"_":123,"ana":124,"ref":125},{"_":127,"ana":128,"ref":129},{"_":131,"ana":132,"ref":133},{"layout":299},{"p":136,"rs":300,"damage":36},{"_":33,"ana":34,"ref":35},{"lettering":302,"dimensions":303},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[304,305],{"type":41,"l":142,"from":43,"to":43,"h":143,"unit":45,"atLeast":143,"atMost":143},{"type":47,"l":48,"from":43,"to":44,"h":145,"unit":45},{"_":307,"notBefore":308,"notAfter":217,"evidence":150},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,[310,311],{"_":55,"type":56,"ref":57,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[313],[66,67],[157,158],{"_":160,"role":161,"ref":162},{"_":317,"type":165},"ME23438",{"_":167,"mainLang":168,"languages":319},[167],{"n":80,"url":321,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004414_tiled.tif",[323],{"atLeast":177,"atMost":177},[91,179,92,180],[97,182,98,183],[327,328,329,123,127,131,103,104,105,106,104,188,189,168],"isic004414","epitaph for eupolemos",{"_":121},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":332,"ptr":333,"ref":334,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"41 fig.23",{"target":113},{"_":115,"target":115},{"file":336,"uri":336,"title":337,"status":338,"editionAuthor":13,"type":339,"objectType":340,"material":341,"condition":36,"layoutDesc":342,"handNote":346,"date":352,"places":354,"geo":357,"country":58,"provenance":55,"provenanceGeo":359,"region":71,"settlement":60,"repository":360,"idno":361,"textLang":362,"tmNumber":36,"facsimile":364,"letterHeights":366,"publications":368,"zotero":369,"keywords":370,"html":374,"bibl":375,"bulletinDateSort":116,"citedRangeSort":376,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004418","Epitaph for [-?-], child of Gerontios",{"_":121},{"_":123,"ana":124,"ref":125},{"_":201,"ana":202,"ref":203},{"_":131,"ana":132,"ref":133},{"layout":343},{"p":344,"rs":345,"damage":36},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":33,"ana":34,"ref":35},{"lettering":347,"dimensions":348},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[349,351],{"type":41,"l":350,"from":43,"to":44,"h":263,"unit":45,"atLeast":263,"atMost":263},"Line 1-2",{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":353,"notBefore":216,"notAfter":217,"evidence":150},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[355,356],{"_":55,"type":56,"ref":57,"corresp":220,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[358],[66,67],[157,158],{"_":226,"role":227,"ref":228},{"type":165},{"_":167,"mainLang":168,"languages":363},[167],{"n":80,"url":365,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004418_tiled.tif",[367],{"atLeast":280,"atMost":280},[91,92,180],[97,98,183],[371,372,373,123,201,131,103,104,105,106,104,242,189,168],"isic004418","epitaph for [-?-], child of gerontios",{"_":121},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":376,"ptr":377,"ref":378,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"113 and 166 tav.XXXIVa",{"target":113},{"_":115,"target":115},{"file":380,"uri":380,"title":337,"status":381,"editionAuthor":13,"type":382,"objectType":383,"material":384,"condition":36,"layoutDesc":385,"handNote":389,"date":394,"places":395,"geo":398,"country":58,"provenance":55,"provenanceGeo":400,"region":71,"settlement":60,"repository":401,"idno":402,"textLang":403,"tmNumber":36,"facsimile":405,"letterHeights":407,"publications":409,"zotero":410,"keywords":411,"html":414,"bibl":415,"bulletinDateSort":116,"citedRangeSort":416,"languageSort":167,"materialSort":131,"typeSort":123},"ISic004417",{"_":121},{"_":123,"ana":124,"ref":125},{"_":201,"ana":202,"ref":203},{"_":131,"ana":132,"ref":133},{"layout":386},{"p":387,"rs":388,"damage":36},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":33,"ana":34,"ref":35},{"lettering":390,"dimensions":391},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[392,393],{"type":41,"l":350,"from":43,"to":44,"h":143,"unit":45,"atLeast":143,"atMost":143},{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":215,"notBefore":216,"notAfter":217,"evidence":150},[396,397],{"_":55,"type":56,"ref":57,"corresp":220,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[399],[66,67],[157,158],{"_":226,"role":227,"ref":228},{"type":165},{"_":167,"mainLang":168,"languages":404},[167],{"n":80,"url":406,"height":172,"width":173,"desc":174,"surfaceType":85},"ISic004417_tiled.tif",[408],{"atLeast":177,"atMost":177},[91,92,180],[97,98,183],[412,372,413,123,201,131,103,104,105,106,104,242,189,168],"isic004417",{"_":121},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":416,"ptr":417,"ref":418,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"113 and 166 tav.XXXIVa-b",{"target":113},{"_":115,"target":115},false],"uses":{"params":["slug"]}}]}
