layoutDesc":132,"handNote":136,"date":144,"places":149,"geo":152,"provenance":53,"provenanceGeo":154,"country":68,"region":69,"settlement":57,"repository":157,"idno":161,"textLang":164,"tmNumber":34,"facsimile":168,"letterHeights":173,"publications":174,"zotero":177,"keywords":180,"html":186,"bibl":187},"ISic004411","Epitaph for Kratisstos",{"_":119},"edited",{"_":121,"ana":122,"ref":123},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":125,"ana":126,"ref":127},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":129,"ana":130,"ref":131},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html",{"layout":133},{"p":134,"rs":135,"damage":34},"Single line of Greek letters filling the width of the stone",{"_":31,"ana":32,"ref":33},{"lettering":137,"dimensions":138},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[139,142],{"type":39,"l":140,"from":41,"to":41,"h":141,"unit":43},"Line 1","30",{"type":45,"l":46,"from":41,"to":42,"h":143,"unit":43},"NA",{"_":145,"notBefore":146,"notAfter":147,"evidence":148,"precision":16},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[150,151],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[153],[63,64],[155,156],38.06519,15.11438,{"_":158,"role":159,"ref":160},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":162,"type":163},"ME23435","inventory",{"_":165,"mainLang":166,"languages":167},"Ancient Greek","grc",[165],{"n":78,"url":169,"height":170,"width":171,"desc":172,"surfaceType":83},"ISic004411_tiled.tif","3680px","5520px","I.Sicily with the pe