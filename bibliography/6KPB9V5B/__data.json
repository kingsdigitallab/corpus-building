,"atMost":172},"Interlineation line 8 to 9","1-5",{"type":52,"l":202,"from":165,"to":170,"h":200,"unit":50,"atLeast":197,"atMost":172},"Interlineation line 9 to 10",{"_":204,"notBefore":205,"notAfter":206,"evidence":207},"5th century CE, with a likely terminus post quem of 403-408 CE, given that a coin of that date was found within the tomb (Tigano 2009: 164; more generally, the tombs of this part of the necropolis all date late 4th to 5th century CE)",403,500,"archaeological-context",[209,212],{"_":210,"type":62,"ref":211,"region":61},"Halaesa","http://pleiades.stoa.org/places/462225",{"_":213,"type":66,"ref":214,"offset":215,"region":61},"Castel di Tusa","http://sws.geonames.org/2525099","near",[217],[218,219],37.99907,14.26197,[221,222],38.0073241,14.2527381,{"_":224,"role":225,"ref":226},"Antiquarium e sito archeologico di Halaesa ","museum","http://sicily.classics.ox.ac.uk/museum/053",{"_":228,"type":229},"ME 20272","inventory",{"_":73,"mainLang":74,"languages":231},[73],"645584",{"n":234,"url":235,"height":236,"width":237,"desc":238,"surfaceType":239},"screen","ISic003337_tiled.tif","3387px","5310px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina","front",[241,244,247,249,251,252,255,257,259,261,264,266,268,269,271,273,274,276,277],{"atLeast":242,"atMost":243},12,18,{"atLeast":245,"atMost":246},14,19,{"atLeast":242,"atMost":248},22,{"atLeast":250,"atMost":248},8,{"atLeast":242,"atMost":243},{"atLeast":253,"atMost":254},9,16,{"atLeast":256,"atMost":245},7,{"atLeast":258,"atMost":242},6,{"atLeast":258,"atMost":260},10,{"atLeast":262,"atMost":263},5,13,{"atLeast":260,"atMost":265},15,{"atLeast":267,"atMost":256},3,{"atLeast":262,"atMost":265},{"atLeast":270,"atMost":260},4,{"atLeast":272,"atMost":256},2,{"atLeast":272,"atMost":256},{"atLeast":275,"atMost":258},1,{"atLeast":275,"atMost":262},{"atLeast":275,"atMost":262},[79,80,83,279,280],"Scibona and Tigano, 2008","Prag, Tigano, 2017, Alesa Archonidea: il lapidarium",[86,87,90,282,283],"ZQQNUUZJ","MI64N