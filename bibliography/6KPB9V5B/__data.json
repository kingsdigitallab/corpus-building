{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":7,"isBulletin":234},{"title":2,"author":3,"date":4,"citation":5,"uri":6},"Epigrafe in greco di IV sec. d.C. di Alesa (Sicilia) in versi e prosa, per la morte di Eirena Philandros, \"carissima a Botis boio-celtico\"","Manganaro Perrone","2006","\u003Cspan>Giacomo Manganaro Perrone, «Epigrafe in greco di IV sec. d.C. di Alesa (Sicilia) in versi e prosa, per la morte di Eirena Philandros, “carissima a Botis boio-celtico”», \u003Ci>Zeitschrift für Papyrologie und Epigraphik\u003C/i> 158 (2006): 89–92\u003C/span>","https://www.zotero.org/groups/isicily/items/6KPB9V5B",[8],{"file":9,"uri":9,"title":10,"status":11,"editionAuthor":13,"type":14,"objectType":18,"material":22,"condition":26,"layoutDesc":27,"handNote":34,"date":122,"places":127,"geo":137,"provenance":129,"provenanceGeo":141,"country":144,"region":145,"settlement":129,"repository":146,"idno":150,"textLang":153,"tmNumber":157,"facsimile":158,"letterHeights":165,"publications":203,"zotero":209,"keywords":215,"html":226,"bibl":227,"bulletinDateSort":232,"citedRangeSort":233,"languageSort":154,"materialSort":23,"typeSort":15},"ISic003337","Funerary inscription for Eirena",{"_":12},"edited",null,{"_":15,"ana":16,"ref":17},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":19,"ana":20,"ref":21},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":23,"ana":24,"ref":25},"marble\n                                    ","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html","",{"layout":28},{"p":29,"rs":30,"damage":26},"Ten lines of Greek filling the available space, decreasing notably in size in the second five lines",{"_":31,"ana":32,"ref":33},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":35,"dimensions":36},"The letters are engraved in a fairly plain, square fashion, with simple serifs. Alpha is mostly with broken bar, sometimes with an extended upper serif, although there is a straight bar example in line 7 and in lines 8 and 10 straight bar descending to left foot; beta is closed, with larger lower eye, generally horizontal along the base; delta varies between regular triangle and oblique lower bar with extended serif above; epsilon has straight bars of equal length, except for instances in lines 9 and 10 when it is lunate; theta is ovoid with connecting straight bar; kappa has short tails; lambda sometimes has an extended upper serif; mu varies between a form with vertical first and last hastae and short middle strokes meeting above the line and cursive form comparable to a lower-case mu in line 9; omicron is full size in the first few lines, but increasingly is smaller and mid-line; sigma is consistently lunate, but more often formed of three straight strokes; less often a single curved stroke; omega is consistently lunate, and sometimes smaller and mid-line. The eta and nu are in ligature in lines 5, 6 and 7. In line 5 the omicron in the final word is inscribed above the other letters (due to omission?). The last two/three words of the last line are enclosed between a pair of christograms. Small hedera occur in lines 1, 3, 5, and 10.",[37,45,51,56,61,64,70,75,80,85,91,96,100,103,107,111,113,117,120],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42,"atLeast":43,"atMost":44},"letterHeight","Line 1","line1","12-18","mm","12","18",{"type":38,"l":46,"from":47,"to":47,"h":48,"unit":42,"atLeast":49,"atMost":50},"Line 2","line2","14-19","14","19",{"type":38,"l":52,"from":53,"to":53,"h":54,"unit":42,"atLeast":43,"atMost":55},"Line 3","line3","12-22","22",{"type":38,"l":57,"from":58,"to":58,"h":59,"unit":42,"atLeast":60,"atMost":55},"Line 4","line4","8-22","8",{"type":38,"l":62,"from":63,"to":63,"h":41,"unit":42,"atLeast":43,"atMost":44},"Line 5","line5",{"type":38,"l":65,"from":66,"to":66,"h":67,"unit":42,"atLeast":68,"atMost":69},"Line 6","line6","9-16","9","16",{"type":38,"l":71,"from":72,"to":72,"h":73,"unit":42,"atLeast":74,"atMost":49},"Line 7","line7","7-14","7",{"type":38,"l":76,"from":77,"to":77,"h":78,"unit":42,"atLeast":79,"atMost":43},"Line 8","line8","6-12","6",{"type":38,"l":81,"from":82,"to":82,"h":83,"unit":42,"atLeast":79,"atMost":84},"Line 9","line9","6-10","10",{"type":38,"l":86,"from":87,"to":87,"h":88,"unit":42,"atLeast":89,"atMost":90},"Line 10","line10","5-13","5","13",{"type":92,"l":93,"from":40,"to":47,"h":94,"unit":42,"atLeast":84,"atMost":95},"interlinear","Interlineation line 1 to 2","10-15","15",{"type":92,"l":97,"from":47,"to":53,"h":98,"unit":42,"atLeast":99,"atMost":74},"Interlineation line 2 to 3","3-7","3",{"type":92,"l":101,"from":53,"to":58,"h":102,"unit":42,"atLeast":89,"atMost":95},"Interlineation line 3 to 4","5-15",{"type":92,"l":104,"from":58,"to":63,"h":105,"unit":42,"atLeast":106,"atMost":84},"Interlineation line 4 to 5","4-10","4",{"type":92,"l":108,"from":63,"to":66,"h":109,"unit":42,"atLeast":110,"atMost":74},"Interlineation line 5 to 6","2-7","2",{"type":92,"l":112,"from":66,"to":72,"h":109,"unit":42,"atLeast":110,"atMost":74},"Interlineation line 6 to 7",{"type":92,"l":114,"from":72,"to":77,"h":115,"unit":42,"atLeast":116,"atMost":79},"Interlineation line 7 to 8","1-6","1",{"type":92,"l":118,"from":77,"to":82,"h":119,"unit":42,"atLeast":116,"atMost":89},"Interlineation line 8 to 9","1-5",{"type":92,"l":121,"from":82,"to":87,"h":119,"unit":42,"atLeast":116,"atMost":89},"Interlineation line 9 to 10",{"_":123,"notBefore":124,"notAfter":125,"evidence":126},"Later 4th — 5th century CE (The tombs of the necropolis are dated to the late 4th and 5th century CE (Tigano 2008b: 49) and the inscription easily fits within this date range.",351,500,"context",[128,132],{"_":129,"type":130,"ref":131},"Halaesa","ancient","http://pleiades.stoa.org/places/462225",{"_":133,"type":134,"ref":135,"offset":136},"Castel di Tusa","modern","http://sws.geonames.org/2525099","near",[138],[139,140],37.99907,14.26197,[142,143],38.007468,14.257626,"Italy","Sicily",{"_":147,"role":148,"ref":149},"Antiquarium e sito archeologico di Halaesa ","museum","http://sicily.classics.ox.ac.uk/museum/053",{"_":151,"type":152},"ME 20272","inventory",{"_":154,"mainLang":155,"languages":156},"Ancient Greek","grc",[154],"645584",{"n":159,"url":160,"height":161,"width":162,"desc":163,"surfaceType":164},"screen","ISic003337_tiled.tif","3387px","5310px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina","front",[166,169,172,174,176,177,180,182,184,186,189,191,193,194,196,198,199,201,202],{"atLeast":167,"atMost":168},12,18,{"atLeast":170,"atMost":171},14,19,{"atLeast":167,"atMost":173},22,{"atLeast":175,"atMost":173},8,{"atLeast":167,"atMost":168},{"atLeast":178,"atMost":179},9,16,{"atLeast":181,"atMost":170},7,{"atLeast":183,"atMost":167},6,{"atLeast":183,"atMost":185},10,{"atLeast":187,"atMost":188},5,13,{"atLeast":185,"atMost":190},15,{"atLeast":192,"atMost":181},3,{"atLeast":187,"atMost":190},{"atLeast":195,"atMost":185},4,{"atLeast":197,"atMost":181},2,{"atLeast":197,"atMost":181},{"atLeast":200,"atMost":183},1,{"atLeast":200,"atMost":187},{"atLeast":200,"atMost":187},[204,205,206,207,208],"L'année épigraphique: revue des publications épigraphiques relatives a l'antiquité romaine., 1888-","Supplementum epigraphicum graecum, 1923-","Manganaro Perrone, 2006, Epigrafe in greco di IV sec. d.C. di Alesa (Sicilia) in versi e prosa, per la morte di Eirena Philandros, \"carissima a Botis boio-celtico\"","Scibona and Tigano, 2008","Prag, Tigano, 2017, Alesa Archonidea: il lapidarium",[210,211,212,213,214],"R46KDTZX","F2GG87EQ","6KPB9V5B","ZQQNUUZJ","MI64NB9L",[216,217,218,15,19,219,220,221,222,223,220,224,225,155],"isic003337","funerary inscription for eirena",{"_":12},"marble","halaesa","castel di tusa","italy","sicily","antiquarium e sito archeologico di halaesa","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"a