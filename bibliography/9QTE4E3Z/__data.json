":42,"h":317,"unit":43},{"_":418,"notBefore":419,"notAfter":420,"evidence":144,"precision":17},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-350,-251,[422,423],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[425],[63,64],[220,221],{"_":377,"role":154,"ref":378},{"_":429,"type":158},"ME23439",{"_":160,"mainLang":161,"languages":431},[160],{"n":78,"url":433,"height":166,"width":167,"desc":168,"surfaceType":83},"ISic004412_tiled.tif",[],[387,89,388],[390,95,391],[438,439,440,119,123,182,100,101,102,103,101,396,185,161],"isic004412","epitaph for aristoboula",{"_":117},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοβούλας \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":443,"ptr":444,"ref":445,"title":2,"citation":5},"116 fig.121",{"target":110},{"_":112,"target":112},{"file":447,"uri":447,"title":448,"status":449,"editionAuthor":12,"type":450,"objectType":451,"material":452,"condition":3,"layoutDesc":453,"handNote":456,"date":461,"places":464,"geo":467,"provenance":53,"provenanceGeo":469,"country":68,"region":69,"settlement":57,"repository":470,"idno":471,"textLang":473,"tmNumber":3,"facsimile":475,"letterHeights":477,"publications":478,"zotero":479,"keywords":480,"html":484,"bibl":485},"ISic004413","Epitaph for Kallo",{"_":117},{"_":119,"ana":120,"ref":121},{"_":123,"ana":124,"ref":353},{"_":182,"ana":128,"ref":129},{"layout":454},{"p":357,"rs":455,"damage":3},{"_":32,"ana":33,"ref":34},{"lettering":457,"dimensions":458},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[459,460],{"type":39,"l":314,"from":41,"to":41,"h":363,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":317,"unit":43},{"_":462,"notBefore"