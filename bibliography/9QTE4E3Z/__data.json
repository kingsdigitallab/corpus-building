:39,"from":40,"to":40,"h":43,"unit":42,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":529,"notBefore":52,"notAfter":441,"evidence":385},[573,574],{"_":56,"type":57,"ref":58},{"_":60,"type":61,"ref":62,"offset":63},[576],[66,67],[69,70],{"_":393,"role":76,"ref":394},{"_":580,"type":80},"ME23438",{"_":82,"mainLang":83,"languages":582},[82],{"n":87,"url":584,"height":216,"width":217,"desc":218,"surfaceType":92},"ISic004414_tiled.tif",[586],{"atLeast":95,"atMost":95},[348,404,102,405],[352,407,108,408],[590,591,592,15,19,23,113,114,115,116,114,413,119,83],"isic004414","epitaph for eupolemos",{"_":181},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":595,"ptr":596,"ref":597,"title":2,"citation":5,"uri":6},"115 fig.119",{"target":124},{"_":126,"target":126},{"file":599,"uri":599,"title":600,"status":601,"editionAuthor":13,"type":602,"objectType":603,"material":604,"condition":26,"layoutDesc":605,"handNote":609,"date":615,"places":617,"geo":620,"provenance":56,"provenanceGeo":622,"country":71,"region":72,"settlement":60,"repository":623,"idno":624,"textLang":626,"tmNumber":26,"facsimile":628,"letterHeights":630,"publications":633,"zotero":634,"keywords":635,"html":639,"bibl":640,"citedRangeSort":641,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":181},{"_":15,"ana":16,"ref":17},{"_":425,"ana":426,"ref":427},{"_":23,"ana":24,"ref":25},{"layout":606},{"p":607,"rs":608,"damage":26},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":610,"dimensions":611},"Somewhat crudely cut and rather i