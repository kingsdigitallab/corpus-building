me\" data-name-type=\"\" data-text=\"Δίοκλε\">\u003Cspan data-text=\"Δίοκλε\" data-n=\"5\" data-lemma=\"Διοκλῆς\">Δίοκλε\u003C/span>\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":233,"ptr":234,"ref":235,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 and fig.112",{"target":126},{"_":128,"target":128},{"file":237,"uri":237,"title":238,"status":239,"editionAuthor":13,"type":240,"objectType":241,"material":242,"condition":28,"layoutDesc":244,"handNote":248,"date":257,"places":260,"geo":263,"country":61,"provenance":58,"provenanceGeo":265,"region":74,"settlement":75,"repository":266,"idno":267,"textLang":269,"tmNumber":271,"facsimile":272,"letterHeights":277,"publications":280,"zotero":283,"keywords":286,"html":290,"bibl":291,"bulletinDateSort":129,"citedRangeSort":292,"languageSort":84,"materialSort":23,"typeSort":15},"ISic001207","Epitaph for Nemeris, a goldsmith",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"type":25,"subtype":28,"resp":243,"ref":27},"#Coccato",{"layout":245},{"p":246,"rs":247,"damage":28},"Five lines of Greek letters, centred on the stone",{"_":33,"ana":34,"ref":35},{"lettering":249,"dimensions":250},"Slightly crudely incised simple broad letters without serifs. Nu i sregular; epsilon has slightly shorter middle bar; mu has slightly inward leaning first and last strokes, the mid-strokes reach down to the base-line; rho has a small eye, not always fully closed; alpha has broken bar; omega varies between open circle closed by horizontal bar and closed ovoid form with horizontal bar; phi has a small circular eye; sigma has standard form with horizontal top and bottom storkes; omicron is approximately the same size as other letters.",[251,256],{"type":40,"l":252,"from":42,"to":253,"h":254,"unit":44,"atLeast":45,"atMost":255},"Lines 1-5","line5","30-45","45",{"type":48,"l":49,"from":42,"to":50,"unit":44},{"_":258,"notBefore":259,"notAfter":55},"2nd century BCE(?)",-200,[261,262],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[264],[69,70],[72,73],{"_":77,"role":78,"ref":79},{"_":268,"type":82},"8706",{"_":84,"mainLang":85,"languages":270},[84],"492811",{"n":89,"url":273,"height":274,"width":275,"desc":276,"surfaceType":94},"ISic001207_tiled.tif","3212px","2498px","Photo J. Prag, courtesy Museo Archeologico Regionale Antonino Salinas",[278],{"atLeast":97,"atMost":279},45,[100,101,102,103,281,282,104],"Manni Piraino, 1976, Contribution Épigraphique à l'Étude de l'esclavage en Sicile","Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano",[106,107,108,109,284,285,110],"R9M263EA","RZSFKACR",[287,288,289,15,19,23,115,116,117,118,119,120,121,85],"isic001207","epitaph for nemeris, a goldsmith",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Νεμέριε\n                    Γρανῶνι\n                    Νυμφόδωρε\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Νεμέριε\">\u003Cspan data-text=\"Νεμέριε\" data-n=\"5\" data-lemma=\"Νεμέριος\">Νεμέριε̣\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Γρανῶνι\">\u003Cspan data-text=\"Γρανῶνι\" data-n=\"10\" data-lemma=\"Γρανῶνις\">Γρανῶνι\u003C/span>\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Νυμφόδωρε\">\u003Cspan data-text=\"Νυμφόδωρε\" data-n=\"15\" data-lemma=\"Νυμφόδωρος\">Νυμφόδωρε\u