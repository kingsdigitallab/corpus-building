se around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",-350,-201,[454,456],{"_":59,"type":60,"ref":61,"corresp":455,"region":62},"#findspot",{"_":64,"type":65,"ref":66,"offset":67,"region":62},[458],[70,71],[73,74],{"_":461,"role":462,"ref":463},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":83},{"_":85,"mainLang":86,"languages":466},[85],{"n":90,"url":468,"height":222,"width":223,"desc":224,"surfaceType":95},"ISic004417_tiled.tif",[470],{"atLeast":98,"atMost":98},[357,105,415],[361,111,418],[474,475,476,15,435,23,116,117,118,119,117,477,122,86],"isic004417","epitaph for [-?-], child of gerontios",{"_":186},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":426,"ptr":480,"ref":481,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":127},{"_":129,"target":129},{"file":483,"uri":483,"title":431,"status":484,"editionAuthor":13,"type":485,"objectType":486,"material":487,"condition":29,"layoutDesc":489,"handNote":493,"date":499,"places":501,"geo":504,"country":62,"provenance":59,"provenanceGeo":506,"region":75,"settlement":64,"repository":507,"idno":508,"textLang":509,"tmNumber":29,"facsimile":511,"letterHeights":513,"publications":516,"zotero":517,"keywords":518,"html":521,"bibl":522,"bulletinDateSort":130,"citedRangeSort":426,"languageSort":85,"materialSort":23,"typeSort":15},"ISic004418",{"_":186},{"_":15,"ana":16,"ref":17},{"_":435,"ana":436,"ref":437},{"_":23,"ana":24,"type":25,"subtype":488,"ref":28},[27],{"layout":490},{"p":491,"rs":492,"damage":29},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":34,"ana":35,"ref":36},{"lettering":494,"dimensions":495},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[496,498],{"type":41,"l":147,"from":43,"to":51,"h":497,"unit":45,"atLeast":497,"atMost":497},"59",{"type":49,"l":50,"from":43,"to":51,"unit":45},{"_":500,"notBefore":451,"notAfter":452,"evidence":395},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[502,503],{"_":59,"type":60,"ref":61,"corresp":455,"region":62},{"_":64,"type":65,"ref":66,"offset":67,"region":62},[505],[70,71],[73,74],{"_":461,"role":462,"ref":463},{"type":83},{"_":85,"mainLang":86,"languages":510},[85],{"n":90,"url":512,"height":222,"width":223,"desc":224,"surfaceType":95},"ISic004418_tiled.tif",[514],{"atLeast":515,"atMost":515},59,[357,105,415],[361,111,418],[519,475,520,15,435,23,116,117,118,119,117,477,122,86],"isic004418",{"_":186},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":426,"ptr":523,"ref":524,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":127},{"_":129,"target":129},{"file":526,"uri":526,"title":527,"status":528,"editionAuthor":13,"type":529,"objectType":530,"material":531,"condition":29,"layoutDesc":533,"handNote":536,"date":541,"places":543,"geo":546,"country":62,"provenance":59,"provenanceGeo":548,"region":75,"settlement":64,"repository":549,"idno":550,"textLang":552,"tmNumber":29,"facsimile":554,"letterHeights":556,"publications":558,"zotero":559,"keywords":560,"html":564,"bibl":565,"bulletinDateSort":130,"citedRangeSort":566,"languageSort":85,"materialSort":23,"typeSort":15},"ISic004413","Epitaph for Kallo",{"_":186},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":379},{"_":23,"ana":24,"type":25,"subtype":532,"ref":28},[27],{"layout":534},{"p":384,"rs":535,"damage":29},{"_":34,"ana":35,"ref":36},{"lettering":537,"dimensions":538},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[539,540],{"type":41,"l":42,"from":43,"to":43,"h":46,"unit":45,"atLeast":46,"atMost":46},{"type":49,"l":50,"from":43,"to":51,"h":52,"unit":45},{"_":542,"notBefore":55,"notAfter":452,"evidence":395},"The goods recovered from the tomb suggest a date in the 3rd century BCE",[544,545],{"_":59,"type":60,"ref":61,"region":62},{"_":64,"type":65,"ref":66,"offset":67,"region":62},[547],[70,71],[73,74],{"_":403,"role":79,"ref":404},{"_":551,"type":83},"ME23436",{"_":85,"mainLang":86,"languages":553},[85],{"n":90,"url":555,"height":222,"width":223,"desc":224,"surfaceType":95},"ISic004413_tiled.tif",[557],{"atLeast":98,"atMost":98},[414,105,415],[417,111,418],[561,562,563,15,19,23,116,117,118,119,117,423,122,86],"isic004413","epitaph for kallo",{"_":186},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":566,"ptr":567,"ref":568,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"115 fig.118",{"target":127},{"_":129,"target":129},{"file":570,"uri":570,"title":571,"status":572,"editionAuthor":13,"type":573,"objectType":574,"material":575,"condition":29,"layoutDesc":577,"handNote":580,"date":585,"places":586,"geo":589,"country":62,"provenance":59,"provenanceGeo":591,"region":75,"settlement":64,"repository":592,"idno":593,"textLang":595,"tmNumber":29,"facsimile":597,"letterHeights":599,"publications":601,"zotero":602,"keywords":603,"html":607,"bibl":608,"bulletinDateSort":130,"citedRangeSort":609,"languageSort":85,"materialSort":23,"typeSort":15},"ISic004414","Epitaph for Eupolemos",{"_":186},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":379},{"_":23,"ana":24,"type":25,"subtype":576,"ref":28},[27],{"layout":578},{"p":384,"rs":579,"damage":29},{"_":34,"ana":35,"ref":36},{"lettering":581,"dimensions":582},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[583,584],{"type":41,"l":42,"from":43,"to":43,"h":46,"unit":45,"atLeast":46,"atMost":46},{"type":49,"l":50,"from":43,"to":51,"h":52,"unit":45},{"_":542,"notBefore":55,"notAfter":452,"evidence":395},[587,588],{"_":59,"type":60,"ref":61,"region":62},{"_":64,"type":65,"ref":66,"offset":67,"region":62},[590],[70,71],[73,74],{"_":403,"role":79,"ref":404},{"_":594,"type":83},"ME23438",{"_":85,"mainLang":86,"languages":596},[85],{"n":90,"url":598,"height":222,"width":223,"desc":224,"surfaceType":95},"ISic004414_tiled.tif",[600],{"atLeast":98,"atMost":98},[357,414,105,415],[361,417,111,418],[604,605,606,15,19,23,116,117,118,119,117,423,122,86],"isic004414","epitaph for eupolemos",{"_":186},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":609,"ptr":610,"ref":611,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"115 fig.119",{"target":127},{"_":129,"target":129},{"file":613,"uri":613,"title":614,"status":615,"editionAuthor":13,"type":616,"objectType":617,"material":618,"condition":29,"layoutDesc":620,"handNote":624,"date":630,"places":632,"geo":635,"country":62,"provenance":59,"provenanceGeo":637,"region":75,"settlement":64,"repository":638,"idno":639,"textLang":641,"tmNumber":29,"facsimile":643,"letterHeights":645,"publications":648,"zotero":649,"keywords":650,"html":654,"bibl":655,"bulletinDateSort":130,"citedRangeSort":656,"languageSort":85,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":186},{"_":15,"ana":16,"ref":17},{"_":435,"ana":436,"ref":437},{"_":23,"ana":24,"type":25,"subtype":619,"ref":28},[27],{"layout":621},{"p":622,"rs":623,"damage":29},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":34,"ana":35,"ref":36},{"lettering":625,"dimensions":626},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[627,629],{"type":41,"l":42,"from":43,"to":43,"h":628,"unit":45,"atLeast":628,"atMost":628},"29",{"type":49,"l":50,"from":43,"to":51,"h":52,"unit":45},{"_":631,"notBefore":451,"notAfter":452,"evidence":395},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[633,634],{"_":59,"type":60,"ref":61,"region":62},{"_":64,"type":65,"ref":66,"offset":67,"region":62},