              \n                                \t\n\t\t\t",{"_":31,"ana":32,"ref":33},{"lettering":126,"dimensions":127},"Crude and irregular letters of unequal size, deeply incised. Omicron is small and mid-line; kappa has short equal length arms attached to the vertical; epsilon has shorter middle bar (i the first instance detached from the vertical); alpha has straight bar; rho has rounded closed eye.",[128,131],{"type":39,"l":129,"from":41,"to":42,"h":130,"unit":43},"Line 1-2","30-75",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":133,"notBefore":134,"notAfter":50,"evidence":135,"precision":16},"3rd century BCE?",301,"lettering",[137,138],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[140],[63,64],"Palermo",{"_":143,"role":144,"ref":145},"Museo Archeologico Regionale Antonino Salinas","museum","http://sicily.classics.ox.ac.uk/museum/064",{"_":147,"type":148},"8703","inventory",{"_":150,"mainLang":151,"languages":152},"Ancient Greek","grc",[150],{"n":74,"url":154,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic001206_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[],[160,161,162,163,86],"IG, 1890","Manni Piraino, 1973, IGMusPalermo","Salinas, 1876-, Notizie degli scavi di antichità","Hoffmann, 1904, SGDI",[165,166,90,167,92],"Q2SBPG9F","F66S4X3M","DQDPC573",[169,170,171,110,114,172,97,98,99,100,173,174,175,151],"isic001206","epitaph for diokles",{"_":108},"sandstone","palermo","museo archeologico regionale antonino salinas","ancient greek",{"file":177,"uri":177,"title":178,"status":179,"editionAuthor":11,"type":180,"objectType":181,"material":182,"condition":34,"layoutDesc":183,"handNote":187,"date":195,"places":199,"geo":202,"country":65,"region":66,"settlement":141,"repository":204,"idno":205,"textLang":207,"facsimile":209,"provenance":53,"letterHeights":214,"publications":215,"zotero":219,"keywords":222,"html":103},"ISic001207","Epitaph for Nemeris, a goldsmith",{"_":10},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":116},{"_":172,"ana":119,"ref":120},{"layout":184},{"p":185,"rs":186,"damage":34},"Five lines of Greek letters, centred on the stone",{"_":31,"ana":32,"ref":33},{"lettering":188,"dimensions":189},"Slightly crudely incised simple broad letters without serifs. Nu i sregular; epsilon has slightly shorter middle bar; mu has slightly inward leaning first and last strokes, the mid-strokes reach down to the base-line; rho has a small eye, not always fully closed; alpha has broken bar; omega varies between open circle closed by horizontal bar and closed ovoid form with horizontal bar; phi has a small circular eye; sigma has standard form with horizontal top and bottom storkes; omicron is approximately the same size as other letters.",[190,194],{"type":39,"l":191,"from":41,"to":192,"h":193,"unit":43},"Lines 1-5","line5","30-45",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":196,"notBefore":197,"notAfter":198,"precision":16},"2nd century BCE(?)",-200,-101,[200,201],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[203],[63,64],{"_":143,"role":144,"ref":145},{"_":206,"type":148},"8706",{"_":150,"mainLang":151,"languages":208},[150],{"n":74,"url":210,"height":211,"width":212,"desc":213,"surfaceType":79},"ISic001207_tiled.tif","3212px","2498px","Photo J. Prag, courtesy Museo Archeologico Regionale Antonino Salinas",[],[216,161,162,163,217,218,86],"Kaibel, 1890, IG","Manni Piraino, 1976, Contribution Épigraphique à l'Étude de l'esclavage en Sicile","Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano",[165,166,90,167,220,221,92],"R9M263EA","RZSFKACR",[223,224,225,110,114,172,97,98,99,100,173,174,175,151],"isic001207","epitaph for nemeris, a goldsmith",{"_":10},{"file":227,"uri":227,"title":228,"status":229,"editionAuthor":11,"type":230,"objectType":231,"material":232,"condition":34,"layoutDesc":233,"handNote":237,"date":243,"places":246,"geo":249,"country":65,"region":66,"settlement":141,"repository":251,"idno":252,"textLang":254,"facsimile":256,"provenance":53,"letterHeights":261,"publications":262,"zotero":263,"keywords":264,"html":268},"ISic001208","Epitaph for Oltiskos",{"_":10},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":116},{"_":172,"ana":119,"ref":120},{"layout":234},{"p":235,"rs":236,"damage":34},"Two lines of Greek letters, centred on the front face of the stone.",{"_":31,"ana":32,"ref":33},{"lettering":238,"dimensions":239},"Neat, but irregularly sized letters. Omicron is smaller than the rest and mid-line; sigma is regular with horizontal top and bottom bars; kappa is tall with short arms, slightly curving out form the middle of the upright; alpha has straight bar (and in the second case is larger; epsilon has shorter middle bar.",[240,242],{"type":39,"l":129,"from":41,"to":42,"h":241,"unit":43},"30-50",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":244,"notBefore":245,"notAfter":198,"precision":16},"3rd — 2nd century BCE",-300,[247,248],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[250],[63,64],{"_":143,"role":144,"ref":145},{"_":253,"type":148},"8702",{"_":150,"mainLang":151,"languages":255},[150],{"n":74,"url":257,"height":258,"width":259,"desc":260,"surfaceType":79},"ISic001208_tiled.tif","2021px","1540px","Scan from IGMusPal, courtesy Museo Archeologico Regionale Antonino Salinas",[],[160,161,162,163,86],[165,166,90,167,92],[265,266,267,110,114,172,97,98,99,100,173,174,175,151],"isic001208","epitaph for oltiskos",{"_":10},"Unknown",{"file":270,"uri":270,"title":271,"status":272,"editionAuthor":11,"type":273,"objectType":274,"material":275,"condition":34,"layoutDesc":276,"handNote":280,"date":288,"places":289,"geo":292,"country":65,"region":66,"settlement":141,"repository":294,"idno":295,"textLang":297,"facsimile":299,"provenance":53,"letterHeights":303,"publications":304,"zotero":305,"keywords":306,"html":268},"ISic001209","Epitaph of Philisto",{"_":10},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":116},{"_":172,"ana":119,"ref":120},{"layout":277},{"p":278,"rs":279,"damage":34},"Single line of Greek letters across the middle of the stone",{"_":31,"ana":32,"ref":33},{"lettering":281,"dimensions":282},"Regular plain letters. Phi is slightly taller than the rest, but with a small circular eye; sigma has horizontal top and bottom bars, with the diagonals joined by a curve; omicron is smaller than the other letters and mid-line.",[283,286],{"type":39,"l":284,"from":41,"to":41,"h":285,"unit":43},"Line 1","30-35",{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},"NA",{"_":244,"notBefore":245,"notAfter":198,"precision":16},[290,291],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[293],[63,64],{"_":143,"role":144,"ref":145},{"_":296,"type":148},"8790",{"_":150,"mainLang":151,"languages":298},[150],{"n":74,"url":300,"height":301,"width":302,"desc":260,"surfaceType":79},"ISic120_tiled.tif","2034px","1459px",[],[216,161,162,163,86],[165,166,90,167,92],[307,308,309,110,114,172,97,98,99,100,173,174,175,151],"isic001209","epitaph of philisto",{"_":10},{"file":311,"uri":311,"title":312,"status":313,"editionAuthor":11,"type":314,"objectType":315,"material":317,"condition":34,"layoutDesc":318,"handNote":322,"date":328,"places":333,"geo":336,"country":65,"region":66,"settlement":57,"repository":338,"idno":341,"textLang":343,"facsimile":345,"provenance":53,"letterHeights":347,"publications":348,"zotero":351,"keywords":354,"html":268},"ISic004411","Epitaph for Kratisstos",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":316},"http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":172,"ana":119,"ref":120},{"layout":319},{"p":320,"rs":321,"damage":34},"Single line of Greek letters filling the width of the stone",{"_":31,"ana":32,"ref":33},{"lettering":323,"dimensions":324},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[325,327],{"type":39,"l":284,"from":41,"to":41,"h":326,"unit":43},"30",{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":329,"notBefore":330,"notAfter":331,"evidence":332,"precision":16},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[334,335],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[337],[63,64],{"_":339,"role":144,"ref":340},"Museo Archeologico Santi Furnari di Tripi","http://sicily.classics.ox.ac.uk/museum/177",{"_":342,"type":148},"ME23435",{"_":150,"mainLang":151,"languages":344},[150],{"n":74,"url":346,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004411_tiled.tif",[],[85,349,86,350],"Bacci et al., 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[91,352,92,353],"ILQ4RQGU","JQQKI6JP",[355,356,357,110,114,172,97,98,99,100,98,358,175,151],"isic004411","epitaph for kratisstos",{"_":108},"museo archeologico santi furnari di tripi",{"file":360,"uri":360,"title":361,"status":362,"editionAuthor":11,"type":363,"objectType":364,"material":365,"condition":34,"layoutDesc":366,"handNote":369,"date":374,"places":378,"geo":381,"country":65,"region":66,"settlement":57,"repository":383,"idno":384,"textLang":386,"facsimile":388,"provenance":53,"letterHeights":390,"publications":391,"zotero":392,"keywords":393,"html":103},"ISic004412","Epitaph for Aristoboula",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":316},{"_":172,"ana":119,"ref":120},{"layout":367},{"p":320,"rs":368,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":370,"dimensions":371},"Slightly irregular letters, becoming slightly more compressed to the right hand end: Alpha broad with broken bar; rho has small closed eye; sigma is four equal bars, angled apart; omicron is small and mid-line; beta has equal closed eyes, with slight gap between them; upsilon asymmetrical.",[372,373],{"type":39,"l":284,"from":41,"to":41,"h":326,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":375,"notBefore":376,"notAfter":377,"evidence":135,"precision":16},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-350,-251,[379,380],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[382],[63,64],{"_":339,"role":144,"ref":340},{"_":385,"type":148},"ME23439",{"_":150,"mainLang":151,"languages":387},[150],{"n":74,"url":389,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004412_tiled.tif",[],[349,86,350],[352,92,353],[394,395,396,110,114,172,97,98,99,100,98,358,175,151],"isic004412","epitaph for aristoboula",{"_":108},{"file":398,"uri":398,"title":399,"status":400,"editionAuthor":11,"type":401,"objectType":402,"material":403,"condition":34,"layoutDesc":404,"handNote":407,"date":412,"places":415,"geo":418,"country":65,"region":66,"settlement":57,"repository":420,"idno":421,"textLang":423,"facsimile":425,"provenance":53,"letterHeights":427,"publications":428,"zotero":429,"keywords":430,"html":103},"ISic004413","Epitaph for Kallo",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":316},{"_":172,"ana":119,"ref":120},{"layout":405},{"p":320,"rs":406,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":408,"dimensions":409},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[410,411],{"type":39,"l":284,"from":41,"to":41,"h":326,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":413,"notBefore":245,"notAfter":414,"evidence":332,"precision":16},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-201,[416,417],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[419],[63,64],{"_":339,"role":144,"ref":340},{"_":422,"type":148},"ME23436",{"_":150,"mainLang":151,"languages":424},[150],{"n":74,"url":426,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004413_tiled.tif",[],[349,86,350],[352,92,353],[431,432,433,110,114,172,97,98,99,100,98,358,175,151],"isic004413","epitaph for kallo",{"_":108},{"file":435,"uri":435,"title":436,"status":437,"editionAuthor":11,"type":438,"objectType":439,"material":440,"condition":34,"layoutDesc":441,"handNote":444,"date":449,"places":450,"geo":453,"country":65,"region":66,"settlement":57,"repository":455,"idno":456,"textLang":458,"facsimile":460,"provenance":53,"letterHeights":462,"publications":463,"zotero":464,"keywords":465,"html":103},"ISic004414","Epitaph for Eupolemos",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":316},{"_":172,"ana":119,"ref":120},{"layout":442},{"p":320,"rs":443,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":445,"dimensions":446},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[447,448],{"type":39,"l":284,"from":41,"to":41,"h":326,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":413,"notBefore":245,"notAfter":414,"evidence":332,"precision":16},[451,452],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[454],[63,64],{"_":339,"role":144,"ref":340},{"_":457,"type":148},"ME23438",{"_":150,"mainLang":151,"languages":459},[150],{"n":74,"url":461,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004414_tiled.tif",[],[85,349,86,350],[91,352,92,353],[466,467,468,110,114,172,97,98,99,100,98,358,175,151],"isic004414","epitaph for eupolemos",{"_":108},{"file":470,"uri":470,"title":471,"status":472,"editionAuthor":11,"type":473,"objectType":474,"material":478,"condition":34,"layoutDesc":479,"handNote":483,"date":488,"places":490,"geo":494,"country":65,"region":66,"settlement":57,"repository":496,"idno":500,"textLang":501,"facsimile":503,"provenance":53,"letterHeights":505,"publications":506,"zotero":507,"keywords":508,"html":103},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":108},{"_":110,"ana":111,"ref":112},{"_":475,"ana":476,"ref":477},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":172,"ana":119,"ref":120},{"layout":480},{"p":481,"rs":482,"damage":34},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":31,"ana":32,"ref":33},{"lettering":484,"dimensions":485},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[486,487],{"type":39,"l":129,"from":41,"to":42,"h":326,"unit":43},{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":489,"notBefore":376,"notAfter":414,"evidence":332,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[491,493],{"_":53,"type":54,"ref":55,"corresp":492},"#findspot",{"_":57,"type":58,"ref":59,"offset":60},[495],[63,64],{"_":497,"role":498,"ref":499},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":148},{"_":150,"mainLang":151,"languages":502},[150],{"n":74,"url":504,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004417_tiled.tif",[],[85,86,350],[91,92,353],[509,510,511,110,475,172,97,98,99,100,98,512,175,151],"isic004417","epitaph for [-?-], child of gerontios",{"_":108},"necropoli di abakainon",{"file":514,"uri":514,"title":471,"status":515,"editionAuthor":11,"type":516,"objectType":517,"material":518,"condition":34,"layoutDesc":519,"handNote":523,"date":529,"places":531,"geo":534,"country":65,"region":66,"settlement":57,"repository":536,"idno":537,"textLang":538,"facsimile":540,"provenance":53,"letterHeights":542,"publications":543,"zotero":544,"keywords":545,"html":103},"ISic004418",{"_":108},{"_":110,"ana":111,"ref":112},{"_":475,"ana":476,"ref":477},{"_":172,"ana":119,"ref":120},{"layout":520},{"p":521,"rs":522,"damage":34},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":524,"dimensions":525},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[526,528],{"type":39,"l":129,"from":41,"to":42,"h":527,"unit":43},"59",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":530,"notBefore":376,"notAfter":414,"evidence":332,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[532,533],{"_":53,"type":54,"ref":55,"corresp":492},{"_":57,"type":58,"ref":59,"offset":60},[535],[63,64],{"_":497,"role":498,"ref":499},{"type":148},{"_":150,"mainLang":151,"languages":539},[150],{"n":74,"url":541,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004418_tiled.tif",[],[85,86,350],[91,92,353],[546,510,547,110,475,172,97,98,99,100,98,512,175,151],"isic004418",{"_":108},{"file":549,"uri":549,"title":550,"status":551,"editionAuthor":11,"type":552,"objectType":553,"material":554,"condition":34,"layoutDesc":555,"handNote":559,"date":565,"places":567,"geo":570,"country":65,"region":66,"settlement":57,"repository":572,"idno":573,"textLang":575,"facsimile":577,"provenance":53,"letterHeights":579,"publications":580,"zotero":581,"keywords":582,"html":103},"ISic004422","Epitaph for Artemidoros (?)",{"_":108},{"_":110,"ana":111,"ref":112},{"_":475,"ana":476,"ref":477},{"_":172,"ana":119,"ref":120},{"layout":556},{"p":557,"rs":558,"damage":34},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":560,"dimensions":561},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[562,564],{"type":39,"l":284,"from":41,"to":41,"h":563,"unit":43},"29",{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":566,"notBefore":376,"notAfter":414,"evidence":332,"precision":16},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[568,569],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[571],[63,64],{"_":339,"role":144,"ref":340},{"_":574,"type":148},"ME23440",{"_":150,"mainLang":151,"languages":576},[150],{"n":74,"url":578,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004422_tiled.tif",[],[86,350],[92,353],[583,584,585,110,475,172,97,98,99,100,98,358,175,151],"isic004422","epitaph for artemidoros (?)",{"_":108}],"uses":{"params":["slug"]}}]}
