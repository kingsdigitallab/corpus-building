le bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[485,487],{"type":38,"l":143,"from":40,"to":48,"h":486,"unit":42,"atLeast":486,"atMost":486},"59",{"type":46,"l":47,"from":40,"to":48,"unit":42},{"_":489,"notBefore":441,"notAfter":442,"evidence":386},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[491,492],{"_":56,"type":57,"ref":58,"corresp":445,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[494],[67,68],[70,71],{"_":451,"role":452,"ref":453},{"type":80},{"_":82,"mainLang":83,"languages":499},[82],{"n":87,"url":501,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004418_tiled.tif",[503],{"atLeast":504,"atMost":504},59,[349,102,406],[353,108,409],[508,465,509,15,426,23,113,114,115,116,114,467,119,83],"isic004418",{"_":182},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":417,"ptr":512,"ref":513,"inscriptionDate":4,"title":2,"citation":5,"uri":6},{"target":124},{"_":126,"target":126},{"file":515,"uri":515,"title":516,"status":517,"editionAuthor":13,"type":518,"objectType":519,"material":520,"condition":26,"layoutDesc":521,"handNote":524,"date":529,"places":531,"geo":534,"country":59,"provenance":56,"provenanceGeo":536,"region":72,"settlement":61,"repository":537,"idno":538,"textLang":540,"tmNumber":26,"facsimile":542,"letterHeights":544,"publications":546,"zotero":547,"keywords":548,"html":552,"bibl":553,"bulletinDateSort":127,"citedRangeSort":554,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004413","Epitaph for Kallo",{"_":182},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":371},{"_":23,"ana":24,"ref":25},{"layout":522},{"p":375,"rs":523,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":525,"dimensions":526},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[527,528],{"type":38,"l":39,"from":40,"to":40,"h":43,"unit":42,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":530,"notBefore":52,"notAfter":442,"evidence":386},"The goods recovered from the tomb suggest a date in the 3rd century BCE",[532,533],{"_":56,"type":57,"ref":58,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[535],[67,68],[70,71],{"_":394,"role":76,"ref":395},{"_":539,"type":80},"ME23436",{"_":82,"mainLang":83,"languages":541},[82],{"n":87,"url":543,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004413_tiled.tif",[545],{"atLeast":95,"atMost":95},[405,102,406],[408,108,409],[549,550,551,15,19,23,113,114,115,116,114,414,119,83],"isic004413","epitaph for kallo",{"_":182},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":554,"ptr":555,"ref":556,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"115 fig.118",{"target":124},{"_":126,"target":126},{"file":558,"uri":558,"title":559,"status":560,"editionAuthor":13,"type":561,"objectType":562,"material":563,"condition":26,"layoutDesc":564,"handNote":567,"date":572,"places":573,"geo":576,"country":59,"provenance":56,"provenanceGeo":578,"region":72,"settlement":61,"repository":579,"idno":580,"textLang":582,"tmNumber":26,"facsimile":584,"letterHeights":586,"publications":588,"zotero":589,"keywords":590,"html":594,"bibl":595,"bulletinDateSort":127,"citedRangeSort":596,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004414","Epitaph for Eupolemos",{"_":182},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":371},{"_":23,"ana":24,"ref":25},{"layout":565},{"p":375,"rs":566,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":568,"dimensions":569},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[570,571],{"type":38,"l":39,"from":40,"to":40,"h":43,"unit":42,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":530,"notBefore":52,"notAfter":442,"evidence":386},[574,575],{"_":56,"type":57,"ref":58,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[577],[67,68],[70,71],{"_":394,"role":76,"ref":395},{"_":581,"type":80},"ME23438",{"_":82,"mainLang":83,"languages":583},[82],{"n":87,"url":585,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004414_tiled.tif",[587],{"atLeast":95,"atMost":95},[349,405,102,406],[353,408,108,409],[591,592,593,15,19,23,113,114,115,116,114,414,119,83],"isic004414","epitaph for eupolemos",{"_":182},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":596,"ptr":597,"ref":598,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"115 fig.119",{"target":124},{"_":126,"target":126},{"file":600,"uri":600,"title":601,"status":602,"editionAuthor":13,"type":603,"objectType":604,"material":605,"condition":26,"layoutDesc":606,"handNote":610,"date":616,"places":618,"geo":621,"country":59,"provenance":56,"provenanceGeo":623,"region":72,"settlement":61,"repository":624,"idno":625,"textLang":627,"tmNumber":26,"facsimile":629,"letterHeights":631,"publications":634,"zotero":635,"keywords":636,"html":640,"bibl":641,"bulletinDateSort":127,"citedRangeSort":642,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":182},{"_":15,"ana":16,"ref":17},{"_":426,"ana":427,"ref":428},{"_":23,"ana":24,"ref":25},{"layout":607},{"p":608,"rs":609,"damage":26},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":611,"dimensions":612},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[613,615],{"type":38,"l":39,"from":40,"to":40,"h":614,"unit":42,"atLeast":614,"atMost":614},"29",{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":617,"notBefore":441,"notAfter":442,"evidence":386},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[619,620],{"_":56,"type":57,"ref":58,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[622],[67,68],[70,71],{"_":394,"role":76,"ref":395},{"_":626,"type":80},"ME23440",{"_":82,"mainLang":83,"languages":628},[82],{"n":87,"url":630,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004422_tiled.tif",[632],{"atLeast":633,"atMost":633},29,[102,406],[108,409],[637,638,639,15,426,23,113,114,115,116,114,414,119,83],"isic004422","epitaph for artemidoros (?)",{"_":182},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":642,"ptr":643,"ref":644,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"116 fig.120",{"target":124},{"_":126,"target":126},{"file":646,"uri":646,"title":647,"status":648,"editionAuthor":13,"type":649,"objectType":650,"material":651,"condition":26,"layoutDesc":652,"handNote":655,"date":660,"places":663,"geo":666,"country":59,"provenance":56,"provenanceGeo":668,"region":72,"settlement":61,"repository":669,"idno":670,"textLang":672,"tmNumber":26,"facsimile":674,"letterHeights":676,"publications":678,"zotero":679,"keywords":680,"html":684,"bibl":685,"bulletinDateSort":127,"citedRangeSort":686,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004412","Epitaph for Aristoboula",{"_":182},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":371},{"_":23,"ana":24,"ref":25},{"layout":653},{"p":375,"rs":654,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":656,"dimensions":657},"Slightly irregular letters, becoming slightly more compressed to the right hand end: Alpha broad with broken bar; rho has small closed eye; sigma is four equal bars, angled apart; omicron is small and mid-line; beta has equal closed eyes, with slight gap between them; upsilon asymmetrical.",[658,659],{"type":38,"l":39,"from":40,"to":40,"h":43,"unit":42,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":661,"notBefore":441,"notAfter":662,"evidence":202},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-251,[664,665],{"_":56,"type":57,"ref":58,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[667],[67,68],[70,71],{"_":394,"role":76,"ref":395},{"_":671,"type":80},"ME23439",{"_":82,"mainLang":83,"languages":673},[82],{"n":87,"url":675,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004412_tiled.tif",[677],{"atLeast":95,"atMost":95},[405,102,406],[408,108,409],[681,682,683,15,19,23,113,114,115,116,114,414,119,83],"isic004412","epitaph for aristoboula",{"_":182},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοβούλας \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":686,"ptr":687,"ref":688,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"116 fig.121",{"target":124},{"_":126,"target":126},false],"uses":{"params":["slug"]}}]}
