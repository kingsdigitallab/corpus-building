6,"ref":27},{"layout":482},{"p":483,"rs":484,"damage":28},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":33,"ana":34,"ref":35},{"lettering":486,"dimensions":487},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[488,490],{"type":40,"l":145,"from":42,"to":50,"h":489,"unit":44,"atLeast":489,"atMost":489},"59",{"type":48,"l":49,"from":42,"to":50,"unit":44},{"_":492,"notBefore":444,"notAfter":445,"evidence":389},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[494,495],{"_":58,"type":59,"ref":60,"corresp":448,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[497],[69,70],[72,73],{"_":454,"role":455,"ref":456},{"type":82},{"_":84,"mainLang":85,"languages":502},[84],{"n":89,"url":504,"height":219,"width":220,"desc":221,"surfaceType":94},"ISic004418_tiled.tif",[506],{"atLeast":507,"atMost":507},59,[352,104,409],[356,110,412],[511,468,512,15,429,23,115,116,117,118,116,470,121,85],"isic004418",{"_":184},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":420,"ptr":515,"ref":516,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":126},{"_":128,"target":128},{"file":518,"uri":518,"title":519,"status":520,"editionAuthor":13,"type":521,"objectType":522,"material":523,"condition":28,"layoutDesc":524,"handNote":527,"date":532,"places":534,"geo":537,"country":61,"provenance":58,"provenanceGeo":539,"region":74,"settlement":63,"repository":540,"idno":541,"textLang":543,"tmNumber":28,"facsimile":545,"letterHeights":547,"publications":549,"zotero":550,"keywords":551,"html":555,"bibl":556,"bulletinDateSort":129,"citedRangeSort":557,"languageSort":84,"materialSort":23,"typeSort":15},"ISic004413","Epitaph for Kallo",{"_":184},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":374},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":525},{"p":378,"rs":526,"damage":28},{"_":33,"ana":34,"ref":35},{"lettering":528,"dimensions":529},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[530,531],{"type":40,"l":41,"from":42,"to":42,"h":45,"unit":44,"atLeast":45,"atMost":45},{"type":48,"l":49,"from":42,"to":50,"h":51,"unit":44},{"_":533,"notBefore":54,"notAfter":445,"evidence":389},"The goods recovered from the tomb suggest a date in the 3rd century BCE",[535,536],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[538],[69,70],[72,73],{"_":397,"role":78,"ref":398},{"_":542,"type":82},"ME23436",{"_":84,"mainLang":85,"languages":544},[84],{"n":89,"url":546,"height":219,"width":220,"desc":221,"surfaceType":94},"ISic004413_tiled.tif",[548],{"atLeast":97,"atMost":97},[408,104,409],[411,110,412],[552,553,554,15,19,23,115,116,117,118,116,417,121,85],"isic004413","epitaph for kallo",{"_":184},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":557,"ptr":558,"ref":559,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"115 fig.118",{"target":126},{"_":128,"target":128},{"file":561,"uri":561,"title":562,"status":563,"edit