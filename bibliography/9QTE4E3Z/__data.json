span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χαῖρε\" data-n=\"10\" data-lemma=\"χαίρω\">χαῖρε\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":231,"ptr":232,"ref":233,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"108 and fig.112",{"target":124},{"_":126,"target":126},{"file":235,"uri":235,"title":236,"status":237,"editionAuthor":13,"type":238,"objectType":239,"material":240,"condition":26,"layoutDesc":241,"handNote":245,"date":254,"places":257,"geo":260,"country":59,"provenance":56,"provenanceGeo":262,"region":72,"settlement":73,"repository":263,"idno":264,"textLang":266,"tmNumber":268,"facsimile":269,"letterHeights":274,"publications":277,"zotero":280,"keywords":283,"html":287,"bibl":288,"bulletinDateSort":127,"citedRangeSort":289,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001207","Epitaph for Nemeris, a goldsmith",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":242},{"p":243,"rs":244,"damage":26},"Five lines of Greek letters, centred on the stone",{"_":31,"ana":32,"ref":33},{"lettering":246,"dimensions":247},"Slightly crudely incised simple broad letters without serifs. Nu i sregular; epsilon has slightly shorter middle bar; mu has slightly inward leaning first and last strokes, the mid-strokes reach down to the base-line; rho has a small eye, not always fully closed; alpha has broken bar; omega varies between open circle closed by horizontal bar and closed ovoid form with horizontal bar; phi has a small circular eye; sigma has standard form with horizontal top and bottom storkes; omicron is approximately the same size as other letters.",[248,253],{"type":38,"l":249,"from":40,"to":250,"h":251,"unit":42,"atLeast":43,"atMost":252},"Lines 1-5","line5","30-45","45",{"type":46,"l":47,"from":40,"to":48,"unit":42},{"_":255,"notBefore":256,"notAfter":53},"2nd century BCE(?)",-200,