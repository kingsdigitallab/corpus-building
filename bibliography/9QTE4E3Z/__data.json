; sigma has horizontal top and bottom strokes.",[463,464],{"type":39,"l":318,"from":41,"to":41,"h":367,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":321,"unit":43},{"_":466,"notBefore":273,"notAfter":467,"evidence":373,"precision":16},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-201,[469,470],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[472],[63,64],[223,224],{"_":381,"role":156,"ref":382},{"_":476,"type":160},"ME23436",{"_":162,"mainLang":163,"languages":478},[162],{"n":78,"url":480,"height":168,"width":169,"desc":170,"surfaceType":83},"ISic004413_tiled.tif",[],[391,90,392],[394,96,395],[485,486,487,121,125,185,101,102,103,104,102,400,188,163],"isic004413","epitaph for kallo",{"_":119},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":490,"ptr":491,"ref":492,"title":2,"citation":4},"115 fig.118",{"target":112},{"_":114,"target":114},{"file":494,"uri":494,"title":495,"status":496,"editionAuthor":11,"type":497,"objectType":498,"material":499,"condition":34,"layoutDesc":500,"handNote":503,"date":508,"places":509,"geo":512,"provenance":53,"provenanceGeo":514,"country":68,"region":69,"settlement":57,"repository":515,"idno":516,"textLang":518,"tmNumber":34,"facsimile":520,"letterHeights":522,"publications":523,"zotero":524,"keywords":525,"html":529,"bibl":530},"ISic004414","Epitaph for Eupolemos",{"_":119},{"_":121,"ana":122,"ref":123},{"_":125,"ana":126,"ref":357},{"_":185,"ana":130,"ref":131},{"layout":501},{"p":361,"rs":502,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":504,"dimensions":505},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[506,507],{"type":39,"l":318,"from":41,"to":41,"h":367,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":321,"unit":43},{"_":466,"notBefore":273,"notAfter":467,"evidence":373,"precision":16},[510,511],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[513],[63,64],[223,224],{"_":381,"role":156,"ref":382},{"_":517,"type":160},"ME23438",{"_":162,"mainLang":163,"languages":519},[162],{"n":78,"url":521,"height":168,"width":169,"desc":170,"surfaceType":83},"ISic004414_tiled.tif",[],[89,391,90,392],[95,394,96,395],[526,527,528,121,125,185,101,102,103,104,102,400,188,163],"isic004414","epitaph for eupolemos",{"_":119},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":531,"ptr":532,"ref":533,"title":2,"citation":4},"115 fig.119",{"target":112},{"_":114,"target":114},{"file":535,"uri":535,"title":536,"status":537,"editionAuthor":11,"type":538,"objectType":539,"material":543,"condition":34,"layoutDesc":544,"handNote":548,"date":553,"places":555,"geo":559,"provenance":53,"provenanceGeo":561,"country":68,"region":69,"settlement":57,"repository":562,"idno":566,"textLang":567,"tmNumber":34,"facsimile":569,"letterHeights":571,"publications":572,"zotero":573,"keywords":574,"html":579,"bibl":580},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":119},{"_":121,"ana":122,"ref":123},{"_":540,"ana":541,"ref":542},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":185,"ana":130,"ref":131},{"layout":545},{"p":546,"rs":547,"damage":34},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":31,"ana":32,"ref":33},{"lettering":549,"dimensions":550},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[551,552],{"type":39,"l":140,"from":41,"to":42,"h":367,"unit":43},{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":554,"notBefore":423,"notAfter":467,"evidence":373,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[556,558],{"_":53,"type":54,"ref":55,"corresp":557},"#findspot",{"_":57,"type":58,"ref":59,"offset":60},[560],[63,64],[223,224],{"_":563,"role":564,"ref":565},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":160},{"_":162,"mainLang":163,"languages":568},[162],{"n":78,"url":570,"height":168,"width":169,"desc":170,"surfaceType":83},"ISic004417_tiled.tif",[],[89,90,392],[95,96,395],[575,576,577,121,540,185,101,102,103,104,102,578,188,163],"isic004417","epitaph for [-?-], child of gerontios",{"_":119},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":403,"ptr":581,"ref":582,"title":2,"citation":4},{"target":112},{"_":114,"target":114},{"file":584,"uri":584,"title":536,"status":585,"editionAuthor":11,"type":586,"objectType":587,"material":588,"condition":34,"layoutDesc":589,"handNote":593,"date":599,"places":601,"geo":604,"provenance":53,"provenanceGeo":606,"country":68,"region":69,"settlement":57,"repository":607,"idno":608,"textLang":609,"tmNumber":34,"facsimile":611,"letterHeights":613,"publications":614,"zotero":615,"keywords":616,"html":619,"bibl":620},"ISic004418",{"_":119},{"_":121,"ana":122,"ref":123},{"_":540,"ana":541,"ref":542},{"_":185,"ana":130,"ref":131},{"layout":590},{"p":591,"rs":592,"damage":34},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":594,"dimensions":595},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[596,598],{"type":39,"l":140,"from":41,"to":42,"h":597,"unit":43},"59",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":600,"notBefore":423,"notAfter":467,"evidence":373,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[602,603],{"_":53,"type":54,"ref":55,"corresp":557},{"_":57,"type":58,"ref":59,"offset":60},[605],[63,64],[223,224],{"_":563,"role":564,"ref":565},{"type":160},{"_":162,"mainLang":163,"languages":610},[162],{"n":78,"url":612,"height":168,"width":169,"desc":170,"surfaceType":83},"ISic004418_tiled.tif",[],[89,90,392],[95,96,395],[617,576,618,121,540,185,101,102,103,104,102,578,188,163],"isic004418",{"_":119},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":403,"p