:16,"ref":17},{"_":19,"ana":20,"ref":370},{"_":23,"ana":24,"ref":25},{"layout":521},{"p":374,"rs":522,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":524,"dimensions":525},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[526,527],{"type":38,"l":39,"from":40,"to":40,"h":43,"unit":42,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":529,"notBefore":52,"notAfter":441,"evidence":385},"The goods recovered from the tomb suggest a date in the 3rd century BCE",[531,532],{"_":56,"type":57,"ref":58,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[534],[67,68],[70,71],{"_":393,"role":76,"ref":394},{"_":538,"type":80},"ME23436",{"_":82,"mainLang":83,"languages":540},[82],{"n":87,"url":542,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004413_tiled.tif",[544],{"atLeast":95,"atMost":95},[404,102,405],[407,108,408],[548,549,550,15,19,23,113,114,115,116,114,413,119,83],"isic004413","epitaph for kallo",{"_":182},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":553,"ptr":554,"ref":555,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"115 fig.118",{"target":124},{"_":126,"target":126},{"file":557,"uri":557,"title":558,"status":559,"editionAuthor":13,"type":560,"objectType":561,"material":562,"condition":26,"layoutDesc":563,"handNote":566,"date":571,"places":572,"geo":575,"country":59,"provenance":56,"provenanceGeo":577,"region":72,"settlement":61,"repository":578,"idno":579,"textLang":581,"tmNumber":26,"facsimile":583,"letterHeights":585,"publications":587,"zotero":588,"keywords":589,"html":593,"bibl":594,"bulletinDateSort":127,"citedRangeSort":595,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004414","Epitaph for Eupolemos",{"_":182},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":370},{"_":23,"ana":24,"ref":25},{"layout":564},{"p":374,"rs":565,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":567,"dimensions":568},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[569,570],{"type":38,"l":39,"from":40,"to":40,"h":43,"unit":42,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":529,"notBefore":52,"notAfter":441,"evidence":385},[573,574],{"_":56,"type":57,"ref":58,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[576],[67,68],[70,71],{"_":393,"role":76,"ref":394},{"_":580,"type":80},"ME23438",{"_":82,"mainLang":83,"languages":582},[82],{"n":87,"url":584,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004414_tiled.tif",[586],{"atLeast":95,"atMost":95},[348,404,102,405],[352,407,108,408],[590,591,592,15,19,23,113,114,115,116,114,413,119,83],"isic004414","epitaph for eupolemos",{"_":182},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":595,"ptr":596,"ref":597,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"115 fig.119",{"target":124},{"_":126,"target":126},{"file":599,"uri":599,"title":600,"status":601,"editionAuthor":13,"type":602,"objectType":603,"material":604,"condition":26,"layoutDesc":605,"handNote":609,"date":615,"places":617,"geo":620,"country":59,"provenance":56,"provenanceGeo":622,"region":72,"settlement":61,"repository":623,"idno":624,"textLang":626,"tmNumber":26,"facsimile":628,"letterHeights":630,"publications":633,"zotero":634,"keywords":635,"html":639,"bibl":640,"bulletinDateSort":127,"citedRangeSort":641,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":182},{"_":15,"ana":16,"ref":17},{"_":425,"ana":426,"ref":427},{"_":23,"ana":24,"ref":25},{"layout":606},{"p":607,"rs":608,"damage":26},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":610,"dimensions":611},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[612,614],{"type":38,"l":39,"from":40,"to":40,"h":613,"unit":42,"atLeast":613,"atMost":613},"29",{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":616,"notBefore":440,"notAfter":441,"evidence":385},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[618,619],{"_":56,"type":57,"ref":58,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[621],[67,68],[70,71],{"_":393,"role":76,"ref":394},{"_":625,"type":80},"ME23440",{"_":82,"mainLang":83,"languages":627},[82],{"n":87,"url":629,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004422_tiled.tif",[631],{"atLeast":632,"atMost":632},29,[102,405],[108,408],[636,637,638,15,425,23,113,114,115,116,114,413,119,83],"isic004422","epitaph for artemidoros (?)",{"_":182},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":641,"ptr":642,"ref":643,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"116 fig.120",{"target":124},{"_":126,"target":126},{"file":645,"uri":645,"title":646,"status":647,"editionAuthor":13,"type":648,"objectType":649,"material":650,"condition":26,"layoutDesc":651,"handNote":654,"date":659,"places":662,"geo":665,"country":59,"provenance":56,"provenanceGeo":667,"region":72,"settlement":61,"repository":668,"idno":669,"textLang":671,"tmNumber":26,"facsimile":673,"letterHeights":675,"publications":677,"zotero":678,"keywords":679,"html":683,"bibl":684,"bulletinDateSort":127,"citedRangeSort":685,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004412","Epitaph for Aristoboula",{"_":182},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":370},{"_":23,"ana":24,"ref":25},{"layout":652},{"p":374,"rs":653,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":655,"dimensions":656},"Slightly irregular letters, becoming slightly more compressed to the right hand end: Alpha broad with broken bar; rho has small closed eye; sigma is four equal bars, angled apart; omicron is small and mid-line; beta has equal closed eyes, with slight gap between them; upsilon asymmetrical.",[657,658],{"type":38,"l":39,"from":40,"to":40,"h":43,"unit":42,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":660,"notBefore":440,"notAfter":661,"evidence":202},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-251,[663,664],{"_":56,"type":57,"ref":58,"region":59},{"_":61,"type":62,"ref":63,"offset":64,"region":59},[666],[67,68],[70,71],{"_":393,"role":76,"ref":394},{"_":670,"type":80},"ME23439",{"_":82,"mainLang":83,"languages":672},[82],{"n":87,"url":674,"height":217,"width":218,"desc":219,"surfaceType":92},"ISic004412_tiled.tif",[676],{"atLeast":95,"atMost":95},[404,102,405],[40