cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[538,540],{"_":53,"type":54,"ref":55,"corresp":539},"#findspot",{"_":57,"type":58,"ref":59,"offset":60},[542],[63,64],{"_":544,"role":545,"ref":546},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":155},{"_":157,"mainLang":158,"languages":549},[157],{"n":74,"url":551,"height":162,"width":163,"desc":164,"surfaceType":79},"ISic004417_tiled.tif",[],[85,86,377],[91,92,380],[556,557,558,117,522,179,97,98,99,100,98,559,182,158],"isic004417","epitaph for [-?-], child of gerontios",{"_":115},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":388,"ptr":562,"ref":563,"title":2,"citation":4},{"target":108},{"_":110,"target":110},{"file":565,"uri":565,"title":518,"status":566,"editionAuthor":11,"type":567,"objectType":568,"material":569,"condition":34,"layoutDesc":570,"handNote":574,"date":580,"places":582,"geo":585,"country":65,"region":66,"settlement":57,"repository":587,"idno":588,"textLang":589,"facsimile":591,"provenance":53,"letterHeights":593,"publications":594,"zotero":595,"keywords":596,"html":599,"bibl":600},"ISic004418",{"_":115},{"_":117,"ana":118,"ref":119},{"_":522,"ana":523,"ref":524},{"_":179,"ana":126,"ref":127},{"layout":571},{"p":572,"rs":573,"damage":34},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":575,"dimensions":576},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[577,579],{"type":39,"l":136,"from":41,"to":42,"h":578,"unit":43},"59",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":581,"notBefore":408,"notAfter":451,"evidence":359,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[583,584],{"_":53,"type":54,"ref":55,"corresp":539},{"_":57,"type":58,"ref":59,"offset":60},[586],[63,64],{"_":544,"role":545,"ref":546},{"type":155},{"_":157,"mainLang":158,"languages":590},[157],{"n":74,"url":592,"height":162,"width":163,"desc":164,"surfaceType":79},"ISic004418_tiled.tif",[],[85,86,377],[91,92,380],[597,557,598,117,522,179,97,98,99,100,98,559,182,158],"isic004418",{"_":115},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":388,"ptr":601,"ref":602,"title":2,"citation":4},{"target":108},{"_":110,"target":110},{"file":604,"uri":604,"title":605,"status":606,"editionAuthor":11,"type":607,"objectType":608,"material":609,"condition":34,"layoutDesc":610,"handNote":614,"date":620,"places":622,"geo":625,"country":65,"region":66,"settlement":57,"repository":627,"idno":628,"textLang":630,"facsimile":632,"provenance":53,"letterHeights":634,"publications":635,"zotero":636,"keywords":637,"html":641,"bibl":642},"ISic004422","Epitaph for Artemidoros (?)",{"_":115},{"_":117,"ana":118,"ref":119},{"_":522,"ana":523,"ref":524},{"_":179,"ana":126,"ref":127},{"layout":611},{"p":612,"rs":613,"damage":34},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":615,"dimensions":616},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[617,619],{"type":39,"l":306,"from":41,"to":41,"h":618,"unit":43},"29",{"type":45,"l":46,"from":41,"to":42,"h":309,"unit":43},{"_":621,"notBefore":408,"notAfter":451,"evidence":359,"precision":16},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[623,624],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[626],[63,64],{"_":366,"role":151,"ref":367},{"_":629,"type":155},"ME23440",{"_":157,"mainLang":158,"languages":631},[157],{"n":74,"url":633,"height":162,"width":163,"desc":164,"surfaceType":79},"ISic004422_tiled.tif",[],[86,377],[92,380],[638,639,640,117,522,179,97,98,99,100,98,385,182,158],"isic004422","epitaph for artemidoros (?)",{"_":115},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":105,"date":3,"citedRange":643,"ptr":644,"ref":645,"title":2,"citation":4},"116 fig.120",{"target":108},{"_":110,"target":110}],"uses":{"params":["slug"]}}]}
