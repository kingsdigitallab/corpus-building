,"h":363,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":317,"unit":43},{"_":462,"notBefore":269,"notAfter":463,"evidence":369,"precision":17},[506,507],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[509],[63,64],[220,221],{"_":377,"role":154,"ref":378},{"_":513,"type":158},"ME23438",{"_":160,"mainLang":161,"languages":515},[160],{"n":78,"url":517,"height":166,"width":167,"desc":168,"surfaceType":83},"ISic004414_tiled.tif",[],[88,387,89,388],[94,390,95,391],[522,523,524,119,123,182,100,101,102,103,101,396,185,161],"isic004414","epitaph for eupolemos",{"_":117},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":527,"ptr":528,"ref":529,"title":2,"citation":5},"115 fig.119",{"target":110},{"_":112,"target":112},{"file":531,"uri":531,"title":532,"status":533,"editionAuthor":12,"type":534,"objectType":535,"material":539,"condition":3,"layoutDesc":540,"handNote":544,"date":549,"places":551,"geo":555,"provenance":53,"provenanceGeo":557,"country":68,"region":69,"settlement":57,"repository":558,"idno":562,"textLang":563,"tmNumber":3,"facsimile":565,"letterHeights":567,"publications":568,"zotero":569,"keywords":570,"html":575,"bibl":576},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":117},{"_":119,"ana":120,"ref":121},{"_":536,"ana":537,"ref":538},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":182,"ana":128,"ref":129},{"layout":541},{"p":542,"rs":543,"damage":3},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":32,"ana":33,"ref":34},{"lettering":545,"dimensions":546},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[547,548],{"type":39,"l":138,"from":41,"to":42,"h":363,"unit":43},{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":550,"notBefore":419,"notAfter":463,"evidence":369,"precision":17},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[552,554],{"_":53,"type":54,"ref":55,"corresp":553},"#findspot",{"_":57,"type":58,"ref":59,"offset":60},[556],[63,64],[220,221],{"_":559,"role":560,"ref":561},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":158},{"_":160,"mainLang":161,"languages":564},[160],{"n":78,"url":566,"height":166,"width":167,"desc":168,"surfaceType":83},"ISic004417_tiled.tif",[],[88,89,388],[94,95,391],[571,572,573,119,536,182,100,101,102,103,101,574,185,161],"isic004417","epitaph for [-?-], child of gerontios",{"_":117},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":399,"ptr":577,"ref":578,"title":2,"citation":5},{"target":110},{"_":112,"target":112},{"file":580,"uri":580,"title":532,"status":581,"editionAuthor":12,"type":582,"objectType":583,"material":584,"condition":3,"layoutDesc":585,"handNote":589,"date":595,"places":597,"geo":600,"provenance":53,"provenanceGeo":602,"country":68,"region":69,"settlement":57,"repository":603,"idno":604,"textLang":605,"tmNumber":3,"facsimile":607,"letterHeights":609,"publications":610,"zotero":611,"keywords":612,"html":615,"bibl":616},"ISic004418",{"_":117},{"_":119,"ana":120,"ref":121},{"_":536,"ana":537,"ref":538},{"_":182,"ana":128,"ref":129},{"layout":586},{"p":587,"rs":588,"damage":3},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":32,"ana":33,"ref":34},{"lettering":590,"dimensions":591},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[592,594],{"type":39,"l":138,"from":41,"to":42,"h":593,"unit":43},"59",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":596,"notBefore":419,"notAfter":463,"evidence":369,"precision":17},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[598,599],{"_":53,"type":54,"ref":55,"corresp":553},{"_":57,"type":58,"ref":59,"offset":60},[601],[63,64],[220,221],{"_":559,"role":560,"ref":561},{"type":158},{"_":160,"mainLang":161,"languages":606},[160],{"n":78,"url":608,"height":166,"width":167,"desc":168,"surfaceType":83},"ISic004418_tiled.tif",[],[88,89,388],[94,95,391],[613,572,614,119,536,182,100,101,102,103,101,574,185,161],"isic004418",{"_":117},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":399,"ptr":617,"ref":618,"title":2,"citation":5},{"target":110},{"_":112,"target":112},{"file":620,"uri":620,"title":621,"status":622,"editionAuthor":12,"type":623,"objectType":624,"material":625,"condition":3,"layoutDesc":626,"handNote":630,"date":636,"places":638,"geo":641,"provenance":53,"provenanceGeo":643,"country":68,"region":69,"settlement":57,"repository":644,"idno":645,"textLang":647,"tmNumber":3,"facsimile":649,"letterHeights":651,"publications":652,"zotero":653,"keywords":654,"html":658,"bibl":659},"ISic004422","Epitaph for Artemidoros (?)",{"_":117},{"_":119,"ana":120,"ref":121},{"_":536,"ana":537,"ref":538},{"_":182,"ana":128,"ref":129},{"layout":627},{"p":628,"rs":629,"damage":3},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":32,"ana":33,"ref":34},{"lettering":631,"dimensions":632},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[633,635],{"type":39,"l":314,"from":41,"to":41,"h":634,"unit":43},"29",{"type":45,"l":46,"from":41,"to":42,"h":317,"unit":43},{"_":637,"notBefore":419,"notAfter":463,"evidence":369,"precision":17},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[639,640],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[642],[63,64],[220,221],{"_":377,"role":154,"ref":378},{"_":646,"type":158},"ME23440",{"_":160,"mainLang":161,"languages":648},[160],{"n":78,"url":650,"height":166,"width":167,"desc":168,"surfaceType":83},"ISic004422_tiled.tif",[],[89,388],[95,391],[655,656,657,119,536,182,100,101,102,103,101,396,185,161],"isic004422","epitaph for artemidoros (?)",{"_":117},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0--