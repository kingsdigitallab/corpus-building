rg/epig10001575",{"file":128,"uri":128,"title":129,"status":130,"editionAuthor":13,"type":131,"objectType":132,"material":133,"condition":26,"layoutDesc":134,"handNote":138,"date":146,"places":147,"geo":150,"provenance":56,"provenanceGeo":152,"country":71,"region":72,"settlement":73,"repository":153,"idno":154,"textLang":156,"tmNumber":158,"facsimile":159,"letterHeights":163,"publications":166,"zotero":167,"keywords":168,"html":172,"bibl":173,"citedRangeSort":174,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001208","Epitaph for Oltiskos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":135},{"p":136,"rs":137,"damage":26},"Two lines of Greek letters, centred on the front face of the stone.",{"_":31,"ana":32,"ref":33},{"lettering":139,"dimensions":140},"Neat, but irregularly sized letters. Omicron is smaller than the rest and mid-line; sigma is regular with horizontal top and bottom bars; kappa is tall with short arms, slightly curving out form the middle of the upright; alpha has straight bar (and in the second case is larger; epsilon has shorter middle bar.",[141,145],{"type":38,"l":142,"from":40,"to":48,"h":143,"unit":42,"atLeast":43,"atMost":144},"Line 1-2","30-50","50",{"type":46,"l":47,"from":40,"to":48,"unit":42},{"_":51,"notBefore":52,"notAfter":53},[148,149],{"_":56,"type":57,"ref":58},{"_":60,"type":61,"ref":62,"offset":63},[151],[66,67],[69,70],{"_":75,"role":76,"ref":77},{"_":155,"type":80},"8702",{"_":82,"mainLang":83,"languages":157},[82],"492812",{"n":87,"url":160,"height":161,"width":162,"desc":91,"surfaceType":92},"ISic001208_tiled.tif","2021px","1540px",[164],{"atLeast":95,"atMost":165},50,[98,99,100,101,102],[104,105,106,107,108],[169,170,171,15,19,23,113,114,115,116,117,118,119,83],"isic001208","epitaph for oltiskos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ὀλτίσκος \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Ἀριστέα \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":174,"ptr":175,"ref":176,"title":2,"citation":5,"uri":6},"107 and fig.111",{"target":124},{"_":126,"target":126},{"file":178,"uri":178,"title":179,"status":180,"editionAuthor":13,"type":182,"objectType":183,"material":184,"condition":26,"layoutDesc":186,"handNote":190,"date":197,"places":202,"geo":205,"provenance":56,"provenanceGeo":207,"country":71,"region":72,"settlement":73,"repository":208,"idno":209,"textLang":211,"tmNumber":213,"facsimile":214,"letterHeights":219,"publications":222,"zotero":223,"keywords":224,"html":228,"bibl":229,"citedRangeSort":230,"languageSort":82,"materialSort":185,"typeSort":15},"ISic001206","Epitaph for Diokles",{"_":181},"edited",{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":185,"ana":24,"ref":25},"sandstone\n                                    ",{"layout":187},{"_":188,"rs":189,"damage":26},"Two lines of Greek letters filling the width of the surviving stone\n                                    \n                                \t\n\t\t\t",{"_":31,"ana":32,"ref":33},{"lettering":191,"dimensions":192},"Crude and irregular letters of unequal size, deeply incised. Omicron is small and mid-line; kappa has short equal length arms attached to the vertical; epsilon has shorter middle bar (i the first instance detached from the vertical); alpha has straight bar; rho has rounded closed eye.",[193,196],{"type":38,"l":142,"from":40,"to":48,"h":194,"unit":42,"atLeast":43,"atMost":195},"30-75","75",{"type":46,"l":47,"from":40,"to":48,"unit":42},{"_":198,"notBefore":199,"notAfter":200,"evidence":201},"3rd century BCE?",301,200,"lettering",[203,204],{"_":56,"type":57,"ref":58},{"_":60,"type":61,"ref":62,"offset":63},[206],[66,67],[],{"_":75,"role":76,"ref":77},{"_":210,"type":80},"8703",{"_":82,"mainLang":83,"languages":212},[82],"492810",{"n":87,"url":215,"height":216,"width":217,"desc":218,"surfaceType":92},"ISic001206_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[220],{"atLeast":95,"atMost":221},75,[98,99,100,101,102],[104,105,106,107,108],[225,226,227,15,19,23,113,114,115,116,117,118,119,83],"isic001206","epitaph for diokles",{"_":181},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Δίοκλε \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>χαῖρε \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":230,"ptr":231,"ref":232,"title":2,"citation":5,"uri":6},"108 and fig.112",{"target":124},{"_":126,"target":126},{"file":234,"uri":234,"title":235,"status":236,"editionAuthor":13,"type":237,"objectType":238,"material":239,"condition":26,"layoutDesc":240,"handNote":244,"date":253,"places":256,"geo":259,"provenance":56,"provenanceGeo":261,"country":71,"region":72,"settlement":73,"repository":262,"idno":263,"textLang":265,"tmNumber":267,"facsimile":268,"letterHeights":273,"publications":276,"zotero":279,"keywords":282,"html":286,"bibl":287,"citedRangeSort":288,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001207","Epitaph for Nemeris, a goldsmith",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":241},{"p":242,"rs":243,"damage":26},"Five lines of Greek letters, centred on the stone",{"_":31,"ana":32,"ref":33},{"lettering":245,"dimensions":246},"Slightly crudely incised simple broad letters without serifs. Nu i sregular; epsilon has slightly shorter middle bar; mu has slightly inward leaning first and last strokes, the mid-strokes reach down to the base-line; rho has a small 