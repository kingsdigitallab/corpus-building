3C/p>",{"author":3,"date":4,"citedRange":599,"ptr":600,"ref":601,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"115 fig.119",{"target":126},{"_":128,"target":128},{"file":603,"uri":603,"title":604,"status":605,"editionAuthor":13,"type":606,"objectType":607,"material":608,"condition":28,"layoutDesc":609,"handNote":613,"date":619,"places":621,"geo":624,"country":61,"provenance":58,"provenanceGeo":626,"region":74,"settlement":63,"repository":627,"idno":628,"textLang":630,"tmNumber":28,"facsimile":632,"letterHeights":634,"publications":637,"zotero":638,"keywords":639,"html":643,"bibl":644,"bulletinDateSort":129,"citedRangeSort":645,"languageSort":84,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":184},{"_":15,"ana":16,"ref":17},{"_":429,"ana":430,"ref":431},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":610},{"p":611,"rs":612,"damage":28},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":33,"ana":34,"ref":35},{"lettering":614,"dimensions":615},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[616,618],{"type":40,"l":41,"from":42,"to":42,"h":617,"unit":44,"atLeast":617,"atMost":617},"29",{"type":48,"l":49,"from":42,"to":50,"h":51,"unit":44},{"_":620,"notBefore":444,"notAfter":445,"evidence":389},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[622,623],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[625],[69,70],[72,73],{"_":397,"role":78,"ref":398},{"_":629,"type":82},"ME23440",{"_":84,"mainLang":85,"languages":631},[84],{"n":89,"url":633,"height":219,"width":220,"desc":221,"surfaceType":94},"ISic004422_tiled.tif",[635],{"atLeast":636,"atMost":636},29,[104,409],[110,412],[640,641,642,15,429,23,115,116,117,118,116,417,121,85],"isic004422","epitaph for artemidoros (?)",{"_":184},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":645,"ptr":646,"ref":647,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"116 fig.120",{"target":126},{"_":128,"target":128},{"file":649,"uri":649,"title":650,"status":651,"editionAuthor":13,"type":652,"objectType":653,"material":654,"condition":28,"layoutDesc":655,"handNote":658,"date":663,"places":666,"geo":669,"country":61,"provenance":58,"provenanceGeo":671,"region":74,"settlement":63,"repository":672,"idno":673,"textLang":675,"tmNumber":28,"facsimile":677,"letterHeights":679,"publications":681,"zotero":682,"keywords":683,"html":687,"bibl":688,"bulletinDateSort":129,"citedRangeSort":689,"languageSort":84,"materialSort":23,"typeSort":15},"ISic004412","Epitaph for Aristoboula",{"_":184},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":374},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":656},{"p":378,"rs":657,"damage":28},{"_":33,"ana":34,"ref":35},{"lettering":659,"dimensions":660},"Slightly irregular letters, becoming slightly more compressed to the right hand end: Alpha broad with broken bar; rho has small closed eye; sigma is four equal bars, angled apart; omicron is small and mid-line; beta has equal closed eyes, with slight gap between them; upsilon asymmetrical.",[661,662],{"type":40,"l":41,"from":42,"to":42,"h":45,"unit":44,"atLeast":45,"atMost":45},{"type":48,"l":49,"from":42,"to":50,"h":51,"unit":44},{"_":664,"notBefore":444,"notAfter":665,"evidence":204},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-251,[667,668],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[670],[69,70],[72,73],{"_":397,"role":78,"ref":398},{"_":674,"type":82},"ME23439",{"_":84,"mainLang":85,"languages":676},[84],{"n":89,"url":678,"height":219,"width":220,"desc":221,"surfaceType":94},"ISic004412_tiled.tif",[680],{"atLeast":97,"atMost":97},[408,104,409],[411,110,412],[684,685,686,15,19,23,115,116,117,118,116,417,121,85],"isic004412","epitaph for aristoboula",{"_":184},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοβούλας \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":689,"ptr":690,"ref":691,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"116 fig.121",{"target":126},{"_":128,"target":128},false],"uses":{"params":["slug"]}}]}
