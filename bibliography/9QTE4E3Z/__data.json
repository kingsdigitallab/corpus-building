for Eupolemos",{"_":120},{"_":122,"ana":123,"ref":124},{"_":126,"ana":127,"ref":370},{"_":190,"ana":131,"ref":132},{"layout":516},{"p":374,"rs":517,"damage":36},{"_":33,"ana":34,"ref":35},{"lettering":519,"dimensions":520},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[521,522],{"type":41,"l":328,"from":43,"to":43,"h":143,"unit":45,"atLeast":143,"atMost":143},{"type":47,"l":48,"from":43,"to":44,"h":332,"unit":45},{"_":480,"notBefore":281,"notAfter":481,"evidence":385},[525,526],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[528],[65,66],[229,230],{"_":393,"role":159,"ref":394},{"_":532,"type":163},"ME23438",{"_":165,"mainLang":166,"languages":534},[165],{"n":80,"url":536,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004414_tiled.tif",[538],{"atLeast":176,"atMost":176},[91,404,92,405],[97,407,98,408],[542,543,544,122,126,190,103,104,105,106,104,413,193,166],"isic004414","epitaph for eupolemos",{"_":120},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":547,"ptr":548,"ref":549,"title":2,"citation":5,"uri":6},"115 fig.119",{"target":113},{"_":115,"target":115},{"file":551,"uri":551,"title":552,"status":553,"editionAuthor":13,"type":554,"objectType":555,"material":559,"condition":36,"layoutDesc":560,"handNote":564,"date":569,"places":571,"geo":575,"provenance":55,"provenanceGeo":577,"country":70,"region":71,"settlement":59,"repository":578,"idno":582,"textLang":583,"tmNumber":36,"facsimile":585,"letterHeights":587,"publications":589,"zotero":590,"keywords":591,"html":596,"bibl":597},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":120},{"_":122,"ana":123,"ref":124},{"_":556,"ana":557,"ref":558},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":190,"ana":131,"ref":132},{"layout":561},{"p":562,"rs":563,"damage":36},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":33,"ana":34,"ref":35},{"lettering":565,"dimensions":566},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[567,568],{"type":41,"l":141,"from":43,"to":44,"h":143,"unit":45,"atLeast":143,"atMost":143},{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":570,"notBefore":436,"notAfter":481,"evidence":385},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[572,574],{"_":55,"type":56,"ref":57,"corresp":573},"#findspot",{"_":59,"type":60,"ref":61,"offset":62},[576],[65,66],[229,230],{"_":579,"role":580,"ref":581},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":163},{"_":165,"mainLang":166,"languages":584},[165],{"n":80,"url":586,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004417_tiled.tif",[588],{"atLeast":176,"atMost":176},[91,92,405],[97,98,408],[592,593,594,122,556,190,103,104,105,106,104,595,193,166],"isic004417","epitaph for [-?-], child of gerontios",{"_":120},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":416,"ptr":598,"ref":599,"title":2,"citation":5,"uri":6},{"target":113},{"_":115,"target":115},{"file":601,"uri":601,"title":552,"status":602,"editionAuthor":13,"type":603,"objectType":604,"material":605,"condition":36,"layoutDesc":606,"handNote":610,"date":616,"places":618,"geo":621,"provenance":55,"provenanceGeo":623,"country":70,"region":71,"settlement":59,"repository":624,"idno":625,"textLang":626,"tmNumber":36,"facsimile":628,"letterHeights":630,"publications":633,"zotero":634,"keywords":635,"html":638,"bibl":639},"ISic004418",{"_":120},{"_":122,"ana":123,"ref":124},{"_":556,"ana":557,"ref":558},{"_":190,"ana":131,"ref":132},{"layout":607},{"p":608,"rs":609,"damage":36},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":33,"ana":34,"ref":35},{"lettering":611,"dimensions":612},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[613,615],{"type":41,"l":141,"from":43,"to":44,"h":614,"unit":45,"atLeast":614,"atMost":614},"59",{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":617,"notBefore":436,"notAfter":481,"evidence":385},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[619,620],{"_":55,"type":56,"ref":57,"corresp":573},{"_":59,"type":60,"ref":61,"offset":62},[622],[65,66],[229,230],{"_":579,"role":580,"ref":581},{"type":163},{"_":165,"mainLang":166,"languages":627},[165],{"n":80,"url":629,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004418_tiled.tif",[631],{"atLeast":632,"atMost":632},59,[91,92,405],[97,98,408],[636,593,637,122,556,190,103,104,105,106,104,595,193,166],"isic004418",{"_":120},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":416,"ptr":640,"ref":641,"title":2,"citation":5,"uri":6},{"target":113},{"_":115,"target":115},{"file":643,"uri":643,"title":644,"status":645,"editionAuthor":13,"type":646,"objectType":647,"material":648,"condition":36,"layoutDesc":649,"handNote":653,"date":659,"places":661,"geo":664,"provenance":55,"provenanceGeo":666,"country":70,"region":71,"settlement":59,"repository":667,"idno":668,"textLang":670,"tmNumber":36,"facsimile":672,"letterHeights":674,"publications":677,"zotero":678,"keywords":679,"html":683,"bibl":684},"ISic004422","Epitaph for Artemidoros (?)",{"_":120},{"_":122,"ana":123,"ref":124},{"_":556,"ana":557,"ref":558},{"_":190,"ana":131,"ref":132},{"layout":650},{"p":651,"rs":652,"damage":36},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":33,"ana":34,"ref":35},{"lettering":654,"dimensions":655},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[656,658],{"type":41,"l":328,"from":43,"to":43,"h":657,"unit":45,"atLeast":657,"atMost":657},"29",{"type":47,"l":48,"from":43,"to":44,"h":332,"unit":45},{"_":660,"notBefore":436,"notAfter":481,"evidence":385},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[662,663],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[665],[65,66],[229,230],{"_":393,"role":159,"ref":394},{"_":669,"type":163},"ME23440",{"_":165,"mainLang":166,"languages":671},[165],{"n":80,"url":673,"height":171,"width":172,"desc":173,"surfaceType":85},"ISic004422_tiled.tif",[675],{"atLeast":676,"atMost":676},29,[92,405],[98,408],[680,681,682,122,556,190,103,104,105,106,104,413,193,166],"isic004422","epitaph for artemidoros (?)",{"_":120},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":685,"ptr":686,"ref":687,"title":2,"citation":5,"uri":6},"116 fig.120",{"target":113},{"_":115,"target":115}],"uses":{"params":["slug"]}}]}
