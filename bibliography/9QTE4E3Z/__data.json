                               \n                                \t\n\t\t\t",{"_":31,"ana":32,"ref":33},{"lettering":126,"dimensions":127},"Crude and irregular letters of unequal size, deeply incised. Omicron is small and mid-line; kappa has short equal length arms attached to the vertical; epsilon has shorter middle bar (i the first instance detached from the vertical); alpha has straight bar; rho has rounded closed eye.",[128,131],{"type":39,"l":129,"from":41,"to":42,"h":130,"unit":43},"Line 1-2","30-75",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":133,"notBefore":134,"notAfter":50,"evidence":135,"precision":16},"3rd century BCE?",301,"lettering",[137,138],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[140],[63,64],"Palermo",{"_":143,"role":144,"ref":145},"Museo Archeologico Regionale Antonino Salinas","museum","http://sicily.classics.ox.ac.uk/museum/064",{"_":147,"type":148},"8703","inventory",{"_":150,"mainLang":151,"languages":152},"Ancient Greek","grc",[150],{"n":74,"url":154,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic001206_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana",[],[160,161,162,163,86],"IG, 1890","Manni Piraino, 1973, IGMusPalermo","Salinas, 1876-, Notizie degli scavi di antichità","Hoffmann, 1904, SGDI",[165,166,90,167,92],"Q2SBPG9F","F66S4X3M","DQDPC573",[169,170,171,110,114,172,97,98,99,100,173,174,175,151],"isic001206","epitaph for diokles",{"_":108},"sandstone","palermo","museo archeologico regionale antonino salinas","ancient greek",{"file":177,"uri":177,"title":178,"status":179,"editionAuthor":11,"type":180,"objectType":181,"material":182,"condition":34,"layoutDesc":183,"handNote":187,"date":195,"places":199,"geo":202,"country":65,"region":66,"settlement":141,"repository":204,"idno":205,"textLang":207,"facsimile":209,"provenance":53,"letterHeights":214,"publications":215,"zotero":219,"keywords":222,"html":103},"ISic001207","Epitaph for Nemeris, a goldsmith",{"_":10},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":116},{"_":172,"ana":119,"ref":120},{"layout":184},{"p":185,"rs":186,"damage":34},"Five lines of Greek letters, centred on the stone",{"_":31,"ana":32,"ref":33},{"lettering":188,"dimensions":189},"Slightly crudely incised simple broad letters without serifs. Nu i sregular; epsilon has slightly shorter middle bar; mu has slightly inward leaning first and last strokes, the mid-strokes reach down to the base-line; rho has a small eye, not always fully closed; alpha has broken bar; omega varies between open circle closed by horizontal bar and closed ovoid form with horizontal bar; phi has a small circular eye; sigma has standard form with horizontal top and bottom storkes; omicron is approximately the same size as other letters.",[190,194],{"type":39,"l":191,"from":41,"to":192,"h":193,"unit":43},"Lines 1-5","line5","30-45",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":196,"notBefore":197,"notAfter":198,"precision":16},"2nd century BCE(?)",-200,-101,[200,201],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[203],[63,64],{"_":143,"role":144,"ref":145},{"_":206,"type":148},"8706",{"_":150,"mainLang":151,"languages":208},[150],{"n":74,"url":210,"height":211,"width":212,"desc":213,"surfaceType":79},"ISic001207_tiled.tif","3212px","2498px","Photo J. Prag, courtesy Museo Archeologico Regionale Antonino Salinas",[],[216,161,162,163,217,218,86],"Kaibel, 1890, IG","Manni Piraino, 1976, Contribution Épigraphique à l'Étude de l'esclavage en Sicile","Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano",[165,166,90,167,220,221,92],"R9M263EA","RZSFKACR",[223,224,225,110,114,172,97,98,99,100,173,174,175,151],"isic001207","epitaph for nemeris, a goldsmith",{"_":10},{"file":227,"uri":227,"title":228,"status":229,"editionAuthor":11,"type":230,"objectType":231,"material":232,"condition":34,"layoutDesc":233,"handNote":237,"date":243,"places":246,"geo":249,"country":65,"region":66,"settlement":141,"repository":251,"idno":252,"textLang":254,"facsimile":256,"provenance":53,"letterHeights":261,"publications":262,"zotero":263,"keywords":264,"html":268},"ISic001208","Epitaph for Oltiskos",{"_":10},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":116},{"_":172,"ana":119,"ref":120},{"layout":234},{"p":235,"rs":236,"damage":34},"Two lines of Greek letters, centred on the front face of the stone.",{"_":31,"ana":32,"ref":33},{"lettering":238,"dimensions":239},"Neat, but irregularly sized letters. Omicron is smaller than the rest and mid-line; sigma is regular with horizontal top and bottom bars; kappa is tall with short arms, slightly curving out form the middle of the upright; alpha has straight bar (and in the second case is larger; epsilon has shorter middle bar.",[240,242],{"type":39,"l":129,"from":41,"to":42,"h":241,"unit":43},"30-50",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":244,"notBefore":245,"notAfter":198,"precision":16},"3rd — 2nd century BCE",-300,[247,248],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[250],[63,64],{"_":143,"role":144,"ref":145},{"_":253,"type":148},"8702",{"_":150,"mainLang":151,"languages":255},[150],{"n":74,"url":257,"height":258,"width":259,"desc":260,"surfaceType":79},"ISic001208_tiled.tif","2021px","1540px","Scan from IGMusPal, courtesy Museo Archeologico Regionale Antonino Salinas",[],[160,161,162,163,86],[165,166,90,167,92],[265,266,267,110,114,172,97,98,99,100,173,174,175,151],"isic001208","epitaph for oltiskos",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ὀλτίσκος \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Ἀριστέα \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":270,"uri":270,"title":271,"status":272,"editionAuthor":11,"type":273,"objectType":274,"material":275,"condition":34,"layoutDesc":276,"handNote":280,"date":288,"places":289,"geo":292,"country":65,"region":66,"settlement":141,"repository":294,"idno":295,"textLang":297,"facsimile":299,"provenance":53,"letterHeights":303,"publications":304,"zotero":305,"keywords":306,"html":310},"ISic001209","Epitaph of Philisto",{"_":10},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":116},{"_":172,"ana":119,"ref":120},{"layout":277},{"p":278,"rs":279,"damage":34},"Single line of Greek letters across the middle of the stone",{"_":31,"ana":32,"ref":33},{"lettering":281,"dimensions":282},"Regular plain letters. Phi is slightly taller than the rest, but with a small circular eye; sigma has horizontal top and bottom bars, with the diagonals joined by a curve; omicron is smaller than the other letters and mid-line.",[283,286],{"type":39,"l":284,"from":41,"to":41,"h":285,"unit":43},"Line 1","30-35",{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},"NA",{"_":244,"notBefore":245,"notAfter":198,"precision":16},[290,291],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[293],[63,64],{"_":143,"role":144,"ref":145},{"_":296,"type":148},"8790",{"_":150,"mainLang":151,"languages":298},[150],{"n":74,"url":300,"height":301,"width":302,"desc":260,"surfaceType":79},"ISic120_tiled.tif","2034px","1459px",[],[216,161,162,163,86],[165,166,90,167,92],[307,308,309,110,114,172,97,98,99,100,173,174,175,151],"isic001209","epitaph of philisto",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φιλιστοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":312,"uri":312,"title":313,"status":314,"editionAuthor":11,"type":315,"objectType":316,"material":318,"condition":34,"layoutDesc":319,"handNote":323,"date":329,"places":334,"geo":337,"country":65,"region":66,"settlement":57,"repository":339,"idno":342,"textLang":344,"facsimile":346,"provenance":53,"letterHeights":348,"publications":349,"zotero":352,"keywords":355,"html":360},"ISic004411","Epitaph for Kratisstos",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":317},"http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":172,"ana":119,"ref":120},{"layout":320},{"p":321,"rs":322,"damage":34},"Single line of Greek letters filling the width of the stone",{"_":31,"ana":32,"ref":33},{"lettering":324,"dimensions":325},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[326,328],{"type":39,"l":284,"from":41,"to":41,"h":327,"unit":43},"30",{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":330,"notBefore":331,"notAfter":332,"evidence":333,"precision":16},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[335,336],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[338],[63,64],{"_":340,"role":144,"ref":341},"Museo Archeologico Santi Furnari di Tripi","http://sicily.classics.ox.ac.uk/museum/177",{"_":343,"type":148},"ME23435",{"_":150,"mainLang":151,"languages":345},[150],{"n":74,"url":347,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004411_tiled.tif",[],[85,350,86,351],"Bacci et al., 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[91,353,92,354],"ILQ4RQGU","JQQKI6JP",[356,357,358,110,114,172,97,98,99,100,98,359,175,151],"isic004411","epitaph for kratisstos",{"_":108},"museo archeologico santi furnari di tripi","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":362,"uri":362,"title":363,"status":364,"editionAuthor":11,"type":365,"objectType":366,"material":367,"condition":34,"layoutDesc":368,"handNote":371,"date":376,"places":380,"geo":383,"country":65,"region":66,"settlement":57,"repository":385,"idno":386,"textLang":388,"facsimile":390,"provenance":53,"letterHeights":392,"publications":393,"zotero":394,"keywords":395,"html":103},"ISic004412","Epitaph for Aristoboula",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":317},{"_":172,"ana":119,"ref":120},{"layout":369},{"p":321,"rs":370,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":372,"dimensions":373},"Slightly irregular letters, becoming slightly more compressed to the right hand end: Alpha broad with broken bar; rho has small closed eye; sigma is four equal bars, angled apart; omicron is small and mid-line; beta has equal closed eyes, with slight gap between them; upsilon asymmetrical.",[374,375],{"type":39,"l":284,"from":41,"to":41,"h":327,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":377,"notBefore":378,"notAfter":379,"evidence":135,"precision":16},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-350,-251,[381,382],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[384],[63,64],{"_":340,"role":144,"ref":341},{"_":387,"type":148},"ME23439",{"_":150,"mainLang":151,"languages":389},[150],{"n":74,"url":391,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004412_tiled.tif",[],[350,86,351],[353,92,354],[396,397,398,110,114,172,97,98,99,100,98,359,175,151],"isic004412","epitaph for aristoboula",{"_":108},{"file":400,"uri":400,"title":401,"status":402,"editionAuthor":11,"type":403,"objectType":404,"material":405,"condition":34,"layoutDesc":406,"handNote":409,"date":414,"places":417,"geo":420,"country":65,"region":66,"settlement":57,"repository":422,"idno":423,"textLang":425,"facsimile":427,"provenance":53,"letterHeights":429,"publications":430,"zotero":431,"keywords":432,"html":103},"ISic004413","Epitaph for Kallo",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":317},{"_":172,"ana":119,"ref":120},{"layout":407},{"p":321,"rs":408,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":410,"dimensions":411},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[412,413],{"type":39,"l":284,"from":41,"to":41,"h":327,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":415,"notBefore":245,"notAfter":416,"evidence":333,"precision":16},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-201,[418,419],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[421],[63,64],{"_":340,"role":144,"ref":341},{"_":424,"type":148},"ME23436",{"_":150,"mainLang":151,"languages":426},[150],{"n":74,"url":428,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004413_tiled.tif",[],[350,86,351],[353,92,354],[433,434,435,110,114,172,97,98,99,100,98,359,175,151],"isic004413","epitaph for kallo",{"_":108},{"file":437,"uri":437,"title":438,"status":439,"editionAuthor":11,"type":440,"objectType":441,"material":442,"condition":34,"layoutDesc":443,"handNote":446,"date":451,"places":452,"geo":455,"country":65,"region":66,"settlement":57,"repository":457,"idno":458,"textLang":460,"facsimile":462,"provenance":53,"letterHeights":464,"publications":465,"zotero":466,"keywords":467,"html":103},"ISic004414","Epitaph for Eupolemos",{"_":108},{"_":110,"ana":111,"ref":112},{"_":114,"ana":115,"ref":317},{"_":172,"ana":119,"ref":120},{"layout":444},{"p":321,"rs":445,"damage":34},{"_":31,"ana":32,"ref":33},{"lettering":447,"dimensions":448},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[449,450],{"type":39,"l":284,"from":41,"to":41,"h":327,"unit":43},{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":415,"notBefore":245,"notAfter":416,"evidence":333,"precision":16},[453,454],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[456],[63,64],{"_":340,"role":144,"ref":341},{"_":459,"type":148},"ME23438",{"_":150,"mainLang":151,"languages":461},[150],{"n":74,"url":463,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004414_tiled.tif",[],[85,350,86,351],[91,353,92,354],[468,469,470,110,114,172,97,98,99,100,98,359,175,151],"isic004414","epitaph for eupolemos",{"_":108},{"file":472,"uri":472,"title":473,"status":474,"editionAuthor":11,"type":475,"objectType":476,"material":480,"condition":34,"layoutDesc":481,"handNote":485,"date":490,"places":492,"geo":496,"country":65,"region":66,"settlement":57,"repository":498,"idno":502,"textLang":503,"facsimile":505,"provenance":53,"letterHeights":507,"publications":508,"zotero":509,"keywords":510,"html":103},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":108},{"_":110,"ana":111,"ref":112},{"_":477,"ana":478,"ref":479},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":172,"ana":119,"ref":120},{"layout":482},{"p":483,"rs":484,"damage":34},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":31,"ana":32,"ref":33},{"lettering":486,"dimensions":487},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[488,489],{"type":39,"l":129,"from":41,"to":42,"h":327,"unit":43},{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":491,"notBefore":378,"notAfter":416,"evidence":333,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[493,495],{"_":53,"type":54,"ref":55,"corresp":494},"#findspot",{"_":57,"type":58,"ref":59,"offset":60},[497],[63,64],{"_":499,"role":500,"ref":501},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":148},{"_":150,"mainLang":151,"languages":504},[150],{"n":74,"url":506,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004417_tiled.tif",[],[85,86,351],[91,92,354],[511,512,513,110,477,172,97,98,99,100,98,514,175,151],"isic004417","epitaph for [-?-], child of gerontios",{"_":108},"necropoli di abakainon",{"file":516,"uri":516,"title":473,"status":517,"editionAuthor":11,"type":518,"objectType":519,"material":520,"condition":34,"layoutDesc":521,"handNote":525,"date":531,"places":533,"geo":536,"country":65,"region":66,"settlement":57,"repository":538,"idno":539,"textLang":540,"facsimile":542,"provenance":53,"letterHeights":544,"publications":545,"zotero":546,"keywords":547,"html":103},"ISic004418",{"_":108},{"_":110,"ana":111,"ref":112},{"_":477,"ana":478,"ref":479},{"_":172,"ana":119,"ref":120},{"layout":522},{"p":523,"rs":524,"damage":34},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":526,"dimensions":527},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[528,530],{"type":39,"l":129,"from":41,"to":42,"h":529,"unit":43},"59",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":532,"notBefore":378,"notAfter":416,"evidence":333,"precision":16},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[534,535],{"_":53,"type":54,"ref":55,"corresp":494},{"_":57,"type":58,"ref":59,"offset":60},[537],[63,64],{"_":499,"role":500,"ref":501},{"type":148},{"_":150,"mainLang":151,"languages":541},[150],{"n":74,"url":543,"height":155,"width":156,"desc":157,"surfaceType":79},"ISic004418_tiled.tif",[],[85,86,351],[91,92,354],[548,512,549,110,477,172,97,98,99,100,98,514,175,151],"isic004418",{"_":108},{"file":551,"uri":551,"title":552,"status":553,"editionAuthor":11,"type":554,"objectType":555,"material":556,"condition":34,"layoutDesc":557,"handNote":561,"date":567,"places":569,"geo":572,"country":65,"region":66,"settlement":57,"repository":574,"idno":575,"textLang":577,"facsimile":579,"provenance":53,"letterHeights":581,"publications":582,"zotero":583,"keywords":584,"html":103},"ISic004422","Epitaph for Artemidoros (?)",{"_":108},{"_":110,"ana":111,"ref":112},{"_":477,"ana":478,"ref":479},{"_":172,"ana":119,"ref":120},{"layout":558},{"p":559,"rs":560,"damage":34},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":562,"dimensions":563},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[564,566],{"type":39,"l":284,"from":41,"to":41,"h":565,"unit":43},"29",{"type":45,"l":46,"from":41,"to":42,"h":287,"unit":43},{"_":568,"notBefore":378,"notAfter":416,"evidence":333,"precision":16},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante q