,{"type":49,"l":50,"from":43,"to":51,"h":52,"unit":45},{"_":676,"notBefore":451,"notAfter":677,"evidence":207},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-251,[679,680],{"_":59,"type":60,"ref":61,"region":62},{"_":64,"type":65,"ref":66,"offset":67,"region":62},[682],[70,71],[73,74],{"_":403,"role":79,"ref":404},{"_":686,"type":83},"ME23439",{"_":85,"mainLang":86,"languages":688},[85],{"n":90,"url":690,"height":222,"width":223,"desc":224,"surfaceType":95},"ISic004412_tiled.tif",[692],{"atLeast":98,"atMost":98},[414,105,415],[417,111,418],[696,697,698,15,19,23,116,117,118,119,117,423,122,86],"isic004412","epitaph for aristoboula",{"_":186},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοβούλας \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":701,"ptr":702,"ref":703,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"116 fig.121",{"target":127},{"_":129,"target":129},false],"uses":{"params":["slug"]}}]}
