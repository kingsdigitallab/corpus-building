ully closed; alpha has broken bar; omega varies between open circle closed by horizontal bar and closed ovoid form with horizontal bar; phi has a small circular eye; sigma has standard form with horizontal top and bottom storkes; omicron is approximately the same size as other letters.",[205,209],{"type":39,"l":206,"from":41,"to":207,"h":208,"unit":43},"Lines 1-5","line5","30-45",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":211,"notBefore":212,"notAfter":213,"precision":17},"2nd century BCE(?)",-200,-101,[215,216],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[218],[63,64],[220,221],38.06519,15.11438,{"_":153,"role":154,"ref":155},{"_":224,"type":158},"8706",{"_":160,"mainLang":161,"languages":226},[160],"492811",{"n":78,"url":229,"height":230,"width":231,"desc":232,"surfaceType":83},"ISic001207_tiled.tif","3212px","2498px","Photo J. Prag, courtesy Museo Archeologico Regionale Antonino Salinas",[],[171,172,87,173,235,236,89],"Contribution Épigraphique à l'Étude de l'esclavage en Sicile, 1976","La Sicilia da Sesto Pompeo a Diocleziano, 1988",[175,176,93,177,238,239,95],"R9M263EA","RZSFKACR",[241,242,243,119,123,182,100,101,102,103,183,184,185,161],"isic001207","epitaph for nemeris, a goldsmith",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Νεμέριε̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γρανῶνι \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>Νυμφόδωρε \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>χρυσοχόε \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>χαῖρε \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":246,"ptr":247,"ref":249,"title":2,"citation":5},"108 fig.113",{"target":248},"https://www.zotero.org/groups/382445/items/9QTE4E3Z",{"_":112,"target":112},{"file":251,"uri":251,"title":252,"status":253,"editionAuthor":12,"type":254,"objectType":255,"material":256,"condition":3,"layoutDesc":257,"handNote":261,"date":267,"places":270,"geo":273,"provenance":53,"provenanceGeo":275,"country":68,"region":69,"settlement":151,"repository":276,"idno":277,"textLang":279,"tmNumber":281,"facsimile":282,"letterHeights":287,"publications":288,"zotero":289,"keywords":290,"html":294,"bibl":295},"ISic001208","Epitaph for Oltiskos",{"_":11},{"_":119,"ana":120,"ref":121},{"_":123,"ana":124,"ref":125},{"_":182,"ana":128,"ref":129},{"layout":258},{"p":259,"rs":260,"damage":3},"Two lines of Greek letters, centred on the front face of the stone.",{"_":32,"ana":33,"ref":34},{"lettering":262,"dimensions":263},"Neat, but irregularly sized letters. Omicron is smaller than the rest and mid-line; sigma is regular with horizontal top and bottom bars; kappa is tall with short arms, slightly curving out form the middle of the upright; alpha has straight bar (and in the second case is larger; epsilon has shorter middle bar.",[264,266],{"type":39,"l":138,"from":41,"to":42,"h":265,"unit":43},"30-50",{"type":45,"l":46,"from":41,"to":42,"unit":43},{"_":268,"notBefore":269,"notAfter":213,"precision":17},"3rd — 2nd century BCE",-300,[271,272],{"_":53,"type":54,"ref":55},{"_":57,"type":58,"ref":59,"offset":60},[274],[63,64],[220,221],{"_":153,"role":154,"ref":155},{"_":278,"type":158},"8702",{"_":160,"mainLang":161,"languages":280},[160],"492812",{"n":78,"url":283,"height":284,"width":285,"desc":286,"surfaceType":83},"ISic001208_tiled.tif","2021px","1540px","Scan from IGMusPal, courtesy Museo Archeologico Regionale Antonino Salinas",[],[171,172,87,173,89],[175,176,93,177,95],[291,292,293,119,123,182,100,101,102,103,183,184,185,161],"isic001208","epitaph for oltiskos",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0--