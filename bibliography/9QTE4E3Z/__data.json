685,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004412","Epitaph for Aristoboula",{"_":181},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":370},{"_":23,"ana":24,"ref":25},{"layout":652},{"p":374,"rs":653,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":655,"dimensions":656},"Slightly irregular letters, becoming slightly more compressed to the right hand end: Alpha broad with broken bar; rho has small closed eye; sigma is four equal bars, angled apart; omicron is small and mid-line; beta has equal closed eyes, with slight gap between them; upsilon asymmetrical.",[657,658],{"type":38,"l":39,"from":40,"to":40,"h":43,"unit":42,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":40,"to":48,"h":49,"unit":42},{"_":660,"notBefore":440,"notAfter":661,"evidence":201},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-251,[663,664],{"_":56,"type":57,"ref":58},{"_":60,"type":61,"ref":62,"offset":63},[666],[66,67],[69,70],{"_":393,"role":76,"ref":394},{"_":670,"type":80},"ME23439",{"_":82,"mainLang":83,"languages":672},[82],{"n":87,"url":674,"height":216,"width":217,"desc":218,"surfaceType":92},"ISic004412_tiled.tif",[676],{"atLeast":95,"atMost":95},[404,102,405],[407,108,408],[680,681,682,15,19,23,113,114,115,116,114,413,119,83],"isic004412","epitaph for aristoboula",{"_":181},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοβούλας \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":685,"ptr":686,"ref":687,"title":2,"citation":5,"uri":6},"116 fig.121",{"target":124},{"_":126,"target":126}],"uses":{"params":["slug"]}}]}
