etive\">\u003Cspan class=\"linenumber\">5\u003C/span>χαῖρε \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":257,"ptr":258,"ref":260,"title":2,"citation":5,"uri":6},"108 fig.113",{"target":259},"https://www.zotero.org/groups/382445/items/9QTE4E3Z",{"_":115,"target":115},{"file":262,"uri":262,"title":263,"status":264,"editionAuthor":13,"type":265,"objectType":266,"material":267,"condition":36,"layoutDesc":268,"handNote":272,"date":279,"places":282,"geo":285,"provenance":55,"provenanceGeo":287,"country":70,"region":71,"settlement":156,"repository":288,"idno":289,"textLang":291,"tmNumber":293,"facsimile":294,"letterHeights":299,"publications":302,"zotero":303,"keywords":304,"html":308,"bibl":309},"ISic001208","Epitaph for Oltiskos",{"_":12},{"_":122,"ana":123,"ref":124},{"_":126,"ana":127,"ref":128},{"_":190,"ana":131,"ref":132},{"layout":269},{"p":270,"rs":271,"damage":36},"Two lines of Greek letters, centred on the front face of the stone.",{"_":33,"ana":34,"ref":35},{"lettering":273,"dimensions":274},"Neat, but irregularly sized letters. Omicron is smaller than the rest and mid-line; sigma is regular with horizontal top and bottom bars; kappa is tall with short arms, slightly curving out form the middle of the upright; alpha has straight bar (and in the second case is larger; epsilon has shorter middle bar.",[275,278],{"type":41,"l":141,"from":43,"to":44,"h":276,"unit":45,"atLeast":143,"atMost":277},"30-50","50",{"type":47,"l":48,"from":43,"to":44,"unit":45},{"_":280,"notBefore":281,"notAfter":222},"3rd — 2nd century BCE",-300,[283,284],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[286],[65,66],[229,230],{"_":158,"role":159,"ref":160},{"_":290,"type":163},"8702",{"_":165,"mainLang":166,"languages":292},[165],"492812",{"n":80,"url":295,"height":296,"width":297,"desc":298,"surfaceType":85},"ISic001208_tiled.tif","2021px","1540px","Scan from IGMusPal, courtesy Museo Archeologico Regionale Antonino Sal