d-hand transcription by Torremuzza, nothing reliable can be said about the letter-forms.",[118,119],{"type":36,"l":37,"from":38,"to":38,"unit":39},{"type":41,"l":42,"from":38,"to":43,"unit":39},{"_":45,"notBefore":46,"notAfter":47,"precision":48},[122,123],{"_":51,"type":52,"ref":53},{"_":55,"type":56,"ref":57},[125],[60,61],{"_":65,"mainLang":66,"languages":127},[65],{"n":69,"url":129,"height":71,"width":72,"desc":73,"surfaceType":74},"ISic001387_tiled.tif",[],[77,79,80,81,82,83],[85,87,88,89,90,91],[134,135,136,13,17,109,96,97,98,99,17,100,66],"isic001387","fragmentary greek inscription (funerary?)",{"_":10},{"file":138,"uri":138,"title":139,"status":140,"editionAuthor":11,"type":141,"objectType":145,"material":154,"condition":24,"layoutDesc":155,"handNote":159,"date":165,"places":166,"geo":172,"country":62,"region":63,"settlement":17,"repository":17,"textLang":176,"facsimile":178,"provenance":168,"letterHeights":183,"publications":184,"zotero":188,"keywords":192,"html":101},"ISic001388","Greek dedication to Herakles",{"_":10},{"_":142,"ana":143,"ref":144},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":146,"ana":147,"ref":148,"certainty":149},"altar\n                                        ","#object.altar","http://www.eagle-network.eu/voc/objtyp/lod/30.html",{"locus":150,"match":151,"assertedValue":152,"desc":153},"value","../@ana","#object.base","base",{"_":21,"ana":22,"ref":23},{"layout":156},{"p":157,"rs":158,"damage":24},"single line of Greek letters, only partly preserved",{"_":29,"ana":30,"ref":31},{"lettering":160,"dimensions":161},"Orsi describes it as 'scritta a buone lettere', and his drawing shows slightly irregular broad square and simple letters: alpha with straight bar; rho with closed eye; kappa with long arms of equal length; epsilon with approximately equal bars.",[162,163],{"type":36,"l":37,"from":38,"to":38,"unit":39},{"type":41,"l":42,"from":38,"to":43,"h":164,"unit":39},"NA",{"_":45,"notBefore":46,"notAfter":47,"precision":48},[167,170],{"_":168,"type":52,"ref":169},"Mendolito","http://pleiades.stoa.org/places/462313",{"_":168,"type":56,"ref":171},"http://sws.geonames.org/11103527",[173],[174,175],37.69904,14.808181,{"_":65,"mainLang":66,"languages":177},[65],{"n":69,"url":179,"height":180,"width":181,"desc":182,"surfaceType":74},"ISic001388_tiled.tif","115px","945px","Drawing of P.Orsi, RSA 1900, p.43 no.2",[],[77,185,186,79,80,81,82,187,83],"Orsi, 1900, Frammenti epigrafici sicelioti","Albanese, 1991, Mendolito","Manganaro, 1961, Iscrizioni di Adrano",[85,189,190,87,88,89,90,191,91],"UE3VRJA7","IVAU3I2N","6V679NMW",[193,194,195,142,196,21,197,197,98,99,17,100,66],"isic001388","greek dedication to herakles",{"_":10},"altar","mendolito",{"file":199,"uri":199,"title":200,"status":201,"editionAuthor":11,"type":202,"objectType":203,"material":204,"condition":24,"layoutDesc":205,"handNote":209,"date":214,"places":215,"geo":218,"country":62,"region":63,"settlement":17,"repository":17,"textLang":220,"facsimile":222,"provenance":51,"letterHeights":224,"publications":225,"zotero":227,"keywords":229,"html":101},"ISic001389","Greek funerary inscription of Kallistratos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":206},{"p":207,"rs":208,"damage":24},"The text is presented as split over three lines",{"_":29,"ana":30,"ref":31},{"lettering":210,"dimensions":211},"Plain transcription in standard capitals makes it impossible to assess the letter-forms.",[212,213],{"type":36,"l":37,"from":38,"to":38,"unit":39},{"type":41,"l":42,"from":38,"to":43,"unit":39},{"_":45,"notBefore":46,"notAfter":47,"precision":48},[216,217],{"_":51,"type":52,"ref":53},{"_":55,"type":56,"ref":57},[219],[60,61],{"_":65,"mainLang":66,"languages":221},[65],{"n":69,"url":223,"height":71,"width":72,"desc":73,"surfaceType":74},"ISic001389_tiled.tif",[],[77,78,79,80,226,81,82,83],"Osann, 1834, Sylloge inscriptionum antiquarum graecarum et latinarum",[85,86,87,88,228,89,90,91],"VATSKP8P",[230,231,232,13,17,21,96,97,98,99,17,100,66],"isic001389","greek funerary inscription of kallistratos",{"_":10},{"file":234,"uri":234,"title":235,"status":236,"editionAuthor":11,"type":237,"objectType":238,"material":239,"condition":24,"layoutDesc":240,"handNote":243,"date":247,"places":248,"geo":251,"country":62,"region":63,"settlement":17,"repository":17,"textLang":253,"facsimile":255,"provenance":51,"letterHeights":257,"publications":258,"zotero":259,"keywords":260,"html":101},"ISic001390","Greek funerary(?) inscription of Nikaios",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":241},{"p":207,"rs":242,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":210,"dimensions":244},[245,246],{"type":36,"l":37,"from":38,"to":38,"unit":39},{"type":41,"l":42,"from":38,"to":43,"h":164,"unit":39},{"_":45,"notBefore":46,"notAfter":47,"precision":48},[249,250],{"_":51,"type":52,"ref":53},{"_":55,"type":56,"ref":57},[252],[60,61],{"_":65,"mainLang":66,"languages":254},[65],{"n":69,"url":256,"height":71,"width":72,"desc":73,"surfaceType":74},"ISic001390_tiled.tif",[],[77,78,81,82,83],[85,86,89,90,91],[261,262,263,13,17,21,96,97,98,99,17,100,66],"isic001390","greek funerary(?) inscription of nikaios",{"_":10},{"file":265,"uri":265,"title":266,"status":267,"editionAuthor":11,"type":268,"objectType":272,"material":276,"condition":24,"layoutDesc":277,"handNote":281,"date":289,"places":293,"geo":297,"country":62,"region":63,"settlement":55,"repository":24,"textLang":299,"facsimile":301,"provenance":51,"letterHeights":306,"publications":307,"zotero":317,"keywords":327,"html":101},"ISic001391","Greek inscription recording enjoyment of a spring",{"_":10},{"_":269,"ana":270,"ref":271},"touristic text","#function.touristic","https://www.eagle-network.eu/voc/typeins/lod/135.html",{"_":273,"ana":274,"ref":275},"rock face","#object.rock-face","http://www.eagle-network.eu/voc/objtyp/lod/211",{"_":109,"ana":110,"ref":111},{"layout":278},{"p":279,"rs":280,"damage":24},"The text maintains a clear left margin, laid out over three lines. The extended spacing in lines 1 and 2 has sometimes suggested to editors that the text divides into columns; however this is probably to compensate for the fact that lines 2 and 3 are shortened by the insertion of a large engraved palm leaf (20 cm high) on the right margin.",{"_":29,"ana":30,"ref":31},{"lettering":282,"dimensions":283},"The text is engraved in large bold letters, with the topmost stroke often extended vertically above the letter on Α, Λ, Δ. Letter forms are somewhat variable within the inscription, with lunate and straight sigma used indiscriminately; epsilon is normally straight, but appears lunate in ΦΗϹΕΙΝΟϹ in line 2; alpha is normally straight but displays broken bar in ΕΥΦΡΑΝΘΗΣΑΝ in line 3; phi has an angular eye in lines 1 and 2 but a rounded eye in line 3; variation within texts is however common, and it is not necessary to assume that this reflects different hands in use within the text. Ligatures are employed several times in the text, which has been the source of several confused readings in the past.",[284,288],{"type":36,"l":285,"from":38,"to":286,"h":287,"unit":39},"Line 1-3","line3","70-90",{"type":41,"l":42,"from":38,"to":43,"unit":39},{"_":290,"notBefore":291,"notAfter":292,"precision":48},"3rd century CE or early 4th century CE (Manganaro)",201,350,[294,296],{"_":51,"type":52,"ref":53,"corresp":295},"#findspot",{"_":55,"type":56,"ref":57},[298],[60,61],{"_":65,"mainLang":66,"languages":300},[65],{"n":69,"url":302,"height":303,"width":304,"desc":305,"surfaceType":74},"ISic001391_tiled.tif","2388px","3716px","Photo J. Prag",[],[77,308,309,310,311,81,82,185,312,313,187,314,315,186,316,78,79,80,83],"Supplementum epigraphicum graecum, 1923-","Bulletin épigraphique, 1888-","Pirro, 1733, Sicilia sacra disquisitionibus, et notitiis illustrata. ... Editio tertia, emendata, & continuatione aucta cura, et studio ... Antonini Mongitore","Amico, 1757-1760, Lexicon topographicum Siculum","Schmoll, 1958, Die vorgriechischen Sprachen siziliens","Soraci, 1958, Appunti di epigrafia greca e romana relativa alla regione hyblense-inessea-adranita","Ferrua, 1989, Note e giunte alle iscrizioni cristiane antiche della Sicilia","Manganaro, 1992, Iscrizioni \"rupestri\" di Sicilia","Libertini, 1932, Adranon. Questioni storiche e topografiche",[85,318,319,320,321,89,90,189,322,323,191,324,325,190,326,86,87,88,91],"F2GG87EQ","77P5MNIR","ZCCYR8S7","YZEYESTP","JQNCGI8C","ZXGG3V8Z","759ZXHKQ","UQRFDXEG","ICCT8RK8",[328,329,330,269,273,109,96,97,98,99,97,100,66],"isic001391","greek inscription recording enjoyment of a spring",{"_":10},{"file":332,"uri":332,"title":333,"status":334,"editionAuthor":11,"type":335,"objectType":339,"material":343,"condition":24,"layoutDesc":344,"handNote":348,"date":364,"places":368,"geo":375,"country":62,"region":63,"settlement":55,"repository":379,"idno":383,"textLang":386,"facsimile":392,"provenance":370,"letterHeights":395,"publications":396,"zotero":401,"keywords":406,"html":101},"ISic001404","Inscribed boundary stone",{"_":10},{"_":336,"ana":337,"ref":338},"terminus","#function.terminus","http://www.eagle-network.eu/voc/typeins/lod/96.html",{"_":340,"ana":341,"ref":342},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250.html",{"_":21,"ana":22,"ref":23},{"layout":345},{"p":346,"rs":347,"damage":24},"Three lines of large letters across the upper part of one of the wider faces. The inscribed field is approximately 0.36 m high x 0.30 m wide. The first line of text is less clear, especially around the upper margin and at the right edge. A continuous horizontal line separates lines 1 and 2.",{"_":29,"ana":30,"ref":31},{"lettering":349,"dimensions":350},"The letters are engraved in broad, rounded strokes (partly the result of weathering) and have a regular form. K has arms that do not quite reach to the top and bottom of the letter; E has strokes of equal length; A has broken bar. The text is either Latin or a mixture or Latin and Greek, given the presence of L in the second line.",[351,353,356,359,361],{"type":36,"l":37,"from":38,"to":38,"h":352,"unit":39},"120-130",{"type":36,"l":354,"from":43,"to":43,"h":355,"unit":39},"Line 2","100-110",{"type":36,"l":357,"from":286,"to":286,"h":358,"unit":39},"Line 3","100",{"type":41,"l":42,"from":38,"to":43,"h":360,"unit":39},"30-40",{"type":41,"l":362,"from":43,"to":286,"h":363,"unit":39},"Interlineation line 2 to 3","10-30",{"_":365,"notBefore":366,"notAfter":367,"precision":48},"5th century CE or later (?)",401,700,[369,372],{"_":370,"type":52,"ref":371},"Centuripae","http://pleiades.stoa.org/places/462153",{"_":373,"type":56,"ref":374},"Centuripe","http://sws.geonames.org/2525032",[376],[377,378],37.62336,14.74049,{"_":380,"role":381,"ref":382},"Museo Archeologico Regionale di Adrano","museum","http://sicily.classics.ox.ac.uk/museum/021",{"_":384,"type":385},"480","inventory",{"_":387,"mainLang":66,"otherLangs":388,"ana":389,"languages":390},"Ancient Greek and Latin","la","#bilingualism.biscriptal-phenomena.graphic-interference",[65,391],"Latin",{"n":69,"url":393,"height":72,"width":71,"desc":394,"surfaceType":74},"ISic001404_tiled.tif","Photo J. Prag, courtesy Museo Archeologico Regionale di Adrano",[],[77,308,81,397,398,399,78,79,80,82,400,83],"Manganaro, 1994, Per una storia della 'chora Katanaia'","Biondi, 2002, Per una carta archeologica del territorio di Centuripe","Biondi, 2010, Centuripe (EN). Indagini su un territorio della Sicilia centro-orientale","Manganaro, 1980, La provincia Romana",[85,318,89,402,403,404,86,87,88,90,405,91],"ZHFSM94Z","CFHKJPUN","GSAMDGK4","VQBJ735Q",[407,408,409,336,340,21,410,411,98,99,97,412,413,66],"isic001404","inscribed boundary stone",{"_":10},"centuripae","centuripe","museo archeologico regionale di adrano","ancient greek and latin",{"file":415,"uri":415,"title":416,"status":417,"editionAuthor":11,"type":418,"objectType":419,"material":422,"condition":426,"layoutDesc":428,"handNote":434,"date":570,"places":575,"geo":578,"country":62,"region":63,"settlement":55,"repository":580,"idno":581,"textLang":583,"facsimile":585,"provenance":51,"letterHeights":590,"publications":591,"zotero":595,"keywords":599,"html":101},"ISic002995","Inscribed altar or statue base",{"_":10},{"_":142,"ana":143,"ref":144},{"_":420,"ana":147,"ref":148,"certainty":421},"altar\n                                    ",{"locus":150,"match":151,"assertedValue":152,"desc":153},{"_":423,"ana":424,"ref":425},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":427},"#condition.damaged",{"layout":429},{"p":430,"rs":431,"damage":432},"The inscribed face is maximum 0.26 m high and 0.497 m wide. The text is extremely irregular and uneven in its layout, with letters of varying size and the horizontal of the lines very erratic. The text appears to observe the left margin with some consistency, but is extremely irregular on the right. The full height of the face is employed: the final line is squeezed.",{"_":29,"ana":30,"ref":31},{"ana":433},"#text_condition.incomplete",{"lettering":435,"dimensions":533},[436,437],"The inscription is crudely engraved and inexpertly laid out on the face. The letter forms are primarily distinguished by their irregularity and the poor quality of the engraving. Theta is formed by large circle with single mid-dot; epsilon on occasion has a shorter middle bar; omega is notable in being consistently extremely open, with short horizontal tails (projecting outwards only); omicron is generally full-size, or nearly so, but also smaller; kappa has equal length arms which join the vertical, but do not generally extend fully to the top/bottom of the line; alpha is broad with straight bar; phi has a rounded closed eye; nu on occasion has a shorter right vertical, leaning outwards; sigma is either four straight bars (with top and bottom strokes open beyond the h