":113},{"_":115,"target":115},{"file":165,"uri":165,"title":166,"status":167,"editionAuthor":13,"type":168,"objectType":169,"material":170,"condition":26,"layoutDesc":171,"handNote":174,"date":179,"places":180,"geo":183,"provenance":51,"provenanceGeo":185,"country":63,"region":64,"settlement":65,"repository":186,"idno":187,"textLang":189,"tmNumber":191,"facsimile":192,"letterHeights":194,"publications":195,"zotero":196,"keywords":197,"html":201,"bibl":202},"ISic001551","I.Sicily inscription 001551",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":172},{"rs":173,"damage":26},{"_":30,"ana":31,"ref":32},{"lettering":175,"dimensions":176},"Relatively broad brushstrokes with some fluidity. Alpha is broad with straight bar; beta has distinct closed eyes, somewhat angular; eta is broad with outward turning lower strokes; theta is ovid with horizontal bar; mu is broad with vertical uprights, and the middle strokes only descending half-way; omicron is sometimes slightly smaller and above the line; sigma is lunate; omega is lunate.",[177,178],{"type":37,"l":38,"from":39,"to":39,"unit":40},{"type":42,"l":43,"from":39,"to":44,"unit":40},{"_":46,"notBefore":47,"notAfter":48},[181,182],{"_":51,"type":52,"ref":53},{"_":55,"type":56,"ref":57},[184],[60,61],[],{"_":67,"role":68,"ref":69},{"_":188,"type":72},"1070",{"_":74,"mainLang":75,"languages":190},[74],"284949",{"n":79,"url":193,"height":81,"width":82,"desc":83,"surfaceType":84},"ISic001551_tiled.tif",[],[149,87,150,88,89,90,91],[152,93,153,94,95,96,97],[198,199,200,15,19,23,102,103,104,105,106,107,108,75],"isic001551","i.sicily inscription 001551",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Μάρχος Σημβρόνις \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>ἥρως ἀγαθός \u003C/span>\u003C/div>  \u