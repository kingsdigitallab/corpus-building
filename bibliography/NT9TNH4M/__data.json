":54},"Lilybaeum","ancient","http://pleiades.stoa.org/places/462281",{"_":56,"type":57,"ref":58},"Marsala","modern","http://sws.geonames.org/6542148",[60],[61,62],37.80355,12.4379,[],"Italy","Sicily",{"_":67,"role":68,"ref":69},"Museo archeologico regionale Lilibeo Marsala - Baglio Anselmi","museum","http://sicily.classics.ox.ac.uk/museum/108",{"type":71},"inventory",{"_":73,"mainLang":74,"languages":75},"Ancient Greek","grc",[73],"284948",{"n":78,"url":79,"height":80,"width":81,"desc":82,"surfaceType":83},"screen","ISic001550_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[86,86,87,88,89,90,91,92],"Supplementum epigraphicum graecum, 1923-","Manni Piraino, 1973, IGMusPalermo","Kretschmer, 1927, Das Femininum von ἥρως","Gabrici, 1929, Stele sepolcrali di Lilibeo a forma di Heroon","Bisi, 1970, Influenze italiote e siceliote sull'arte tardo-punica. Le stele funerarie di Lilibeo","Di Stefano, 1984, Lilibeo. Testimonianze archeologiche dal IV sec a.C. al V sec. d.C.","Vento, 2000, Le stele dipinte di Lilibeo",[94,94,95,96,97,98,99,100],"F2GG87EQ","F66S4X3M","NT9TNH4M","W9I8NZBC","2DZ9TJFH","Q5PB252W","RTAB9A28",[102,103,104,15,19,23,105,106,107,108,106,109,110,74],"isic001550","i.sicily inscription 001550",{"_":12},"lilybaeum","marsala","italy","sicily","museo archeologico regionale lilibeo marsala - baglio anselmi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Μαρία ἥρυς \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>ἀγαθά \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":113,"ptr":114,"ref":116,"title":2,"citation":5,"uri":6},"306 no.3",{"target":115},"http://zotero.org/groups/3