0002533",{"file":118,"uri":118,"title":119,"status":120,"editionAuthor":11,"type":121,"objectType":122,"material":123,"condition":24,"layoutDesc":124,"handNote":127,"date":132,"places":133,"geo":136,"provenance":50,"provenanceGeo":138,"country":62,"region":63,"settlement":139,"repository":140,"idno":143,"textLang":145,"tmNumber":147,"facsimile":148,"letterHeights":150,"publications":151,"zotero":152,"keywords":153,"html":159,"bibl":160},"ISic001551","I.Sicily inscription 001551",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":125},{"rs":126,"damage":24},{"_":28,"ana":29,"ref":30},{"lettering":128,"dimensions":129},"Relatively broad brushstrokes with some fluidity. Alpha is broad with straight bar; beta has distinct closed eyes, somewhat angular; eta is broad with outward turning lower strokes; theta is ovid with horizontal bar; mu is broad with vertical uprights, and the middle strokes only descending half-way; omicron is sometimes slightly smaller and above the line; sigma is lunate; omega is lunate.",[130,131],{"type":35,"l":36,"from":37,"to":37,"unit":38},{"type":40,"l":41,"from":37,"to":42,"unit":38},{"_":44,"notBefore":45,"notAfter":46,"precision":47},[134,135],{"_":50,"type":51,"ref":52},{"_":54,"type":55,"ref":56},[137],[59,60],[],"Palermo",{"_":141,"role":66,"ref":142},"Museo Archeologico Regionale Antonino Salinas","http://sicily.classics.ox.ac.uk/museum/064",{"_":144,"type":69},"1070",{"_":71,"mainLang":72,"languages":146},[71],"284949",{"n":76,"url":149,"height":78,"width":79,"desc":80,"surfaceType":81},"ISic001551_tiled.tif",[],[84,85,86,87,88,89,90],[92,93,94,95,96,97,98],[154,155,156,13,17,21,103,104,105,106,157,158,108,72],"isic001551","i.sicily inscription 001551",{"_":10},"palermo","museo archeologico regionale antonino salinas","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenu