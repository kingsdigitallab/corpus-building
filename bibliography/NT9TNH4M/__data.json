e\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Μάρχος Σημβρόνις \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>ἥρως ἀγαθός \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":162,"ptr":163,"ref":164,"title":2,"citation":5,"uri":6},"306 no.1",{"target":115},{"_":117,"target":117},{"file":166,"uri":166,"title":167,"status":168,"editionAuthor":13,"type":169,"objectType":170,"material":171,"condition":26,"layoutDesc":172,"handNote":175,"date":180,"places":181,"geo":184,"provenance":52,"provenanceGeo":186,"country":64,"region":65,"settlement":140,"repository":187,"idno":188,"textLang":190,"tmNumber":192,"facsimile":193,"letterHeights":195,"publications":196,"zotero":197,"keywords":198,"html":202,"bibl":203},"ISic001553","I.Sicily inscription 001553",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":173},{"rs":174,"damage":26},{"_":30,"ana":31,"ref":32},{"lettering":176,"dimensions":177},"Simple letters with slight serfis to the strokes, particularly to the top of the alpha. Alpha is broad with straight bar. The initial theta appears circular with a central point; the final theta has a detached horizontal bar and is slightly ovoid.",[178,179],{"type":37,"l":38,"from":39,"to":39,"unit":40},{"type":42,"l":43,"from":39,"to":44,"unit":40},{"_":46,"notBefore":47,"notAfter":48,"precision":49},[182,183],{"_":52,"type":53,"ref":54},{"_":56,"type":57,"ref":58},[185],[61,62],[],{"_":142,"role":68,"ref":143},{"_":189,"type":71},"1067",{"_":73,"mainLang":74,"languages":191},[73],"284952",{"n":78,"url":194,"height":80,"width":81,"desc":82,"surfaceType":83},"ISic001553_tiled.tif",[],[86,86,86,87,88,89,90,92],[94,94,94,95,96,97,98,100],[199,200,201,15,19,23,105,106,107,108,158,159,110,74],"isic001553","i.sicily inscription 001553",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" i