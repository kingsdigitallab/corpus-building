na":30,"ref":31},{"lettering":433,"dimensions":434},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[435,436],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":397,"notBefore":134,"notAfter":180,"evidence":50,"precision":51},[439,440],{"_":54,"type":55,"ref":56,"corresp":270},{"_":58,"type":59,"ref":60,"offset":61},[442],[64,65],[67,68],{"_":276,"role":277,"ref":278},{"type":77},{"_":79,"mainLang":80,"languages":447},[79],{"n":83,"url":449,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004419_tiled.tif",[],[94],[99],[454,455,456,14,253,22,104,105,106,107,105,291,109,80],"isic004419","epitaph for aristarchos",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":459,"ptr":460,"ref":461,"title":2,"citation":5},"108 no.9 and fig.10",{"target":114},{"_":116,"target":116},{"file":463,"uri":463,"title":464,"status":465,"editionAuthor":12,"type":466,"objectType":467,"material":468,"condition":3,"layoutDesc":469,"handNote":473,"date":479,"places":480,"geo":483,"provenance":54,"provenanceGeo":485,"country":69,"region":70,"settlement":58,"repository":486,"idno":487,"textLang":488,"tmNumber":3,"facsimile":490,"letterHeights":492,"publications":493,"zotero":494,"keywords":495,"html":499,"bibl":500},"ISic004420","Epitaph for Aristokrates",{"_":11},{"_":14,"ana":15,"ref":16},{"_":253,"ana":254,"ref":255},{"_":22,"ana":23,"ref":24},{"layout":470},{"p":471,"rs":472,"damage":3},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":29,"ana":30,"ref":31},{"lettering":474,"dimensions":475},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[476,478],{"type":36,"l":354,"from":38,"to":44,"h":477,"unit":40},"49",{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":397,"notBefore":134,"notAfter":180,"evidence":50,"precision":51},[481,482],{"_":54,"type":55,"ref":56,"corresp":270},{"_":58,"type":59,"ref":60,"offset":61},[484],[64,65],[67,68],{"_":276,"role":277,"ref":278},{"type":77},{"_":79,"mainLang":80,"languages":489},[79],{"n":83,"url":491,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004420_tiled.tif",[],[94],[99],[496,497,498,14,253,22,104,105,106,107,105,291,109,80],"isic004420","epitaph for aristokrates",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":501,"ptr":502,"ref":503,"title":2,"citation":5},"108 no.10 and fig.11",{"target":114},{"_":116,"target":116},{"file":505,"uri":505,"title":506,"status":507,"editionAuthor":12,"type":508,"objectType":509,"material":510,"condition":3,"layoutDesc":511,"handNote":515,"date":521,"places":523,"geo":526,"provenance":54,"provenanceGeo":528,"country":69,"region":70,"settlement":58,"repository":529,"idno":530,"textLang":531,"tmNumber":3,"facsimile":533,"letterHeights":535,"publications":536,"zotero":537,"keywords":538,"html":542,"bibl":543},"ISic004421","Epitaph for Athanippos",{"_":11},{"_":14,"ana":15,"ref":16},{"_":253,"ana":254,"ref":255},{"_":22,"ana":23,"ref":24},{"layout":512},{"p":513,"rs":514,"damage":3},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":29,"ana":30,"ref":31},{"lettering":516,"dimensions":517},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[518,520],{"type":36,"l":37,"from":38,"to":38,"h":519,"unit":40},"29",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":522,"notBefore":134,"notAfter":180,"evidence":50,"precision":51},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[524,525],{"_":54,"type":55,"ref":56,"corresp":270},{"_":58,"type":59,"ref":60,"offset":61},[527],[64,65],[67,68],{"_":276,"role":277,"ref":278},{"type":77},{"_":79,"mainLang":80,"languages":532},[79],{"n":83,"url":534,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004421_tiled.tif",[],[94],[99],[539,540,541,14,253,22,104,105,106,107,105,291,109,80],"isic004421","epitaph for athanippos",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":544,"ptr":545,"ref":546,"title":2,"citation":5},"108 no.11 and fig.12",{"target":114},{"_":116,"target":116},{"file":548,"uri":548,"title":549,"status":550,"editionAuthor":12,"type":551,"objectType":552,"material":553,"condition":3,"layoutDesc":554,"handNote":558,"date":563,"places":565,"geo":568,"provenance":54,"provenanceGeo":570,"country":69,"region":70,"settlement":58,"repository":571,"idno":572,"textLang":574,"tmNumber":3,"facsimile":576,"letterHeights":578,"publications":579,"zotero":580,"keywords":581,"html":585,"bibl":586},"ISic004422","Epitaph for Artemidoros (?)",{"_":11},{"_":14,"ana":15,"ref":16},{"_":253,"ana":254,"ref":255},{"_":22,"ana":23,"ref":24},{"layout":555},{"p":556,"rs":557,"damage":3},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":29,"ana":30,"ref":31},{"lettering":559,"dimensions":560},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[561,562],{"type":36,"l":37,"from":38,"to":38,"h":519,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":564,"notBefore":134,"notAfter":180,"evidence":50,"precision":51},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[566,567],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[569],[64,65],[67,68],{"_":72,"role":73,"ref":74},{"_":573,"type":77},"ME23440",{"_":79,"mainLang":80,"languages":575},[79],{"n":83,"url":577,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004422_tiled.tif",[],[93,94],[98,99],[582,583,584,14,253,22,104,105,106,107,105,108,109,80],"isic004422","epitaph for artemidoros (?)",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":587,"ptr":588,"ref":589,"title":2,"citation":5},"108 no.12 and fig.13",{"target":114},{"_":116,"target":116}],"uses":{"params":["slug"]}}]}
