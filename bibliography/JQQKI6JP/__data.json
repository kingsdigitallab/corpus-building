38,"l":356,"from":40,"to":46,"h":41,"unit":42},"Line 1-2",{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":269,"notBefore":136,"notAfter":182,"evidence":52,"precision":53},[360,361],{"_":56,"type":57,"ref":58,"corresp":272},{"_":60,"type":61,"ref":62,"offset":63},[363],[66,67],[69,70],{"_":278,"role":279,"ref":280},{"type":79},{"_":81,"mainLang":82,"languages":368},[81],{"n":85,"url":370,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004417_tiled.tif",[],[93,95,96],[98,100,101],[375,376,377,15,255,23,106,107,108,109,107,293,111,82],"isic004417","epitaph for [-?-], child of gerontios",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":380,"ptr":381,"ref":382,"title":2,"citation":5,"uri":6},"107 no.7 and fig.8",{"target":116},{"_":118,"target":118},{"file":384,"uri":384,"title":343,"status":385,"editionAuthor":13,"type":386,"objectType":387,"material":388,"condition":26,"layoutDesc":389,"handNote":393,"date":398,"places":400,"geo":403,"provenance":56,"provenanceGeo":405,"country":71,"region":72,"settlement":60,"repository":406,"idno":407,"textLang":408,"tmNumber":26,"facsimile":410,"letterHeights":412,"publications":413,"zotero":414,"keywords":415,"html":418,"bibl":419},"ISic004418",{"_":12},{"_":15,"ana":16,"ref":17},{"_":255,"ana":256,"ref":257},{"_":23,"ana":24,"ref":25},{"layout":390},{"p":391,"rs":392,"damage":26},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":394,"dimensions":395},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[396,397],{"type":38,"l":356,"from":40,"to":46,"h":314,"unit":42},{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":399,"notBefore":136,"notAfter":182,"evidence":52,"precision":53},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[401,402],{"_":56,"type":57,"ref":58,"corresp":272},{"_":60,"type":61,"ref":62,"offset":63},[404],[66,67],[69,70],{"_":278,"role":279,"ref":280},{"type":79},{"_":81,"mainLang":82,"languages":409},[81],{"n":85,"url":411,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004418_tiled.tif",[],[93,95,96],[98,100,101],[416,376,417,15,255,23,106,107,108,109,107,293,111,82],"isic004418",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":420,"ptr":421,"ref":422,"title":2,"citation":5,"uri":6},"107 no.8 and fig.9",{"target":116},{"_":118,"target":118},{"file":424,"uri":424,"title":425,"status":426,"editionAuthor":13,"type":427,"objectType":428,"material":429,"condition":26,"layoutDesc":430,"handNote":434,"date":439,"places":440,"geo":443,"provenance":56,"provenanceGeo":445,"country":71,"region":72,"settlement":60,"repository":446,"idno":447,"textLang":448,"tmNumber":26,"facsimile":450,"letterHeights":452,"publications":453,"zotero":454,"keywords":455,"html":459,"bibl":460},"ISic004419","Epitaph for Aristarchos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":255,"ana":256,"ref":257},{"_":23,"ana":24,"ref":25},{"layout":431},{"p":432,"rs":433,"damage":26},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":31,"ana":32,"ref":33},{"lettering":435,"dimensions":436},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[437,438],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":399,"notBefore":136,"notAfter":182,"evidence":52,"precision":53},[441,442],{"_":56,"type":57,"ref":58,"corresp":272},{"_":60,"type":61,"ref":62,"offset":63},[444],[66,67],[69,70],{"_":278,"role":279,"ref":280},{"type":79},{"_":81,"mainLang":82,"languages":449},[81],{"n":85,"url":451,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004419_tiled.tif",[],[96],[101],[456,457,458,15,255,23,106,107,108,109,107,293,111,82],"isic004419","epitaph for aristarchos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":461,"ptr":462,"ref":463,"title":2,"citation":5,"uri":6},"108 no.9 and fig.10",{"target":116},{"_":118,"target":118},{"file":465,"uri":465,"title":466,"status":467,"editionAuthor":13,"type":468,"objectType":469,"material":470,"condition":26,"layoutDesc":471,"handNote":475,"date":481,"places":482,"geo":485,"provenance":56,"provenanceGeo":487,"country":71,"region":72,"settlement":60,"repository":488,"idno":489,"textLang":490,"tmNumber":26,"facsimile":492,"letterHeights":494,"publications":495,"zotero":496,"keywords":497,"html":501,"bibl":502},"ISic004420","Epitaph for Aristokrates",{"_":12},{"_":15,"ana":16,"ref":17},{"_":255,"ana":256,"ref":257},{"_":23,"ana":24,"ref":25},{"layout":472},{"p":473,"rs":474,"damage":26},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":31,"ana":32,"ref":33},{"lettering":476,"dimensions":477},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[478,480],{"type":38,"l":356,"from":40,"to":46,"h":479,"unit":42},"49",{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":399,"notBefore":136,"notAfter":182,"evidence":52,"precision":53},[483,484],{"_":56,"type":57,"ref":58,"corresp":272},{"_":60,"type":61,"ref":62,"offset":63},[486],[66,67],[69,70],{"_":278,"role":279,"ref":280},{"type":79},{"_":81,"mainLang":82,"languages":491},[81],{"n":85,"url":493,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004420_tiled.tif",[],[96],[101],[498,499,500,15,255,23,106,107,108,109,107,293,111,82],"isic004420","epitaph for aristokrates",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":503,"ptr":504,"ref":505,"title":2,"citation":5,"uri":6},"108 no.10 and fig.11",{"target":116},{"_":118,"target":118},{"file":507,"uri":507,"title":508,"status":509,"editionAuthor":13,"type":510,"objectType":511,"material":512,"condition":26,"layoutDesc":513,"handNote":517,"date":523,"places":525,"geo":528,"provenance":56,"provenanceGeo":530,"country":71,"region":72,"settlement":60,"repository":531,"idno":532,"textLang":533,"tmNumber":26,"facsimile":535,"letterHeights":537,"publications":538,"zotero":539,"keywords":540,"html":544,"bibl":545},"ISic004421","Epitaph for Athanippos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":255,"ana":256,"ref":257},{"_":23,"ana":24,"ref":25},{"layout":514},{"p":515,"rs":516,"damage":26},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":31,"ana":32,"ref":33},{"lettering":518,"dimensions":519},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[520,522],{"type":38,"l":39,"from":40,"to":40,"h":521,"unit":42},"29",{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":524,"notBefore":136,"notAfter":182,"evidence":52,"precision":53},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[526,527],{"_":56,"type":57,"ref":58,"corresp":272},{"_":60,"type":61,"ref":62,"offset":63},[529],[66,67],[69,70],{"_":278,"role":279,"ref":280},{"type":79},{"_":81,"mainLang":82,"languages":534},[81],{"n":85,"url":536,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004421_tiled.tif",[],[96],[101],[541,542,543,15,255,23,106,107,108,109,107,293,111,82],"isic004421","epitaph for athanippos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":546,"ptr":547,"ref":548,"title":2,"citation":5,"uri":6},"108 no.11 and fig.12",{"target":116},{"_":118,"target":118},{"file":550,"uri":550,"title":551,"status":552,"editionAuthor":13,"type":553,"objectType":554,"material":555,"condition":26,"layoutDesc":556,"handNote":560,"date":565,"places":567,"geo":570,"provenance":56,"provenanceGeo":572,"country":71,"region":72,"settlement":60,"repository":573,"idno":574,"textLang":576,"tmNumber":26,"facsimile":578,"letterHeights":580,"publications":581,"zotero":582,"keywords":583,"html":587,"bibl":588},"ISic004422","Epitaph for Artemidoros (?)",{"_":12},{"_":15,"ana":16,"ref":17},{"_":255,"ana":256,"ref":257},{"_":23,"ana":24,"ref":25},{"layout":557},{"p":558,"rs":559,"damage":26},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":561,"dimensions":562},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[563,564],{"type":38,"l":39,"from":40,"to":40,"h":521,"unit":42},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":566,"notBefore":136,"notAfter":182,"evidence":52,"precision":53},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[568,569],{"_":56,"type":57,"ref":58},{"_":60,"type":61,"ref":62,"offset":63},[571],[66,67],[69,70],{"_":74,"role":75,"ref":76},{"_":575,"type":79},"ME23440",{"_":81,"mainLang":82,"languages":577},[81],{"n":85,"url":579,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004422_tiled.tif",[],[95,96],[100,101],[584,585,586,15,255,23,106,107,108,109,107,110,111,82],"isic004422","epitaph for artemidoros (?)",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":589,"ptr":590,"ref":591,"title":2,"citation":5,"uri":6},"108 no.12 and fig.13",{"target":116},{"_":118,"target":118}],"uses":{"params":["slug"]}}]}
