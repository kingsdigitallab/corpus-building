7,"ref":78},{"_":153,"type":81},"ME23439",{"_":83,"mainLang":84,"languages":155},[83],{"n":87,"url":157,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004412_tiled.tif",[159],{"atLeast":95,"atMost":95},[98,99,100],[103,104,105],[163,164,165,15,19,23,110,111,112,113,111,114,115,84],"isic004412","epitaph for aristoboula",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοβούλας \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":168,"ptr":169,"ref":170,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.2 and fig.3",{"target":120},{"_":122,"target":122},{"file":172,"uri":172,"title":173,"status":174,"editionAuthor":13,"type":175,"objectType":176,"material":177,"condition":29,"layoutDesc":179,"handNote":182,"date":187,"places":191,"geo":194,"country":61,"provenance":58,"provenanceGeo":196,"region":74,"settlement":63,"repository":197,"idno":198,"textLang":200,"tmNumber":29,"facsimile":202,"letterHeights":204,"publications":206,"zotero":207,"keywords":208,"html":212,"bibl":213,"bulletinDateSort":123,"citedRangeSort":214,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004413","Epitaph for Kallo",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"type":25,"subtype":178,"ref":28},[27],{"layout":180},{"p":32,"rs":181,"damage":29},{"_":34,"ana":35,"ref":36},{"lettering":183,"dimensions":184},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[185,186],{"type":41,"l":42,"from":43,"to":43,"h":44,"unit":45,"atLeast":44,"atMost":44},{"type":47,"l":48,"from":43,"to":49,"h":50,"unit":45},{"_":188,"notBefore":189,"notAfter":190,"evidence":55},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[192,193],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[195],[69,70],[72,73],{"_":76,"role":77,"ref":78},{"_":199,"type":81},"ME23436",{"_":83,"mainLang":84,"languages":201},[83],{"n":87,"url":203,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004413_tiled.tif",[205],{"atLeast":95,"atMost":95},[98,99,100],[103,104,105],[209,210,211,15,19,23,110,111,112,113,111,114,115,84],"isic004413","epitaph for kallo",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":214,"ptr":215,"ref":216,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.3 and fig.4",{"target":120},{"_":122,"target":122},{"file":218,"uri":218,"title":219,"status":220,"editionAuthor":13,"type":221,"objectType":222,"material":223,"condition":29,"layoutDesc":225,"handNote":228,"date":233,"places":234,"geo":237,"country":61,"provenance":58,"provenanceGeo":239,"region":74,"settlement":63,"repository":240,"idno":241,"textLang":243,"tmNumber":29,"facsimile":245,"letterHeights":247,"publications":249,"zotero":250,"keywords":251,"html":255,"bibl":256,"bulletinDateSort":123,"citedRangeSort":257,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004414","Epitaph for Eupolemos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"type":25,"subtype":224,"ref":28},[27],{"layout":226},{"p":32,"rs":227,"damage":29},{"_":34,"ana":35,"ref":36},{"lettering":229,"dimensions":230},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[231,232],{"type":41,"l":42,"from":43,"to":43,"h":44,"unit":45,"atLeast":44,"atMost":44},{"type":47,"l":48,"from":43,"to":49,"h":50,"unit":45},{"_":188,"notBefore":189,"notAfter":190,"evidence":55},[235,236],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[238],[69,70],[72,73],{"_":76,"role":77,"ref":78},{"_":242,"type":81},"ME23438",{"_":83,"mainLang":84,"languages":244},[83],{"n":87,"url":246,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004414_tiled.tif",[248],{"atLeast":95,"atMost":95},[97,98,99,100],[102,103,104,105],[252,253,254,15,19,23,110,111,112,113,111,114,115,84],"isic004414","epitaph for eupolemos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":257,"ptr":258,"ref":259,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.4 and fig.5",{"target":120},{"_":122,"target":122},{"file":261,"uri":261,"title":262,"status":263,"editionAuthor":13,"type":264,"objectType":265,"material":269,"condition":29,"layoutDesc":271,"handNote":275,"date":280,"places":282,"geo":286,"country":61,"provenance":58,"provenanceGeo":288,"region":74,"settlement":63,"repository":289,"idno":293,"textLang":294,"tmNumber":29,"facsimile":296,"letterHeights":298,"publications":300,"zotero":301,"keywords":302,"html":307,"bibl":308,"bulletinDateSort":123,"citedRangeSort":309,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":266,"ana":267,"ref":268},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":23,"ana":24,"type":25,"subtype":270,"ref":28},[27],{"layout":272},{"p":273,"rs":274,"damage":29},"Single line of greek letters approximately centred on the face of the plinth",{"_":34,"ana":35,"ref":36},{"lettering":276,"dimensions":277},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[278,279],{"type":41,"l":42,"from":43,"to":43,"h":44,"unit":45,"atLeast":44,"atMost":44},{"type":47,"l":48,"from":43,"to":49,"h":50,"unit":45},{"_":281,"notBefore":142,"notAfter":190,"evidence":55},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[283,285],{"_":58,"type":59,"ref":60,"corresp":284,"region":61},"#findspot",{"_":63,"type":64,"ref":65,"offset":66,"region":61},[287],[69,70],[72,73],{"_":290,"role":291,"ref":292},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":81},{"_":83,"mainLang":84,"languages":295},[83],{"n":87,"url":297,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004415_tiled.tif",[299],{"atLeast":95,"atMost":95},[97,100],[102,105],[303,304,305,15,266,23,110,111,112,113,111,306,115,84],"isic004415","epitaph for krimma, child of aunakos",{"_":12},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":309,"ptr":310,"ref":311,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.5 and fig.6",{"target":120},{"_":122,"target":122},{"file":313,"uri":313,"title":314,"status":315,"editionAuthor":13,"type":316,"objectType":317,"material":318,"condition":29,"layoutDesc":320,"handNote":324,"date":330,"places":331,"geo":334,"country":61,"provenance":58,"provenanceGeo":336,"region":74,"settlement":63,"repository":337,"idno":338,"textLang":339,"tmNumber":29,"facsimile":341,"letterHeights":343,"publications":346,"zotero":347,"keywords":348,"html":352,"bibl":353,"bulletinDateSort":123,"citedRangeSort":354,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004416","Epitaph for Philon, son Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":266,"ana":267,"ref":268},{"_":23,"ana":24,"type":25,"subtype":319,"ref":28},[27],{"layout":321},{"p":322,"rs":323,"damage":29},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":34,"ana":35,"ref":36},{"lettering":325,"dimensions":326},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[327,329],{"type":41,"l":42,"from":43,"to":43,"h":328,"unit":45,"atLeast":328,"atMost":328},"59",{"type":47,"l":48,"from":43,"to":49,"h":50,"unit":45},{"_":281,"notBefore":142,"notAfter":190,"evidence":55},[332,333],{"_":58,"type":59,"ref":60,"corresp":284,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[335],[69,70],[72,73],{"_":290,"role":291,"ref":292},{"type":81},{"_":83,"mainLang":84,"languages":340},[83],{"n":87,"url":342,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004416_tiled.tif",[344],{"atLeast":345,"atMost":345},59,[97,100],[102,105],[349,350,351,15,266,23,110,111,112,113,111,306,115,84],"isic004416","epitaph for philon, son aunakos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":354,"ptr":355,"ref":356,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.6 and fig.7",{"target":120},{"_":122,"target":122},{"file":358,"uri":358,"title":359,"status":360,"editionAuthor":13,"type":361,"objectType":362,"material":363,"condition":29,"layoutDesc":365,"handNote":369,"date":375,"places":376,"geo":379,"country":61,"provenance":58,"provenanceGeo":381,"region":74,"settlement":63,"repository":382,"idno":383,"textLang":384,"tmNumber":29,"facsimile":386,"letterHeights":388,"publications":390,"zotero":391,"keywords":392,"html":396,"bibl":397,"bulletinDateSort":123,"citedRangeSort":398,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":12},{"_":15,"ana":16,"ref":17},{"_":266,"ana":267,"ref":268},{"_":23,"ana":24,"type":25,"subtype":364,"ref":28},[27],{"layout":366},{"p":367,"rs":368,"damage":29},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":34,"ana":35,"ref":36},{"lettering":370,"dimensions":371},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[372,374],{"type":41,"l":373,"from":43,"to":49,"h":44,"unit":45,"atLeast":44,"atMost":44},"Line 1-2",{"type":47,"l":48,"from":43,"to":49,"unit":45},{"_":281,"notBefore":142,"notAfter":190,"evidence":55},[377,378],{"_":58,"type":59,"ref":60,"corresp":284,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[380],[69,70],[72,73],{"_":290,"role":291,"ref":292},{"type":81},{"_":83,"mainLang":84,"languages":385},[83],{"n":87,"url":387,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004417_tiled.tif",[389],{"atLeast":95,"atMost":95},[97,99,100],[102,104,105],[393,394,395,15,266,23,110,111,112,113,111,306,115,84],"isic004417","epitaph for [-?-], child of gerontios",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":398,"ptr":399,"ref":400,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.7 and fig.8",{"target":120},{"_":122,"target":122},{"file":402,"uri":402,"title":359,"status":403,"editionAuthor":13,"type":404,"objectType":405,"material":406,"condition":29,"layoutDesc":408,"handNote":412,"date":417,"places":419,"geo":422,"country":61,"provenance":58,"provenanceGeo":424,"region":74,"settlement":63,"repository":425,"idno":426,"textLang":427,"tmNumber":29,"facsimile":429,"letterHeights":431,"publications":433,"zotero":434,"keywords":435,"html":438,"bibl":439,"bulletinDateSort":123,"citedRangeSort":440,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004418",{"_":12},{"_":15,"ana":16,"ref":17},{"_":266,"ana":267,"ref":268},{"_":23,"ana":24,"type":25,"subtype":407,"ref":28},[27],{"layout":409},{"p":410,"rs":411,"damage":29},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":34,"ana":35,"ref":36},{"lettering":413,"dimensions":414},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[415,416],{"type":41,"l":373,"from":43,"to":49,"h":328,"unit":45,"atLeast":328,"atMost":328},{"type":47,"l":48,"from":43,"to":49,"unit":45},{"_":418,"notBefore":142,"notAfter":190,"evidence":55},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[420,421],{"_":58,"type":59,"ref":60,"corresp":284,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[423],[69,70],[72,73],{"_":290,"role":291,"ref":292},{"type":81},{"_":83,"mainLang":84,"languages":428},[83],{"n":87,"url":430,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004418_tiled.tif",[432],{"atLeast":345,"atMost":345},[97,99,100],[102,104,105],[436,394,437,15,266,23,110,111,112,113,111,306,115,84],"isic004418",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":440,"ptr":441,"ref":442,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.8 and fig.9",{"target":120},{"_":122,"target":122},{"file":444,"uri":444,"title":445,"status":446,"editionAuthor":13,"type":447,"objectType":448,"material":449,"condition":29,"layoutDesc":451,"handNote":455,"date":460,"places":461,"geo":464,"country":61,"provenance":58,"provenanceGeo":466,"region":74,"settlement":63,"repository":467,"idno":468,"textLang":469,"tmNumber":29,"facsimile":471,"letterHeights":473,"publications":475,"zotero":476,"keywords":477,"html":481,"bibl":482,"bulletinDateSort":123,"citedRangeSort":483,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004419","Epitaph for Aristarchos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":266,"ana":267,"ref":268},{"_":23,"ana":24,"type":25,"subtype":450,"ref":28},[27],{"layout":452},{"p":453,"rs":454,"damage":29},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":34,"ana":35,"ref":36},{"lettering":456,"dimensions":457},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[458,459],{"type":41,"l":42,"from":43,"to":43,"h":44,"unit":45,"atLeast":44,"atMost":44},{"type":47,"l":48,"from":43,"to":49,"h":50,"unit":45},{"_":418,"notBefore":142,"notAfter":190,"evidence":55},[462,463],{"_":58,"type":59,"ref":60,"corresp":284,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[465],[69,70],[72,73],{"_":290,"role":291,"ref":292},{"type":81},{"_":83,"mainLang":84,"languages":470},[83],{"n":87,"url":472,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004419_tiled.tif",[474],{"atLeast":95,"atMost":95},[100],[105],[478,479,480,15,266,23,110,111,112,113,111,306,115,84],"isic004419","epitaph for aristarchos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":483,"ptr":484,"ref":485,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 no.9 and fig.10",{"target":120},{"_":122,"target":122},{"file":487,"uri":487,"title":488,"status":489,"editionAuthor":13,"type":490,"objectType":491,"material":492,"condition":29,"layoutDesc":494,"handNote":498,"date":504,"places":505,"geo":508,"country":61,"provenance":58,"provenanceGeo":510,"region":74,"settlement":63,"repository":511,"idno":512,"textLang":513,"tmNumber":29,"facsimile":515,"letterHeights":517,"publications":520,"zotero":521,"keywords":522,"html":526,"bibl":527,"bulletinDateSort":123,"citedRangeSort":528,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004420","Epitaph for Aristokrates",{"_":12},{"_":15,"ana":16,"ref":17},{"_":266,"ana":267,"ref":268},{"_":23,"ana":24,"type":25,"subtype":493,"ref":28},[27],{"layout":495},{"p":496,"rs":497,"damage":29},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":34,"ana":35,"ref":36},{"lettering":499,"dimensions":500},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[501,503],{"type":41,"l":373,"from":43,"to":49,"h":502,"unit":45,"atLeast":502,"atMost":502},"49",{"type":47,"l":48,"from":43,"to":49,"unit":45},{"_":418,"notBefore":142,"notAfter":190,"evidence":55},[506,507],{"_":58,"type":59,"ref":60,"corresp":284,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[509],[69,70],[72,73],{"_":290,"role":291,"ref":292},{"type":81},{"_":83,"mainLang":84,"languages":514},[83],{"n":87,"url":516,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004420_tiled.tif",[518],{"atLeast":519,"atMost":519},49,[100],[105],[523,524,525,15,266,23,110,111,112,113,111,306,115,84],"isic004420","epitaph for aristokrates",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":528,"ptr":529,"ref":530,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 no.10 and fig.11",{"target":120},{"_":122,"target":122},{"file":532,"uri":532,"title":533,"status":534,"editionAuthor":13,"type":535,"objectType":536,"material":537,"condition":29,"layoutDesc":539,"handNote":543,"date":549,"places":551,"geo":554,"country":61,"provenance":58,"provenanceGeo":556,"region":74,"settlement":63,"repository":557,"idno":558,"textLang":559,"tmNumber":29,"facsimile":561,"letterHeights":563,"publications":566,"zotero":567,"keywords":568,"html":572,"bibl":573,"bulletinDateSort":123,"citedRangeSort":574,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004421","Epitaph for Athanippos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":266,"ana":267,"ref":268},{"_":23,"ana":24,"type":25,"subtype":538,"ref":28},[27],{"layout":540},{"p":541,"rs":542,"damage":29},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":34,"ana":35,"ref":36},{"lettering":544,"dimensions":545},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[546,548],{"type":41,"l":42,"from":43,"to":43,"h":547,"unit":45,"atLeast":547,"atMost":547},"29",{"type":47,"l":48,"from":43,"to":49,"h":50,"unit":45},{"_":550,"notBefore":142,"notAfter":190,"evidence":55},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[552,553],{"_":58,"type":59,"ref":60,"corresp":284,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[555],[69,70],[72,73],{"_":290,"role":291,"ref":292},{"type":81},{"_":83,"mainLang":84,"languages":560},[83],{"n":87,"url":562,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004421_tiled.tif",[564],{"atLeast":565,"atMost":565},29,[100],[105],[569,570,571,15,266,23,110,111,112,113,111,306,115,84],"isic004421","epitaph for athanippos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":574,"ptr":575,"ref":576,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 no.11 and fig.12",{"target":120},{"_":122,"target":122},{"file":578,"uri":578,"title":579,"status":580,"editionAuthor":13,"type":581,"objectType":582,"material":583,"condition":29,"layoutDesc":585,"handNote":589,"date":594,"places":596,"geo":599,"country":61,"provenance":58,"provenanceGeo":601,"region":74,"settlement":63,"repository":602,"idno":603,"textLang":605,"tmNumber":29,"facsimile":607,"letterHeights":609,"publications":611,"zotero":612,"keywords":613,"html":617,"bibl":618,"bulletinDateSort":123,"citedRangeSort":619,"languageSort":83,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":12},{"_":15,"ana":16,"ref":17},{"_":266,"ana":267,"ref":268},{"_":23,"ana":24,"type":25,"subtype":584,"ref":28},[27],{"layout":586},{"p":587,"rs":588,"damage":29},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":34,"ana":35,"ref":36},{"lettering":590,"dimensions":591},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[592,593],{"type":41,"l":42,"from":43,"to":43,"h":547,"unit":45,"atLeast":547,"atMost":547},{"type":47,"l":48,"from":43,"to":49,"h":50,"unit":45},{"_":595,"notBefore":142,"notAfter":190,"evidence":55},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[597,598],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"offset":66,"region":61},[600],[69,70],[72,73],{"_":76,"role":77,"ref":78},{"_":604,"type":81},"ME23440",{"_":83,"mainLang":84,"languages":606},[83],{"n":87,"url":608,"height":89,"width":90,"desc":91,"surfaceType":92},"ISic004422_tiled.tif",[610],{"atLeast":565,"atMost":565},[99,100],[104,105],[614,615,616,15,266,23,110,111,112,113,111,114,115,84],"isic004422","epitaph for artemidoros (?)",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":619,"ptr":620,"ref":621,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 no.12 and fig.13",{"target":120},{"_":122,"target":122},false],"uses":{"params":["slug"]}}]}
