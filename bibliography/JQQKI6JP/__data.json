3C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοβούλας \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":161,"ptr":162,"ref":163,"title":2,"citation":5,"uri":6},"107 no.2 and fig.3",{"target":116},{"_":118,"target":118},{"file":165,"uri":165,"title":166,"status":167,"editionAuthor":13,"type":168,"objectType":169,"material":170,"condition":26,"layoutDesc":171,"handNote":174,"date":179,"places":183,"geo":186,"provenance":56,"provenanceGeo":188,"country":71,"region":72,"settlement":60,"repository":189,"idno":190,"textLang":192,"tmNumber":26,"facsimile":194,"letterHeights":196,"publications":197,"zotero":198,"keywords":199,"html":203,"bibl":204},"ISic004413","Epitaph for Kallo",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":172},{"p":29,"rs":173,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":175,"dimensions":176},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[177,178],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":180,"notBefore":181,"notAfter":182,"evidence":52,"precision":53},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[184,185],{"_":56,"type":57,"ref":58},{"_":60,"type":61,"ref":62,"offset":63},[187],[66,67],[69,70],{"_":74,"role":75,"ref":76},{"_":191,"type":79},"ME23436",{"_":81,"mainLang":82,"languages":193},[81],{"n":85,"url":195,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004413_tiled.tif",[],[94,95,96],[99,100,101],[200,201,202,15,19,23,106,107,108,109,107,110,111,82],"isic004413","epitaph for kallo",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":205,"ptr":206,"ref":207,"title":2,"citation":5,"uri":6},"107 no.3 and fig.4",{"target":116},{"_":118,"target":118},{"file":209,"uri":209,"title":210,"status":211,"editionAuthor":13,"type":212,"objectType":213,"material":214,"condition":26,"layoutDesc":215,"handNote":218,"date":223,"places":224,"geo":227,"provenance":56,"provenanceGeo":229,"country":71,"region":72,"settlement":60,"repository":230,"idno":231,"textLang":233,"tmNumber":26,"facsimile":235,"letterHeights":237,"publications":238,"zotero":239,"keywords":240,"html":244,"bibl":245},"ISic004414","Epitaph for Eupolemos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":216},{"p":29,"rs":217,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":219,"dimensions":220},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[221,222],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":180,"notBefore":181,"notAfter":182,"evidence":52,"precision":53},[225,226],{"_":56,"type":57,"ref":58},{"_":60,"type":61,"ref":62,"offset":63},[228],[66,67],[69,70],{"_":74,"role":75,"ref":76},{"_":232,"type":79},"ME23438",{"_":81,"mainLang":82,"languages":234},[81],{"n":85,"url":236,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004414_tiled.tif",[],[93,94,95,96],[98,99,100,101],[241,242,243,15,19,23,106,107,108,109,107,110,111,82],"isic004414","epitaph for eupolemos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":246,"ptr":247,"ref":248,"title":2,"citation":5,"uri":6},"107 no.4 and fig.5",{"target":116},{"_":118,"target":118},{"file":250,"uri":250,"title":251,"status":252,"editionAuthor":13,"type":253,"objectType":254,"material":258,"condition":26,"layoutDesc":259,"handNote":263,"date":268,"places":270,"geo":274,"provenance":56,"provenanceGeo":276,"country":71,"region":72,"settlement":60,"repository":277,"idno":281,"textLang":282,"tmNumber":26,"facsimile":284,"letterHeights":286,"publications":287,"zotero":288,"keywords":289,"html":294,"bibl":295},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":255,"ana":256,"ref":257},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":23,"ana":24,"ref":25},{"layout":260},{"p":261,"rs":262,"damage":26},"Single line of greek letters approximately centred on the face of the plinth",{"_":31,"ana":32,"ref":33},{"lettering":264,"dimensions":265},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[266,267],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":269,"notBefore":136,"notAfter":182,"evidence":52,"precision":53},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[271,273],{"_":56,"type":57,"ref":58,"corresp":272},"#findspot",{"_":60,"type":61,"ref":62,"offset":63},[275],[66,67],[69,70],{"_":278,"role":279,"ref":280},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":79},{"_":81,"mainLang":82,"languages":283},[81],{"n":85,"url":285,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic004415_tiled.tif",[],[93,96],[98,101],[290,291,292,15,255,23,106,107,108,109,107,293,111,82],"isic004415","epitaph for krimma, child of aunakos",{"_":12},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":296,"ptr":297,"ref":298,"title":2,"citation":5,"uri":6},"107 no.5 and fig.6",{"target":116},{"_":118,"target":118},{"file":300,"uri":300,"title":301,"status":302,"editionAuthor":13,"type":303,"objectType":304,"material":305,"condition":26,"layoutDesc":306,"handNote":310,"date":316,"places":317,"geo":320,"provenance":56,"provenanceGeo":322,"country":71,"region":72,"settlement":60,"repository":323,"idno":324,"textLang":325,"tmNumber":26,"facsimile":327,"letterHeights":329,"publications":330,"zotero":331,"keywords":332,"html":336,"bibl":337},"ISic004416","Epitaph for Philon, son Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":255,"ana":256,"ref":257},{"_":23,"ana":24,"ref":25},{"layout":307},{"p":308,"rs":309,"damage":26},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":31,"ana":32,"ref":33},{"lettering":311,"dimensions":312},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[313,315],{"type":38,"l":39,"from":40,"to":40,"h":314,"unit":42},"59",