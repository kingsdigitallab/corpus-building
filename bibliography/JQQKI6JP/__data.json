04,"ptr":205,"ref":206,"title":2,"citation":4},"107 no.3 and fig.4",{"target":115},{"_":117,"target":117},{"file":208,"uri":208,"title":209,"status":210,"editionAuthor":11,"type":211,"objectType":212,"material":213,"condition":24,"layoutDesc":214,"handNote":217,"date":222,"places":223,"geo":226,"provenance":54,"provenanceGeo":228,"country":69,"region":70,"settlement":58,"repository":229,"idno":230,"textLang":232,"tmNumber":24,"facsimile":234,"letterHeights":236,"publications":237,"zotero":238,"keywords":239,"html":243,"bibl":244},"ISic004414","Epitaph for Eupolemos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":215},{"p":27,"rs":216,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":218,"dimensions":219},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[220,221],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":179,"notBefore":180,"notAfter":181,"evidence":50,"precision":51},[224,225],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[227],[64,65],[67,68],{"_":72,"role":73,"ref":74},{"_":231,"type":77},"ME23438",{"_":79,"mainLang":80,"languages":233},[79],{"n":83,"url":235,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004414_tiled.tif",[],[91,92,93,94],[96,97,98,99],[240,241,242,13,17,21,104,105,106,107,105,108,109,80],"isic004414","epitaph for eupolemos",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":245,"ptr":246,"ref":247,"title":2,"citation":4},"107 no.4 and fig.5",{"target":115},{"_":117,"target":117},{"file":249,"uri":249,"title":250,"status":251,"editionAuthor":11,"type":252,"objectType":253,"material":257,"condition":24,"layoutDesc":258,"handNote":262,"date":267,"places":269,"geo":273,"provenance":54,"provenanceGeo":275,"country":69,"region":70,"settlement":58,"repository":276,"idno":280,"textLang":281,"tmNumber":24,"facsimile":283,"letterHeights":285,"publications":286,"zotero":287,"keywords":288,"html":293,"bibl":294},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":254,"ana":255,"ref":256},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":21,"ana":22,"ref":23},{"layout":259},{"p":260,"rs":261,"damage":24},"Single line of greek letters approximately centred on the face of the plinth",{"_":29,"ana":30,"ref":31},{"lettering":263,"dimensions":264},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[265,266],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":268,"notBefore":135,"notAfter":181,"evidence":50,"precision":51},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[270,272],{"_":54,"type":55,"ref":56,"corresp":271},"#findspot",{"_":58,"type":59,"ref":60,"offset":61},[274],[64,65],[67,68],{"_":277,"role":278,"ref":279},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":77},{"_":79,"mainLang":80,"languages":282},[79],{"n":83,"url":284,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004415_tiled.tif",[],[91,94],[96,99],[289,290,291,13,254,21,104,105,106,107,105,292,109,80],"isic004415","epitaph for krimma, child of aunakos",{"_":10},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":295,"ptr":296,"ref":297,"title":2,"citation":4},"107 no.5 and fig.6",{"target":115},{"_":117,"target":117},{"file":299,"uri":299,"title":300,"status":301,"editionAuthor":11,"type":302,"objectType":303,"material":304,"condition":24,"layoutDesc":305,"handNote":309,"date":315,"places":316,"geo":319,"provenance":54,"provenanceGeo":321,"country":69,"region":70,"settlement":58,"repository":322,"idno":323,"textLang":324,"tmNumber":24,"facsimile":326,"letterHeights":328,"publications":329,"zotero":330,"keywords":331,"html":335,"bibl":336},"ISic004416","Epitaph for Philon, son Aunakos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":254,"ana":255,"ref":256},{"_":21,"ana":22,"ref":23},{"layout":306},{"p":307,"rs":308,"damage":24},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":29,"ana":30,"ref":31},{"lettering":310,"dimensions":311},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[312,314],{"type":36,"l":37,"from":38,"to":38,"h":313,"unit":40},"59",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":268,"notBefore":135,"notAfter":181,"evidence":50,"precision":51},[317,31