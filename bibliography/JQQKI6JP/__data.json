2,"citation":4},"107 no.2 and fig.3",{"target":112},{"_":114,"target":114},{"file":160,"uri":160,"title":161,"status":162,"editionAuthor":11,"type":163,"objectType":164,"material":165,"condition":24,"layoutDesc":166,"handNote":169,"date":174,"places":178,"geo":181,"country":66,"region":67,"settlement":58,"repository":183,"idno":184,"textLang":186,"facsimile":188,"provenance":54,"letterHeights":190,"publications":191,"zotero":192,"keywords":193,"html":197,"bibl":198},"ISic004413","Epitaph for Kallo",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":167},{"p":27,"rs":168,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":170,"dimensions":171},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[172,173],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":175,"notBefore":176,"notAfter":177,"evidence":50,"precision":51},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[179,180],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[182],[64,65],{"_":69,"role":70,"ref":71},{"_":185,"type":74},"ME23436",{"_":76,"mainLang":77,"languages":187},[76],{"n":80,"url":189,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004413_tiled.tif",[],[89,90,91],[94,95,96],[194,195,196,13,17,21,101,102,103,104,102,105,106,77],"isic004413","epitaph for kallo",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":199,"ptr":200,"ref":201,"title":2,"citation":4},"107 no.3 and fig.4",{"target":112},{"_":114,"target":114},{"file":203,"uri":203,"title":204,"status":205,"editionAuthor":11,"type":206,"objectType":207,"material":208,"condition":24,"layoutDesc":209,"handNote":212,"date":217,"places":218,"geo":221,"country":66,"region":67,"settlement":58,"repository":223,"idno":224,"textLang":226,"facsimile":228,"provenance":54,"letterHeights":230,"publications":231,"zotero":232,"keywords":233,"html":237,"bibl":238},"ISic004414","Epitaph for Eupolemos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":210},{"p":27,"rs":211,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":213,"dimensions":214},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[215,216],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":175,"notBefore":176,"notAfter":177,"evidence":50,"precision":51},[219,220],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[222],[64,65],{"_":69,"role":70,"ref":71},{"_":225,"type":74},"ME23438",{"_":76,"mainLang":77,"languages":227},[76],{"n":80,"url":229,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004414_tiled.tif",[],[88,89,90,91],[93,94,95,96],[234,235,236,13,17,21,101,102,103,104,102,105,106,77],"isic004414","epitaph for eupolemos",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":239,"ptr":240,"ref":241,"title":2,"citation":4},"107 no.4 and fig.5",{"target":112},{"_":114,"target":114},{"file":243,"uri":243,"title":244,"status":245,"editionAuthor":11,"type":246,"objectType":247,"material":251,"condition":24,"layoutDesc":252,"handNote":256,"date":261,"places":263,"geo":267,"country":66,"region":67,"settlement":58,"repository":269,"idno":273,"textLang":274,"facsimile":276,"provenance":54,"letterHeights":278,"publications":279,"zotero":280,"keywords":281,"html":286,"bibl":287},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":248,"ana":249,"ref":250},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":21,"ana":22,"ref":23},{"layout":253},{"p":254,"rs":255,"damage":24},"Single line of greek letters approximately centred on the face of the plinth",{"_":29,"ana":30,"ref":31},{"lettering":257,"dimensions":258},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[259,260],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":262,"notBefore":132,"notAfter":177,"evidence":50,"precision":51},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[264,266],{"_":54,"type":55,"ref":56,"corresp":265},"#findspot",{"_":58,"type":59,"ref":60,"offset":61},[268],[64,65],{"_":270,"role":271,"ref":272},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":74},{"_":76,"mainLang":77,"languages":275},[76],{"n":80,"url":277,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004415_tiled.tif",[],[88,91],[93,96],[282,283,284,13,248,21,101,102,103,104,102,285,106,77],"isic004415","epitaph for krimma, child of aunakos",{"_":10},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":288,"ptr":289,"ref":290,"title":2,"citation":4},"107 no.5 and fig.6",{"target":112},{"_":114,"target":114},{"file":292,"uri":292,"title":293,"status":294,"editionAuthor":11,"type":295,"objectType":296,"material":297,"condition":24,"layoutDesc":298,"handNote":302,"date":308,"places":309,"geo":312,"country":66,"region":67,"settlement":58,"repository":314,"idno":315,"textLang":316,"facsimile":318,"provenance":54,"letterHeights":320,"publications":321,"zotero":322,"keywords":323,"html":327,"bibl":328},"ISic004416","Epitaph for Philon, son Aunakos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":248,"ana":249,"ref":250},{"_":21,"ana":22,"ref":23},{"layout":299},{"p":300,"rs":301,"damage":24},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":29,"ana":30,"ref":31},{"lettering":303,"dimensions":304},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[305,307],{"type":36,"l":37,"from":38,"to":38,"h":306,"unit":40},"59",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":262,"notBefore":132,"notAfter":177,"evidence":50,"precision":51},[310,311],{"_":54,"type":55,"ref":56,"corresp":265},{"_":58,"type":59,"ref":60,"offset":61},[313],[64,65],{"_":270,"role":271,"ref":272},{"type":74},{"_":76,"mainLang":77,"languages":317},[76],{"n":80,"url":319,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004416_tiled.tif",[],[88,91],[93,96],[324,325,326,13,248,21,101,102,103,104,102,285,106,77],"isic004416","epitaph for philon, son aunakos",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":329,"ptr":330,"ref":331,"title":2,"citation":4},"107 no.6 and fig.7",{"target":112},{"_":114,"target":114},{"file":333,"uri":333,"title":334,"status":335,"editionAuthor":11,"type":336,"objectType":337,"material":338,"condition":24,"layoutDesc":339,"handNote":343,"date":349,"places":350,"geo":353,"country":66,"region":67,"settlement":58,"repository":355,"idno":356,"textLang":357,"facsimile":359,"provenance":54,"letterHeights":361,"publications":362,"zotero":363,"keywords":364,"html":368,"bibl":369},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":10},{"_":13,"ana":14,"ref":15},{"_":248,"ana":249,"ref":250},{"_":21,"ana":22,"ref":23},{"layout":340},{"p":341,"rs":342,"damage":24},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":29,"ana":30,"ref":31},{"lettering":344,"dimensions":345},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[346,348],{"type":36,"l":347,"from":38,"to":44,"h":39,"unit":40},"Line 1-2",{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":262,"notBefore":132,"notAfter":177,"evidence":50,"precision":51},[351,352],{"_":54,"type":55,"ref":56,"corresp":265},{"_":58,"type":59,"ref":60,"offset":61},[354],[64,65],{"_":270,"role":271,"ref":272},{"type":74},{"_":76,"mainLang":77,"languages":358},[76],{"n":80,"url":360,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004417_tiled.tif",[],[88,90,91],[93,95,96],[365,366,367,13,248,21,101,102,103,104,102,285,106,77],"isic004417","epitaph for [-?-], child of gerontios",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":370,"ptr":371,"ref":372,"title":2,"citation":4},"107 no.7 and fig.8",{"target":112},{"_":114,"target":114},{"file":374,"uri":374,"title":334,"status":375,"editionAuthor":11,"type":376,"objectType":377,"material":378,"condition":24,"layoutDesc":379,"handNote":383,"date":388,"places":390,"geo":393,"country":66,"region":67,"settlement":58,"repository":395,"idno":396,"textLang":397,"facsimile":399,"provenance":54,"letterHeights":401,"publications":402,"zotero":403,"keywords":404,"html":407,"bibl":408},"ISic004418",{"_":10},{"_":13,"ana":14,"ref":15},{"_":248,"ana":249,"ref":250},{"_":21,"ana":22,"ref":23},{"layout":380},{"p":381,"rs":382,"damage":24},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":29,"ana":30,"ref":31},{"lettering":384,"dimensions":385},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[386,387],{"type":36,"l":347,"from":38,"to":44,"h":306,"unit":40},{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":389,"notBefore":132,"notAfter":177,"evidence":50,"precision":51},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[391,392],{"_":54,"type":55,"ref":56,"corresp":265},{"_":58,"type":59,"ref":60,"offset":61},[394],[64,65],{"_":270,"role":271,"ref":272},{"type":74},{"_":76,"mainLang":77,"languages":398},[76],{"n":80,"url":400,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004418_tiled.tif",[],[88,90,91],[93,95,96],[405,366,406,13,248,21,101,102,103,104,102,285,106,77],"isic004418",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":409,"ptr":410,"ref":411,"title":2,"citation":4},"107 no.8 and fig.9",{"target":112},{"_":114,"target":114},{"file":413,"uri":413,"title":414,"status":415,"editionAuthor":11,"type":416,"objectType":417,"material":418,"condition":24,"layoutDesc":419,"handNote":423,"date":428,"places":429,"geo":432,"country":66,"region":67,"settlement":58,"repository":434,"idno":435,"textLang":436,"facsimile":438,"provenance":54,"letterHeights":440,"publications":441,"zotero":442,"keywords":443,"html":447,"bibl":448},"ISic004419","Epitaph for Aristarchos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":248,"ana":249,"ref":250},{"_":21,"ana":22,"ref":23},{"layout":420},{"p":421,"rs":422,"damage":24},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":29,"ana":30,"ref":31},{"lettering":424,"dimensions":425},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[426,427],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":389,"notBefore":132,"notAfter":177,"evidence":50,"precision":51},[430,431],{"_":54,"type":55,"ref":56,"corresp":265},{"_":58,"type":59,"ref":60,"offset":61},[433],[64,65],{"_":270,"role":271,"ref":272},{"type":74},{"_":76,"mainLang":77,"languages":437},[76],{"n":80,"url":439,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004419_tiled.tif",[],[91],[96],[444,445,446,13,248,21,101,102,103,104,102,285,106,77],"isic004419","epitaph for aristarchos",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":449,"ptr":450,"ref":451,"title":2,"citation":4},"108 no.9 and fig.10",{"target":112},{"_":114,"target":114},{"file":453,"uri":453,"title":454,"status":455,"editionAuthor":11,"type":456,"objectType":457,"material":458,"condition":24,"layoutDesc":459,"handNote":463,"date":469,"places":470,"geo":473,"country":66,"region":67,"settlement":58,"repository":475,"idno":476,"textLang":477,"facsimile":479,"provenance":54,"letterHeights":481,"publications":482,"zotero":483,"keywords":484,"html":488,"bibl":489},"ISic004420","Epitaph for Aristokrates",{"_":10},{"_":13,"ana":14,"ref":15},{"_":248,"ana":249,"ref":250},{"_":21,"ana":22,"ref":23},{"layout":460},{"p":461,"rs":462,"damage":24},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":29,"ana":30,"ref":31},{"lettering":464,"dimensions":465},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[466,468],{"type":36,"l":347,"from":38,"to":44,"h":467,"unit":40},"49",{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":389,"notBefore":132,"notAfter":177,"evidence":50,"precision":51},[471,472],{"_":54,"type":55,"ref":56,"corresp":265},{"_":58,"type":59,"ref":60,"offset":61},[474],[64,65],{"_":270,"role":271,"ref":272},{"type":74},{"_":76,"mainLang":77,"languages":478},[76],{"n":80,"url":480,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004420_tiled.tif",[],[91],[96],[485,486,487,13,248,21,101,102,103,104,102,285,106,77],"isic004420","epitaph for aristokrates",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":490,"ptr":491,"ref":492,"title":2,"citation":4},"108 no.10 and fig.11",{"target":112},{"_":114,"target":114},{"file":494,"uri":494,"title":495,"status":496,"editionAuthor":11,"type":497,"objectType":498,"material":499,"condition":24,"layoutDesc":500,"handNote":504,"date":510,"places":512,"geo":515,"country":66,"region":67,"settlement":58,"repository":517,"idno":518,"textLang":519,"facsimile":521,"provenance":54,"letterHeights":523,"publications":524,"zotero":525,"keywords":526,"html":530,"bibl":531},"ISic004421","Epitaph for Athanippos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":248,"ana":249,"ref":250},{"_":21,"ana":22,"ref":23},{"layout":501},{"p":502,"rs":503,"damage":24},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":29,"ana":30,"ref":31},{"lettering":505,"dimensions":506},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[507,509],{"type":36,"l":37,"from":38,"to":38,"h":508,"unit":40},"29",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":511,"notBefore":132,"notAfter":177,"evidence":50,"precision":51},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[513,514],{"_":54,"type":55,"ref":56,"corresp":265},{"_":58,"type":59,"ref":60,"offset":61},[516],[64,65],{"_":270,"role":271,"ref":272},{"type":74},{"_":76,"mainLang":77,"languages":520},[76],{"n":80,"url":522,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004421_tiled.tif",[],[91],[96],[527,528,529,13,248,21,101,102,103,104,102,285,106,77],"isic004421","epitaph for athanippos",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":532,"ptr":533,"ref":534,"title":2,"citation":4},"108 no.11 and fig.12",{"target":112},{"_":114,"target":114},{"file":536,"uri":536,"title":537,"status":538,"editionAuthor":11,"type":539,"objectType":540,"material":541,"condition":24,"layoutDesc":542,"handNote":546,"date":551,"places":553,"geo":556,"country":66,"region":67,"settlement":58,"repository":558,"idno":559,"textLang":561,"facsimile":563,"provenance":54,"letterHeights":565,"publications":566,"zotero":567,"keywords":568,"html":572,"bibl":573},"ISic004422","Epitaph for Artemidoros (?)",{"_":10},{"_":13,"ana":14,"ref":15},{"_":248,"ana":249,"ref":250},{"_":21,"ana":22,"ref":23},{"layout":543},{"p":544,"rs":545,"damage":24},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":29,"ana":30,"ref":31},{"lettering":547,"dimensions":548},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[549,550],{"type":36,"l":37,"from":38,"to":38,"h":508,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":552,"notBefore":132,"notAfter":177,"evidence":50,"precision":51},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[554,555],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[557],[64,65],{"_":69,"role":70,"ref":71},{"_":560,"type":74},"ME23440",{"_":76,"mainLang":77,"languages":562},[76],{"n":80,"url":564,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004422_tiled.tif",[],[90,91],[95,96],[569,570,571,13,248,21,101,102,103,104,102,105,106,77],"isic004422","epitaph for artemidoros (?)",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":109,"date":3,"citedRange":574,"ptr":575,"ref":576,"title":2,"citation":4},"108 no.12 and fig.13",{"target":112},{"_":114,"target":114}],"uses":{"params":["slug"]}}]}
