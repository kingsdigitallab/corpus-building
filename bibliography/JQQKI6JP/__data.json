},{"_":183,"notBefore":184,"notAfter":185,"evidence":52},[229,230],{"_":55,"type":56,"ref":57,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[232],[66,67],[69,70],{"_":73,"role":74,"ref":75},{"_":236,"type":78},"ME23438",{"_":80,"mainLang":81,"languages":238},[80],{"n":84,"url":240,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004414_tiled.tif",[242],{"atLeast":92,"atMost":92},[94,95,96,97],[99,100,101,102],[246,247,248,15,19,23,107,108,109,110,108,111,112,81],"isic004414","epitaph for eupolemos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":251,"ptr":252,"ref":253,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"107 no.4 and fig.5",{"target":117},{"_":119,"target":119},{"file":255,"uri":255,"title":256,"status":257,"editionAuthor":13,"type":258,"objectType":259,"material":263,"condition":26,"layoutDesc":264,"handNote":268,"date":273,"places":275,"geo":279,"country":58,"provenance":55,"provenanceGeo":281,"region":71,"settlement":60,"repository":282,"idno":286,"textLang":287,"tmNumber":26,"facsimile":289,"letterHeights":291,"publications":293,"zotero":294,"keywords":295,"html":300,"bibl":301,"bulletinDateSort":120,"citedRangeSort":302,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":260,"ana":261,"ref":262},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":23,"ana":24,"ref":25},{"layout":265},{"p":266,"rs":267,"damage":26},"Single line of greek letters approximately centred on the face of the plinth",{"_":31,"ana":32,"ref":33},{"lettering":269,"dimensions":270},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[271,272],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42,"atLeast":41,"atMost":41},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":274,"notBefore":138,"notAfter":185,"evidence":52},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[276,278],{"_":55,"type":56,"ref":57,"corresp":277,"region":58},"#findspot",{"_":60,"type":61,"ref":62,"offset":63,"region":58},[280],[66,67],[69,70],{"_":283,"role":284,"ref":285},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":78},{"_":80,"mainLang":81,"languages":288},[80],{"n":84,"url":290,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004415_tiled.tif",[292],{"atLeast":92,"atMost":92},[94,97],[99,102],[296,297,298,15,260,23,107,108,109,110,108,299,112,81],"isic004415","epitaph for krimma, child of aunakos",{"_":12},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":302,"ptr":303,"ref":304,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"107 no.5 and fig.6",{"target":117},{"_":119,"target":119},{"file":306,"uri":306,"title":307,"status":308,"editionAuthor":13,"type":309,"objectType":310,"material":311,"condition":26,"layoutDesc":312,"handNote":316,"date":322,"places":323,"geo":326,"country":58,"provenance":55,"provenanceGeo":328,"region":71,"settlement":60,"repository":329,"idno":330,"textLang":331,"tmNumber":26,"facsimile":333,"letterHeights":335,"publications":338,"zotero":339,"keywords":340,"html":344,"bibl":345,"bulletinDateSort":120,"citedRangeSort":346,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004416","Epitaph for Philon, son Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":260,"ana":261,"ref":262},{"_":23,"ana":24,"ref":25},{"layout":313},{"p":314,"rs":315,"damage":26},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":31,"ana":32,"ref":33},{"lettering":317,"dimensions":318},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[319,321],{"type":38,"l":39,"from":40,"to":40,"h":320,"unit":42,"atLeast":320,"atMost":320},"59",{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":274,"notBefore":138,"notAfter":185,"evidence":52},[324,325],{"_":55,"type":56,"ref":57,"corresp":277,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[327],[66,67],[69,70],{"_":283,"role":284,"ref":285},{"type":78},{"_":80,"mainLang":81,"languages":332},[80],{"n":84,"url":334,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004416_tiled.tif",[336],{"atLeast":337,"atMost":337},59,[94,97],[99,102],[341,342,343,15,260,23,107,108,109,110,108,299,112,81],"isic004416","epitaph for philon, son aunakos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":346,"ptr":347,"ref":348,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"107 no.6 and fig.7",{"target":117},{"_":119,"target":119},{"file":350,"uri":350,"title":351,"status":352,"editionAuthor":13,"type":353,"objectType":354,"material":355,"condition":26,"layoutDesc":356,"handNote":360,"date":366,"places":367,"geo":370,"country":58,"provenance":55,"provenanceGeo":372,"region":71,"settlement":60,"repository":373,"idno":374,"textLang":375,"tmNumber":26,"facsimile":377,"letterHeights":379,"publications":381,"zotero":382,"keywords":383,"html":387,"bibl":388,"bulletinDateSort":120,"citedRangeSort":389,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":12},{"_":15,"ana":16,"ref":17},{"_":260,"ana":261,"ref":262},{"_":23,"ana":24,"ref":25},{"layout":357},{"p":358,"rs":359,"damage":26},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":31,"ana":32,"ref":33},{"lettering":361,"dimensions":362},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[363,365],{"type":38,"l":364,"from":40,"to":46,"h":41,"unit":42,"atLeast":41,"atMost":41},"Line 1-2",{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":274,"notBefore":138,"notAfter":185,"evidence":52},[368,369],{"_":55,"type":56,"ref":57,"corresp":277,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[371],[66,67],[69,70],{"_":283,"role":284,"ref":285},{"type":78},{"_":80,"mainLang":81,"languages":376},[80],{"n":84,"url":378,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004417_tiled.tif",[380],{"atLeast":92,"atMost":92},[94,96,97],[99,101,102],[384,385,386,15,260,23,107,108,109,110,108,299,112,81],"isic004417","epitaph for [-?-], child of gerontios",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":389,"ptr":390,"ref":391,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"107 no.7 and fig.8",{"target":117},{"_":119,"target":119},{"file":393,"uri":393,"title":351,"status":394,"editionAuthor":13,"type":395,"objectType":396,"material":397,"condition":26,"layoutDesc":398,"handNote":402,"date":407,"places":409,"geo":412,"country":58,"provenance":55,"provenanceGeo":414,"region":71,"settlement":60,"repository":415,"idno":416,"textLang":417,"tmNumber":26,"facsimile":419,"letterHeights":421,"publications":423,"zotero":424,"keywords":425,"html":428,"bibl":429,"bulletinDateSort":120,"citedRangeSort":430,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004418",{"_":12},{"_":15,"ana":16,"ref":17},{"_":260,"ana":261,"ref":262},{"_":23,"ana":24,"ref":25},{"layout":399},{"p":400,"rs":401,"damage":26},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":403,"dimensions":404},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[405,406],{"type":38,"l":364,"from":40,"to":46,"h":320,"unit":42,"atLeast":320,"atMost":320},{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":408,"notBefore":138,"notAfter":185,"evidence":52},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[410,411],{"_":55,"type":56,"ref":57,"corresp":277,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[413],[66,67],[69,70],{"_":283,"role":284,"ref":285},{"type":78},{"_":80,"mainLang":81,"languages":418},[80],{"n":84,"url":420,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004418_tiled.tif",[422],{"atLeast":337,"atMost":337},[94,96,97],[99,101,102],[426,385,427,15,260,23,107,108,109,110,108,299,112,81],"isic004418",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":430,"ptr":431,"ref":432,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"107 no.8 and fig.9",{"target":117},{"_":119,"target":119},{"file":434,"uri":434,"title":435,"status":436,"editionAuthor":13,"type":437,"objectType":438,"material":439,"condition":26,"layoutDesc":440,"handNote":444,"date":449,"places":450,"geo":453,"country":58,"provenance":55,"provenanceGeo":455,"region":71,"settlement":60,"repository":456,"idno":457,"textLang":458,"tmNumber":26,"facsimile":460,"letterHeights":462,"publications":464,"zotero":465,"keywords":466,"html":470,"bibl":471,"bulletinDateSort":120,"citedRangeSort":472,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004419","Epitaph for Aristarchos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":260,"ana":261,"ref":262},{"_":23,"ana":24,"ref":25},{"layout":441},{"p":442,"rs":443,"damage":26},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":31,"ana":32,"ref":33},{"lettering":445,"dimensions":446},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[447,448],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42,"atLeast":41,"atMost":41},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":408,"notBefore":138,"notAfter":185,"evidence":52},[451,452],{"_":55,"type":56,"ref":57,"corresp":277,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[454],[66,67],[69,70],{"_":283,"role":284,"ref":285},{"type":78},{"_":80,"mainLang":81,"languages":459},[80],{"n":84,"url":461,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004419_tiled.tif",[463],{"atLeast":92,"atMost":92},[97],[102],[467,468,469,15,260,23,107,108,109,110,108,299,112,81],"isic004419","epitaph for aristarchos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":472,"ptr":473,"ref":474,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"108 no.9 and fig.10",{"target":117},{"_":119,"target":119},{"file":476,"uri":476,"title":477,"status":478,"editionAuthor":13,"type":479,"objectType":480,"material":481,"condition":26,"layoutDesc":482,"handNote":486,"date":492,"places":493,"geo":496,"country":58,"provenance":55,"provenanceGeo":498,"region":71,"settlement":60,"repository":499,"idno":500,"textLang":501,"tmNumber":26,"facsimile":503,"letterHeights":505,"publications":508,"zotero":509,"keywords":510,"html":514,"bibl":515,"bulletinDateSort":120,"citedRangeSort":516,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004420","Epitaph for Aristokrates",{"_":12},{"_":15,"ana":16,"ref":17},{"_":260,"ana":261,"ref":262},{"_":23,"ana":24,"ref":25},{"layout":483},{"p":484,"rs":485,"damage":26},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":31,"ana":32,"ref":33},{"lettering":487,"dimensions":488},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[489,491],{"type":38,"l":364,"from":40,"to":46,"h":490,"unit":42,"atLeast":490,"atMost":490},"49",{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":408,"notBefore":138,"notAfter":185,"evidence":52},[494,495],{"_":55,"type":56,"ref":57,"corresp":277,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[497],[66,67],[69,70],{"_":283,"role":284,"ref":285},{"type":78},{"_":80,"mainLang":81,"languages":502},[80],{"n":84,"url":504,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004420_tiled.tif",[506],{"atLeast":507,"atMost":507},49,[97],[102],[511,512,513,15,260,23,107,108,109,110,108,299,112,81],"isic004420","epitaph for aristokrates",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":516,"ptr":517,"ref":518,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"108 no.10 and fig.11",{"target":117},{"_":119,"target":119},{"file":520,"uri":520,"title":521,"status":522,"editionAuthor":13,"type":523,"objectType":524,"material":525,"condition":26,"layoutDesc":526,"handNote":530,"date":536,"places":538,"geo":541,"country":58,"provenance":55,"provenanceGeo":543,"region":71,"settlement":60,"repository":544,"idno":545,"textLang":546,"tmNumber":26,"facsimile":548,"letterHeights":550,"publications":553,"zotero":554,"keywords":555,"html":559,"bibl":560,"bulletinDateSort":120,"citedRangeSort":561,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004421","Epitaph for Athanippos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":260,"ana":261,"ref":262},{"_":23,"ana":24,"ref":25},{"layout":527},{"p":528,"rs":529,"damage":26},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":31,"ana":32,"ref":33},{"lettering":531,"dimensions":532},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[533,535],{"type":38,"l":39,"from":40,"to":40,"h":534,"unit":42,"atLeast":534,"atMost":534},"29",{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":537,"notBefore":138,"notAfter":185,"evidence":52},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[539,540],{"_":55,"type":56,"ref":57,"corresp":277,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[542],[66,67],[69,70],{"_":283,"role":284,"ref":285},{"type":78},{"_":80,"mainLang":81,"languages":547},[80],{"n":84,"url":549,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004421_tiled.tif",[551],{"atLeast":552,"atMost":552},29,[97],[102],[556,557,558,15,260,23,107,108,109,110,108,299,112,81],"isic004421","epitaph for athanippos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":561,"ptr":562,"ref":563,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"108 no.11 and fig.12",{"target":117},{"_":119,"target":119},{"file":565,"uri":565,"title":566,"status":567,"editionAuthor":13,"type":568,"objectType":569,"material":570,"condition":26,"layoutDesc":571,"handNote":575,"date":580,"places":582,"geo":585,"country":58,"provenance":55,"provenanceGeo":587,"region":71,"settlement":60,"repository":588,"idno":589,"textLang":591,"tmNumber":26,"facsimile":593,"letterHeights":595,"publications":597,"zotero":598,"keywords":599,"html":603,"bibl":604,"bulletinDateSort":120,"citedRangeSort":605,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":12},{"_":15,"ana":16,"ref":17},{"_":260,"ana":261,"ref":262},{"_":23,"ana":24,"ref":25},{"layout":572},{"p":573,"rs":574,"damage":26},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":576,"dimensions":577},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[578,579],{"type":38,"l":39,"from":40,"to":40,"h":534,"unit":42,"atLeast":534,"atMost":534},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":581,"notBefore":138,"notAfter":185,"evidence":52},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[583,584],{"_":55,"type":56,"ref":57,"region":58},{"_":60,"type":61,"ref":62,"offset":63,"region":58},[586],[66,67],[69,70],{"_":73,"role":74,"ref":75},{"_":590,"type":78},"ME23440",{"_":80,"mainLang":81,"languages":592},[80],{"n":84,"url":594,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004422_tiled.tif",[596],{"atLeast":552,"atMost":552},[96,97],[101,102],[600,601,602,15,260,23,107,108,109,110,108,111,112,81],"isic004422","epitaph for artemidoros (?)",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":605,"ptr":606,"ref":607,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"108 no.12 and fig.13",{"target":117},{"_":119,"target":119},false],"uses":{"params":["slug"]}}]}
