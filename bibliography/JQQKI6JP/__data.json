an two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[39,45],{"type":40,"l":41,"from":42,"to":42,"h":43,"unit":44,"atLeast":43,"atMost":43},"letterHeight","Line 1","line1","30","mm",{"type":46,"l":47,"from":42,"to":48,"h":49,"unit":44},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":51,"notBefore":52,"notAfter":53,"evidence":54},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context",[56,61],{"_":57,"type":58,"ref":59,"region":60},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062","Sicilia",{"_":62,"type":63,"ref":64,"offset":65,"region":60},"Tripi","modern","http://sws.geonames.org/2522853","near",[67],[68,69],38.05191,15.10158,[71,72],38.06519,15.11438,"Sicily",{"_":75,"role":76,"ref":77},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":79,"type":80},"ME23435","inventory",{"_":82,"mainLang":83,"languages":84},"Ancient Greek","grc",[82],{"n":86,"url":87,"height":88,"width":89,"desc":90,"surfaceType":91},"screen","ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[93],{"atLeast":94,"atMost":94},30,[96,97,98,99],"Bacci, Coppolino, 2009, La Necropoli di Abakainon: primi dati","Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2015, Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[101,102,103,104],"DX8AWC9Q","ILQ4RQGU","9QTE4E3Z","JQQKI6JP",[106,107,108,15,19,23,109,110,111,112,110,113,114,83],"isic004411","epitaph for kratisstos",{"_":12},"abacaenum","tripi","sicilia","sicily","museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\