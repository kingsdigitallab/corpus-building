r":181,"evidence":50,"precision":51},[359,360],{"_":54,"type":55,"ref":56,"corresp":271},{"_":58,"type":59,"ref":60,"offset":61},[362],[64,65],[67,68],{"_":277,"role":278,"ref":279},{"type":77},{"_":79,"mainLang":80,"languages":367},[79],{"n":83,"url":369,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004417_tiled.tif",[],[91,93,94],[96,98,99],[374,375,376,13,254,21,104,105,106,107,105,292,109,80],"isic004417","epitaph for [-?-], child of gerontios",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":379,"ptr":380,"ref":381,"title":2,"citation":4},"107 no.7 and fig.8",{"target":115},{"_":117,"target":117},{"file":383,"uri":383,"title":342,"status":384,"editionAuthor":11,"type":385,"objectType":386,"material":387,"condition":24,"layoutDesc":388,"handNote":392,"date":397,"places":399,"geo":402,"provenance":54,"provenanceGeo":404,"country":69,"region":70,"settlement":58,"repository":405,"idno":406,"textLang":407,"tmNumber":24,"facsimile":409,"letterHeights":411,"publications":412,"zotero":413,"keywords":414,"html":417,"bibl":418},"ISic004418",{"_":10},{"_":13,"ana":14,"ref":15},{"_":254,"ana":255,"ref":256},{"_":21,"ana":22,"ref":23},{"layout":389},{"p":390,"rs":391,"damage":24},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":29,"ana":30,"ref":31},{"lettering":393,"dimensions":394},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[395,396],{"type":36,"l":355,"from":38,"to":44,"h":313,"unit":40},{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":398,"notBefore":135,"notAfter":181,"evidence":50,"precision":51},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[400,401],{"_":54,"type":55,"ref":56,"corresp":271},{"_":58,"type":59,"ref":60,"offset":61},[403],[64,65],[67,68],{"_":277,"role":278,"ref":279},{"type":77},{"_":79,"mainLang":80,"languages":408},[79],{"n":83,"url":410,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004418_tiled.tif",[],[91,93,94],[96,98,99],[415,375,416,13,254,21,104,105,106,107,105,292,109,80],"isic004418",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":419,"ptr":420,"ref":421,"title":2,"citation":4},"107 no.8 and fig.9",{"target":115},{"_":117,"target":117},{"file":423,"uri":423,"title":424,"status":425,"editionAuthor":11,"type":426,"objectType":427,"material":428,"condition":24,"layoutDesc":429,"handNote":433,"date":438,"places":439,"geo":442,"provenance":54,"provenanceGeo":444,"country":69,"region":70,"settlement":58,"repository":445,"idno":446,"textLang":447,"tmNumber":24,"facsimile":449,"letterHeights":451,"publications":452,"zotero":453,"keywords":454,"html":458,"bibl":459},"ISic004419","Epitaph for Aristarchos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":254,"ana":255,"ref":256},{"_":21,"ana":22,"ref":23},{"layout":430},{"p":431,"rs":432,"damage":24},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":29,"ana":30,"ref":31},{"lettering":434,"dimensions":435},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[436,437],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":398,"notBefore":135,"notAfter":181,"evidence":50,"precision":51},[440,441],{"_":54,"type":55,"ref":56,"corresp":271},{"_":58,"type":59,"ref":60,"offset":61},[443],[64,65],[67,68],{"_":277,"role":278,"ref":279},{"type":77},{"_":79,"mainLang":80,"languages":448},[79],{"n":83,"url":450,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004419_tiled.tif",[],[94],[99],[455,456,457,13,254,21,104,105,106,107,105,292,109,80],"isic004419","epitaph for aristarchos",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":460,"ptr":461,"ref":462,"title":2,"citation":4},"108 no.9 and fig.10",{"target":115},{"_":117,"target":117},{"file":464,"uri":464,"title":465,"status":466,"editionAuthor":11,"type":467,"objectType":468,"material":469,"condition":24,"layoutDesc":470,"handNote":474,"date":480,"places":481,"geo":484,"provenance":54,"provenanceGeo":486,"country":69,"region":70,"settlement":58,"repository":487,"idno":488,"textLang":489,"tmNumber":24,"facsimile":491,"letterHeights":493,"publications":494,"zotero":495,"keywords":496,"html":500,"bibl":501},"ISic004420","Epitaph for Aristokrates",{"_":10},{"_":13,"ana":14,"ref":15},{"_":254,"ana":255,"ref":256},{"_":21,"ana":22,"ref":23},{"layout":471},{"p":472,"rs":473,"damage":24},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":29,"ana":30,"ref":31},{"lettering":475,"dimensions":476},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[477,479],{"type":36,"l":355,"from":38,"to":44,"h":478,"unit":40},"49",{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":398,"notBefore":135,"notAfter":181,"evidence":50,"precision":51},[482,483],{"_":54,"type":55,"ref":56,"corresp":271},{"_":58,"type":59,"ref":60,"offset":61},[485],[64,65],[67,68],{"_":277,"role":278,"ref":279},{"type":77},{"_":79,"mainLang":80,"languages":490},[79],{"n":83,"url":492,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004420_tiled.tif",[],[94],[99],[497,498,499,13,254,21,104,105,106,107,105,292,109,80],"isic004420","epitaph for aristokrates",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":502,"ptr":503,"ref":504,"title":2,"citation":4},"108 no.10 and fig.11",{"target":115},{"_":117,"target":117},{"file":506,"uri":506,"title":507,"status":508,"editionAuthor":11,"type":509,"objectType":510,"material":511,"condition":24,"layoutDesc":512,"handNote":516,"date":522,"places":524,"geo":527,"provenance":54,"provenanceGeo":529,"country":69,"region":70,"settlement":58,"repository":530,"idno":531,"textLang":532,"tmNumber":24,"facsimile":534,"letterHeights":536,"publications":537,"zotero":538,"keywords":539,"html":543,"bibl":544},"ISic004421","Epitaph for Athanippos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":254,"ana":255,"ref":256},{"_":21,"ana":22,"ref":23},{"layout":513},{"p":514,"rs":515,"damage":24},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":29,"ana":30,"ref":31},{"lettering":517,"dimensions":518},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[519,521],{"type":36,"l":37,"from":38,"to":38,"h":520,"unit":40},"29",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":523,"notBefore":135,"notAfter":181,"evidence":50,"precision":51},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[525,526],{"_":54,"type":55,"ref":56,"corresp":271},{"_":58,"type":59,"ref":60,"offset":61},[528],[64,65],[67,68],{"_":277,"role":278,"ref":279},{"type":77},{"_":79,"mainLang":80,"languages":533},[79],{"n":83,"url":535,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004421_tiled.tif",[],[94],[99],[540,541,542,13,254,21,104,105,106,107,105,292,109,80],"isic004421","epitaph for athanippos",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":545,"ptr":546,"ref":547,"title":2,"citation":4},"108 no.11 and fig.12",{"target":115},{"_":117,"target":117},{"file":549,"uri":549,"title":550,"status":551,"editionAuthor":11,"type":552,"objectType":553,"material":554,"condition":24,"layoutDesc":555,"handNote":559,"date":564,"places":566,"geo":569,"provenance":54,"provenanceGeo":571,"country":69,"region":70,"settlement":58,"repository":572,"idno":573,"textLang":575,"tmNumber":24,"facsimile":577,"letterHeights":579,"publications":580,"zotero":581,"keywords":582,"html":586,"bibl":587},"ISic004422","Epitaph for Artemidoros (?)",{"_":10},{"_":13,"ana":14,"ref":15},{"_":254,"ana":255,"ref":256},{"_":21,"ana":22,"ref":23},{"layout":556},{"p":557,"rs":558,"damage":24},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":29,"ana":30,"ref":31},{"lettering":560,"dimensions":561},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[562,563],{"type":36,"l":37,"from":38,"to":38,"h":520,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":565,"notBefore":135,"notAfter":181,"evidence":50,"precision":51},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[567,568],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[570],[64,65],[67,68],{"_":72,"role":73,"ref":74},{"_":574,"type":77},"ME23440",{"_":79,"mainLang":80,"languages":576},[79],{"n":83,"url":578,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004422_tiled.tif",[],[93,94],[98,99],[583,584,585,13,254,21,104,105,106,107,105,108,109,80],"isic004422","epitaph for artemidoros (?)",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":588,"ptr":589,"ref":590,"title":2,"citation":4},"108 no.12 and fig.13",{"target":115},{"_":117,"target":117}],"uses":{"params":["slug"]}}]}
