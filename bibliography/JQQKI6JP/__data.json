107 no.3 and fig.4",{"target":114},{"_":116,"target":116},{"file":207,"uri":207,"title":208,"status":209,"editionAuthor":12,"type":210,"objectType":211,"material":212,"condition":3,"layoutDesc":213,"handNote":216,"date":221,"places":222,"geo":225,"provenance":54,"provenanceGeo":227,"country":69,"region":70,"settlement":58,"repository":228,"idno":229,"textLang":231,"tmNumber":3,"facsimile":233,"letterHeights":235,"publications":236,"zotero":237,"keywords":238,"html":242,"bibl":243},"ISic004414","Epitaph for Eupolemos",{"_":11},{"_":14,"ana":15,"ref":16},{"_":18,"ana":19,"ref":20},{"_":22,"ana":23,"ref":24},{"layout":214},{"p":27,"rs":215,"damage":3},{"_":29,"ana":30,"ref":31},{"lettering":217,"dimensions":218},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[219,220],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":178,"notBefore":179,"notAfter":180,"evidence":50,"precision":51},[223,224],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[226],[64,65],[67,68],{"_":72,"role":73,"ref":74},{"_":230,"type":77},"ME23438",{"_":79,"mainLang":80,"languages":232},[79],{"n":83,"url":234,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004414_tiled.tif",[],[91,92,93,94],[96,97,98,99],[239,240,241,14,18,22,104,105,106,107,105,108,109,80],"isic004414","epitaph for eupolemos",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":244,"ptr":245,"ref":246,"title":2,"citation":5},"107 no.4 and fig.5",{"target":114},{"_":116,"target":116},{"file":248,"uri":248,"title":249,"status":250,"editionAuthor":12,"type":251,"objectType":252,"material":256,"condition":3,"layoutDesc":257,"handNote":261,"date":266,"places":268,"geo":272,"provenance":54,"provenanceGeo":274,"country":69,"region":70,"settlement":58,"repository":275,"idno":279,"textLang":280,"tmNumber":3,"facsimile":282,"letterHeights":284,"publications":285,"zotero":286,"keywords":287,"html":292,"bibl":293},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":11},{"_":14,"ana":15,"ref":16},{"_":253,"ana":254,"ref":255},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":22,"ana":23,"ref":24},{"layout":258},{"p":259,"rs":260,"damage":3},"Single line of greek letters approximately centred on the face of the plinth",{"_":29,"ana":30,"ref":31},{"lettering":262,"dimensions":263},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[264,265],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":267,"notBefore":134,"notAfter":180,"evidence":50,"precision":51},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[269,271],{"_":54,"type":55,"ref":56,"corresp":270},"#findspot",{"_":58,"type":59,"ref":60,"offset":61},[273],[64,65],[67,68],{"_":276,"role":277,"ref":278},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":77},{"_":79,"mainLang":80,"languages":281},[79],{"n":83,"url":283,"height":85,"width":86,"desc":87,"surfaceType":88},"ISic004415_tiled.tif",[],[91,94],[96,99],[288,289,290,14,253,22,104,105,106,107,105,291,109,80],"isic004415","epitaph for krimma, child of aunakos",{"_":11},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":294,"ptr":295,"ref":296,"title":2,"citation":5},"107 no.5 and fig.6",{"target":114},{"_":116,"target":116},{"file":298,"uri":298,"title":299,"status":300,"editionAuthor":12,"type":301,"objectType":302,"material":303,"condition":3,"layoutDesc":304,"handNote":308,"date":314,"places":315,"geo":318,"provenance":54,"provenanceGeo":320,"country":69,"region":70,"settlement":58,"repository":321,"idno":322,"textLang":323,"tmNumber":3,"facsimile":325,"letterHeights":327,"publications":328,"zotero":329,"keywords":330,"html":334,"bibl":335},"ISic004416","Epitaph for Philon, son Aunakos",{"_":11},{"_":14,"ana":15,"ref":16},{"_":253,"ana":254,"ref":255},{"_":22,"ana":23,"ref":24},{"layout":305},{"p":306,"rs":307,"damage":3},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":29,"ana":30,"ref":31},{"lettering":309,"dimensions":310},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[311,313],{"type":36,"l":37,"from":38,"to":38,"h":312,"unit":40},"59",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":267,"notBefore":134,"notAfter":180,"evidence":50,"precision":51},[316,317],{"_":54,"type":55,"ref":56,"corresp":270},{"_":58,"type":5