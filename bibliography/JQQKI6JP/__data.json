{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":5},{"title":2,"date":3,"citation":4},"Nuove iscrizioni funerarie dalla necropoli di Abakainon","2018","\u003Cspan>Girolamo Sofia, «Nuove iscrizioni funerarie dalla necropoli di Abakainon», \u003Ci>Zeitschrift für Papyrologie und Epigraphik\u003C/i> 206 (2018): 103–12\u003C/span>",[6,108,148,186,221,265,301,337,371,406,442,479],{"file":7,"uri":7,"title":8,"status":9,"editionAuthor":11,"type":12,"objectType":16,"material":20,"condition":24,"layoutDesc":25,"handNote":32,"date":46,"places":52,"geo":62,"country":66,"region":67,"settlement":58,"repository":68,"idno":72,"textLang":75,"facsimile":79,"provenance":54,"letterHeights":86,"publications":87,"zotero":92,"keywords":97,"html":107},"ISic004411","Epitaph for Kratisstos",{"_":10},"edited",null,{"_":13,"ana":14,"ref":15},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":17,"ana":18,"ref":19},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":21,"ana":22,"ref":23},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html","",{"layout":26},{"p":27,"rs":28,"damage":24},"Single line of Greek letters filling the width of the stone",{"_":29,"ana":30,"ref":31},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":33,"dimensions":34},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[35,41],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},"letterHeight","Line 1","line1","30","mm",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":47,"notBefore":48,"notAfter":49,"evidence":50,"precision":51},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context","low",[53,57],{"_":54,"type":55,"ref":56},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062",{"_":58,"type":59,"ref":60,"offset":61},"Tripi","modern","http://sws.geonames.org/2522853","near",[63],[64,65],38.05191,15.10158,"Italy","Sicily",{"_":69,"role":70,"ref":71},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":73,"type":74},"ME23435","inventory",{"_":76,"mainLang":77,"languages":78},"Ancient Greek","grc",[76],{"n":80,"url":81,"height":82,"width":83,"desc":84,"surfaceType":85},"screen","ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[88,89,90,91],"Bacci and Coppolino, 2009, La Necropoli di Abakainon: primi dati","Bacci et al., 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2015, Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[93,94,95,96],"DX8AWC9Q","ILQ4RQGU","9QTE4E3Z","JQQKI6JP",[98,99,100,13,17,21,101,102,103,104,102,105,106,77],"isic004411","epitaph for kratisstos",{"_":10},"abacaenum","tripi","italy","sicily","museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"file":109,"uri":109,"title":110,"status":111,"editionAuthor":11,"type":112,"objectType":113,"material":114,"condition":24,"layoutDesc":115,"handNote":118,"date":123,"places":128,"geo":131,"country":66,"region":67,"settlement":58,"repository":133,"idno":134,"textLang":136,"facsimile":138,"provenance":54,"letterHeights":140,"publications":141,"zotero":142,"keywords":143,"html":147},"ISic004412","Epitaph for Aristoboula",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":116},{"p":27,"rs":117,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":119,"dimensions":120},"Slightly irregular letters, becoming slightly more compressed to the right hand end: Alpha broad with broken bar; rho has small closed eye; sigma is four equal bars, angled apart; omicron is small and mid-line; beta has equal closed eyes, with slight gap between them; upsilon asymmetrical.",[121,122],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":124,"notBefore":125,"notAfter":126,"evidence":127,"precision":51},"Letter forms suggest a date in the 4th or earlier 3rd century BCE",-350,-251,"lettering",[129,130],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[132],[64,65],{"_":69,"role":70,"ref":71},{"_":135,"type":74},"ME23439",{"_":76,"mainLang":77,"languages":137},[76],{"n":80,"url":139,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004412_tiled.tif",[],[89,90,91],[94,95,96],[144,145,146,13,17,21,101,102,103,104,102,105,106,77],"isic004412","epitaph for aristoboula",{"_":10},"Text encoding: Jonathan Prag, edition source:",{"file":149,"uri":149,"title":150,"status":151,"editionAuthor":11,"type":152,"objectType":153,"material":154,"condition":24,"layoutDesc":155,"handNote":158,"date":163,"places":167,"geo":170,"country":66,"region":67,"settlement":58,"repository":172,"idno":173,"textLang":175,"facsimile":177,"provenance":54,"letterHeights":179,"publications":180,"zotero":181,"keywords":182,"html":147},"ISic004413","Epitaph for Kallo",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":156},{"p":27,"rs":157,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":159,"dimensions":160},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[161,162],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":164,"notBefore":165,"notAfter":166,"evidence":50,"precision":51},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[168,169],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[171],[64,65],{"_":69,"role":70,"ref":71},{"_":174,"type":74},"ME23436",{"_":76,"mainLang":77,"languages":176},[76],{"n":80,"url":178,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004413_tiled.tif",[],[89,90,91],[94,95,96],[183,184,185,13,17,21,101,102,103,104,102,105,106,77],"isic004413","epitaph for kallo",{"_":10},{"file":187,"uri":187,"title":188,"status":189,"editionAuthor":11,"type":190,"objectType":191,"material":192,"condition":24,"layoutDesc":193,"handNote":196,"date":201,"places":202,"geo":205,"country":66,"region":67,"settlement":58,"repository":207,"idno":208,"textLang":210,"facsimile":212,"provenance":54,"letterHeights":214,"publications":215,"zotero":216,"keywords":217,"html":147},"ISic004414","Epitaph for Eupolemos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":21,"ana":22,"ref":23},{"layout":194},{"p":27,"rs":195,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":197,"dimensions":198},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[199,200],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":164,"notBefore":165,"notAfter":166,"evidence":50,"precision":51},[203,204],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[206],[64,65],{"_":69,"role":70,"ref":71},{"_":209,"type":74},"ME23438",{"_":76,"mainLang":77,"languages":211},[76],{"n":80,"url":213,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004414_tiled.tif",[],[88,89,90,91],[93,94,95,96],[218,219,220,13,17,21,101,102,103,104,102,105,106,77],"isic004414","epitaph for eupolemos",{"_":10},{"file":222,"uri":222,"title":223,"status":224,"editionAuthor":11,"type":225,"objectType":226,"material":230,"condition":24,"layoutDesc":231,"handNote":235,"date":240,"places":242,"geo":246,"country":66,"region":67,"settlement":58,"repository":248,"idno":252,"textLang":253,"facsimile":255,"provenance":54,"letterHeights":257,"publications":258,"zotero":259,"keywords":260,"html":147},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":227,"ana":228,"ref":229},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":21,"ana":22,"ref":23},{"layout":232},{"p":233,"rs":234,"damage":24},"Single line of greek letters approximately centred on the face of the plinth",{"_":29,"ana":30,"ref":31},{"lettering":236,"dimensions":237},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[238,239],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":241,"notBefore":125,"notAfter":166,"evidence":50,"precision":51},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[243,245],{"_":54,"type":55,"ref":56,"corresp":244},"#findspot",{"_":58,"type":59,"ref":60,"offset":61},[247],[64,65],{"_":249,"role":250,"ref":251},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":74},{"_":76,"mainLang":77,"languages":254},[76],{"n":80,"url":256,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004415_tiled.tif",[],[88,91],[93,96],[261,262,263,13,227,21,101,102,103,104,102,264,106,77],"isic004415","epitaph for krimma, child of aunakos",{"_":10},"necropoli di abakainon",{"file":266,"uri":266,"title":267,"status":268,"editionAuthor":11,"type":269,"objectType":270,"material":271,"condition":24,"layoutDesc":272,"handNote":276,"date":282,"places":283,"geo":286,"country":66,"region":67,"settlement":58,"repository":288,"idno":289,"textLang":290,"facsimile":292,"provenance":54,"letterHeights":294,"publications":295,"zotero":296,"keywords":297,"html":147},"ISic004416","Epitaph for Philon, son Aunakos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":227,"ana":228,"ref":229},{"_":21,"ana":22,"ref":23},{"layout":273},{"p":274,"rs":275,"damage":24},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":29,"ana":30,"ref":31},{"lettering":277,"dimensions":278},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[279,281],{"type":36,"l":37,"from":38,"to":38,"h":280,"unit":40},"59",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":241,"notBefore":125,"notAfter":166,"evidence":50,"precision":51},[284,285],{"_":54,"type":55,"ref":56,"corresp":244},{"_":58,"type":59,"ref":60,"offset":61},[287],[64,65],{"_":249,"role":250,"ref":251},{"type":74},{"_":76,"mainLang":77,"languages":291},[76],{"n":80,"url":293,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004416_tiled.tif",[],[88,91],[93,96],[298,299,300,13,227,21,101,102,103,104,102,264,106,77],"isic004416","epitaph for philon, son aunakos",{"_":10},{"file":302,"uri":302,"title":303,"status":304,"editionAuthor":11,"type":305,"objectType":306,"material":307,"condition":24,"layoutDesc":308,"handNote":312,"date":318,"places":319,"geo":322,"country":66,"region":67,"settlement":58,"repository":324,"idno":325,"textLang":326,"facsimile":328,"provenance":54,"letterHeights":330,"publications":331,"zotero":332,"keywords":333,"html":147},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":10},{"_":13,"ana":14,"ref":15},{"_":227,"ana":228,"ref":229},{"_":21,"ana":22,"ref":23},{"layout":309},{"p":310,"rs":311,"damage":24},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":29,"ana":30,"ref":31},{"lettering":313,"dimensions":314},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[315,317],{"type":36,"l":316,"from":38,"to":44,"h":39,"unit":40},"Line 1-2",{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":241,"notBefore":125,"notAfter":166,"evidence":50,"precision":51},[320,321],{"_":54,"type":55,"ref":56,"corresp":244},{"_":58,"type":59,"ref":60,"offset":61},[323],[64,65],{"_":249,"role":250,"ref":251},{"type":74},{"_":76,"mainLang":77,"languages":327},[76],{"n":80,"url":329,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004417_tiled.tif",[],[88,90,91],[93,95,96],[334,335,336,13,227,21,101,102,103,104,102,264,106,77],"isic004417","epitaph for [-?-], child of gerontios",{"_":10},{"file":338,"uri":338,"title":303,"status":339,"editionAuthor":11,"type":340,"objectType":341,"material":342,"condition":24,"layoutDesc":343,"handNote":347,"date":352,"places":354,"geo":357,"country":66,"region":67,"settlement":58,"repository":359,"idno":360,"textLang":361,"facsimile":363,"provenance":54,"letterHeights":365,"publications":366,"zotero":367,"keywords":368,"html":147},"ISic004418",{"_":10},{"_":13,"ana":14,"ref":15},{"_":227,"ana":228,"ref":229},{"_":21,"ana":22,"ref":23},{"layout":344},{"p":345,"rs":346,"damage":24},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":29,"ana":30,"ref":31},{"lettering":348,"dimensions":349},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[350,351],{"type":36,"l":316,"from":38,"to":44,"h":280,"unit":40},{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":353,"notBefore":125,"notAfter":166,"evidence":50,"precision":51},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[355,356],{"_":54,"type":55,"ref":56,"corresp":244},{"_":58,"type":59,"ref":60,"offset":61},[358],[64,65],{"_":249,"role":250,"ref":251},{"type":74},{"_":76,"mainLang":77,"languages":362},[76],{"n":80,"url":364,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004418_tiled.tif",[],[88,90,91],[93,95,96],[369,335,370,13,227,21,101,102,103,104,102,264,106,77],"isic004418",{"_":10},{"file":372,"uri":372,"title":373,"status":374,"editionAuthor":11,"type":375,"objectType":376,"material":377,"condition":24,"layoutDesc":378,"handNote":382,"date":387,"places":388,"geo":391,"country":66,"region":67,"settlement":58,"repository":393,"idno":394,"textLang":395,"facsimile":397,"provenance":54,"letterHeights":399,"publications":400,"zotero":401,"keywords":402,"html":147},"ISic004419","Epitaph for Aristarchos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":227,"ana":228,"ref":229},{"_":21,"ana":22,"ref":23},{"layout":379},{"p":380,"rs":381,"damage":24},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":29,"ana":30,"ref":31},{"lettering":383,"dimensions":384},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[385,386],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":353,"notBefore":125,"notAfter":166,"evidence":50,"precision":51},[389,390],{"_":54,"type":55,"ref":56,"corresp":244},{"_":58,"type":59,"ref":60,"offset":61},[392],[64,65],{"_":249,"role":250,"ref":251},{"type":74},{"_":76,"mainLang":77,"languages":396},[76],{"n":80,"url":398,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004419_tiled.tif",[],[91],[96],[403,404,405,13,227,21,101,102,103,104,102,264,106,77],"isic004419","epitaph for aristarchos",{"_":10},{"file":407,"uri":407,"title":408,"status":409,"editionAuthor":11,"type":410,"objectType":411,"material":412,"condition":24,"layoutDesc":413,"handNote":417,"date":423,"places":424,"geo":427,"country":66,"region":67,"settlement":58,"repository":429,"idno":430,"textLang":431,"facsimile":433,"provenance":54,"letterHeights":435,"publications":436,"zotero":437,"keywords":438,"html":147},"ISic004420","Epitaph for Aristokrates",{"_":10},{"_":13,"ana":14,"ref":15},{"_":227,"ana":228,"ref":229},{"_":21,"ana":22,"ref":23},{"layout":414},{"p":415,"rs":416,"damage":24},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":29,"ana":30,"ref":31},{"lettering":418,"dimensions":419},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[420,422],{"type":36,"l":316,"from":38,"to":44,"h":421,"unit":40},"49",{"type":42,"l":43,"from":38,"to":44,"unit":40},{"_":353,"notBefore":125,"notAfter":166,"evidence":50,"precision":51},[425,426],{"_":54,"type":55,"ref":56,"corresp":244},{"_":58,"type":59,"ref":60,"offset":61},[428],[64,65],{"_":249,"role":250,"ref":251},{"type":74},{"_":76,"mainLang":77,"languages":432},[76],{"n":80,"url":434,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004420_tiled.tif",[],[91],[96],[439,440,441,13,227,21,101,102,103,104,102,264,106,77],"isic004420","epitaph for aristokrates",{"_":10},{"file":443,"uri":443,"title":444,"status":445,"editionAuthor":11,"type":446,"objectType":447,"material":448,"condition":24,"layoutDesc":449,"handNote":453,"date":459,"places":461,"geo":464,"country":66,"region":67,"settlement":58,"repository":466,"idno":467,"textLang":468,"facsimile":470,"provenance":54,"letterHeights":472,"publications":473,"zotero":474,"keywords":475,"html":147},"ISic004421","Epitaph for Athanippos",{"_":10},{"_":13,"ana":14,"ref":15},{"_":227,"ana":228,"ref":229},{"_":21,"ana":22,"ref":23},{"layout":450},{"p":451,"rs":452,"damage":24},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":29,"ana":30,"ref":31},{"lettering":454,"dimensions":455},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[456,458],{"type":36,"l":37,"from":38,"to":38,"h":457,"unit":40},"29",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":460,"notBefore":125,"notAfter":166,"evidence":50,"precision":51},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[462,463],{"_":54,"type":55,"ref":56,"corresp":244},{"_":58,"type":59,"ref":60,"offset":61},[465],[64,65],{"_":249,"role":250,"ref":251},{"type":74},{"_":76,"mainLang":77,"languages":469},[76],{"n":80,"url":471,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004421_tiled.tif",[],[91],[96],[476,477,478,13,227,21,101,102,103,104,102,264,106,77],"isic004421","epitaph for athanippos",{"_":10},{"file":480,"uri":480,"title":481,"status":482,"editionAuthor":11,"type":483,"objectType":484,"material":485,"condition":24,"layoutDesc":486,"handNote":490,"date":495,"places":497,"geo":500,"country":66,"region":67,"settlement":58,"repository":502,"idno":503,"textLang":505,"facsimile":507,"provenance":54,"letterHeights":509,"publications":510,"zotero":511,"keywords":512,"html":147},"ISic004422","Epitaph for Artemidoros (?)",{"_":10},{"_":13,"ana":14,"ref":15},{"_":227,"ana":228,"ref":229},{"_":21,"ana":22,"ref":23},{"layout":487},{"p":488,"rs":489,"damage":24},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":29,"ana":30,"ref":31},{"lettering":491,"dimensions":492},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[493,494],{"type":36,"l":37,"from":38,"to":38,"h":457,"unit":40},{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},{"_":496,"notBefore":125,"notAfter":166,"evidence":50,"precision":51},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[498,499],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[501],[64,65],{"_":69,"role":70,"ref":71},{"_":504,"type":74},"ME23440",{"_":76,"mainLang":77,"languages":506},[76],{"n":80,"url":508,"height":82,"width":83,"desc":84,"surfaceType":85},"ISic004422_tiled.tif",[],[90,91],[95,96],[513,514,515,13,227,21,101,102,103,104,102,105,106,77],"isic004422","epitaph for artemidoros (?)",{"_":10}],"uses":{"params":["slug"]}}]}
