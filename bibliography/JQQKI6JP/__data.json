he 3rd century BCE",-300,-201,[189,190],{"_":57,"type":58,"ref":59,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[192],[68,69],[71,72],{"_":75,"role":76,"ref":77},{"_":196,"type":80},"ME23436",{"_":82,"mainLang":83,"languages":198},[82],{"n":86,"url":200,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004413_tiled.tif",[202],{"atLeast":94,"atMost":94},[97,98,99],[102,103,104],[206,207,208,15,19,23,109,110,111,112,110,113,114,83],"isic004413","epitaph for kallo",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":211,"ptr":212,"ref":213,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.3 and fig.4",{"target":119},{"_":121,"target":121},{"file":215,"uri":215,"title":216,"status":217,"editionAuthor":13,"type":218,"objectType":219,"material":220,"condition":28,"layoutDesc":221,"handNote":224,"date":229,"places":230,"geo":233,"country":60,"provenance":57,"provenanceGeo":235,"region":73,"settlement":62,"repository":236,"idno":237,"textLang":239,"tmNumber":28,"facsimile":241,"letterHeights":243,"publications":245,"zotero":246,"keywords":247,"html":251,"bibl":252,"bulletinDateSort":122,"citedRangeSort":253,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004414","Epitaph for Eupolemos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":222},{"p":31,"rs":223,"damage":28},{"_":33,"ana":34,"ref":35},{"lettering":225,"dimensions":226},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[227,228],{"type":40,"l":41,"from":42,"to":42,"h":43,"unit":44,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":42,"to":48,"h":49,"unit":44},{"_":185,"notBefore":186,"notAfter":187,"evidence":54},[231,232],{"_":57,"type":58,"ref":59,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[234],[68,69],[71,72],{"_":75,"role":76,"ref":77},{"_":238,"type":80},"ME23438",{"_":82,"mainLang":83,"languages":240},[82],{"n":86,"url":242,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004414_tiled.tif",[244],{"atLeast":94,"atMost":94},[96,97,98,99],[101,102,103,104],[248,249,250,15,19,23,109,110,111,112,110,113,114,83],"isic004414","epitaph for eupolemos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":253,"ptr":254,"ref":255,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.4 and fig.5",{"target":119},{"_":121,"target":121},{"file":257,"uri":257,"title":258,"status":259,"editionAuthor":13,"type":260,"objectType":261,"material":265,"condition":28,"layoutDesc":266,"handNote":270,"date":275,"places":277,"geo":281,"country":60,"provenance":57,"provenanceGeo":283,"region":73,"settlement":62,"repository":284,"idno":288,"textLang":289,"tmNumber":28,"facsimile":291,"letterHeights":293,"publications":295,"zotero":296,"keywords":297,"html":302,"bibl":303,"bulletinDateSort":122,"citedRangeSort":304,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":262,"ana":263,"ref":264},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":267},{"p":268,"rs":269,"damage":28},"Single line of greek letters approximately centred on the face of the plinth",{"_":33,"ana":34,"ref":35},{"lettering":271,"dimensions":272},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[273,274],{"type":40,"l":41,"from":42,"to":42,"h":43,"unit":44,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":42,"to":48,"h":49,"unit":44},{"_":276,"notBefore":140,"notAfter":187,"evidence":54},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[278,280],{"_":57,"type":58,"ref":59,"corresp":279,"region":60},"#findspot",{"_":62,"type":63,"ref":64,"offset":65,"region":60},[282],[68,69],[71,72],{"_":285,"role":286,"ref":287},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":80},{"_":82,"mainLang":83,"languages":290},[82],{"n":86,"url":292,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004415_tiled.tif",[294],{"atLeast":94,"atMost":94},[96,99],[101,104],[298,299,300,15,262,23,109,110,111,112,110,301,114,83],"isic004415","epitaph for krimma, child of aunakos",{"_":12},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":304,"ptr":305,"ref":306,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.5 and fig.6",{"target":119},{"_":121,"target":121},{"file":308,"uri":308,"title":309,"status":310,"editionAuthor":13,"type":311,"objectType":312,"material":313,"condition":28,"layoutDesc":314,"handNote":318,"date":324,"places":325,"geo":328,"country":60,"provenance":57,"provenanceGeo":330,"region":73,"settlement":62,"repository":331,"idno":332,"textLang":333,"tmNumber":28,"facsimile":335,"letterHeights":337,"publications":340,"zotero":341,"keywords":342,"html":346,"bibl":347,"bulletinDateSort":122,"citedRangeSort":348,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004416","Epitaph for Philon, son Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":262,"ana":263,"ref":264},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":315},{"p":316,"rs":317,"damage":28},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":33,"ana":34,"ref":35},{"lettering":319,"dimensions":320},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[321,323],{"type":40,"l":41,"from":42,"to":42,"h":322,"unit":44,"atLeast":322,"atMost":322},"59",{"type":46,"l":47,"from":42,"to":48,"h":49,"unit":44},{"_":276,"notBefore":140,"notAfter":187,"evidence":54},[326,327],{"_":57,"type":58,"ref":59,"corresp":279,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[329],[68,69],[71,72],{"_":285,"role":286,"ref":287},{"type":80},{"_":82,"mainLang":83,"languages":334},[82],{"n":86,"url":336,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004416_tiled.tif",[338],{"atLeast":339,"atMost":339},59,[96,99],[101,104],[343,344,345,15,262,23,109,110,111,112,110,301,114,83],"isic004416","epitaph for philon, son aunakos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":348,"ptr":349,"ref":350,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.6 and fig.7",{"target":119},{"_":121,"target":121},{"file":352,"uri":352,"title":353,"status":354,"editionAuthor":13,"type":355,"objectType":356,"material":357,"condition":28,"layoutDesc":358,"handNote":362,"date":368,"places":369,"geo":372,"country":60,"provenance":57,"provenanceGeo":374,"region":73,"settlement":62,"repository":375,"idno":376,"textLang":377,"tmNumber":28,"facsimile":379,"letterHeights":381,"publications":383,"zotero":384,"keywords":385,"html":389,"bibl":390,"bulletinDateSort":122,"citedRangeSort":391,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":12},{"_":15,"ana":16,"ref":17},{"_":262,"ana":263,"ref":264},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":359},{"p":360,"rs":361,"damage":28},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":33,"ana":34,"ref":35},{"lettering":363,"dimensions":364},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[365,367],{"type":40,"l":366,"from":42,"to":48,"h":43,"unit":44,"atLeast":43,"atMost":43},"Line 1-2",{"type":46,"l":47,"from":42,"to":48,"unit":44},{"_":276,"notBefore":140,"notAfter":187,"evidence":54},[370,371],{"_":57,"type":58,"ref":59,"corresp":279,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[373],[68,69],[71,72],{"_":285,"role":286,"ref":287},{"type":80},{"_":82,"mainLang":83,"languages":378},[82],{"n":86,"url":380,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004417_tiled.tif",[382],{"atLeast":94,"atMost":94},[96,98,99],[101,103,104],[386,387,388,15,262,23,109,110,111,112,110,301,114,83],"isic004417","epitaph for [-?-], child of gerontios",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":391,"ptr":392,"ref":393,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.7 and fig.8",{"target":119},{"_":121,"target":121},{"file":395,"uri":395,"title":353,"status":396,"editionAuthor":13,"type":397,"objectType":398,"material":399,"condition":28,"layoutDesc":400,"handNote":404,"date":409,"places":411,"geo":414,"country":60,"provenance":57,"provenanceGeo":416,"region":73,"settlement":62,"repository":417,"idno":418,"textLang":419,"tmNumber":28,"facsimile":421,"letterHeights":423,"publications":425,"zotero":426,"keywords":427,"html":430,"bibl":431,"bulletinDateSort":122,"citedRangeSort":432,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004418",{"_":12},{"_":15,"ana":16,"ref":17},{"_":262,"ana":263,"ref":264},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":401},{"p":402,"rs":403,"damage":28},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":33,"ana":34,"ref":35},{"lettering":405,"dimensions":406},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[407,408],{"type":40,"l":366,"from":42,"to":48,"h":322,"unit":44,"atLeast":322,"atMost":322},{"type":46,"l":47,"from":42,"to":48,"unit":44},{"_":410,"notBefore":140,"notAfter":187,"evidence":54},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[412,413],{"_":57,"type":58,"ref":59,"corresp":279,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[415],[68,69],[71,72],{"_":285,"role":286,"ref":287},{"type":80},{"_":82,"mainLang":83,"languages":420},[82],{"n":86,"url":422,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004418_tiled.tif",[424],{"atLeast":339,"atMost":339},[96,98,99],[101,103,104],[428,387,429,15,262,23,109,110,111,112,110,301,114,83],"isic004418",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":432,"ptr":433,"ref":434,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"107 no.8 and fig.9",{"target":119},{"_":121,"target":121},{"file":436,"uri":436,"title":437,"status":438,"editionAuthor":13,"type":439,"objectType":440,"material":441,"condition":28,"layoutDesc":442,"handNote":446,"date":451,"places":452,"geo":455,"country":60,"provenance":57,"provenanceGeo":457,"region":73,"settlement":62,"repository":458,"idno":459,"textLang":460,"tmNumber":28,"facsimile":462,"letterHeights":464,"publications":466,"zotero":467,"keywords":468,"html":472,"bibl":473,"bulletinDateSort":122,"citedRangeSort":474,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004419","Epitaph for Aristarchos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":262,"ana":263,"ref":264},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":443},{"p":444,"rs":445,"damage":28},"Remains of a single line of Greek letters, somewhat irregularly laid out and not following the horizontal",{"_":33,"ana":34,"ref":35},{"lettering":447,"dimensions":448},"Somewhat irregular plainly cut, widely spaced letters. Rho has closed and regular eye; sigma has horizontal upper and lower strokes, the intermediate strokes joined by a curve; alpha is broad with straight bar; omicron is small and mid-line.",[449,450],{"type":40,"l":41,"from":42,"to":42,"h":43,"unit":44,"atLeast":43,"atMost":43},{"type":46,"l":47,"from":42,"to":48,"h":49,"unit":44},{"_":410,"notBefore":140,"notAfter":187,"evidence":54},[453,454],{"_":57,"type":58,"ref":59,"corresp":279,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[456],[68,69],[71,72],{"_":285,"role":286,"ref":287},{"type":80},{"_":82,"mainLang":83,"languages":461},[82],{"n":86,"url":463,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004419_tiled.tif",[465],{"atLeast":94,"atMost":94},[99],[104],[469,470,471,15,262,23,109,110,111,112,110,301,114,83],"isic004419","epitaph for aristarchos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[Ἀ]ρισταρχου̣ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":474,"ptr":475,"ref":476,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 no.9 and fig.10",{"target":119},{"_":121,"target":121},{"file":478,"uri":478,"title":479,"status":480,"editionAuthor":13,"type":481,"objectType":482,"material":483,"condition":28,"layoutDesc":484,"handNote":488,"date":494,"places":495,"geo":498,"country":60,"provenance":57,"provenanceGeo":500,"region":73,"settlement":62,"repository":501,"idno":502,"textLang":503,"tmNumber":28,"facsimile":505,"letterHeights":507,"publications":510,"zotero":511,"keywords":512,"html":516,"bibl":517,"bulletinDateSort":122,"citedRangeSort":518,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004420","Epitaph for Aristokrates",{"_":12},{"_":15,"ana":16,"ref":17},{"_":262,"ana":263,"ref":264},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":485},{"p":486,"rs":487,"damage":28},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":33,"ana":34,"ref":35},{"lettering":489,"dimensions":490},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[491,493],{"type":40,"l":366,"from":42,"to":48,"h":492,"unit":44,"atLeast":492,"atMost":492},"49",{"type":46,"l":47,"from":42,"to":48,"unit":44},{"_":410,"notBefore":140,"notAfter":187,"evidence":54},[496,497],{"_":57,"type":58,"ref":59,"corresp":279,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[499],[68,69],[71,72],{"_":285,"role":286,"ref":287},{"type":80},{"_":82,"mainLang":83,"languages":504},[82],{"n":86,"url":506,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004420_tiled.tif",[508],{"atLeast":509,"atMost":509},49,[99],[104],[513,514,515,15,262,23,109,110,111,112,110,301,114,83],"isic004420","epitaph for aristokrates",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":518,"ptr":519,"ref":520,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 no.10 and fig.11",{"target":119},{"_":121,"target":121},{"file":522,"uri":522,"title":523,"status":524,"editionAuthor":13,"type":525,"objectType":526,"material":527,"condition":28,"layoutDesc":528,"handNote":532,"date":538,"places":540,"geo":543,"country":60,"provenance":57,"provenanceGeo":545,"region":73,"settlement":62,"repository":546,"idno":547,"textLang":548,"tmNumber":28,"facsimile":550,"letterHeights":552,"publications":555,"zotero":556,"keywords":557,"html":561,"bibl":562,"bulletinDateSort":122,"citedRangeSort":563,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004421","Epitaph for Athanippos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":262,"ana":263,"ref":264},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":529},{"p":530,"rs":531,"damage":28},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":33,"ana":34,"ref":35},{"lettering":533,"dimensions":534},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[535,537],{"type":40,"l":41,"from":42,"to":42,"h":536,"unit":44,"atLeast":536,"atMost":536},"29",{"type":46,"l":47,"from":42,"to":48,"h":49,"unit":44},{"_":539,"notBefore":140,"notAfter":187,"evidence":54},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[541,542],{"_":57,"type":58,"ref":59,"corresp":279,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[544],[68,69],[71,72],{"_":285,"role":286,"ref":287},{"type":80},{"_":82,"mainLang":83,"languages":549},[82],{"n":86,"url":551,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004421_tiled.tif",[553],{"atLeast":554,"atMost":554},29,[99],[104],[558,559,560,15,262,23,109,110,111,112,110,301,114,83],"isic004421","epitaph for athanippos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":563,"ptr":564,"ref":565,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 no.11 and fig.12",{"target":119},{"_":121,"target":121},{"file":567,"uri":567,"title":568,"status":569,"editionAuthor":13,"type":570,"objectType":571,"material":572,"condition":28,"layoutDesc":573,"handNote":577,"date":582,"places":584,"geo":587,"country":60,"provenance":57,"provenanceGeo":589,"region":73,"settlement":62,"repository":590,"idno":591,"textLang":593,"tmNumber":28,"facsimile":595,"letterHeights":597,"publications":599,"zotero":600,"keywords":601,"html":605,"bibl":606,"bulletinDateSort":122,"citedRangeSort":607,"languageSort":82,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":12},{"_":15,"ana":16,"ref":17},{"_":262,"ana":263,"ref":264},{"_":23,"ana":24,"type":25,"subtype":26,"ref":27},{"layout":574},{"p":575,"rs":576,"damage":28},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":33,"ana":34,"ref":35},{"lettering":578,"dimensions":579},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[580,581],{"type":40,"l":41,"from":42,"to":42,"h":536,"unit":44,"atLeast":536,"atMost":536},{"type":46,"l":47,"from":42,"to":48,"h":49,"unit":44},{"_":583,"notBefore":140,"notAfter":187,"evidence":54},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[585,586],{"_":57,"type":58,"ref":59,"region":60},{"_":62,"type":63,"ref":64,"offset":65,"region":60},[588],[68,69],[71,72],{"_":75,"role":76,"ref":77},{"_":592,"type":80},"ME23440",{"_":82,"mainLang":83,"languages":594},[82],{"n":86,"url":596,"height":88,"width":89,"desc":90,"surfaceType":91},"ISic004422_tiled.tif",[598],{"atLeast":554,"atMost":554},[98,99],[103,104],[602,603,604,15,262,23,109,110,111,112,110,113,114,83],"isic004422","epitaph for artemidoros (?)",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":607,"ptr":608,"ref":609,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"108 no.12 and fig.13",{"target":119},{"_":121,"target":121},false],"uses":{"params":["slug"]}}]}
