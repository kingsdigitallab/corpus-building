line1","30","mm",{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":49,"notBefore":50,"notAfter":51,"evidence":52,"precision":53},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context","low",[55,59],{"_":56,"type":57,"ref":58},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062",{"_":60,"type":61,"ref":62,"offset":63},"Tripi","modern","http://sws.geonames.org/2522853","near",[65],[66,67],38.05191,15.10158,[69,70],38.06519,15.11438,"Italy","Sicily",{"_":74,"role":75,"ref":76},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":78,"type":79},"ME23435","inventory",{"_":81,"mainLang":82,"languages":83},"Ancient Greek","grc",[81],{"n":85,"url":86,"height":87,"width":88,"desc":89,"surfaceType":90},"screen","ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[93,94,95,96],"Bacci, Coppolino, 2009, La Necropoli di Abakainon: primi dati","Bacci, Coppolino, Sofia, Arizia, 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2015, Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[98,99,100,101],"DX8AWC9Q","ILQ4RQGU","9QTE4E3Z","JQQKI6JP",[103,104,105,15,19,23,106,107,108,109,107,110,111,82],"isic004411","epitaph for kratisstos",{"_":12},"abacaenum","tripi","italy","sicily","museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":11