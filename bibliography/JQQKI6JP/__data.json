{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":5},{"title":2,"date":3,"citation":4},"Nuove iscrizioni funerarie dalla necropoli di Abakainon","2018","\u003Cspan>Girolamo Sofia, «Nuove iscrizioni funerarie dalla necropoli di Abakainon», \u003Ci>Zeitschrift für Papyrologie und Epigraphik\u003C/i> 206 (2018): 103–12\u003C/span>",[6,118,163,207,248,298,340,382,422,463,505,548],{"file":7,"uri":7,"title":8,"status":9,"editionAuthor":11,"type":12,"objectType":16,"material":20,"condition":24,"layoutDesc":25,"handNote":32,"date":46,"places":52,"geo":62,"provenance":54,"provenanceGeo":66,"country":69,"region":70,"settlement":58,"repository":71,"idno":75,"textLang":78,"tmNumber":24,"facsimile":82,"letterHeights":89,"publications":90,"zotero":95,"keywords":100,"html":110,"bibl":111},"ISic004411","Epitaph for Kratisstos",{"_":10},"edited",null,{"_":13,"ana":14,"ref":15},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":17,"ana":18,"ref":19},"stele","#object.stele","http://www.eagle-network.eu/voc/objtyp/lod/250",{"_":21,"ana":22,"ref":23},"sandstone","#material.stone.sandstone","http://www.eagle-network.eu/voc/material/lod/75.html","",{"layout":26},{"p":27,"rs":28,"damage":24},"Single line of Greek letters filling the width of the stone",{"_":29,"ana":30,"ref":31},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":33,"dimensions":34},"Plain wide letters: kappa has arms of almost full length, not quite joining the vertical; rho is closed; alpha broad with straight bar; sigma has horizontal top and bottom bars, joined by a curving stroke rather than two distinct diagonals; omega sits very slightly above the line, is circular and open with short arms",[35,41],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},"letterHeight","Line 1","line1","30","mm",{"type":42,"l":43,"from":38,"to":44,"h":45,"unit":40},"interlinear","Interlineation line 1 to 2","line2","NA",{"_":47,"notBefore":48,"notAfter":49,"evidence":50,"precision":51},"Dated to the end of the 4th century BCE by the burial goods",-325,-301,"archaeological-context","low",[53,57],{"_":54,"type":55,"ref":56},"Abacaenum","ancient","http://pleiades.stoa.org/places/462062",{"_":58,"type":59,"ref":60,"offset":61},"Tripi","modern","http://sws.geonames.org/2522853","near",[63],[64,65],38.05191,15.10158,[67,68],38.06519,15.11438,"Italy","Sicily",{"_":72,"role":73,"ref":74},"Museo Archeologico Santi Furnari di Tripi","museum","http://sicily.classics.ox.ac.uk/museum/177",{"_":76,"type":77},"ME23435","inventory",{"_":79,"mainLang":80,"languages":81},"Ancient Greek","grc",[79],{"n":83,"url":84,"height":85,"width":86,"desc":87,"surfaceType":88},"screen","ISic004411_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[91,92,93,94],"Bacci and Coppolino, 2009, La Necropoli di Abakainon: primi dati","Bacci et al., 2015, Tripi. Il museo archeologico \"Santi Furnari\". Guida all'esposizione","Sofia, 2015, Abakainon. Nella dimora di Ade. La necropoli in contrada Cardusa a Tripi","Sofia, 2018, Nuove iscrizioni funerarie dalla necropoli di Abakainon",[96,97,98,99],"DX8AWC9Q","ILQ4RQGU","9QTE4E3Z","JQQKI6JP",[101,102,103,13,17,21,104,105,106,107,105,108,109,80],"isic004411","epitaph for kratisstos",{"_":10},"abacaenum","tripi","italy","sicily","museo archeologico santi furnari di tripi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κρατίσστω \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":112,"date":3,"citedRange":113,"ptr":114,"ref":116,"title":2,"citation":4},"Sofia","107 no.1 and fig.2",{"target":115},"http://zo