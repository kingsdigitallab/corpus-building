,102],[158,159,160,15,19,23,107,108,109,110,108,111,112,81],"isic004412","epitaph for aristoboula",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοβούλας \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":163,"ptr":164,"ref":165,"title":2,"citation":5,"uri":6},"107 no.2 and fig.3",{"target":117},{"_":119,"target":119},{"file":167,"uri":167,"title":168,"status":169,"editionAuthor":13,"type":170,"objectType":171,"material":172,"condition":26,"layoutDesc":173,"handNote":176,"date":181,"places":185,"geo":188,"provenance":55,"provenanceGeo":190,"country":70,"region":71,"settlement":59,"repository":191,"idno":192,"textLang":194,"tmNumber":26,"facsimile":196,"letterHeights":198,"publications":200,"zotero":201,"keywords":202,"html":206,"bibl":207,"citedRangeSort":208,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004413","Epitaph for Kallo",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":174},{"p":29,"rs":175,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":177,"dimensions":178},"Broad simple letters: kappa has short, approximately equal arms; alpha is broad with broken bar; omicron is small and mid-line; sigma has horizontal top and bottom strokes.",[179,180],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42,"atLeast":41,"atMost":41},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":182,"notBefore":183,"notAfter":184,"evidence":52},"The goods recovered from the tomb suggest a date in the 3rd century BCE",-300,-201,[186,187],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[189],[65,66],[68,69],{"_":73,"role":74,"ref":75},{"_":193,"type":78},"ME23436",{"_":80,"mainLang":81,"languages":195},[80],{"n":84,"url":197,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004413_tiled.tif",[199],{"atLeast":92,"atMost":92},[95,96,97],[100,101,102],[203,204,205,15,19,23,107,108,109,110,108,111,112,81],"isic004413","epitaph for kallo",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Καλλοῦς \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":208,"ptr":209,"ref":210,"title":2,"citation":5,"uri":6},"107 no.3 and fig.4",{"target":117},{"_":119,"target":119},{"file":212,"uri":212,"title":213,"status":214,"editionAuthor":13,"type":215,"objectType":216,"material":217,"condition":26,"layoutDesc":218,"handNote":221,"date":226,"places":227,"geo":230,"provenance":55,"provenanceGeo":232,"country":70,"region":71,"settlement":59,"repository":233,"idno":234,"textLang":236,"tmNumber":26,"facsimile":238,"letterHeights":240,"publications":242,"zotero":243,"keywords":244,"html":248,"bibl":249,"citedRangeSort":250,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004414","Epitaph for Eupolemos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":219},{"p":29,"rs":220,"damage":26},{"_":31,"ana":32,"ref":33},{"lettering":222,"dimensions":223},"Plain letters carved in a deep square cut: E has shorter mid-bar; upsilon slightly exceeds the line; pi is wide and square in form, with fractionally shorter right hasta; omicron is only slightly smaller than the other letters; mu has vertical first and last strokes, while the mid-strokes descend less than half-way.",[224,225],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42,"atLeast":41,"atMost":41},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":182,"notBefore":183,"notAfter":184,"evidence":52},[228,229],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[231],[65,66],[68,69],{"_":73,"role":74,"ref":75},{"_":235,"type":78},"ME23438",{"_":80,"mainLang":81,"languages":237},[80],{"n":84,"url":239,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004414_tiled.tif",[241],{"atLeast":92,"atMost":92},[94,95,96,97],[99,100,101,102],[245,246,247,15,19,23,107,108,109,110,108,111,112,81],"isic004414","epitaph for eupolemos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Εὐπολέμου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":250,"ptr":251,"ref":252,"title":2,"citation":5,"uri":6},"107 no.4 and fig.5",{"target":117},{"_":119,"target":119},{"file":254,"uri":254,"title":255,"status":256,"editionAuthor":13,"type":257,"objectType":258,"material":262,"condition":26,"layoutDesc":263,"handNote":267,"date":272,"places":274,"geo":278,"provenance":55,"provenanceGeo":280,"country":70,"region":71,"settlement":59,"repository":281,"idno":285,"textLang":286,"tmNumber":26,"facsimile":288,"letterHeights":290,"publications":292,"zotero":293,"keywords":294,"html":299,"bibl":300,"citedRangeSort":301,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004415","Epitaph for Krimma, child of Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":259,"ana":260,"ref":261},"plinth","#object.arch_element.plinth","https://www.eagle-network.eu/voc/objtyp/lod/1910.html",{"_":23,"ana":24,"ref":25},{"layout":264},{"p":265,"rs":266,"damage":26},"Single line of greek letters approximately centred on the face of the plinth",{"_":31,"ana":32,"ref":33},{"lettering":268,"dimensions":269},"Small simple letters. Kappa has short equal arms, attached to the vertical; rho has small closed eye; mu has slanting first and final strokes, with the mid-strokes joining as a curve and only descending half-way; alpha is broad with straight bar, in one case slightly curved with the apex extending at the top; nu has shorter right vertical joining the diagonal above the line; omicron is small and mid-line.",[270,271],{"type":38,"l":39,"from":40,"to":40,"h":41,"unit":42,"atLeast":41,"atMost":41},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":273,"notBefore":137,"notAfter":184,"evidence":52},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[275,277],{"_":55,"type":56,"ref":57,"corresp":276},"#findspot",{"_":59,"type":60,"ref":61,"offset":62},[279],[65,66],[68,69],{"_":282,"role":283,"ref":284},"Necropoli di Abakainon","site","http://sicily.classics.ox.ac.uk/museum/186",{"type":78},{"_":80,"mainLang":81,"languages":287},[80],{"n":84,"url":289,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004415_tiled.tif",[291],{"atLeast":92,"atMost":92},[94,97],[99,102],[295,296,297,15,259,23,107,108,109,110,108,298,112,81],"isic004415","epitaph for krimma, child of aunakos",{"_":12},"necropoli di abakainon","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Κριμμα Αυνακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":301,"ptr":302,"ref":303,"title":2,"citation":5,"uri":6},"107 no.5 and fig.6",{"target":117},{"_":119,"target":119},{"file":305,"uri":305,"title":306,"status":307,"editionAuthor":13,"type":308,"objectType":309,"material":310,"condition":26,"layoutDesc":311,"handNote":315,"date":321,"places":322,"geo":325,"provenance":55,"provenanceGeo":327,"country":70,"region":71,"settlement":59,"repository":328,"idno":329,"textLang":330,"tmNumber":26,"facsimile":332,"letterHeights":334,"publications":337,"zotero":338,"keywords":339,"html":343,"bibl":344,"citedRangeSort":345,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004416","Epitaph for Philon, son Aunakos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":259,"ana":260,"ref":261},{"_":23,"ana":24,"ref":25},{"layout":312},{"p":313,"rs":314,"damage":26},"Single line of greek letters approximately centred on the face of the plinth, descending to right",{"_":31,"ana":32,"ref":33},{"lettering":316,"dimensions":317},"Crude and irregularly carved large letters. Phi has a small eye, seemingly formed of two small loops; omega is small, mid-line, open, with outward/downward sloping tails; nu is large and uneven; alpha is broad, but the form of the bar is illegible; kappa has short equal arms joined to the vertical; omicron appears small and midline.",[318,320],{"type":38,"l":39,"from":40,"to":40,"h":319,"unit":42,"atLeast":319,"atMost":319},"59",{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":273,"notBefore":137,"notAfter":184,"evidence":52},[323,324],{"_":55,"type":56,"ref":57,"corresp":276},{"_":59,"type":60,"ref":61,"offset":62},[326],[65,66],[68,69],{"_":282,"role":283,"ref":284},{"type":78},{"_":80,"mainLang":81,"languages":331},[80],{"n":84,"url":333,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004416_tiled.tif",[335],{"atLeast":336,"atMost":336},59,[94,97],[99,102],[340,341,342,15,259,23,107,108,109,110,108,298,112,81],"isic004416","epitaph for philon, son aunakos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Φίλων Αυ̣νακου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":345,"ptr":346,"ref":347,"title":2,"citation":5,"uri":6},"107 no.6 and fig.7",{"target":117},{"_":119,"target":119},{"file":349,"uri":349,"title":350,"status":351,"editionAuthor":13,"type":352,"objectType":353,"material":354,"condition":26,"layoutDesc":355,"handNote":359,"date":365,"places":366,"geo":369,"provenance":55,"provenanceGeo":371,"country":70,"region":71,"settlement":59,"repository":372,"idno":373,"textLang":374,"tmNumber":26,"facsimile":376,"letterHeights":378,"publications":380,"zotero":381,"keywords":382,"html":386,"bibl":387,"citedRangeSort":388,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004417","Epitaph for [-?-], child of Gerontios",{"_":12},{"_":15,"ana":16,"ref":17},{"_":259,"ana":260,"ref":261},{"_":23,"ana":24,"ref":25},{"layout":356},{"p":357,"rs":358,"damage":26},"Remains of two lines of Greek letters, apparently centred on the face of the plinth; the second line sits directly above the lower moulding",{"_":31,"ana":32,"ref":33},{"lettering":360,"dimensions":361},"Simple, widely spaced letters. Omega is wide and open, with horizontal tails; rho has a large, closed eye; omicron is small and mid-line; nu is regular and with both verticals full length",[362,364],{"type":38,"l":363,"from":40,"to":46,"h":41,"unit":42,"atLeast":41,"atMost":41},"Line 1-2",{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":273,"notBefore":137,"notAfter":184,"evidence":52},[367,368],{"_":55,"type":56,"ref":57,"corresp":276},{"_":59,"type":60,"ref":61,"offset":62},[370],[65,66],[68,69],{"_":282,"role":283,"ref":284},{"type":78},{"_":80,"mainLang":81,"languages":375},[80],{"n":84,"url":377,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004417_tiled.tif",[379],{"atLeast":92,"atMost":92},[94,96,97],[99,101,102],[383,384,385,15,259,23,107,108,109,110,108,298,112,81],"isic004417","epitaph for [-?-], child of gerontios",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ω\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[Γ]ε̣ρόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":388,"ptr":389,"ref":390,"title":2,"citation":5,"uri":6},"107 no.7 and fig.8",{"target":117},{"_":119,"target":119},{"file":392,"uri":392,"title":350,"status":393,"editionAuthor":13,"type":394,"objectType":395,"material":396,"condition":26,"layoutDesc":397,"handNote":401,"date":406,"places":408,"geo":411,"provenance":55,"provenanceGeo":413,"country":70,"region":71,"settlement":59,"repository":414,"idno":415,"textLang":416,"tmNumber":26,"facsimile":418,"letterHeights":420,"publications":422,"zotero":423,"keywords":424,"html":427,"bibl":428,"citedRangeSort":429,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004418",{"_":12},{"_":15,"ana":16,"ref":17},{"_":259,"ana":260,"ref":261},{"_":23,"ana":24,"ref":25},{"layout":398},{"p":399,"rs":400,"damage":26},"Most of the lower line of Greek text is preserved, centred on the front face of the plinth; traces of a preceding line are visible.",{"_":31,"ana":32,"ref":33},{"lettering":402,"dimensions":403},"Neat, regular, simply cut, widely spaced letters. Epsilon has shorter middle bar; rho has closed, regular eye; omicron is small and mid-line; nu is broad with verticals of equal length.",[404,405],{"type":38,"l":363,"from":40,"to":46,"h":319,"unit":42,"atLeast":319,"atMost":319},{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":407,"notBefore":137,"notAfter":184,"evidence":52},"The tomb has not been excavated fully, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[409,410],{"_":55,"type":56,"ref":57,"corresp":276},{"_":59,"type":60,"ref":61,"offset":62},[412],[65,66],[68,69],{"_":282,"role":283,"ref":284},{"type":78},{"_":80,"mainLang":81,"languages":417},[80],{"n":84,"url":419,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004418_tiled.tif",[421],{"atLeast":336,"atMost":336},[94,96,97],[99,101,102],[425,384,426,15,259,23,107,108,109,110,108,298,112,81],"isic004418",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ς̣ \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Γ̣ερόντιου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":429,"ptr":430,"ref":431,"title":2,"citation":5,"uri":6},"107 no.8 and fig.9",{"target":117},{"_":119,"target":119},{"file":433,"uri":433,"title":434,"status":435,"editionAuthor":13,"type":436,"objectType":437,"material":438,"condition":26,"layoutDesc":439,"handNote":443,"date":449,"places":450,"geo":453,"provenance":55,"provenanceGeo":455,"country":70,"region":71,"settlement":59,"repository":456,"idno":457,"textLang":458,"tmNumber":26,"facsimile":460,"letterHeights":462,"publications":465,"zotero":466,"keywords":467,"html":471,"bibl":472,"citedRangeSort":473,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004420","Epitaph for Aristokrates",{"_":12},{"_":15,"ana":16,"ref":17},{"_":259,"ana":260,"ref":261},{"_":23,"ana":24,"ref":25},{"layout":440},{"p":441,"rs":442,"damage":26},"Two lines of Greek letters rather irregularly laid out (not strictly observing the horizontal) and not strictly centred; the single word is split across two lines",{"_":31,"ana":32,"ref":33},{"lettering":444,"dimensions":445},"Somewhat irregular plainly cut, widely spaced letters, poorly laid out. Alpha is broad with straight bar; rho has closed eye, somewhat angular in the first instance, more curved in the second; sigma has horizontal top and bottom strokes, angular mid-strokes, very crudely done in the first instance; omicron is very small and mid-line; kappa has short equal bars joined to the vertical; epsilon has shorter middle bar.",[446,448],{"type":38,"l":363,"from":40,"to":46,"h":447,"unit":42,"atLeast":447,"atMost":447},"49",{"type":44,"l":45,"from":40,"to":46,"unit":42},{"_":407,"notBefore":137,"notAfter":184,"evidence":52},[451,452],{"_":55,"type":56,"ref":57,"corresp":276},{"_":59,"type":60,"ref":61,"offset":62},[454],[65,66],[68,69],{"_":282,"role":283,"ref":284},{"type":78},{"_":80,"mainLang":81,"languages":459},[80],{"n":84,"url":461,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004420_tiled.tif",[463],{"atLeast":464,"atMost":464},49,[97],[102],[468,469,470,15,259,23,107,108,109,110,108,298,112,81],"isic004420","epitaph for aristokrates",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">\u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀριστοκρά \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τεος \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":473,"ptr":474,"ref":475,"title":2,"citation":5,"uri":6},"108 no.10 and fig.11",{"target":117},{"_":119,"target":119},{"file":477,"uri":477,"title":478,"status":479,"editionAuthor":13,"type":480,"objectType":481,"material":482,"condition":26,"layoutDesc":483,"handNote":487,"date":493,"places":495,"geo":498,"provenance":55,"provenanceGeo":500,"country":70,"region":71,"settlement":59,"repository":501,"idno":502,"textLang":503,"tmNumber":26,"facsimile":505,"letterHeights":507,"publications":510,"zotero":511,"keywords":512,"html":516,"bibl":517,"citedRangeSort":518,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004421","Epitaph for Athanippos",{"_":12},{"_":15,"ana":16,"ref":17},{"_":259,"ana":260,"ref":261},{"_":23,"ana":24,"ref":25},{"layout":484},{"p":485,"rs":486,"damage":26},"A single line of Greek letters filling the width of the stele, approximately 20 cm from the top of the stele.",{"_":31,"ana":32,"ref":33},{"lettering":488,"dimensions":489},"Plainly cut and fairly regular squarish letters. Alpha has broken bar (and in the first instance, shows a slight apex at the top); theta is smaller than other letters and mid-line, with a single central dot; nu has equal length vertical strokes (the right slightly off vertical); pi is quadrate in form with nearly equal length vertical strokes and slightly overlapping horizontal; omicron is slightly smaller than other letters and mid-line.",[490,492],{"type":38,"l":39,"from":40,"to":40,"h":491,"unit":42,"atLeast":491,"atMost":491},"29",{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":494,"notBefore":137,"notAfter":184,"evidence":52},"The tomb has not been excavated, but the cemetery went out of use around the end of the 3rd century BCE, offering a terminus ante quem",[496,497],{"_":55,"type":56,"ref":57,"corresp":276},{"_":59,"type":60,"ref":61,"offset":62},[499],[65,66],[68,69],{"_":282,"role":283,"ref":284},{"type":78},{"_":80,"mainLang":81,"languages":504},[80],{"n":84,"url":506,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004421_tiled.tif",[508],{"atLeast":509,"atMost":509},29,[97],[102],[513,514,515,15,259,23,107,108,109,110,108,298,112,81],"isic004421","epitaph for athanippos",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀθανίππου \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":518,"ptr":519,"ref":520,"title":2,"citation":5,"uri":6},"108 no.11 and fig.12",{"target":117},{"_":119,"target":119},{"file":522,"uri":522,"title":523,"status":524,"editionAuthor":13,"type":525,"objectType":526,"material":527,"condition":26,"layoutDesc":528,"handNote":532,"date":537,"places":539,"geo":542,"provenance":55,"provenanceGeo":544,"country":70,"region":71,"settlement":59,"repository":545,"idno":546,"textLang":548,"tmNumber":26,"facsimile":550,"letterHeights":552,"publications":554,"zotero":555,"keywords":556,"html":560,"bibl":561,"citedRangeSort":562,"languageSort":80,"materialSort":23,"typeSort":15},"ISic004422","Epitaph for Artemidoros (?)",{"_":12},{"_":15,"ana":16,"ref":17},{"_":259,"ana":260,"ref":261},{"_":23,"ana":24,"ref":25},{"layout":529},{"p":530,"rs":531,"damage":26},"A single line of rather irregular Greek letters, seemingly not precisely centred on the stone, with empty space below; the right hand end of the text is lost to damage.",{"_":31,"ana":32,"ref":33},{"lettering":533,"dimensions":534},"Somewhat crudely cut and rather irregular letters. Alpha has straight bar; rho has somewhat elongated closed eye; epsilon has shorter middle bar; mu has vertical first and last strokes, mid-strokes formed by diagonals which meet about half-way down; delta is rather small and off-vertical; omega appears to be small, above the line, open, and with outward and downward angled arms.",[535,536],{"type":38,"l":39,"from":40,"to":40,"h":491,"unit":42,"atLeast":491,"atMost":491},{"type":44,"l":45,"from":40,"to":46,"h":47,"unit":42},{"_":538,"notBefore":137,"notAfter":184,"evidence":52},"The cemetery went out of use around the end of the 3rd century BCE or early 2nd century, offering a terminus ante quem",[540,541],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61,"offset":62},[543],[65,66],[68,69],{"_":73,"role":74,"ref":75},{"_":547,"type":78},"ME23440",{"_":80,"mainLang":81,"languages":549},[80],{"n":84,"url":551,"height":86,"width":87,"desc":88,"surfaceType":89},"ISic004422_tiled.tif",[553],{"atLeast":509,"atMost":509},[96,97],[101,102],[557,558,559,15,259,23,107,108,109,110,108,111,112,81],"isic004422","epitaph for artemidoros (?)",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἀρτεμιδω̣[ρου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":562,"ptr":563,"ref":564,"title":2,"citation":5,"uri":6},"108 no.12 and fig.13",{"target":117},{"_":119,"target":119},{"file":566,"uri":566,"title":567,"status":568,"editionAuthor":13,"type":569,"objectType":570,"material":571,"condi