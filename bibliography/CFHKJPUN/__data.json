 Greek, given the presence of L in the second line.",[35,41,45,49,53],{"type":36,"l":37,"from":38,"to":38,"h":39,"unit":40},"letterHeight","Line 1","line1","120-130","mm",{"type":36,"l":42,"from":43,"to":43,"h":44,"unit":40},"Line 2","line2","100-110",{"type":36,"l":46,"from":47,"to":47,"h":48,"unit":40},"Line 3","line3","100",{"type":50,"l":51,"from":38,"to":43,"h":52,"unit":40},"interlinear","Interlineation line 1 to 2","30-40",{"type":50,"l":54,"from":43,"to":47,"h":55,"unit":40},"Interlineation line 2 to 3","10-30",{"_":57,"notBefore":58,"notAfter":59,"precision":60},"5th century CE or later (?)",401,700,"low",[62,66],{"_":63,"type":64,"ref":65},"Centuripae","ancient","http://pleiades.stoa.org/places/462153",{"_":67,"type":68,"ref":69},"Centuripe","modern","http://sws.geonames.org/2525032",[71],[72,73],37.62336,14.74049,[75,76],37.6313,14.79676,"Italy","Sicily","Adrano",{"_":81,"role":82,"ref":83},"Museo Archeologico Regionale di Adrano","museum","http://sicily.classics.ox.ac.uk/museum/021",{"_":85,"type":86},"480","inventory",{"_":88,"mainLang":89,"otherLangs":90,"ana":91,"languages":92},"Ancient Greek and Latin","grc","la","#bilingualism.biscriptal-phenomena.graphic-interference",[93,94],"Ancient Greek","Latin","493020",{"n":97,"url":98,"height":99,"width":100,"desc":101,"surfaceType":102},"screen","ISic001404_tiled.tif","5520px","3680px","Photo J. Prag, courtesy Museo Archeologico Regionale di Adrano","front",[],[105,106,107,108,109,110,111,112,113,114,115,116],"IG, 1890","Supplementum epigraphicum graecum, 1923-",", , 1853, CIG","Per una storia della 'chora Katanaia', 1994","Per una carta archeologica del territorio di Centuripe, 2002","Centuripe (EN). Indagini su un territorio della Sicilia centro-orientale, 2010","Siciliæ obiacentium insular. et Bruttiorum antiquæ tabulæ, cum animadversionib, 1624 [1625]","Siciliae et objacentium insularum veterum inscriptionum nova collectio, 1769","Siciliae et objacentium insularum veterum inscriptionum nova collectio pr