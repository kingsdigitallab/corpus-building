{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":7,"isBulletin":815},{"title":2,"author":3,"date":4,"citation":5,"uri":6},"Centuripe","Libertini","1926","\u003Cspan>Guido Libertini, \u003Ci>Centuripe\u003C/i> (Catania, 1926)\u003C/span>","https://www.zotero.org/groups/isicily/items/VJZRAI26",[8,140,220,286,370,431,495,575,644],{"file":9,"uri":9,"title":10,"status":11,"editionAuthor":13,"type":14,"objectType":18,"material":22,"condition":32,"layoutDesc":34,"handNote":43,"date":60,"places":65,"geo":74,"country":70,"provenance":67,"provenanceGeo":78,"region":81,"settlement":2,"repository":82,"idno":86,"textLang":89,"tmNumber":93,"facsimile":94,"letterHeights":101,"publications":107,"zotero":114,"keywords":121,"html":132,"bibl":133,"bulletinDateSort":139,"citedRangeSort":134,"languageSort":90,"materialSort":23,"typeSort":15},"ISic000655","Honorific inscription for Clodia Falconilla",{"_":12},"edited",null,{"_":15,"ana":16,"ref":17},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html",{"_":19,"ana":20,"ref":21},"plaque","#object.plaque","https://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":23,"ana":24,"type":25,"subtype":26,"resp":30,"ref":31},"Coarse-grained, banded, white marble, likely Thasian-1, Thasian-2, Proconnesian. Digital microscopy: heteroblastic fabric (identification based on pXRF, digital microscopy)","#material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Thasian-1 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Thasian-2 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Proconnesian","stone.marble",[27,28,29],"Thasian-1","Thasian-2","Proconnesian","#Coccato","http://www.eagle-network.eu/voc/material/lod/48.html",{"ana":33},"#condition.damaged",{"layout":35},{"p":36,"rs":37,"damage":41},"Five lines of Latin text, in straight alignment and shifted toward the right, with a wider left margin.The letters in the first line, which is partially legible, are of slightly greater module than those in the following lines, and are more widely spaced. The last line – of which only parts of one or more letters are preserved (perhaps an A and and the left apex of a V; an M is also possible) are preserved – appears more centered, with both left and right margins wider.",{"_":38,"ana":39,"ref":40},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":42},"text_condition.partly_illegible",{"lettering":44,"dimensions":45},"Elegant square capital letters, slightly verticalized, with serifs. The O in l. 1 is square in shape compared to the O in the other lines; A has a vertical crossbar, P has an open loop. In l. 2, a triple nexus links the letters T, R, and I, with the I rising above. In l. 4, there is spacing between the words Sosius and Priscus. Comma-shaped punctuation marks appear in ll. 1 and 3. A damaged ivy leaf appears at the end of l. 1.",[46,53],{"type":47,"l":48,"from":49,"to":50,"h":51,"unit":52,"atLeast":51,"atMost":51},"letterHeight","Line 1-4","line1","line4","80","mm",{"type":54,"l":55,"from":49,"to":56,"h":57,"unit":52,"atLeast":58,"atMost":59},"interlinear","Interlineation line 1 to 5","line5","30-35","30","35",{"_":61,"notBefore":62,"notAfter":63,"evidence":64},"Early 2nd century, mother of cos. 108 CE",101,120,"prosopography",[66,71],{"_":67,"type":68,"ref":69,"region":70},"Centuripae","ancient","http://pleiades.stoa.org/places/462153","Sicilia",{"_":2,"type":72,"ref":73,"region":70},"modern","http://sws.geonames.org/2525032",[75],[76,77],37.62336,14.74049,[79,80],37.62257,14.74099,"Sicily",{"_":83,"role":84,"ref":85},"Museo Archeologico Regionale di Centuripe","museum","http://sicily.classics.ox.ac.uk/museum/002",{"_":87,"type":88},"KA0858","inventory",{"_":90,"mainLang":91,"languages":92},"Latin","la",[90],"493945",{"n":95,"url":96,"height":97,"width":98,"desc":99,"surfaceType":100},"screen","ISic000655_tiled.tif","3680