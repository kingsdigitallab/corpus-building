 id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>ἐκ τῶν ἰδίων \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">l.3 reg., orig. ἐπόησε\u003C/p>",{"author":3,"date":4,"citedRange":641,"ptr":642,"ref":643,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"78",{"target":136},{"_":138,"target":138},{"file":645,"uri":645,"title":646,"status":647,"editionAuthor":13,"type":648,"objectType":649,"material":650,"condition":653,"layoutDesc":654,"handNote":659,"date":766,"places":770,"geo":773,"country":70,"provenance":67,"provenanceGeo":775,"region":81,"settlement":776,"repository":777,"idno":780,"textLang":782,"tmNumber":784,"facsimile":785,"letterHeights":788,"publications":798,"zotero":801,"keywords":804,"html":810,"bibl":811,"bulletinDateSort":139,"citedRangeSort":814,"languageSort":612,"materialSort":153,"typeSort":436},"ISic001394","A dedication to Apollo",{"_":12},{"_":436,"ana":437,"ref":438},{"_":19,"ana":20,"ref":151},{"_":153,"ana":651,"type":154,"subtype":652,"resp":30,"ref":155},"#material.inorganic.stone.sedimentary_rock.limestone.calcarenite",[234],{"ana":33},{"layout":655},{"p":656,"rs":657,"damage":658},"Five lines of Greek text, with a regular left margin, but uneven right margin; line 3 in particular shows signs of cramping in the second half. The lower half of the final line is lost through damage.",{"_":38,"ana":39,"ref":40},{"ana":164},{"lettering":660,"dimensions":746},[661,662],"Neat, regular letters, mostly of wide module, without serifs. Alpha is broad with straight bar; epsilon has notably short middle bar; kappa has arms of almost full length; omicron is only lightly smaller than other letters (19-20 mm); pi has even length vertical hastae; rho has small closed round head; sigma is four bar with extended horizontal top and bottom strokes; upsilon is neatly symmetrical; phi has small circular eye with vertical only slightly extended (26 mm); omega is full-size and nearly circular, closed, with long horizontal.",{"_":6