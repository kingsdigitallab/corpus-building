onia di Augusta Himereorum Thermitanorum",[99,94,95,96,97,98,101,285,103,286],"7IFS6HUP","UK3583CG",[288,289,290,161,17,122,108,109,110,111,109,291,114,72],"isic000092","honours for caius maesius",{"_":10},"museo civico baldassare romano","Text encoding: Tuuli Ahlholm, edition source:",{"file":294,"uri":294,"title":295,"status":296,"editionAuthor":11,"type":298,"objectType":299,"material":303,"condition":304,"layoutDesc":305,"handNote":311,"date":345,"places":348,"geo":351,"country":60,"region":61,"settlement":53,"repository":353,"idno":354,"textLang":356,"facsimile":358,"provenance":49,"letterHeights":361,"publications":380,"zotero":382,"keywords":384,"html":388},"ISic000093","Honorific for Titianus on the occasion of his assumption of the toga virilis",{"_":297},"edited",{"_":161,"ana":162,"ref":163},{"_":300,"ana":301,"ref":302},"stele","#object.stele","https://www.eagle-network.eu/voc/objtyp/lod/250",{"_":122,"ana":123,"ref":124},{"ana":167},{"layout":306},{"p":307,"rs":308,"damage":309},"Eight lines of continuous Latin text. Text fills most of stone, with stone-carver attempting to centre text onto stone. Upright hedera in line 4, with right-facing tail. Two final lines smaller.  Occasional use of interpuncts, in lines 1, 2, 5 and 6: tick-shaped in line 1, and more Y-shaped in subsequent lines. Some sort of interpunct/squiggle in line 8. Representing a pointed tilde (~)",{"_":28,"ana":29,"ref":30},{"ana":310},"#text_condition.complete",{"lettering":312,"dimensions":313},"Letters are tall and elongated. Ornate serifs used on every letter. Letters extremely regular and spacing between letters is consistent.",[314,317,321,324,328,330,334,340,344],{"type":34,"l":131,"from":36,"to":36,"h":315,"unit":37,"atLeast":316,"atMost":180},"87-92","87",{"type":34,"l":182,"from":41,"to":41,"h":318,"unit":37,"atLeast":319,"atMost":320},"81-89","81","89",{"type":34,"l":187,"from":188,"to":188,"h":322,"unit":37,"atLeast":323,"atMost":320},"82-89","82",{"type":34,"l":193,"from":194,"to":194,"h":325,"unit":37,"atLeast":326,"atMost":327},"79-93","79","93",{"type":34,"l":199,"from":200,"to":200,"h":329,"unit":37,"atLeast":320,"atMost":185},"89-90",{"type":34,"l":204,"from":205,"to":205,"h":331,"unit":37,"atLeast":332,"atMost":333},"78-85","78","85",{"type":34,"l":335,"from":336,"to":336,"h":337,"unit":37,"atLeast":338,"atMost":339},"Line 7","line7","19-23","19","23",{"type":34,"l":341,"from":342,"to":342,"h":343,"unit":37,"atLeast":338,"atMost":229},"Line 8","line8","19-22",{"type":39,"l":133,"from":36,"to":41,"unit":37},{"_":346,"notBefore":347,"notAfter":45,"evidence":234},"3rd century CE on prosopographical grounds (but difficult to pin down more tightly) - so too Barbieri",201,[349,350],{"_":49,"type":50,"ref":51,"cert":46},{"_":53,"type":54,"ref":55},[352],[58,59],{"_":241,"role":65,"ref":242},{"_":355,"type":69},"109",{"_":71,"mainLang":72,"languages":357},[71],{"n":75,"url":359,"height":78,"width":77,"desc":360,"surfaceType":80},"ISic000093_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 08-07-2022",[362,364,367,369,372,373,376,379],{"atLeast":363,"atMost":253},87,{"atLeast":365,"atMost":366},81,89,{"atLeast":368,"atMost":366},82,{"atLeast":370,"atMost":371},79,93,{"atLeast":366,"atMost":256},{"atLeast":374,"atMost":375},78,85,{"atLeast":377,"atMost":378},19,23,{"atLeast":377,"atMost":279},[88,281,84,85,86,87,90,91,381,92],"Barbieri, 1961, Nuove inscrizioni di Marsala",[99,94,95,96,97,98,101,102,383,103],"KHCM59WG",[385,386,387,161,300,122,108,109,110,111,109,291,114,72],"isic000093","honorific for titianus on the occasion of his assumption of the toga virilis",{"_":297},"Text encoding: Tuuli Ahlholm; Alex Antoniou, edition source:",{"file":390,"uri":390,"title":391,"status":392,"editionAuthor":11,"type":393,"objectType":394,"material":398,"condition":24,"layoutDesc":402,"handNote":406,"date":410,"