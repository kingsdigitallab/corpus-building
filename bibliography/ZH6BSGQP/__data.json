u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan class=\"underline\">πινον\u003C/span>  \u003Cspan class=\"underline\">τὰ\u003C/span>  \u003Cspan class=\"underline\">\u003Cspan class=\"supraline\" title=\"line above\">θ\u003C/span>(ε)\u003Cspan class=\"supraline\" title=\"line above\">ῶ\u003C/span>\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ν\u003C/span>\u003C/span>  \u003Cspan class=\"underline\">\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ἐ\u003C/span>νθάδ\u003C/span>’ [ἐ]μέ. εὐψύχ\u003Cspan class=\"small\" title=\"small character: ι\">ι\u003C/span> οὐδ\u003Cspan class=\"small\" title=\"small character: ὶ\">ὶ\u003C/span>ς \u003Cspan class=\"small\" title=\"small character: ἀ\">ἀ\u003C/span>-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>\u003Cspan class=\"underline\">θά\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ν͡α͡τ\u003C/span>ος\u003C/span> · \u003Cspan class=\"underline\">ταῦτα\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Οὐάλης\">\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Οὐάλης\">\u003Cspan class=\"underline\">Οὐάλ\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">η͡ς\u003C/span>\u003C/span>\u003C/span>\u003C/span>  \u003Cspan class=\"underline\">μ\u003C/span>\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ν͡ή\u003C/span>μ\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">η͡ς\u003C/span> χ\u003Cspan class=\"small\" title=\"small character: ά\">ά\u003C/span>ριν ἀ\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ν͡έ\u003C/span>-\u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>\u003Cspan class=\"underline\">θηκα\u003C/span>  \u003Cspan class=\"underline\">ἐγὼ\u003C/span>  \u003Cspan class=\"underline\">σέ\u003C/span>  \u003Cspan class=\"underline\">ἐμὲ\u003C/span>  \u003Cspan class=\"underline\">τίς\u003C/span>. \u003Cspan class=\"underline\">Εὐψύχι\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Νικήφορε\">\u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Νικήφορε\">\u003Cspan class=\"underline\">Ν\u003C/span>ι̣κ\u003Cspan class=\"small\" title=\"small character: ή\">ή\u003C/span>φορε\u003C/span>\u003C/span> οὐδὶς ἀθά\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ν͡α͡τ\u003C/span>\u003Cspan class=\"small\" title=\"small character: ος\">ος\u003C/span>  \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":137,"ptr":138,"ref":140,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"526-528",{"target":139},"https://www.zotero.org/groups/382445/items/ZH6BSGQP",{"_":141,"target":141},"https://biblio.inscriptiones.org/epig10001622",1981,false],"uses":{"params":["slug"]}}]}
