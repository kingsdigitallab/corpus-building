":30},{"dimensions":117},[118,122],{"type":34,"l":119,"from":36,"to":120,"h":121,"unit":37},"Lines 1-5","line5","33-34",{"type":39,"l":123,"from":36,"to":120,"h":124,"unit":37},"Interlineation lines 1 to 5","11-15",{"_":126,"notBefore":127,"notAfter":128,"precision":46},"2nd — 3rd century CE",101,300,[130,131],{"_":49,"type":50,"ref":51},{"_":53,"type":54,"ref":55},[133],[58,59],{"_":63,"role":64,"ref":65},{"_":136,"type":68},"A3573",{"_":70,"mainLang":71,"languages":138},[70],{"n":74,"url":140,"height":76,"width":77,"desc":78,"surfaceType":79},"ISic001497_tiled.tif",[],[82,83,85,84],[88,89,91,90],[145,146,147,13,17,21,97,98,99,100,98,101,102,71],"isic001497","epitaph for caius terentius symphorus",{"_":10},"Text encoding: Michael Economou, edition source:",{"file":150,"uri":150,"title":151,"status":152,"editionAuthor":11,"type":153,"objectType":154,"material":155,"condition":24,"layoutDesc":156,"handNote":159,"date":163,"places":164,"geo":167,"country":60,"region":61,"settlement":53,"repository":169,"idno":170,"textLang":171,"facsimile":175,"provenance":49,"letterHeights":177,"publications":178,"zotero":180,"keywords":182,"html":187},"ISic001498","I.Sicily inscription 001498",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":111,"ana":22,"ref":23},{"layout":157},{"rs":158,"damage":24},{"_":28,"ana":29,"ref":30},{"dimensions":160},[161,162],{"type":34,"l":35,"from":36,"to":36,"unit":37},{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":126,"notBefore":127,"notAfter":128,"precision":46},[165,166],{"_":49,"type":50,"ref":51},{"_":53,"type":54,"ref":55},[168],[58,59],{"_":63,"role":64,"ref":65},{"_":136,"type":68},{"_":172,"mainLang":173,"languages":174},"Ancient Greek","grc",[172],{"n":74,"url":176,"height":76,"width":77,"desc":78,"surfaceType":79},"ISic001498_tiled.tif",[],[179,83,85,84,86],"Supplementum epigraphicum graecum, 1923-",[181,89,91,90,92],"F2GG87EQ",[183,184,185,13,17,21,97,98,99,100,98,101,186,173],"isic001498","i.sicily inscription 001498",{"_":10},"ancient greek","Text encoding: Estella Kessler, edition source:",{"file":189,"uri":189,"title":190,"status":191,"editionAuthor":11,"type":192,"objectType":196,"material":200,"condition":204,"layoutDesc":206,"handNote":214,"date":221,"places":226,"geo":229,"country":60,"region":61,"settlement":53,"repository":231,"idno":232,"textLang":234,"facsimile":238,"provenance":49,"letterHeights":240,"publications":241,"zotero":248,"keywords":255,"html":261},"ISic001621","I.Sicily inscription 001621",{"_":10},{"_":193,"ana":194,"ref":195},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":197,"ana":198,"ref":199},"altar","#object.altar","http://www.eagle-network.eu/voc/objtyp/lod/29.html",{"_":201,"ana":202,"ref":203},"limestone (Muschelkalk)","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":205},"#con",{"layout":207},{"p":208,"rs":209,"damage":24},"The inscription is cut into the stucco in the recess and the letters are painted red. Much of the bottom of the stucco has been damaged. “It is highly likely that there was a third line in the [recessed stucco] panel, and quite possible that there were further lines on a block below.” (Crawford 2011)",[210,211],{"_":28,"ana":29,"ref":30},{"_":212,"ana":213},"Rubrication, red coloured","#execution.rubrication.red",{"lettering":215,"dimensions":216},"The text is written in the adapted Ionic Greek alphabet which was usually employed to write Oscan in Lucania and Bruttium from around the fourth to the first centuries BC.",[217,220],{"type":34,"l":218,"from":36,"to":41,"h":219,"unit":37},"Line 1-2","20",{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":222,"notBefore":223,"notAfter":224,"evidence":225},"After the Mamertine occupation in 288 BCE, perhaps soon after, and unlikely to be later than the third century.",-288,-201,"textual-context",[227,228],{"_":49,"type":50,"ref":51},{"_":53,"type":54,"ref":55},[230],[58,59],{"_":63,"role":64,"ref":65},{"_":233,"type":68},"A240",{"_":235,"mainLang":236,"languages":237},"Oscan","osc",[235],{"n":74,"url":239,"height":76,"width":77,"desc":78,"surfaceType":79},"ISic001621_tiled.tif",[],[242,84,243,244,245,246,247],"Vetter, 1953, Handbuch der italischen Dialekte","Parlangèli, 1956, Le iscrizioni osche (mamertine) di Messina","Rix, 2002, Sabellische Texte : die Texte des Oskischen, Umbrischen und Südpikenischen","Crawford, 2011, Imagines Italicae. A Corpus of Italic Inscriptions","Crawford, 2006, The Oscan Inscriptions of Messana","Mastelloni, 2005, Messana e i Mamertini",[249,90,250,251,252,253,254],"6C5ZKCF2","AFQ8FDTW","SH6KBKBT","2BHFHCRR","G82KT6YE","NLNL64ZE",[256,257,258,193,197,259,97,98,99,100,98,101,260,236],"isic001621","i.sicily inscription 001621",{"_":10},"limestone (muschelkalk)","oscan","Text encoding: Katherine McDonald, edition source:",{"file":263,"uri":263,"title":264,"status":265,"editionAuthor":11,"type":266,"objectType":267,"material":271,"condition":273,"layoutDesc":275,"handNote":281,"date":286,"places":289,"geo":292,"country":60,"region":61,"settlement":53,"repository":294,"idno":295,"textLang":297,"facsimile":299,"provenance":49,"letterHeights":304,"publications":305,"zotero":307,"keywords":309,"html":313},"ISic001623","Dedication to Apollo",{"_":10},{"_":193,"ana":194,"ref":195,"cert":46},{"_":268,"ana":269,"ref":270},"block","#object.block","http://www.eagle-network.eu/voc/objtyp/lod/189.html",{"_":272,"ana":202,"ref":203},"limestone",{"ana":274},"#condition.damaged",{"layout":276},{"p":277,"rs":278,"damage":279},"Two lines with clear vacats above and below, uniform right margin",{"_":28,"ana":29,"ref":30},{"ana":280},"#text_condition.incomplete",{"dimensions":282},[283,285],{"type":34,"l":218,"from":36,"to":41,"h":284,"unit":37},"60-90",{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":287,"notBefore":223,"notAfter":288,"evidence":225},"mid-3rd century BCE",-225,[290,291],{"_":49,"type":50,"ref":51},{"_":53,"type":54,"ref":55