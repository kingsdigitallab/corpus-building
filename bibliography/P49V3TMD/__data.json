":29,"ref":30},{"ana":280},{"lettering":451,"dimensions":452},"Lunate sigma and epsilon.",[453,454],{"type":34,"l":35,"from":36,"to":36,"unit":37},{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":418,"notBefore":379,"notAfter":128,"precision":46},[457,458],{"_":49,"type":50,"ref":51},{"_":53,"type":54,"ref":55},[460],[58,59],{"_":63,"role":64,"ref":65},{"_":172,"mainLang":173,"languages":463},[172],{"n":74,"url":465,"height":76,"width":77,"desc":78,"surfaceType":79},"ISic003509_tiled.tif",[],[83,84],[89,90],[470,471,472,13,17,21,97,98,99,100,98,101,186,173],"isic003509","i.sicily inscription 003509",{"_":10},{"file":474,"uri":474,"title":475,"status":476,"editionAuthor":11,"type":477,"objectType":478,"material":479,"condition":24,"layoutDesc":480,"handNote":484,"date":497,"places":498,"geo":501,"country":60,"region":61,"settlement":53,"repository":503,"idno":504,"textLang":506,"facsimile":508,"provenance":49,"letterHeights":510,"publications":511,"zotero":512,"keywords":513,"html":517},"ISic003510","Epitaph for Lucius Ostrius Crescens",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":111,"ana":22,"ref":23},{"layout":481},{"p":482,"rs":483,"damage":24},"Four lines of Latin letters approximately centred on the stone",{"_":28,"ana":29,"ref":30},{"lettering":485,"dimensions":486},"Thinly but deeply incised regular letters with minimal serifs and of slightly uneven size. R has a small open eye, with a long straight tail; E is fully perpendicular with equal length strokes; M is made up four equal oblique strokes reaching to top and bottom of the line.",[487,489,492,495],{"type":34,"l":35,"from":36,"to":36,"h":488,"unit":37},"25",{"type":34,"l":490,"from":41,"to":41,"h":491,"unit":37},"Line 2","20-22",{"type":34,"l":493,"from":494,"to":372,"h":219,"unit":37},"Lines 3-4","line3",{"type":39,"l":375,"from":36,"to":372,"h":496,"unit":37},"9-14",{"_":418,"notBefore":379,"notAfter":128,"precision":46},[499,500],{"_":49,"type":50,"ref":51},{"_":53,"type":54,