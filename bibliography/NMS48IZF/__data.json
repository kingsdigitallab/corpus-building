lass=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":120,"ptr":182,"ref":183,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":122},{"_":124,"target":124},{"file":185,"uri":185,"title":186,"status":187,"editionAuthor":13,"type":188,"objectType":190,"material":192,"condition":196,"layoutDesc":197,"handNote":203,"date":215,"places":218,"geo":222,"country":64,"provenance":61,"provenanceGeo":224,"region":74,"settlement":66,"repository":225,"textLang":228,"tmNumber":232,"facsimile":233,"letterHeights":238,"publications":245,"zotero":247,"keywords":249,"html":256,"bibl":257,"bulletinDateSort":125,"citedRangeSort":258,"languageSort":229,"materialSort":193,"typeSort":15},"ISic003420","Fragment of an imperial honorific",{"_":12},{"_":15,"ana":16,"ref":189},"https://www.eagle-network.eu/voc/objtyp/lod/69.html",{"_":19,"ana":20,"ref":191},"https://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":193,"ana":194,"type":25,"subtype":195,"resp":27,"ref":28},"Coarse-grained, homogeneous, white marble, likely Aphrodisian, Parian-2, Parian-3, Parian-4, Proconnesian, Thasian-3 (identification based on digital microscopy)","#material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Aphrodisian #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-2 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-3 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Parian-4 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Proconnesian #material.inorganic.stone.metamorphic_rock.marble.dolomitic_marble.Thasian-3","Aphrodisian|Parian-2|Parian-3|Parian-4|Proconnesian|Thasian-3",{"ana":30},{"layout":198},{"p":199,"rs":200,"damage":201},"The beginning of two lines of monumental letters are preserved on the stone. A substantial left margin is preserved at the start of each line. Unless the lines below were substantially further indented, there was no text below; the preserved vacat above line 1 (90mm)  is significantly greater than that between lines 1 and 2 (57mm), so it is unclear if another line originally stood above (the top of the stone appears intact) - if it did, it was either significantly above the preserved first line and/or indented several letters to the right.",{"_":34,"ana":35,"ref":36},{"ana":202},"#text_condition.incomplete",{"lettering":204,"dimensions":205},"Deep, very regular, v-cut letters, with a broad v-cut, hair-line extensions to wedge serifs, and a quite wide square module. The I in line one is extended.",[206,210,213],{"type":42,"l":207,"from":44,"to":44,"h":208,"unit":47,"atLeast":209,"atMost":209},"Line 1","68 (I = 87)","68",{"type":42,"l":211,"from":53,"to":53,"h":212,"unit":47,"atLeast":212,"atMost":212},"Line 2","58",{"type":51,"l":52,"from":44,"to":53,"h":214,"unit":47,"atLeast":214,"atMost":214},"57",{"_":216,"notBefore":154,"notAfter":58,"evidence":217},"First or second century","lettering",[219,221],{"_":61,"type":62,"ref":63,"corresp":220,"region":64},"#findspot",{"_":66,"type":67,"ref":68,"region":64},[223],[71,72],[],{"_":226,"role":77,"ref":227},"Teatro Romano di Catania","http://sicily.classics.ox.ac.uk/museum/017",{"_":229,"mainLang":230,"languages":231},"Latin","la",[229],"644815",{"n":88,"url":234,"height":235,"width":236,"desc":237,"surfaceType":93},"ISic003420_tiled.tif","4080px","3072px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2024-03-19",[239,241,243],{"atLeast":240,"atMost":240},68,{"atLeast":242,"atMost":242},58,{"atLeast":244,"atMost":244},57,[102,246],"Manganaro, 1988, La Sicilia da Sesto Pompeo a Diocleziano",[107,248],"RZSFKACR",[250,251,252,15,19,253,112,113,114,115,113,254,255,230],"isic003420","fragment of an imperial honorific",{"_":12},"coarse-grained, homogeneous, white marble, likely aphrodisian, parian-2, parian-3, parian-4, proconnesian, thasian-3 (identification based on digital microscopy)","teatro romano di catania","latin","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>div[o \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>tri[bunicia potestate \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":258,"ptr":259,"ref":260,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"241",{"target":122},{"_":124,"target":124},{"file":262,"uri":262,"title":263,"status":264,"editionAuthor":13,"type":266,"objectType":268,"material":269,"condition":37,"layoutDesc":273,"handNote":281,"date":289,"places":292,"geo":295,"country":64,"provenance":61,"provenanceGeo":297,"region":74,"settlement":66,"repository":300,"idno":301,"textLang":303,"tmNumber":305,"facsimile":306,"letterHeights":309,"publications":314,"zotero":316,"keywords":318,"html":323,"bibl":324,"bulletinDateSort":125,"citedRangeSort":325,"languageSort":229,"materialSort":270,"typeSort":15},"ISic000337","Fragmentary inscription of Lucius Caelius",{"_":265},"edited",{"_":15,"ana":16,"ref":17,"cert":267},"low",{"_":19,"ana":20,"ref":137},{"_":270,"ana":271,"type":25,"subtype":272,"resp":27,"ref":28},"Very fine-grained, veined, white marble, likely Lunense, Docimian, Göktepe, Hymettan. Digital microscopy: homeoblastic fabric (identification based on pXRF, digital microscopy)","#material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Lunense #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Docimian #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Goktepe #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Hymettan","Lunense|Docimian|Gök