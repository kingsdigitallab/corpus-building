21,"ref":22},{"_":24,"ana":25,"ref":26},{"ana":234},{"layout":298},{"rs":299,"damage":27},{"_":33,"ana":34,"ref":35},{"lettering":301,"dimensions":302},"Relatively tall letters with modest serfis/terminations to the strokes. Rho is open; Sigma is four-bar, with very shallow middle strokes; Mu has all four strokes oblique, with the middle strokes only half-height.",[303,308],{"type":43,"l":304,"from":45,"to":53,"h":305,"unit":47,"atLeast":306,"atMost":307},"Lines 1-2","25-28","25","28",{"type":51,"l":52,"from":45,"to":53,"h":248,"unit":47},{"_":310,"notBefore":57,"notAfter":150},"1st — 2nd century CE",[312,313],{"_":61,"type":62,"ref":63},{"_":65,"type":66,"ref":67},[315],[70,71],[],{"_":78,"role":79,"ref":80},{"_":162,"mainLang":159,"languages":319},[162],"645531",{"n":90,"url":322,"height":92,"width":93,"desc":323,"surfaceType":95},"ISic003208_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2016-05-13.",[325],{"atLeast":326,"atMost":327},25,28,[274,104,105],[277,108,109],[331,332,333,292,20,24,114,115,116,117,115,118,219,159],"isic003208","fragment of an honorary inscription?",{"_":131},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span> ΙΑ · Ι · ΡΗ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>  \u003Cspan data-text=\"ψηφίσμα\" data-n=\"50\" data-lemma=\"ψήφισμα\">ψηφί]σμα\u003C/span>  \u003Cspan data-text=\"παρὰ\" data-n=\"55\" data-lemma=\"παρά\">πα̣[ρὰ?\u003C/span>  \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \