":307,"unit":37},"not measured",{"_":309,"notBefore":310,"notAfter":311,"evidence":312,"precision":147},"later Hellenistic (i.e. 2nd or early 1st century BCE)",-200,-51,"lettering",[314,315],{"_":48,"type":49,"ref":50},{"_":52,"type":53,"ref":54},[317],[57,58],"Siracusa",{"_":320,"role":321,"ref":322},"Museo Archeologico Regionale Paolo Orsi","museum","http://sicily.classics.ox.ac.uk/museum/097",{"_":324,"type":325},"27720","inventory",{"_":154,"mainLang":155,"languages":327},[154],{"n":66,"url":329,"height":68,"width":69,"desc":330,"surfaceType":71},"ISic001394_tiled.tif","Photo J. Prag, Aut. Assessorato Beni Culturali Regione Siciliana n.10681 del 06/05/2014",[],[161,75,333,164,334,335],"IGRR, 1906-1927","Libertini, 1926, Centuripe","Korhonen, Soraci, 2019, Forme amministrative e scelte linguistiche nelle epigrafi e nelle monete della Sicilia romana",[168,78,337,171,338,339],"KSH4D9GK","VJZRAI26","I8LT7XNE",[341,342,343,131,187,191,83,84,85,86,344,345,178,155],"isic001394","a dedication to apollo",{"_":184},"siracusa","museo archeologico regionale paolo orsi",{"file":347,"uri":347,"title":348,"status":349,"editionAuthor":11,"type":350,"objectType":351,"material":352,"condition":24,"layoutDesc":354,"handNote":357,"date":362,"places":367,"geo":370,"country":372,"region":373,"settlement":374,"repository":375,"idno":378,"textLang":380,"provenance":48,"letterHeights":382,"publications":383,"zotero":386,"keywords":389,"html":179},"ISic001395","I.Sicily inscription 001395",{"_":10},{"_":131,"ana":132,"ref":133},{"_":187,"ana":188,"ref":189},{"_":353,"ana":22,"ref":23},"marble (white)",{"layout":355},{"rs":356,"damage":24},{"_":28,"ana":29,"ref":30},{"lettering":358,"dimensions":359},"Note presence of rhomboid omega and omicron, regular epsilon and sigma according to the transcription in the BM catalogue",[360,361],{"type":34,"l":35,"from":36,"to":36,"unit":37},{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":363,"notBefore":364,"notAfter":365,"evidence":366},"Lettering of this sort can be observed already in the later Hellenistic period in Sicily, but the use of marble may suggest that the piece belongs in the Roman period, although the absence of Roman names in turn might suggest an earlier date. Perhaps second century CE?",101,200,"lettering, material-context",[368,369],{"_":48,"type":49,"ref":50},{"_":52,"type":53,"ref":54},[371],[57,58],"United Kingdom","England","London",{"_":376,"role":321,"ref":377},"The British Museum","https://www.britishmuseum.org/",{"_":379,"type":325},"1863,0728.190",{"_":154,"mainLang":155,"languages":381},[154],[],[161,384,164,165,75,385,334],"Marshall, 1874-1916, The collection of ancient Greek inscriptions in the British Museum","Ansaldi, 1981, Memorie storiche di Centuripe",[168,387,171,172,78,388,338],"GYATLCPD","FD9JT2RS",[390,391,392,131,187,353,83,84,393,394,395,396,178,155],"isic001395","i.sicily inscription 001395",{"_":10},"united kingdom","england","london","the british museum",{"file":398,"uri":398,"title":399,"status":400,"editionAuthor":11,"type":401,"objectType":402,"material":404,"condition":405,"layoutDesc":406,"handNote":412,"date":434,"places":438,"geo":441,"country":59,"region":60,"settlement":318,"repository":443,"idno":444,"textLang":446,"facsimile":448,"provenance":48,"letterHeights":453,"publications":454,"zotero":456,"keywords":458,"html":462},"ISic001397","Epitaph for Glykera",{"_":184},{"_":13,"ana":14,"ref":15},{"_":187,"ana":188,"ref":403},"http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":191,"ana":192,"ref":193},{"ana":195},{"layout":407},{"p":408,"rs":409,"damage":410},"The layout is unusual, with the text centred in a pseudo-stoichedon, the letters equal in number on each line, irrespective of word-breaks, and vertically aligned, and the final empty letter space in line 5 occupied by a hedera. ",{"_":28,"ana":29,"ref":30},{"ana":411},"#text_condition.complete",{"lettering":413,"dimensions":414},"Neatly carved, regular letters of slightly uneven height (not v-cut, simple groove). Lunate epsilon and sigma, alpha with extended upper stroke, slight serifs to most strokes. Single interpunct before age.",[415,417,419,421,423,425,427,429,432],{"type":34,"l":35,"from":36,"to":36,"h":416,"unit":37},"26-28 (Ε is 20)",{"type":34,"l":293,"from":41,"to":41,"h":418,"unit":37},"21-23 (Σ is 18)",{"type":34,"l":296,"from":297,"to":297,"h":420,"unit":37},"23-25 (Ε is 20)",{"type":34,"l":300,"from":301,"to":301,"h":422,"unit":37},"20-24",{"type":34,"l":303,"from":304,"to":304,"h":424,"unit":37},"21-22",{"type":39,"l":40,"from":36,"to":41,"h":426,"unit":37},"10",{"type":39,"l":428,"from":41,"to":297,"h":426,"unit":37},"Interlineation line 2 to 3",{"type":39,"l":430,"from":297,"to":301,"h":431,"unit":37},"Interlineation line 3 to 4","15",{"type":39,"l":433,"from":301,"to":304,"h":426,"unit":37},"Interlineation line 4 to 5",{"_":435,"notBefore":44,"notAfter":436,"evidence":437},"1st-3rd century CE",300,"lettering, textual-context",[439,440],{"_":48,"type":49,"ref":50},{"_":52,"type":53,"ref":54},[442],[57,58],{"_":320,"role":321,"ref":322},{"_":445,"type":325},"35826",{"_":154,"mainLang":155,"languages":447},[154],{"n":66,"url":449,"height":450,"width":451,"desc":452,"surfaceType":71},"ISic001397_tiled.tif","2880px","3480px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2014-09-11",[],[455,161,75],"anonymous, 1844",[457,168,78],"W95DKLZ",[459,460,461,13,187,191,83,84,85,86,344,345,178,155],"isic001397","epitaph for glykera",{"_":184},"Text encoding: Andoni Llamazares, Jonathan Prag; edition source: autopsy Prag 2014-09-11",{"file":464,"uri":464,"title":465,"status":466,"editionAuthor":11,"type":467,"objectType":468,"material":469,"condition":470,"layoutDesc":471,"handNote":476,"date":485,"places":487,"geo":490,"country":59,"region":60,"settlement":318,"repository":492,"idno":493,"textLang":495,"facsimile":497,"prov