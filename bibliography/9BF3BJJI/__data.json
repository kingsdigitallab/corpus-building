ance":48,"letterHeights":159,"publications":160,"zotero":167,"keywords":174,"html":179},"ISic001393","I.Sicily inscription 001393",{"_":10},{"_":131,"ana":132,"ref":133},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":95,"ana":96,"ref":97},{"_":99,"ana":100,"ref":101},{"layout":137},{"rs":138,"damage":24},{"_":28,"ana":29,"ref":30},{"dimensions":140},[141,142],{"type":34,"l":35,"from":36,"to":36,"unit":37},{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":144,"notBefore":145,"notAfter":146,"precision":147},"3rd — 1st century BCE",-300,-1,"low",[149,150],{"_":48,"type":49,"ref":50},{"_":52,"type":53,"ref":54},[152],[57,58],{"_":154,"mainLang":155,"languages":156},"Ancient Greek","grc",[154],{"n":66,"url":158,"height":68,"width":69,"desc":70,"surfaceType":71},"ISic001393_tiled.tif",[],[161,162,163,164,75,165,166],"Kaibel, 1890, IG","Bulletin épigraphique, 1888-","Dubois, 1989, IGDS1","Hoffmann, 1904, SGDI","Manganaro, 1963, Nuove ricerche di epigrafia siceliota","Cappelletti, 2020, Sull'amphipolos in IG XIV 574 da Centuripe",[168,169,170,171,78,172,173],"Q2SBPG9F","77P5MNIR","RWXNUFEX","DQDPC573","M3UEW68D","5VBVFAQC",[175,176,177,131,95,99,83,84,85,86,95,178,155],"isic001393","i.sicily inscription 001393",{"_":10},"ancient greek","Text encoding: Jonathan Prag",{"file":181,"uri":181,"title":182,"status":183,"editionAuthor":11,"type":185,"objectType":186,"material":190,"condition":194,"layoutDesc":196,"handNote":202,"date":308,"places":313,"geo":316,"country":59,"region":60,"settlement":318,"repository":319,"idno":323,"textLang":326,"facsimile":328,"provenance":48,"letterHeights":331,"publications":332,"zotero":336,"keywords":340,"html":179},"ISic001394","A dedication to Apollo",{"_":184},"edited",{"_":131,"ana":132,"ref":133},{"_":187,"ana":188,"ref":189},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":191,"ana":192,"ref":193},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":195},"#condition.damaged",{"layout":197},{"p":198,"rs":199,"damage":200},"Five lines of Greek text, with a regular left margin, but uneven right margin; line 3 in particular shows signs of cramping in the second half. The lower half of the final line is lost through damage.",{"_":28,"ana":29,"ref":30},{"ana":201},"#text_condition.incomplete",{"lettering":203,"dimensions":289},[204,205],"Neat, regular letters, mostly of wide module, without serifs. Alpha is broad with straight bar; epsilon has notably short middle bar; kappa has arms of almost full length; omicron is only lightly smaller than other letters (19-20 mm); pi has even length vertical hastae; rho has small closed round head; sigma is four bar with extended horizontal top and bottom strokes; upsilon is neatly symmetrical; phi has small circular eye with vertical only slightly extended (26 mm); omega is full-size and nearly circular, closed, with long horizontal.",{"_":206,"ref":207},"\n                                    Types list:\n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                   