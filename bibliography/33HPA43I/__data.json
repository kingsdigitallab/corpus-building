 with several others almost certainly belongs in the context of the monumental stoa of the later second century BCE.",[590,591],{"_":265,"type":116,"ref":266},{"_":265,"type":120,"ref":268},[593],[271,272],{"_":595,"role":130,"ref":596},"Biblioteca comunale Calatafimi Segesta","http://sicily.classics.ox.ac.uk/museum/195",{"_":136,"mainLang":137,"languages":598},[136],{"n":140,"url":600,"height":281,"width":282,"desc":504,"surfaceType":145},"ISic001112_tiled.tif",[],[148,292,149,150,553,152,603,153,155],"Guarducci, 1876-, Notizie degli scavi di antichità",[157,304,158,159,556,161,510,162,164],[606,607,608,321,570,21,313,313,171,172,561,609,174,137],"isic001112","i.sicily inscription 001112",{"_":10},"biblioteca comunale calatafimi segesta","Text encoding: Giorgia Capra",{"file":612,"uri":612,"title":613,"status":614,"editionAuthor":615,"type":620,"objectType":623,"material":624,"condition":625,"layoutDesc":627,"handNote":633,"date":641,"places":646,"geo":649,"country":126,"region":127,"settlement":265,"repository":651,"idno":652,"textLang":654,"provenance":265,"letterHeights":656,"publications":657,"zotero":662,"keywords":667,"html":672},"ISic002727","Inscription recording works undertaken by the agoranomos Herakleios",{"_":10},{"title":616,"date":617,"citation":618,"ref":619},"Inscriptiones Segestanae. Le iscrizioni greche e latine di Segesta","2019","\u003Cspan>Carmine Ampolo e Donatella Erdas, \u003Ci>Inscriptiones Segestanae. Le iscrizioni greche e latine di Segesta\u003C/i> (Pisa: Edizioni della Normale, 2019)\u003C/span>","http://zotero.org/groups/382445/items/3PK3JKXR",{"_":621,"ana":622,"ref":522,"cert":370},"building; honorific ","#function.building #function.honorific",{"_":470,"ana":471,"ref":472},{"_":21,"ana":22,"ref":23},{"ana":626},"#condition.complete",{"layout":628},{"p":629,"rs":630,"damage":631},"Text is set out over three lines, the first two left justified, the third crudely centred, with a vacat both above and below.",{"_":29,"ana":30,"ref":31},{"ana":632},"#text_condition.complete",{"lettering":634,"dimensions":635},"The letters are incised somewhat crudely, more in the style of scratched than formally engraved letters, but of roughly equal size throughout. Lunate epsilon and sigma, uncial omega, mu tending towards cursive.",[636,639],{"type":101,"l":637,"from":103,"to":245,"h":638,"unit":104},"Line 1-3","17-22",{"type":106,"l":640,"from":103,"to":108,"unit":104},"Interlineation line 1 to 2 ",{"_":642,"notBefore":643,"notAfter":644,"evidence":645},"1st century BCE",-100,-1,"lettering",[647,648],{"_":265,"type":116,"ref":266},{"_":265,"type":120,"ref":268},[650],[271,272],{"_":274,"role":275,"ref":276},{"_":653,"type":134},"SG6496",{"_":136,"mainLang":137,"languages":655},[136],[],[291,658,659,660,661,153,155],"Dubois, 2008, IGDS2","Nenci, 1995, Iscrizioni greche e latine","Nenci, 1997, Novità epigrafiche dall'area elima","Giustolisi, 1999, Petra: atlante delle antiche strutture rupestri dell'alta valle del Platani (Castronovo)",[303,663,664,665,666,162,164],"SM2KDHZC","WHBJDH75","4FSSHE62","GGJ4H43M",[668,669,670,671,470,21,313,313,171,172,313,314,174,137],"isic002727","inscription recording works undertaken by the agoranomos herakleios",{"_":10},"building; honorific","Text encoding: Jonathan Prag; edition source: \u003Ca href=\"http://zotero.org/groups/382445/items/3PK3JKXR\">http://zotero.org/groups/382445/items/3PK3JKXR\u003C/a>",{"file":674,"uri":674,"title":675,"status":676,"editionAuthor":677,"type":678,"objectType":679,"material":680,"condition":681,"layoutDesc":682,"handNote":687,"date":693,"places":695,"geo":698,"country":126,"region":127,"settlement":265,"repository":700,"idno":701,"textLang":706,"provenance":265,"letterHeights":708,"publications":709,"zotero":710,"keywords":711,"html":672},"ISic002728","Fragment of a block, bearing the name Appeiraios",{"_":10},{"title":616,"date":617,"citation":618,"ref":619},{"_":321,"ana":322,"ref":323},{"_":570,"ana":571,"ref":572},{"_":21,"ana":22,"ref":23},{"ana":475},{"layout":683},{"p":684,"rs":685,"damage":686},"Parts of two lines preserved, with a wide space between them; unclear if more lines were preserved above.",{"_":29,"ana":30,"ref":31},{"ana":481},{"lettering":688,"dimensions":689},"The letters are somewhat worn, but present a regular and wide/square module, broadly and deeply incised. Alpha with straight bar, epsilon with shorter middle bar, omicron smaller and above the line, rho with a small closed eye.",[690,692],{"type":101,"l":102,"from":103,"to":103,"h":691,"unit":104},"13-17 (13 = omicron)",{"type":106,"l":107,"from":103,"to":108,"unit":104},{"_":694,"notBefore":491,"notAfter":644,"evidence":645},"2nd — 1st century BCE",[696,697],{"_":265,"type":116,"ref":266},{"_":265,"type":120,"ref":268},[699],[271,272],{"_":274,"role":275,"ref":276},[702,704],{"_":703,"type":134},"SG7542",{"_":705,"type":134},"IG2627",{"_":136,"mainLang":137,"languages":707},[136],[],[291,658,659,660,153,155],[303,663,664,665,162,164],[712,713,714,321,570,21,313,313,171,172,313,314,174,137],"isic002728","fragment of a block, bearing the name appeiraios",{"_":10},{"file":716,"uri":716,"title":717,"status":718,"editionAuthor":11,"type":719,"objectType":720,"material":721,"condition":24,"layoutDesc":722,"handNote":726,"date":733,"places":735,"geo":738,"country":126,"region":127,"settlement":265,"repository":740,"idno":741,"textLang":743,"facsimile":745,"provenance":265,"letterHeights":747,"publications":748,"zotero":749,"keywords":750,"html":175},"ISic002938","I.Sicily inscription 002938",{"_":10},{"_":520,"ana":521,"ref":522},{"_":570,"ana":571,"ref":572},{"_":21,"ana":22,"ref":23},{"layout":723},{"p":724,"rs":725,"damage":24},"Three of four original ines partially preserved.",{"_":29,"ana":30,"ref":31},{"lettering":727,"dimensions":728},"Alpha with broken bar; omicron smaller than other letters.",[729,732],{"type":101,"l":730,"from":108,"to":249,"h":731,"unit":104},"Lines 2-4","28-42",{"type":106,"l":107,"from":103,"to":108,"un