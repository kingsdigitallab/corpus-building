?)",{"_":114},"draft",{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":117},"http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":119,"ana":120,"ref":121},"marble","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":123},{"p":124,"rs":125,"damage":24},"Four lines of Latin letters, the first line centred, lines 2-4 maintaining a consistent left margin; vacats at top and bottom of the stone. Double guidelines are present above and below lines 2 and 3, but not closely observed (contra Bivona), and seemingly not present for lines 1 and 4.",{"_":29,"ana":30,"ref":31},{"lettering":127,"dimensions":128},"Large neatly carved letters with simple serifs; a very neat hedera at the start of line 1.",[129,131,133,135,139],{"type":36,"l":37,"from":38,"to":38,"h":130,"unit":40},"incomplete",{"type":36,"l":42,"from":43,"to":43,"h":132,"unit":40},"35-37",{"type":36,"l":46,"from":47,"to":47,"h":134,"unit":40},"36",{"type":36,"l":136,"from":137,"to":137,"h":138,"unit":40},"Line 4","line4","33-38",{"type":50,"l":51,"from":38,"to":43,"unit":40},{"_":53,"notBefore":141,"notAfter":142,"evidence":143},51,200,"lettering",[145,146],{"_":58,"type":59,"ref":60,"cert":61},{"_":63,"type":64,"ref":65},[148],[68,69],{"_":73,"role":74,"ref":75},{"_":151,"type":78},"23ab",{"_":80,"mainLang":81,"languages":153},[80],{"n":84,"url":155,"height":87,"width":86,"desc":156,"surfaceType":89},"ISic000140_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-07.",[],[92,93,94],[96,97,98],[161,162,163,13,17,119,103,104,105,106,104,107,108,81],"isic000140","funerary inscription for a woman (caninia?)",{"_":114},"Text encoding: Tuuli Ahlholm; Jonathan Prag, edition source:",{"file":166,"uri":166,"title":167,"status":168,"editionAuthor":11,"type":169,"objectType":170,"material":171,"condition":24,"layoutDesc":172,"handNote":176,"date":185,"places":188,"geo":191,"country":70,"region":71,"settlement":63,"repository":193,"idno":194,"textLang":196,"facsimile":198,"provenance":58,"letterHeights":201,"publications":202,"zotero":203,"keywords":204,"html":164},"ISic000155","Fragment recording two freedmen",{"_":10},{"_":13,"ana":14,"ref":15,"cert":61},{"_":17,"ana":18,"ref":117},{"_":119,"ana":120,"ref":121},{"layout":173},{"p":174,"rs":175,"damage":24},"Two lines of Latin letters, the first larger than the second.",{"_":29,"ana":30,"ref":31},{"lettering":177,"dimensions":178},"Tall thin letters with serifs and some use of comma-shaped interpuncts, well carved.",[179,181,183],{"type":36,"l":37,"from":38,"to":38,"h":180,"unit":40},"41-50",{"type":36,"l":42,"from":43,"to":43,"h":182,"unit":40},"28-31",{"type":50,"l":51,"from":38,"to":43,"h":184,"unit":40},"5",{"_":186,"notBefore":54,"notAfter":187},"Roman imperial period",250,[189,190],{"_":58,"type":59,"ref":60,"cert":61},{"_":63,"type":64,"ref":65},[192],[68,69],{"_":73,"role":74,"ref":75},{"_":195,"type":78},"6",{"_":80,"mainLang":81,"languages":197},[80],{"n":84,"url":199,"height":86,"width":87,"desc":200,"surfaceType":89},"ISic000155_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-06.",[],[92,93,94],[96,97,98],[205,206,207,13,17,119,103,104,105,106,104,107,108,81],"isic000155","fragment recording two freedmen",{"_":10},{"file":209,"uri":209,"title":210,"status":211,"editionAuthor":11,"type":212,"objectType":213,"material":214,"condition":24,"layoutDesc":215,"handNote":219,"date":228,"places":231,"geo":234,"country":70,"region":71,"settlement":63,"repository":236,"idno":237,"textLang":239,"facsimile":241,"provenance":58,"letterHeights":244,"publications":245,"zotero":246,"keywords":247,"html":164},"ISic000161","Epitaph of Lucius Cornelius Auctus",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":119,"ana":120,"ref":121},{"layout":216},{"p":217,"rs":218,"damage":24},"Three slightly irregular and roughly centred lines of Latin letters, with single use of hedera in the middle of the name; the final letters of the cognomen are combined in a mixture of large and small letters, almost monogram-like.",{"_":29,"ana":30,"ref":31},{"lettering":220,"dimensions":221},"Somewhat fluid letters, with extensions to the apices of letters such as M and A, absence of cross-bar on A, L with oblique lower stroke.",[222,223,225,227],{"type":36,"l":37,"from":38,"to":38,"h":77,"unit":40},{"type":36,"l":42,"from":43,"to":43,"h":224,"unit":40},"26-38",{"type":36,"l":46,"from":47,"to":47,"h":226,"unit":40},"22-28",{"type":50,"l":51,"from":38,"to":43,"unit":40},{"_":229,"notBefore":230,"notAfter":187,"evidence":143},"Dated by Bivona between 150 and 250 CE.",151,[232,233],{"_":58,"type":59,"ref":60},{"_":63,"type":64,"ref":65},[235],[68,69],{"_":73,"role":74,"ref":75},{"_":238,"type":78},"8ab",{"_":80,"mainLang":81,"languages":240},[80],{"n":84,"url":242,"height":86,"width":87,"desc":243,"surfaceType":89},"ISic000161_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2018-07-10",[],[92,93,94],[96,97,98],[248,249,250,13,17,119,103,104,105,106,104,107,108,81],"isic000161","epitaph of lucius cornelius auctus",{"_":10},{"file":252,"uri":252,"title":253,"status":254,"editionAuthor":11,"type":255,"objectType":256,"material":257,"condition":24,"layoutDesc":258,"handNote":262,"date":274,"places":275,"geo":278,"country":70,"region":71,"settlement":63,"repository":280,"idno":281,"textLang":283,"facsimile":285,"provenance":58,"letterHeights":287,"publications":288,"zotero":289,"keywords":290,"html":164},"ISic000162","Epitaph for Cornelius Castor",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":119,"ana":120,"ref":121},{"layout":259},{"p":260,"rs":261,"damage":24},"Four lines of Latin, approximately centred with slightly inconsistent comma-shaped interpuncts. The lines are not perfectly horizontal or evenly spaced, with slightly irregular letters.",{"_":29,"ana":30,"ref":31},{"lettering":263,"dimensions":264},"Thinly carved letters with serfis and some curving flourishes, such as extended tail to the initial M. R in line 2 is open, whereas R in line 3 has a faint closing line. A has oblique cross bar descending to left. Interpunct end of line 2 is almost a hedera.",[265,267,269,271,273],{"type":36,"l":37,"from":38,"to":38,"h":266,"unit":40},"30",{"type":36,"l":42,"from":43,"to":43,"h":268,"unit":40},"25-30",{"type":36,"l":46,"from":47,"to":47,"h":270,"unit":40},"25-29",{"type":36,"l":136,"from":137,"to":137,"h":272,"unit":40},"23-24",{"type":50,"l":51,"from":38,"to":43,"unit":40},{"_":229,"notBefore":230,"notAfter":187,"evidence":143},[276,277],{"_":58,"type":59,"ref":60},{"_":63,"type":64,"ref":65},[279],[68,69],{"_":73,"role":74,"ref":75},{"_":282,"type":78},"13ac",{"_":80,"mainLang":81,"languages":284},[80],{"n":84,"url":286,"height":86,"width":87,"desc":243,"surfaceType":89},"ISic000162_tiled.tif",[],[92,93,94],[96,97,98],[291,292,293,13,17,119,103,104,105,106,104,107,108,81],"isic000162","epitaph for cornelius castor",{"_":10},{"file":295,"uri":295,"title":296,"status":297,"editionAuthor":11,"type":298,"objectType":299,"material":300,"condition":24,"layoutDesc":301,"handNote":305,"date":321,"places":323,"geo":326,"country":70,"region":71,"settlement":63,"repository":328,"idno":329,"textLang":331,"facsimile":333,"provenance":58,"letterHeights":335,"publications":336,"zotero":337,"keywords":338,"html":109},"ISic000163","Funerary inscription for Cornelia Scepsis",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":119,"ana":120,"ref":121},{"layout":302},{"p":303,"rs":304,"damage":24},"Five lines of Latin letters, roughly centred on stone",{"_":29,"ana":30,"ref":31},{"lettering":306,"dimensions":307},"Well-formed and straight letters, with regular spaces between letters. Serifs on most letters. Use of comma-shaped interpuncts between each word. Letter heights reduce in size at the end of lines 2 and 3. Extended 'I' in line 5 (27 mm).",[308,310,312,314,316,320],{"type":36,"l":37,"from":38,"to":38,"h":309,"unit":40},"32",{"type":36,"l":42,"from":43,"to":43,"h":311,"unit":40},"23-29",{"type":36,"l":46,"from":47,"to":47,"h":313,"unit":40},"27-30",{"type":36,"l":136,"from":137,"to":137,"h":315,"unit":40},"28",{"type":36,"l":317,"from":318,"to":318,"h":319,"unit":40},"Line 5","line5","22",{"type":50,"l":51,"from":38,"to":43,"unit":40},{"_":322,"notBefore":230,"notAfter":187,"evidence":143},"\n                                Bivona (1994, 184) dates this inscription, as well as,\n                                and\n                                to between the second-half of the second century CE and early third century CE\n                            ",[324,325],{"_":58,"type":59,"ref":60},{"_":63,"type":64,"ref":65},[327],[68,69],{"_":73,"role":74,"ref":75},{"_":330,"type":78},"7ad",{"_":80,"mainLang":81,"languages":332},[80],{"n":84,"url":334,"height":86,"width":87,"desc":243,"surfaceType":89},"ISic000163_tiled.tif",[],[92,93,94],[96,97,98],[339,340,341,13,17,119,103,104,105,106,104,107,108,81],"isic000163","funerary inscription for cornelia scepsis",{"_":10},{"file":343,"uri":343,"title":344,"status":345,"editionAuthor":11,"type":346,"objectType":347,"material":349,"condition":24,"layoutDesc":350,"handNote":354,"date":366,"places":367,"geo":370,"country":70,"region":71,"settlement":63,"repository":372,"idno":373,"textLang":375,"facsimile":377,"provenance":58,"letterHeights":379,"publications":380,"zotero":381,"keywords":382,"html":164},"ISic000164","Epitaph for Cornelia Soteris",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":348},"https://www.eagle-network.eu/voc/objtyp/lod/259.htm",{"_":119,"ana":120,"ref":121},{"layout":351},{"p":352,"rs":353,"damage":24},"Four lines of Latin letters approximately centred on the stone, but not perfectly horizontal. The first two lines are larger, with hedera in line 1, basic interpuncts elsewhere.",{"_":29,"ana":30,"ref":31},{"lettering":355,"dimensions":356},"Letters are somewhat irregular, some taller and thinner, with serifs.",[357,359,361,363,365],{"type":36,"l":37,"from":38,"to":38,"h":358,"unit":40},"46",{"type":36,"l":42,"from":43,"to":43,"h":360,"unit":40},"48-58 (C and T are tall)",{"type":36,"l":46,"from":47,"to":47,"h":362,"unit":40},"28-33",{"type":36,"l":136,"from":137,"to":137,"h":364,"unit":40},"31-37",{"type":50,"l":51,"from":38,"to":43,"unit":40},{"_":229,"notBefore":230,"notAfter":187,"evidence":143},[368,369],{"_":58,"type":59,"ref":60},{"_":63,"type":64,"ref":65},[371],[68,69],{"_":73,"role":74,"ref":75},{"_":374,"type":78},"19ae",{"_":80,"mainLang":81,"languages":376},[80],{"n":84,"url":378,"height":86,"width":87,"desc":243,"surfaceType":89},"ISic000164_tiled.tif",[],[92,93,94],[96,97,98],[383,384,385,13,17,119,103,104,105,106,104,107,108,81],"isic000164","epitaph for cornelia soteris",{"_":10},{"file":387,"uri":387,"title":388,"status":389,"editionAuthor":11,"type":390,"objectType":391,"material":392,"condition":24,"layoutDesc":393,"handNote":397,"date":405,"places":410,"geo":413,"country":70,"region":71,"settlement":63,"repository":415,"idno":416,"textLang":418,"facsimile":420,"provenance":58,"letterHeights":423,"publications":424,"zotero":426,"keywords":428,"html":432},"ISic000186","Fragment of a later Roman Latin inscription",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":119,"ana":120,"ref":121},{"layout":394},{"p":395,"rs":396,"damage":24},"Remains of two evenly spaced lines of Latin letters; use of double-dot interpuncts.",{"_":29,"ana":30,"ref":31},{"lettering":398,"dimensions":399},"Regularly cut letters of moderate width module (rectangular but not narrow). Vertical strokes of A and N in line 2 do no