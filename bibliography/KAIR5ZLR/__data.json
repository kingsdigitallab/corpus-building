ISic001694","Fragment of a public inscription",{"_":10},{"_":161,"ana":162,"ref":163},"public text","#function.legal #function.document.public","https://www.eagle-network.eu/voc/typeins/lod/5.html",{"_":165,"ana":166,"ref":167},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":21,"ana":22,"ref":23},{"ana":170},"#condition.fragment",{"layout":172},{"p":173,"rs":174,"damage":175},"Remains of two columns of text, with a space between of 1-2.5 cm. The right margin of the left column (A) is uneven, with a vacat equivalent to two line ends above the end of the first visibile line of text; the left margin of the right column is consistent.",{"_":29,"ana":30,"ref":31},{"ana":176},"#text_condition.incomplete",{"lettering":178,"dimensions":179},"Arena notes that the quadrangular module of the individual letters is somewhat irregular, with the combined module of omicron-nu (used as a control across multiple similar fragments) being 10mm from centre to centre. Letters with neat terminal serifs, elegantly cut.",[180,184],{"type":36,"l":181,"from":38,"to":182,"h":183,"unit":39},"Line 1-5","line5","8",{"type":41,"l":185,"from":38,"to":182,"h":186,"unit":39},"Interlineation","6",{"_":188,"notBefore":189,"notAfter":190,"evidence":191,"precision":48},"Later 2nd century BCE or early C1 BCE",-150,-51,"lettering",[193,194],{"_":51,"type":52,"ref":53},{"_":55,"type":56,"ref":57,"offset":58},[196],[61,62],{"_":67,"role":68,"ref":69},{"_":199,"type":73},"ME30906",{"_":77,"mainLang":78,"languages":201},[77],{"n":81,"url":203,"height":83,"width":84,"desc":85,"surfaceType":86},"ISic001694_tiled.tif",[],[113],[141],[208,209,210,161,165,21,148,149,150,151,152,153,154,78],"isic001694","fragment of a public inscription",{"_":10},{"file":212,"uri":212,"title":158,"status":213,"editionAuthor":11,"type":214,"objectType":218,"material":219,"condition":220,"layoutDesc":221,"handNote":226,"date":231,"places":232,"geo":235,"country":63,"region":64,"settlement":65,"repositor