03C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>Conco]ṛdiae · Aug[ustae\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ethus · sev[ir\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":125,"ptr":126,"ref":128,"title":2,"citation":5,"uri":6},"85-87",{"target":127},"https://www.zotero.org/groups/382445/items/BCIMMIKZ",{"_":129,"target":129},"https://biblio.inscriptiones.org/epig10001670",{"file":131,"uri":131,"title":132,"status":133,"editionAuthor":13,"type":134,"objectType":135,"material":138,"condition":26,"layoutDesc":139,"handNote":143,"date":161,"places":166,"geo":169,"provenance":54,"provenanceGeo":171,"country":69,"region":70,"settlement":54,"repository":174,"idno":175,"textLang":177,"tmNumber":179,"facsimile":180,"letterHeights":185,"publications":195,"zotero":197,"keywords":199,"html":203,"bibl":204},"ISic000804","Dedication of a statue to Ceres, by Iulius Acilius Hermes, sevir",{"_":12},{"_":15,"ana":16,"ref":17},{"_":136,"ana":137,"ref":21},"statue base","#object.statue_base",{"_":23,"ana":24,"ref":25},{"layout":140},{"p":141,"rs":142,"damage":26},"The Latin text is engraved over two lines (letters c.20 mm high, but of uneven height), to a maximum length of 52 cm.",{"_":31,"ana":32,"ref":33},{"lettering":144,"dimensions":145}," The letters show some irregularity, with fairly pronounced serifs, and lengthy tails to the letter R. The first two words are separated from the rest by a space; an interpunct is visible at the end of the dedicant’s name, and the final abbreviated phrase is separated from the rest by a large hedera (ivy leaf). The letter I in line 1 is frequently taller than the rest (but so too is the first L in line 1); the final I of line 1 is somewhat irregularly carved.",[146,151,156],{"type":38,"l":147,"from":40,"to":40,"h":148,"unit":43,"atLeast":149,"atMost":150},"Line 1","18-25","18","25",{"type":38,"l":152,"from":41,"to":41,"h":153,"unit":43,"atLeast":154,"atMost":155},"Line 2","19-23","19","23",{"type":45,"l":157,"from":40,"to":41,"h":158,"unit":43,"atLeast":159,"atMost":160},"Interlineation lines 1-2","7-15","7","15",{"_":162,"notBefore":163,"notAfter":164,"evidence":165},"Statue can be dated stylistically to the late Antonine period (i.e. the 180s or 190s CE), and the text is compatible with such a date.",180,199,"context",[167,168],{"_":54,"type":55,"ref":56},{"_":58,"type":59,"ref":60,"offset":61},[170],[64,65],[172,173],37.998037,14.262643,{"_":72,"role":73,"ref":74},{"_":176,"type":77},"ME 20194",{"_":79,"mainLang":80,"languages":178},[79],"175724",{"n":84,"url":181,"height":182,"width":183,"desc":184,"surfaceType":89},"ISic000804_tiled.tif","1949px","4512px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina",[186,189,192],{"atLeast":187,"atMost":188},18,25,{"atLeast":190,"atMost":191},19,23,{"atLeast":193,"atMost":194},7,15,[94,95,96,196,100,101,102],"Scibona, 2008, Statuary",[104,105,106,198,110,111,112],"EQC3W4UU",[200,201,202,15,136,23,117,118,119,120,117,121,122,80],"isic000804","dedication of a statue to ceres, by iulius acilius hermes, sevir",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Cereri sacr(um) \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> Iulius Acilius Her-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>mes · pro honor(e) seviratus ❦ d(eae) d(onum) d(edit) \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":205,"ptr":206,"ref":207,"title":2,"citation":5,"uri":6},"80-87 fig.7",{"target":127},{"_":129,"target":129}],"uses":{"params":["slug"]}}]}
