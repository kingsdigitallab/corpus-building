{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":7},{"title":2,"author":3,"date":4,"citation":5,"uri":6},"Le sculture da Alesa","Portale","2009","\u003Cspan>Elisa Chiara Portale, «Le sculture da Alesa», in \u003Ci>Alaisa-Halaesa. Scavi e ricerche (1970-2007)\u003C/i>, a c. di G. Scibona e G. Tigano (Messina: Sicania, 2009), 67–92\u003C/span>","https://www.zotero.org/groups/isicily/items/BCIMMIKZ",[8,130],{"file":9,"uri":9,"title":10,"status":11,"editionAuthor":13,"type":14,"objectType":18,"material":22,"condition":26,"layoutDesc":27,"handNote":34,"date":48,"places":52,"geo":62,"provenance":54,"provenanceGeo":66,"country":69,"region":70,"settlement":54,"repository":71,"idno":75,"textLang":78,"tmNumber":82,"facsimile":83,"letterHeights":90,"publications":93,"zotero":103,"keywords":113,"html":123,"bibl":124},"ISic000768","Dedication by a sevir to Concordia",{"_":12},"edited",null,{"_":15,"ana":16,"ref":17},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":19,"ana":20,"ref":21},"base","#object.base","http://www.eagle-network.eu/voc/objtyp/lod/57.html",{"_":23,"ana":24,"ref":25},"marble (white)","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html","",{"layout":28},{"p":29,"rs":30,"damage":26},"The epigraphic face is preserved for a width of 12.5 cm, with two lines of Latin letters filling the available field.",{"_":31,"ana":32,"ref":33},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":35,"dimensions":36},"The letters are tall, neatly cut and closely spaced (height c.30mm), and words are separated by simple triangular interpuncts. The letters are lightly serifed. E is tall and narrow, T has a curved cross-bar, rising to the right.",[37,44],{"type":38,"l":39,"from":40,"to":41,"h":42,"unit":43,"atLeast":42,"atMost":42},"letterHeight","Line 1-2","line1","line2","30","mm",{"type":45,