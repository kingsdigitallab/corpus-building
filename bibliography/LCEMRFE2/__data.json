{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":7,"isBulletin":123},{"title":2,"author":3,"date":4,"citation":5,"uri":6},"Segesta. Supplemento epigrafico 2021","Ampolo","2021","\u003Cspan>Carmine Ampolo, «Segesta. Supplemento epigrafico 2021», \u003Ci>Annali della Scuola Normale Superiore di Pisa, Classe di Lettere e Filosofia\u003C/i> Series 5, 13/2, supplemento (2021): 64–66\u003C/span>","https://www.zotero.org/groups/isicily/items/LCEMRFE2",[8],{"file":9,"uri":9,"title":10,"status":11,"editionAuthor":13,"type":14,"objectType":17,"material":21,"condition":29,"layoutDesc":31,"handNote":40,"date":55,"places":60,"geo":69,"country":65,"provenance":62,"provenanceGeo":73,"region":76,"settlement":62,"repository":77,"idno":81,"textLang":87,"tmNumber":91,"facsimile":92,"letterHeights":99,"publications":102,"zotero":104,"keywords":106,"html":115,"bibl":116,"bulletinDateSort":122,"citedRangeSort":117,"languageSort":88,"materialSort":22,"typeSort":15},"ISic001699","I.Sicily inscription 001699",{"_":12},"draft",null,{"_":15,"ana":16},"unknown","#function.unknown",{"_":18,"ana":19,"ref":20},"block","#object.block","http://www.eagle-network.eu/voc/objtyp/lod/189.html",{"_":22,"ana":23,"type":24,"subtype":25,"resp":27,"ref":28},"limestone","#material.inorganic.stone.sedimentary_rock.limestone.calcarenite","stone.calcarenite",[26],"unspecified","#Coccato","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":30},"#condition.fragments.contiguous",{"layout":32},{"p":33,"rs":34,"damage":38},"Two lines of large Greek letters preserved across the long face of the rectangular block.",{"_":35,"ana":36,"ref":37},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":39},"#text_condition.incomplete",{"lettering":41,"dimensions":42},"Plain and thinly incised, regular letters with a reasonably wide module. Alpha has straight bar; kappa has full length arms, rho has a large rounded eye; omicron is full size.",[43,52],{"type":44,"l":45,"from":46,"to":47,"h":48,"unit":49,"atLeast":50,"atMost":51},"letterHeight","Line 1-2","line1","line2","98-100","mm","98","100",{"type":53,"l":54,"from":46,"to":47,"unit":49},"interlinear","Interlineation line 1 to 2",{"_":56,"notBefore":57,"notAfter":58,"evidence":59},"The editors adopt a cautious reading, given the plain form of the letters and the limited extent of the text, suggesting C3 BCE - C1 CE, but with a preference for C2-1 BCE.",-300,100,"lettering",[61,66],{"_":62,"type":63,"ref":64,"region":65},"Segesta","ancient","https://pleiades.stoa.org/places/462487","Sicilia",{"_":62,"type":67,"ref":68,"region":65},"modern","http://sws.geonames.org/2523171",[70],[71,72],37.94171,12.83649,[74,75],37.939381,12.842901,"Sicily",{"_":78,"role":79,"ref":80},"Parco archeologico di Segesta","site","http://sicily.classics.ox.ac.uk/museum/196",[82,85],{"_":83,"type":84},"16987","inventory",{"_":86,"type":84},"17031",{"_":88,"mainLang":89,"languages":90},"Ancient Greek","grc",[88],"",{"n":93,"url":94,"height":95,"width":96,"desc":97,"surfaceType":98},"screen","ISic001699_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[100],{"atLeast":101,"atMost":58},98,[103],"Ampolo, 2021, Segesta. Supplemento epigrafico 2021",[105],"LCEMRFE2",[107,108,109,15,18,22,110,110,111,112,110,113,114,89],"isic001699","i.sicily inscription 001699",{"_":12},"segesta","sicilia","sicily","parco archeologico di segesta","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Φαλάκρου\">\u003Cspan data-type=\"name