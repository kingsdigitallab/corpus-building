{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":7},{"title":2,"author":3,"date":4,"citation":5,"uri":6},"Segesta. Supplemento epigrafico 2021","Ampolo","2021","\u003Cspan>Carmine Ampolo, «Segesta. Supplemento epigrafico 2021», \u003Ci>Annali della Scuola Normale Superiore di Pisa, Classe di Lettere e Filosofia\u003C/i> Series 5, 13/2, supplemento (2021): 64–66\u003C/span>","https://www.zotero.org/groups/isicily/items/LCEMRFE2",[8],{"file":9,"uri":9,"title":10,"status":11,"editionAuthor":13,"type":14,"objectType":17,"material":21,"condition":25,"layoutDesc":27,"handNote":36,"date":49,"places":55,"geo":63,"provenance":57,"provenanceGeo":67,"country":70,"region":71,"settlement":57,"repository":72,"idno":76,"textLang":82,"tmNumber":86,"facsimile":87,"letterHeights":94,"publications":95,"zotero":97,"keywords":99,"html":108,"bibl":109},"ISic001699","I.Sicily inscription 001699",{"_":12},"draft",null,{"_":15,"ana":16},"unknown","#function.unknown",{"_":18,"ana":19,"ref":20},"block","#object.block","http://www.eagle-network.eu/voc/objtyp/lod/189.html",{"_":22,"ana":23,"ref":24},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":26},"#condition.fragments.contiguous",{"layout":28},{"p":29,"rs":30,"damage":34},"Two lines of large Greek letters preserved across the long face of the rectangular block.",{"_":31,"ana":32,"ref":33},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":35},"#text_condition.incomplete",{"lettering":37,"dimensions":38},"Plain and thinly incised, regular letters with a reasonably wide module. Alpha has straight bar; kappa has full length arms, rho has a large rounded eye; omicron is full size.",[39,46],{"type":40,"l":41,"from":42,"to":43,"h":44,"unit":45},"letterHeight","Line 1-2","line1","line2","98-100","mm",{"type":47,"l":48,"from":42,"to":43,"unit":45},"interlinear","Interlineation line 1 to 2",{"_":50,"notBefore":51,"notAfter":52,"evidence":53,"precision":54},"The editors adopt a cautious reading, given the plain form of the letters and the limited extent of the text, suggesting C3 BCE - C1 CE, but with a preference for C2-1 BCE.",-300,100,"lettering","low",[56,60],{"_":57,"type":58,"ref":59},"Segesta","ancient","https://pleiades.stoa.org/places/462487",{"_":57,"type":61,"ref":62},"modern","http://sws.geonames.org/2523171",[64],[65,66],37.94171,12.83649,[68,69],37.939381,12.842901,"Italy","Sicily",{"_":73,"role":74,"ref":75},"Parco archeologico di Segesta","site","http://sicily.classics.ox.ac.uk/museum/196",[77,80],{"_":78,"type":79},"16987","inventory",{"_":81,"type":79},"17031",{"_":83,"mainLang":84,"languages":85},"Ancient Greek","grc",[83],"",{"n":88,"url":89,"height":90,"width":91,"desc":92,"surfaceType":93},"screen","ISic001699_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[96],"Ampolo, 2021, Segesta. Supplemento epigrafico 2021",[98],"LCEMRFE2",[100,101,102,15,18,22,103,103,104,105,103,106,107,84],"isic001699","i.sicily inscription 001699",{"_":12},"segesta","italy","sicily","parco archeologico di segesta","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Φαλάκρου\">Φα]λάκρου\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΑΔΡ̣ΑΝΟΥΑΝ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,