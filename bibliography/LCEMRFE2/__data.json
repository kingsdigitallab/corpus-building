{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":6},{"title":2,"author":3,"date":4,"citation":5},"Segesta. Supplemento epigrafico 2021","","2021","\u003Cspan>Carmine Ampolo, «Segesta. Supplemento epigrafico 2021», \u003Ci>Annali della Scuola Normale Superiore di Pisa, Classe di Lettere e Filosofia\u003C/i> Series 5, 13/2, supplemento (2021): 64–66\u003C/span>",[7],{"file":8,"uri":8,"title":9,"status":10,"editionAuthor":12,"type":13,"objectType":16,"material":20,"condition":24,"layoutDesc":26,"handNote":35,"date":48,"places":54,"geo":62,"provenance":56,"provenanceGeo":66,"country":69,"region":70,"settlement":56,"repository":71,"idno":75,"textLang":81,"tmNumber":3,"facsimile":85,"letterHeights":92,"publications":93,"zotero":95,"keywords":97,"html":106,"bibl":107},"ISic001699","I.Sicily inscription 001699",{"_":11},"draft",null,{"_":14,"ana":15},"unknown","#function.unknown",{"_":17,"ana":18,"ref":19},"block","#object.block","http://www.eagle-network.eu/voc/objtyp/lod/189.html",{"_":21,"ana":22,"ref":23},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":25},"#condition.fragments.contiguous",{"layout":27},{"p":28,"rs":29,"damage":33},"Two lines of large Greek letters preserved across the long face of the rectangular block.",{"_":30,"ana":31,"ref":32},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":34},"#text_condition.incomplete",{"lettering":36,"dimensions":37},"Plain and thinly incised, regular letters with a reasonably wide module. Alpha has straight bar; kappa has full length arms, rho has a large rounded eye; omicron is full size.",[38,45],{"type":39,"l":40,"from":41,"to":42,"h":43,"unit":44},"letterHeight","Line 1-2","line1","line2","98-100","mm",{"type":46,"l":47,"from":41,"to":42,"unit":44},"interlinear","Interlineation line 1 to 2",{"_":49,"notBefore":50,"notAfter":51,"evidence":52,"precision":53},"The editors adopt a cautious reading, given the plain form of the letters and the limited extent of the text, suggesting C3 BCE - C1 CE, but with a preference for C2-1 BCE.",-300,100,"lettering","low",[55,59],{"_":56,"type":57,"ref":58},"Segesta","ancient","https://pleiades.stoa.org/places/462487",{"_":56,"type":60,"ref":61},"modern","http://sws.geonames.org/2523171",[63],[64,65],37.94171,12.83649,[67,68],37.939381,12.842901,"Italy","Sicily",{"_":72,"role":73,"ref":74},"Parco archeologico di Segesta","site","http://sicily.classics.ox.ac.uk/museum/196",[76,79],{"_":77,"type":78},"16987","inventory",{"_":80,"type":78},"17031",{"_":82,"mainLang":83,"languages":84},"Ancient Greek","grc",[82],{"n":86,"url":87,"height":88,"width":89,"desc":90,"surfaceType":91},"screen","ISic001699_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[94],"Segesta. Supplemento epigrafico 2021, 2021",[96],"LCEMRFE2",[98,99,100,14,17,21,101,101,102,103,101,104,105,83],"isic001699","i.sicily inscription 001699",{"_":11},"segesta","italy","sicily","parco archeologico di segesta","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Φαλάκρου\">Φα]λάκρου\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΑΔΡ̣ΑΝΟΥΑΝ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":108,"ptr":109,"ref":111,"title":2,"citation":5},"G35.a-b",{"target":110