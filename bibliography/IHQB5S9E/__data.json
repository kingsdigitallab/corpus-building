{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":5},{"title":2,"date":3,"citation":4},"Epigrafia greca","1984-1985","\u003Cspan>Antonietta Brugnone, «Epigrafia greca», \u003Ci>Kokalos\u003C/i> 30–31 (1985 1984): 231–55\u003C/span>",[6,260,316,440],{"file":7,"uri":7,"title":8,"status":9,"editionAuthor":11,"type":12,"objectType":16,"material":20,"condition":24,"layoutDesc":25,"handNote":32,"date":186,"places":192,"geo":202,"country":206,"region":207,"settlement":208,"repository":209,"idno":213,"textLang":216,"facsimile":220,"provenance":194,"letterHeights":227,"publications":228,"zotero":238,"keywords":248,"html":259},"ISic002754","I.Sicily inscription 002754",{"_":10},"draft",null,{"_":13,"ana":14,"ref":15},"oracle","#function.oracle","http://www.eagle-network.eu/voc/typeins/lod/429.html",{"_":17,"ana":18,"ref":19},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":21,"ana":22,"ref":23},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html","",{"layout":26},{"p":27,"rs":28,"damage":24},"The left margin of the text is carefully justified, but the right margin is very uneven, with several extensive vacats at line end.",{"_":29,"ana":30,"ref":31},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":33,"dimensions":173},[34,35],"Regular small letters of generally consistent size, deeply cut with pronounced terminal serifs on some strokes. Alpha is broad with straight bar, occasional extension of apex; beta appears open with rounded but not fully circular equal loops; epsilon has shorter middle bar, and upper and lower strokes often curve outwards at the ends; theta is ovoid with complete horizontal bar; kappa has short, equal length tails; mu has middle stroks joining well above the line; nu has the lower right angle above the line with shorter right vertical stroke; omicron is smaller and above the line; pi has shorter right vertical; rho is closed with generally circular eye; sigma has upper and lower horizontals curving slightly outwards at the ends, and the middle strokes often form into a single curving stroke; phi has a rounded eye, with the vertical extended, up to 17mm; psi has extended vertical and straight arms; omega is small, rounded, above the line, and open, with generally horizontal tail strokes.",{"_":36,"ref":37},"\n                                    Types list:\n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n                                    \n            