{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":6},{"title":2,"author":3,"date":4,"citation":5},"L'Agorà (scavi 1970-2004)","","2009","\u003Cspan>G. Scibona, «L’Agorà (scavi 1970-2004)», in \u003Ci>Alaisa-Halaesa. Scavi e ricerche (1970-2007)\u003C/i>, a c. di G. Scibona e G. Tigano (Messina: Regione Siciliana, 2009), 9–43\u003C/span>",[7],{"file":8,"uri":8,"title":9,"status":10,"editionAuthor":12,"type":13,"objectType":17,"material":21,"condition":3,"layoutDesc":25,"handNote":32,"date":47,"places":53,"geo":63,"provenance":55,"provenanceGeo":67,"country":68,"region":69,"settlement":55,"repository":70,"idno":74,"textLang":77,"tmNumber":81,"facsimile":82,"letterHeights":89,"publications":90,"zotero":94,"keywords":98,"html":109,"bibl":110},"ISic003591","Honours for Aelius Asinius Petitus, rhetor",{"_":11},"edited",null,{"_":14,"ana":15,"ref":16},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html",{"_":18,"ana":19,"ref":20},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":22,"ana":23,"ref":24},"marble\n                                    ","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html",{"layout":26},{"p":27,"rs":28,"damage":3},"Five lines of Greek letters are preserved.",{"_":29,"ana":30,"ref":31},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":33,"dimensions":34},"The letters are very neatly and regularly V-cut, well spaced and generously proportioned; height 56-63 mm. Serifs are mostly deep triangular terminations to the principal strokes. Σ and Ε are lunate, the latter with a short middle bar; Ν has a rounded join between the second and third strokes; Α has a slight apex, and a horizontal bar; Π has vertical hastae of equal length, and the cross-bar overlaps slightly on both sides; Ρ is not quite closed, with a well-rounded eye; the vertical stroke of Φ extends up to join the base of the letter on the line above. Interpuncts are used regularly to mark word-breaks and have the form of a comma.",[35,42],{"type":36,"l":37,"from":38,"to":39,"h":40,"unit":41},"letterHeight","Lines 1-5","line1","line5","56-63","mm",{"type":43,"l":44,"from":38,"to":45,"h":46,"unit":41},"interlinear","Interlineation","line2","not measured",{"_":48,"notBefore":49,"notAfter":50,"evidence":51,"precision":52},"Second half of 2nd century CE",151,200,"context","low",[54,58],{"_":55,"type":56,"ref":57},"Halaesa","ancient","http://pleiades.stoa.org/places/462225",{"_":59,"type":60,"ref":61,"offset":62},"Castel di Tusa","modern","http://sws.geonames.org/2525099","near",[64],[65,66],37.99907,14.26197,[],"Italy","Sicily",{"_":71,"role":72,"ref":73},"Antiquarium e sito archeologico di Halaesa ","museum","http://sicily.classics.ox.ac.uk/museum/053",{"_":75,"type":76},"30602","inventory",{"_":78,"mainLang":79,"languages":80},"Ancient Greek","grc",[78],"645670",{"n":83,"url":84,"height":85,"width":86,"desc":87,"surfaceType":88},"screen","ISic003591_tiled.tif","3680px","4872px","Photo J.Prag courtesy Soprintendenza BBCCAA di Messina","front",[],[91,92,93],"Alesa Archonidea dalla riscoperta tardo rinascimentale agli scavi del XX secolo, 2008","L'Agorà (scavi 1970-2004), 2009",", , 2017, Alesa Archonidea: il lapidarium",[95,96,97],"JX9IX97G","DSZEF4K5","MI64NB9L",[99,100,101,14,18,102,103,104,105,106,103,107,108,79],"isic003591","honours for aelius asinius petitus, rhetor",{"_":11},"marble","halaesa","castel di tusa","italy","sicily","antiquarium e sito archeologico di halaesa","ancient greek","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>Α]ἴ̣λιον · Ἀσί-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>νιον · Πέτει-\u003Cbr id=\