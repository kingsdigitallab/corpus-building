{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":7},{"title":2,"author":3,"date":4,"citation":5,"uri":6},"L'Agorà (scavi 1970-2004)","Scibona","2009","\u003Cspan>G. Scibona, «L’Agorà (scavi 1970-2004)», in \u003Ci>Alaisa-Halaesa. Scavi e ricerche (1970-2007)\u003C/i>, a c. di G. Scibona e G. Tigano (Messina: Regione Siciliana, 2009), 9–43\u003C/span>","https://www.zotero.org/groups/isicily/items/DSZEF4K5",[8],{"file":9,"uri":9,"title":10,"status":11,"editionAuthor":13,"type":14,"objectType":18,"material":22,"condition":26,"layoutDesc":27,"handNote":34,"date":51,"places":56,"geo":66,"provenance":58,"provenanceGeo":70,"country":71,"region":72,"settlement":58,"repository":73,"idno":77,"textLang":80,"tmNumber":84,"facsimile":85,"letterHeights":92,"publications":96,"zotero":100,"keywords":104,"html":115,"bibl":116},"ISic003591","Honours for Aelius Asinius Petitus, rhetor",{"_":12},"edited",null,{"_":15,"ana":16,"ref":17},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html",{"_":19,"ana":20,"ref":21},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":23,"ana":24,"ref":25},"marble\n                                    ","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html","",{"layout":28},{"p":29,"rs":30,"damage":26},"Five lines of Greek letters are preserved.",{"_":31,"ana":32,"ref":33},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":35,"dimensions":36},"The letters are very neatly and regularly V-cut, well spaced and generously proportioned; height 56-63 mm. Serifs are mostly deep triangular terminations to the principal strokes. Σ and Ε are lunate, the latter with a short middle bar; Ν has a rounded join between the second and third strokes; Α has a slight apex, and a horizontal bar; Π has vertical hastae of equal length, and the cross-bar overlaps slightly on both sides; Ρ is not quite closed, with a well-rounded eye; the vertical stroke of Φ extends up to join the base of the letter on the line above. Interpuncts are used regularly to mark word-breaks and have the form of a comma.",[37,46],{"type":38,"l":39,"from":40,"to":41,"h":42,"unit":43,"atLeast":44,"atMost":45},"letterHeight","Lines 1-5","line1","line5","56-63","mm","56","63",{"type":47,"l":48,"from":40,"to":49,"h":50,"unit":43},"interlinear","Interlineation","line2","not measured",{"_":52,"notBefore":53,"notAfter":54,"evidence":55},"Second half of 2nd century CE",151,200,"context",[57,61],{"_":58,"type":59,"ref":60},"Halaesa","ancient","http://pleiades.stoa.org/places/462225",{"_":62,"type":63,"ref":64,"offset":65},"Castel di Tusa","modern","http://sws.geonames.org/2525099","near",[67],[68,69],37.99907,14.26197,[],"Italy","Sicily",{"_":74,"role":75,"ref":76},"Antiquarium e sito archeologico di Halaesa ","museum","http://sicily.classics.ox.ac.uk/museum/053",{"_":78,"type":79},"30602","inventory",{"_":81,"mainLang":82,"languages":83},"Ancient Greek","grc",[81],"645670",{"n":86,"url":87,"height":88,"width":89,"desc":90,"surfaceType":91},"screen","ISic003591_tiled.tif","3680px","4872px","Photo J.Prag courtesy Soprintendenza BBCCAA di Messina","front",[93],{"atLeast":94,"atMost":95},56,63,[97,98,99],"Scibona, 2008, Alesa Archonidea dalla riscoperta tardo rinascimentale agli scavi del XX secolo","Scibona, 2009, L'Agorà (scavi 1970-2004)","Prag, Tigano, 2017, Alesa Archonidea: il lapidarium",[101,102,103],"JX9IX97G","DSZEF4K5","MI64NB9L",[105,106,107,15,19,108,109,110,111,112,109,113,114,82],"isic003591","honours for aelius asinius petitus, rhetor",{"_":12},"marble","halaesa","castel di tusa","italy","sicily","antiquarium e sito archeologico di halaesa","ancient greek","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan