{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":6},{"title":2,"author":3,"date":4,"citation":5},"Alesa Archonidea. Guide to the Antiquarium",", ","2008","\u003Cspan>G. Scibona and G. Tigano, \u003Ci>Alesa Archonidea. Guide to the Antiquarium\u003C/i> (Palermo: Regione Siciliana, 2008)\u003C/span>",[7,154,270],{"file":8,"uri":8,"title":9,"status":10,"editionAuthor":12,"type":13,"objectType":17,"material":21,"condition":25,"layoutDesc":27,"handNote":36,"date":67,"places":73,"geo":82,"provenance":75,"provenanceGeo":86,"country":89,"region":90,"settlement":75,"repository":91,"idno":95,"textLang":98,"tmNumber":102,"facsimile":103,"letterHeights":110,"publications":111,"zotero":124,"keywords":137,"html":147,"bibl":148},"ISic000584","Funerary inscription for Marcus Limbricius and his wife Helvia Arura",{"_":11},"edited",null,{"_":14,"ana":15,"ref":16},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":18,"ana":19,"ref":20},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":22,"ana":23,"ref":24},"limestone","#material.stone.limestone","http://www.eagle-network.eu/voc/material/lod/66.html",{"ana":26},"#condition.damaged",{"layout":28},{"p":29,"rs":30,"damage":34},"Latin text preserved in full over four lines, vertically centred on the stone, with a vacat below. The first line is the largest, the third line smallest and most compressed.",{"_":31,"ana":32,"ref":33},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"ana":35},"#text_condition.complete",{"lettering":37,"dimensions":38},"The letters are large and simply cut, without serifs. M has hastae of equal length, all off-vertical; S is shallow; R is closed with a long tail extending from the eye; B has small upper eye, closed; V is wide; F has shorter lower bar; E has equal short bars; C is not perfectly curved/circular, but rather shallow. Interpuncts throughout, formed of light vertical strokes.",[39,45,49,53,57,61,64],{"type":40,"l":41,"from":42,"to":42,"h":43,"unit":44},"letterHeight","Line 1","line1","42-45","mm",{"type":40,"l":46,"from":47,"to":47,"h":48,"unit":44},"Line 2","line2","38-42",{"type":40,"l":50,"from":51,"to":51,"h":52,"unit":44},"Line 3","line3","33-38",{"type":40,"l":54,"from":55,"to":55,"h":56,"unit":44},"Line 4","line4","36-40",{"type":58,"l":59,"from":42,"to":47,"h":60,"unit":44},"interlinear","Interlineation line 1 to 2","17-20",{"type":58,"l":62,"from":47,"to":51,"h":63,"unit":44},"Interlineation line 2 to 3","18-20",{"type":58,"l":65,"from":51,"to":55,"h":66,"unit":44},"Interlineation line 3 to 4","14-17",{"_":68,"notBefore":69,"notAfter":70,"evidence":71,"precision":72},"1st century CE",1,100,"lettering","low",[74,78],{"_":75,"type":76,"ref":77},"Halaesa","ancient","http://pleiades.stoa.org/places/462225",{"_":79,"type":80,"ref":81},"Castel di Tusa","modern","http://sws.geonames.org/2525099",[83],[84,85],37.99907,14.26197,[87,88],37.996456,14.261844,"Italy","Sicily",{"_":92,"role":93,"ref":94},"Antiquarium e sito archeologico di Halaesa ","museum","http://sicily.classics.ox.ac.uk/museum/053",{"_":96,"type":97},"ME 20273","inventory",{"_":99,"mainLang":100,"languages":101},"Latin","la",[99],"491841",{"n":104,"url":105,"height":106,"width":107,"desc":108,"surfaceType":109},"screen","ISic000584_tiled.tif","3680px","5520px","Photo J. Prag courtesy Soprintendenza BBCCAA di Messina","front",[],[112,113,114,115,116,117,118,119,120,121,122,123],"Siciliae obiacentium insular et Bruttiorum antiquae tabulae cum animadversionibus Georgii Gualtheri, 1624","Siciliæ obiacentium insular. et Bruttiorum antiquæ tabulæ, cum animadversionib, 1624 [1625]","Novus thesaurus veterum inscriptionum in praecipuis earumdem collectionibus hactenus praetermissarum, collectore Ludovico Antonio Muratorio .... Tomus secundus, 1740","Storia di Alesa, antica città di Sicilia, 1753","Siciliae et objacentium insularum veterum inscriptionum nova collectio, 1769","Siciliae et objacentium insularum veterum inscriptionum nova collectio prolegomenis et notis illustrata, et iterum cum emendationibus, & auctariis evulgata, 1784","CIL, 1883","Revisioni epigrafiche alesine e nuove inedite trascrizioni della grande tabula di Alesa, 1993","Alesa Arconidea: ricerche su un'antica città della Sicilia tirrenica, 2006",", , 2008, Alesa Archonidea. Guide to the Antiquarium","Spazio pubblico e memoria civica. Le epigrafi dall'agora di Alesa, 2012",", , 2017, Alesa Archonidea: il lapidarium",[125,126,127,128,129,130,131,132,133,134,135,136],"GIN6NANU","ZP8DE8KS","9S5VIRWZ","U7S4ZAG3","SPTB56H3","7PSFHSUH","GQN8UZSI","HQDFME9N","J4XWZPV6","ZQQNUUZJ","CJISRIUV","MI64NB9L",[138,139,140,14,18,22,141,142,143,144,141,145,146,100],"isic000584","funerary inscription for marcus limbricius and his wife helvia arura",{"_":11},"halaesa","castel di tusa","italy","sicily","antiquarium e sito archeologico di halaesa","latin","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marcus · Limbricius · Marci · filius ·\n                    Falerna tribu · Rufus\">\u003Cspan data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Marcus\">M(arcus)\u003C/span> · \u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Limbricius\">Limbricius\u003C/span> · \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Marci\">\u003Cspan data-type=\"name\" data-name-type=\"patronym\" data-text=\"Marci\">M(arci)\u003C/span>\u003C/span> · f(ilius) · \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>Fal(erna tribu) · \u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Rufus\">Rufus\u003C/span>\u003C/span> · \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>v(ivens) · sibi · et · \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Helviae · Arurae\">\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Helviae\">Helviae\u003C/span> · \u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Arurae\">Arurae\u003C/span>\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>uxori · suae · \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":149,"ptr":150,"ref":152,"title":2,"citation":5},"52 ph",{"target":151},"https://www.zotero.org/groups/382445/items/ZQQNUUZJ",{"_":153,"target":153},"https://biblio.inscriptiones.org/epig10001590",{"file":155,"uri":155,"title":156,"status":157,"editionAuthor":12,"type":158,"objectType":159,"material":160,"condition":164,"layoutDesc":165,"handNote":169,"date":225,"places":230,"geo":234,"provenance":75,"provenanceGeo":236,"country":89,"region":90,"settlement":75,"repository":239,"idno":240,"textLang":242,"tmNumber":246,"facsimile":247,"letterHeights":251,"publications":252,"zotero":255,"keywords":259,"html":265,"bibl":266},"ISic003337","Funerary inscription for Eirena",{"_":11},{"_":14,"ana":15,"ref":16},{"_":18,"ana":19,"ref":20},{"_":161,"ana":162,"ref":163},"marble\n                                    ","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html","",{"layout":166},{"p":167,"rs":168,"damage":164},"Ten lines of Greek filling the available space, decreasing notably in size in the second five lines",{"_":31,"ana":32,"ref":33},{"lettering":170,"dimensions":171},"The letters are engraved in a fairly plain, square fashion, with simple serifs. Alpha is mostly with broken bar, sometimes with an extended upper serif, although there is a straight bar example in line 7 and in lines 8 and 10 straight bar descending to left foot; beta is closed, with larger lower eye, generally horizontal along the base; delta varies between regular triangle and oblique lower bar with extended serif above; epsilon has straight bars of equal length, except for instances in lines 9 and 10 when it is lunate; theta is ovoid with connecting straight bar; kappa has short tails; lambda sometimes has an extended upper serif; mu varies between a form with vertical first and last hastae and short middle strokes meeting above the line and cursive form comparable to a lower-case mu in line 9; omicron is full size in the first few lines, but increasingly is smaller and mid-line; sigma is consistently lunate, but more often formed of three straight strokes; less often a single curved stroke; omega is consistently lunate, and sometimes smaller and mid-line. The eta and nu are in ligature in lines 5, 6 and 7. In line 5 the omicron in the final word is inscribed above the other letters (due to omission?). The last two/three words of the last line are enclosed between a pair of christograms. Small hedera occur in lines 1, 3, 5, and 10.",[172,174,176,178,180,183,187,191,195,199,203,205,207,209,212,215,217,220,223],{"type":40,"l":41,"from":42,"to":42,"h":173,"unit":44},"12-18",{"type":40,"l":46,"from":47,"to":47,"h":175,"unit":44},"14-19",{"type":40,"l":50,"from":51,"to":51,"h":177,"unit":44},"12-22",{"type":40,"l":54,"from":55,"to":55,"h":179,"unit":44},"8-22",{"type":40,"l":181,"from":182,"to":182,"h":173,"unit":44},"Line 5","line5",{"type":40,"l":184,"from":185,"to":185,"h":186,"unit":44},"Line 6","line6","9-16",{"type":40,"l":188,"from":189,"to":189,"h":190,"unit":44},"Line 7","line7","7-14",{"type":40,"l":192,"from":193,"to":193,"h":194,"unit":44},"Line 8","line8","6-12",{"type":40,"l":196,"from":197,"to":197,"h":198,"unit":44},"Line 9","line9","6-10",{"type":40,"l":200,"from":201,"to":201,"h":202,"unit":44},"Line 10","line10","5-13",{"type":58,"l":59,"from":42,"to":47,"h":204,"unit":44},"10-15",{"type":58,"l":62,"from":47,"to":51,"h":206,"unit":44},"3-7",{"type":58,"l":65,"from":51,"to":55,"h":208,"unit":44},"5-15",{"type":58,"l":210,"from":55,"to":182,"h":211,"unit":44},"Interlineation line 4 to 5","4-10",{"type":58,"l":213,"from":182,"to":185,"h":214,"unit":44},"Interlineation line 5 to 6","2-7",{"type":58,"l":216,"from":185,"to":189,"h":214,"unit":44},"Interlineation line 6 to 7",{"type":58,"l":218,"from":189,"to":193,"h":219,"unit":44},"Interlineation line 7 to 8","1-6",{"type":58,"l":221,"from":193,"to":197,"h":222,"unit":44},"Interlineation line 8 to 9","1-5",{"type":58,"l":224,"from":197,"to":201,"h":222,"unit":44},"Interlineation line 9 to 10",{"_":226,"notBefore":227,"notAfter":228,"evidence":229,"precision":72},"Later 4th — 5th century CE (The tombs of the necropolis are dated to the late 4th and 5th century CE (Tigano 2008b: 49) and the inscription easily fits within this date range.",351,500,"context",[231,232],{"_":75,"type":76,"ref":77},{"_":79,"type":80,"ref":81,"offset":233},"near",[235],[84,85],[237,238],38.007468,14.257626,{"_":92,"role":93,"ref":94},{"_":241,"type":97},"ME 20272",{"_":243,"mainLang":244,"languages":245},"Ancient Greek","grc",[243],"645584",{"n":104,"url":248,"height":249,"width":250,"desc":108,"surfaceType":109},"ISic003337_tiled.tif","3387px","5310px",[],[12,253,254,121,123],"Supplementum epigraphicum graecum, 1923-","Epigrafe in greco di IV sec. d.C. di Alesa (Sicilia) in versi e prosa, per la morte di Eirena Philandros, \"carissima a Botis boio-celtico\", 2006",[256,257,258,134,136],"R46KDTZX","F2GG87EQ","6KPB9V5B",[260,261,262,14,18,263,141,142,143,144,141,145,264,244],"isic003337","funerary inscription for eirena",{"_":11},"marble","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Ἡ πᾶσι ❦ ἐν βροτοῖσειν \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>σεμνῶς τὸν βίον ἀνα-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>διξαμένη ❦ φίλανδρος \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>ὡς οὐτ᾿ ἄλλη γυναικῶν. \u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>Εἰρ\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ή͡ν\u003C/span>α ἔνθαδε κεῖτε ❦ τέκν\u003Cspan class=\"error\" title=\"hi tag with rend=stacked is not supported!\">ο\u003C/span>ι-\u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>σι στοργ\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ὴ͡ν\u003C/span> λαμπρῶς εὐνοησα-\u003Cbr id=\"al7-interpretive\">\u003Cspan class=\"linenumber\">7\u003C/span>μέ\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ν͡η\u003C/span> ❦ τριακοστῷ καὶ δευτέρῳ περι-\u003Cbr id=\"al8-interpretive\">\u003Cspan class=\"linenumber\">8\u003C/span>πλεκομένῳ ἔτι Μοίρες βουλεύμα-\u003Cbr id=\"al9-interpretive\">\u003Cspan class=\"linenumber\">9\u003C/span>τι, μετὰ μεγίστου κλέους τέλος \u003Cbr id=\"al10-interpretive\">\u003Cspan class=\"linenumber\">10\u003C/span>ἔλαχεν ❦ ☧ Βωτιβοῖο φιλτ&lt;ά&gt;τη ❦ ☧ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">l.10 ά\u003C/p>",{"author":3,"date":4,"citedRange":267,"ptr":268,"ref":269,"title":2,"citation":5},"46-49, 52 ph",{"target":151},{"_":153,"target":153},{"file":271,"uri":271,"title":272,"status":273,"editionAuthor":12,"type":274,"objectType":278,"material":279,"condition":164,"layoutDesc":280,"handNote":288,"date":296,"places":298,"geo":301,"provenance":75,"provenanceGeo":303,"country":89,"region":90,"settlement":75,"repository":306,"idno":307,"textLang":309,"tmNumber":311,"facsimile":312,"letterHeights":315,"publications":316,"zotero":317,"keywords":318,"html":322,"bibl":323},"ISic003579","Record of building expenses",{"_":11},{"_":275,"ana":276,"ref":277},"building","#function.building","http://www.eagle-network.eu/voc/typeins/lod/86.html",{"_":18,"ana":19,"ref":20},{"_":263,"ana":162,"ref":163},{"layout":281},{"p":282,"rs":283,"damage":164}," On the reverse, above the line of holes, is a Latin inscription running the width of the slab. One fragment is lost from the upper part of the text",[284,285],{"_":31,"ana":32,"ref":33},{"_":286,"ana":287},"Rubrication, red coloured","#execution.rubrication.red",{"lettering":289,"dimensions":290},"The letters preserve red paint within them. The letters are neatly V-cut and regular, with triangular serifs to the ends of the strokes. M has sloping hastae; C is tall and shallow; P is curved and open; S is tall and falls forward slightly. Simple triangular interpuncts stand between each word and after the last word.",[291,293],{"type":40,"l":41,"from":42,"to":42,"h":292,"unit":44},"65-70",{"type":58,"l":294,"from":42,"to":47,"h":295,"unit":44},"Interlineation","n/a",{"_":68,"notBefore":69,"notAfter":70,"evidence":297,"precision":72},"context, lettering",[299,300],{"_":75,"type":76,"ref":77},{"_":79,"type":80,"ref":81,"offset":233},[302],[84,85],[304,305],37.997856,14.262463,{"_":92,"role":93,"ref":94},{"_":308,"type":97},"ME 20199",{"_":99,"mainLang":100,"languages":310},[99],"645650",{"n":104,"url":313,"height":314,"width":107,"desc":108,"surfaceType":109},"ISic003579_tiled.tif","2320px",[],[121,123],[134,136],[319,320,321,275,18,263,141,142,143,144,141,145,146,100],"isic003579","record of building expenses",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>impensa · \u003Cspan class=\"intraline\" title=\"line through\">(sestertium) · CC|ϽϽ · fecit · \u003C/span>\u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":324,"ptr":325,"ref":326,"title":2,"citation":5},"27",{"target":151},{"_":153,"target":153}],"uses":{"params":["slug"]}}]}
