Desc":292,"handNote":296,"date":306,"places":310,"geo":313,"country":61,"region":62,"settlement":54,"repository":315,"idno":316,"textLang":318,"facsimile":320,"provenance":50,"letterHeights":322,"publications":323,"zotero":325,"keywords":326,"html":187},"ISic001279","Edict of Flavius Felix Eumathus regarding the Thermae Achillianae",{"_":10},{"_":13,"ana":14,"ref":15},{"_":17,"ana":18,"ref":19},{"_":124,"ana":125,"ref":126},{"layout":293},{"p":294,"rs":295,"damage":24},"Greek text over four lines. The fourth line is shorter than the\n                                        other three and ends with a vacat. The letters are broadly regular and neatly\n                                        cut, but the sizing and spacing varies considerably across the four lines.",{"_":28,"ana":29,"ref":30},{"lettering":297,"dimensions":298},"Letters are wide and omicron, phi, sigma, epsilon and theta are, on\n                                    occasion formed by overlarge circles. Epsilon, sigma and omega are lunate. Xsi is\n                                    formed in a distinctive, ornate fashion. Interpuncts are used occasionally, and\n                                    formed of an 's' shape, sometimes forward, sometimes backward facing. Numerals are\n                                    marked with a supraline.",[299,303],{"type":35,"l":300,"from":37,"to":301,"h":302,"unit":38},"Line 1-4","line4","44-62",{"type":40,"l":304,"from":37,"to":301,"h":305,"unit":38},"Lines 1-4","9-27",{"_":307,"notBefore":308,"notAfter":308,"evidence":309},"434 CE (reporting an edict from the consuls of 433)",434,"internal-date",[311,312],{"_":50,"type":51,"ref":52},{"_":54,"type":55,"ref":56},[314],[59,60],{"_":64,"role":65,"ref":66},{"_":317,"type":69},"265",{"_":158,"mainLang":155,"languages":319},[158],{"n":75,"url":321,"height":77,"width":78,"desc":79,"surfaceType":80},"ISic001279_tiled.tif",[],[166,84,84,167,167,167,168,168,324,169,86,88,90],"Korhonen, 2004, IMusCatania",[173,93,93,174,174,1