kward facing. Numerals are\n                                    marked with a supraline.",[222,228],{"type":41,"l":223,"from":43,"to":224,"h":225,"unit":44,"atLeast":226,"atMost":227},"Line 1-4","line4","44-62","44","62",{"type":46,"l":229,"from":43,"to":224,"h":230,"unit":44,"atLeast":231,"atMost":232},"Lines 1-4","9-27","9","27",{"_":234,"notBefore":235,"notAfter":235,"evidence":236},"434 CE (reporting an edict from the consuls of 433)",434,"internal-date",[238,239],{"_":55,"type":56,"ref":57,"region":58},{"_":60,"type":61,"ref":62,"region":58},[241],[65,66],[243,244],37.502284,15.087585,{"_":72,"role":73,"ref":74},{"_":247,"type":77},"265",{"_":79,"mainLang":80,"languages":249},[79],"492884",{"n":84,"url":252,"height":253,"width":254,"desc":88,"surfaceType":89},"ISic001279_tiled.tif","354px","2152px",[256,259],{"atLeast":257,"atMost":258},44,62,{"atLeast":260,"atMost":261},9,27,[92,93,93,94,94,94,95,95,263,96,100,181,105],"Korhonen, 2004, IMusCatania",[107,108,108,109,109,109,110,110,187,111,115,186,120],[266,267,268,15,19,212,126,127,128,129,127,130,131,80],"isic001279","edict of flavius felix eumathus regarding the thermae achillianae",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>  \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Φλάβιος Φῆλιξ Εὐμάθιος\">\u003Cspan data-type=\"name\" data-name-type=\"nomen\" data-text=\"Φλάβιος\">Φλάβιος\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Φῆλιξ\">Φῆλιξ\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Εὐμάθιος\">Εὐμάθιος\u003C/span>\u003C/span> ὁ λαμπρ[ότατος ὑπατικὸς τῆς Σικελῶν ἐπα]ρχίας εἶπεν · αἱ θερμαὶ αἱ Ἀχιλλιαναὶ ἐξ ἀρ[χ]αίας διατυπώσεως ἀνήλ \u003Cspan class=\"underline\">ω\u003C/span> [σαν πήσας \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span> καθ’? ἑκάστην