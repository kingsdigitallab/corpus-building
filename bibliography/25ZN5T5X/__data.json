ury on the basis of the lettering.",301,400,"lettering",[290,291],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61},[293],[64,65],{"_":69,"role":70,"ref":71},{"_":76,"mainLang":77,"languages":296},[76],{"n":80,"url":298,"height":82,"width":83,"desc":299,"surfaceType":85},"ISic000160_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-06.",[],[302,303,89,192,137,88,304],"Castelli, 1769, Siciliae et objacentium insularum veterum inscriptionum nova collectio","Castelli, 1784, Siciliae et objacentium insularum veterum inscriptionum nova collectio prolegomenis et notis illustrata, et iterum cum emendationibus, & auctariis evulgata","Ferrua, 1941, Analecta sicula",[306,307,92,195,139,91,308],"SPTB56H3","7PSFHSUH","P7QQ9SB6",[310,311,312,109,17,21,97,98,99,100,98,101,102,77],"isic000160","funerary epitaph for cornelius acathobus",{"_":149},{"file":314,"uri":314,"title":315,"status":316,"editionAuthor":11,"type":317,"objectType":318,"material":320,"condition":24,"layoutDesc":321,"handNote":325,"date":330,"places":332,"geo":335,"country":66,"region":67,"settlement":59,"repository":337,"textLang":338,"facsimile":340,"provenance":55,"letterHeights":345,"publications":346,"zotero":348,"keywords":350,"html":354},"ISic000177","Fragmentary Latin epitaph",{"_":149},{"_":109,"ana":110,"ref":111},{"_":17,"ana":18,"ref":319},"http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":21,"ana":22,"ref":23},{"layout":322},{"p":323,"rs":324,"damage":24},"Remains of three lines of Latin letters, of which the first much larger than the second and third, with indications that the text was centred on the stone.",{"_":29,"ana":30,"ref":31},{"lettering":326,"dimensions":327},"Fairly tall narrow letters, deeply incised, L in line 1 with long descending lower stroke; O in line three smaller and mid-line; substantial but crude interpuncts.",[328,329],{"type":36,"l":37,"from":38,"to":38,"unit":40},{"type":46,"l":47,"from":38,"to":43,"unit":40},{"_":50,"notBefore":331,"notAfter":52},101,[333,334],{"_":55,"type":56,"ref":57},{"_":59,"type":60,"ref":61},[336],[64,65],{"_":69,"role":70,"ref":71},{"_":76,"mainLang":77,"languages":339},[76],{"n":80,"url":341,"height":342,"width":343,"desc":344,"surfaceType":85},"ISic000177_tiled.tif","2240px","3348px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo from I.L. Termini",[],[347,89,192,88],"Romano, 1832, Inscriptio Thermis nuper inventa",[349,92,195,91],"LXIPEQLG",[351,352,353,109,17,21,97,98,99,100,98,101,102,77],"isic000177","fragmentary latin epitaph",{"_":149},"Text encoding: Jonathan Prag",{"file":356,"uri":356,"title":357,"status":358,"editionAuthor":11,"type":359,"objectType":360,"material":361,"condition":24,"layoutDesc":362,"handNote":366,"date":375,"places":376,"geo":379,"country":66,"region":67,"settlement":59,"repository":381,"idno":382,"textLang":384,"facsimile":386,"provenance":55,"letterHeights":389,"publications":390,"zotero":391,"keywords":392,"html":396},"ISic000181","Epitaph for L. Herennius Certus",{"_":149},{"_":109,"ana":110,"ref":111},{"_":17,"ana":18,"ref":319},{"_":21,"ana":22,"ref":23},{"layout":363},{"p":364,"rs":365,"damage":24},"Three lines of Latin text, line 3 is almost entirely missing. Ill-defined interpuncts used, some triangular. Large vacat at the end of line 3. Abrasions at the beginning of line 2 frustrate precision of comprehension.",{"_":29,"ana":30,"ref":31},{"lettering":367,"dimensions":368},"Slightly haphazard letters, but otherwise tall and well-spaced. Serifs used on most letters.",[369,371,372,374],{"type":36,"l":37,"from":38,"to":38,"h":370,"unit":40},"39-42",{"type":36,"l":42,"from":43,"to":43,"h":167,"unit":40},{"type":36,"l":171,"from":172,"to":172,"h":373,"unit":40},"irrecoverable",{"type":46,"l":47,"from":38,"to":43,"unit":40},{"_":50,"notBefore":51,"notAfter":52},[377,378],{"_":55,"type":56,"ref":57,"cert":128},{"_":59,"type":60,"ref":61},[380],[64,65],{"_":69,"role":70,"ref":71},{"_":383,"type":74},"65 A/B",{"_":76,"mainLang":77,"languages":385},[76],{"n":80,"url":387,"height":82,"width":83,"desc":388,"surfaceType":85},"ISic000181_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-07",[],[191,89,192,88],[194,92,195,91],[393,394,395,109,17,21,97,98,99,100,98,101,102,77],"isic000181","epitaph for l. herennius certus",{"_":149},"Text encoding: Jonathan Prag, Alex Antoniou",{"file":398,"uri":398,"title":399,"status":400,"editionAuthor":11,"type":401,"objectType":402,"material":403,"condition":24,"layoutDesc":404,"handNote":408,"date":418,"places":419,"geo":422,"country":66,"region":67,"settlement":59,"repository":424,"idno":425,"textLang":427,"facsimile":429,"provenance":55,"letterHeights":431,"publications":432,"zotero":434,"keywords":436,"html":396},"ISic000183","Funerary epitaph for Marcus Hortesius Primus",{"_":149},{"_":109,"ana":110,"ref":111},{"_":17,"ana":18,"ref":319},{"_":156,"ana":157,"ref":158},{"layout":405},{"p":406,"rs":407,"damage":24},"Three lines of Latin text, with triangular interpuncts",{"_":29,"ana":30,"ref":31},{"lettering":409,"dimensions":410},"Letter shapes and orientation are slightly erratic, but the letters are extremely thin and with exaggerated serif tails, with a strong leftward slant to the vertical axis. The long legs of the \"R\"s are particularly distinctive.",[411,413,415,417],{"type":36,"l":37,"from":38,"to":38,"h":412,"unit":40},"40-49",{"type":36,"l":42,"from":43,"to":43,"h":414,"unit":40},"30-34",{"type":36,"l":171,"from":172,"to":172,"h":416,"unit":40},"41-50",{"type":46,"l":47,"from":38,"to":43,"unit":40},{"_":50,"notBefore":331,"notAfter":52},[420,421],{"_":55,"type":56,"re