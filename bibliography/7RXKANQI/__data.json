 consistently used, with one elegant example in line 2",[36,43],{"type":37,"l":38,"from":39,"to":40,"h":41,"unit":42},"letterHeight","Lines 1-6","line1","line6","72","mm",{"type":44,"l":45,"from":39,"to":46,"h":47,"unit":42},"interlinear","Line 1-2","line2","not measured",{"_":49,"notBefore":50,"notAfter":51,"evidence":52,"precision":17},"later 2nd or 3rd century CE (Vallarino on palaeographic grounds)",151,300,"lettering",[54,58],{"_":55,"type":56,"ref":57},"Agrigentum","ancient","http://pleiades.stoa.org/places/462086",{"_":59,"type":60,"ref":61},"Agrigento","modern","http://sws.geonames.org/6541860",[63],[64,65],37.32084,13.58876,[67,68],37.298238,13.589125,"Italy","Sicily",{"_":72,"role":73,"ref":74},"Museo Regionale Archeologico Pietro Griffo","museum","http://sicily.classics.ox.ac.uk/museum/130",{"type":76},"inventory",{"_":78,"mainLang":79,"languages":80},"Latin","la",[78],{"n":82,"url":83,"height":84,"width":85,"desc":86,"surfaceType":87},"screen","ISic004373_tiled.tif","2767px","2562px","Image courtesy of Giulio Vallarino","front",[],[12,90,91,92],"L'epigrafe dall'area del Tempio ellenistico-romano, 2017","Un nuovo \"curator rei publicae\" Liparese da Agrigento, 2018","L'epigrafe del curator rei publicae Liparitanorum, 2022",[94,95,96,97],"R46KDTZX","7RXKANQI","C395ZWLV","9SN32HDD",[99,100,101,102,19,23,103,104,105,106,104,107,108,79],"isic004373","dedication by a curator of the res publica liparitanorum",{"_":11},"honorific","agrigentum","agrigento","italy","sicily","museo regionale archeologico pietro griffo","latin","\u003Cdiv class=\"textpart\" lang=\"la\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al0a-interpretive\">\u003C!--0-->\u003C/a>[\u003Cspan dir=\"ltr\" class=\"gap\">⁦ - - - - - - - - - - ⁩\u003C/span>] \u003Cbr id=\"al1-interpretive\">\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 7.\u003C/span>]\u003Cspan dir=\"ltr\" class=\"gap\">.\u003C/span>us \u003Cspan dir=\"ltr\">(vac.1)\u003C/s