ventory",{"_":72,"mainLang":73,"languages":74},"Ancient Greek","grc",[72],{"n":76,"url":77,"height":78,"width":79,"desc":80,"surfaceType":81},"screen","ISic000964_tiled.tif","3680px","5520px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana","front",[],[84,85,86,87,88,89,90,91],"Kaibel, 1890, IG","Supplementum epigraphicum graecum, 1923-","Bulletin épigraphique, 1888-","Korhonen, 2004, IMusCatania","Kirchhoff, 1877, CIG","Agnello, 1953, Silloge di iscrizioni paleocristiane della Sicilia","IGCVO, 1989","Feissel, 1981, Notes d'épigraphie chrétienne (V)",[93,94,95,96,97,98,99,100],"Q2SBPG9F","F2GG87EQ","77P5MNIR","2EUC82DH","533T8HNS","D9BZFDDR","9CT5ZWIK","AWUTDEHF",[102,103,104,13,17,21,105,106,107,108,106,109,110,73],"isic000964","funerary inscription for agathon",{"_":10},"catina","catania","italy","sicily","museo civico di catania","ancient greek","Text encoding: Jonathan Prag",{"file":113,"uri":113,"title":114,"status":115,"editionAuthor":11,"type":117,"objectType":118,"material":122,"condition":24,"layoutDesc":123,"handNote":127,"date":136,"places":139,"geo":142,"country":62,"region":63,"settlement":55,"repository":144,"idno":145,"textLang":147,"facsimile":149,"provenance":51,"letterHeights":152,"publications":153,"zotero":156,"keywords":159,"html":111},"ISic001344","Funerary inscription for Agathe",{"_":116},"edited",{"_":13,"ana":14,"ref":15},{"_":119,"ana":120,"ref":121},"lid or cover (of an urn?)","#object.cover","http://www.eagle-network.eu/voc/objtyp/lod/84.html",{"_":21,"ana":22,"ref":23},{"layout":124},{"p":125,"rs":126,"damage":24},"The text is set out over nine lines, complete apart from the very\n                                        ends of lines 9 and 10. Chi-rho symbols are set to the left of line two and the\n                                        right of line three, and a star is set in the middle between lines one and two.\n                                        There is some crowding in the final two lines. The text is approximately centred\n                                        on the disc and the crowding at the end of line 8 in particular suggests that\n                                        the stone was cut to this circular shape prior to engraving.",{"_":28,"ana":29,"ref":30},{"lettering":128,"dimensions":129},"The letters are neatly but irregularly cut. Lunate epsilon, sigma and\n                                    omega; alpha has a steeply left sloping cross-bar, the right hasta extended well\n                                    above the rest of the letter; beta is tall, with two closed eyes, separated from\n                                    each other. Supralinear lines are used above numerals and also in line 6.",[130,134],{"type":34,"l":131,"from":36,"to":132,"h":133,"unit":38},"Line 1-9","line9","8-21",{"type":40,"l":135,"from":36,"to":42,"unit":38},"Interlineation not recorded",{"_":137,"notBefore":46,"notAfter":138,"precision":48},"4th or 5th century CE",500,[140,141],{"_":51,"type":52,"ref":53},{"_":55,"type":56,"ref":57},[143],[60,61],{"_":65,"role":66,"ref":67},{"_":146,"type":70},"719",{"_":72,"mainLang":73,"languages":148},[72],{"n":76,"url":150,"height":78,"width":79,"desc":151,"surfaceType":81},"ISic001344_tiled.tif","Photo J.Prag",[],[84,85,86,87,88,154,89,91,155],"Wilhelm, 1909, Beitraege zur griechischen Inschriftenkunde","Ferrua, 1989, Note e giunte alle iscrizioni cristiane antiche della Sicilia",[93,94,95,96,97,157,98,100,158],"5FKDFIPR","759ZXHKQ",[160,161,162,13,119,21,105,106,107,108,106,109,110,73],"isic001344","funerary inscription for agathe",{"_":116},{"file":164,"uri":164,"title":165,"status":166,"editionAuthor":11,"type":167,"objectType":168,"material":169,"condition":24,"layoutDesc":173,"handNote":176,"date":180,"places":182,"geo":189,"country":62,"region":63,"settlement":187,"repository":193,"idno":196,"textLang":198,"facsimile":200,"provenanc