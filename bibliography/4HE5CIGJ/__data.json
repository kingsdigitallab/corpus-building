:203,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"112",{"target":120},{"_":122,"target":122},{"file":205,"uri":205,"title":206,"status":207,"editionAuthor":13,"type":209,"objectType":213,"material":215,"condition":222,"layoutDesc":224,"handNote":230,"date":243,"places":248,"geo":255,"country":57,"provenance":250,"provenanceGeo":259,"region":69,"settlement":253,"repository":262,"idno":265,"textLang":267,"tmNumber":269,"facsimile":270,"letterHeights":273,"publications":279,"zotero":281,"keywords":283,"html":291,"bibl":292,"bulletinDateSort":123,"citedRangeSort":293,"languageSort":78,"materialSort":216,"typeSort":210},"ISic000655","Honorific inscription for Clodia Falconilla",{"_":208},"edited",{"_":210,"ana":211,"ref":212},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html",{"_":133,"ana":134,"ref":214},"https://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":216,"ana":217,"type":139,"subtype":218,"resp":28,"ref":141},"Coarse-grained, banded, white marble, likely Thasian-1, Thasian-2, Proconnesian. Digital microscopy: heteroblastic fabric (identification based on pXRF, digital microscopy)","#material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Thasian-1 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Thasian-2 #material.inorganic.stone.metamorphic_rock.marble.calcitic_marble.Proconnesian",[219,220,221],"Thasian-1","Thasian-2","Proconnesian",{"ana":223},"#condition.damaged",{"layout":225},{"p":226,"rs":227,"damage":228},"Five lines of Latin text, in straight alignment and shifted toward the right, with a wider left margin.The letters in the first line, which is partially legible, are of slightly greater module than those in the following lines, and are more widely spaced. The last line – of which only parts of one or more letters are preserved (perhaps an A and and the left apex of a V; an M is also possible) are preserved – appears more centered, with both left and right margins wider.",{"_":34,"ana":35,"ref":36},{"ana":229},"text_condition.partly_illegible",{"lettering":231,"dimensions":232},"Elegant square capital letters, slightly verticalized, with serifs. The O in l. 1 is square in shape compared to the O in the other lines; A has a vertical crossbar, P has an open loop. In l. 2, a triple nexus links the letters T, R, and I, with the I rising above. In l. 4, there is spacing between the words Sosius and Priscus. Comma-shaped punctuation marks appear in ll. 1 and 3. A damaged ivy leaf appears at the end of l. 1.",[233,237],{"type":40,"l":234,"from":42,"to":235,"h":236,"unit":43,"atLeast":236,"atMost":236},"Line 1-4","line4","80",{"type":45,"l":238,"from":42,"to":239,"h":240,"unit":43,"atLeast":241,"atMost":242},"Interlineation line 1 to 5","line5","30-35","30","35",{"_":244,"notBefore":245,"notAfter":246,"evidence":247},"Early 2nd century, mother of cos. 108 CE",101,120,"prosopography",[249,252],{"_":250,"type":55,"ref":251,"region":57},"Centuripae","http://pleiades.stoa.org/places/462153",{"_":253,"type":60,"ref":254,"region":57},"Centuripe","http://sws.geonames.org/2525032",[256],[257,258],37.62336,14.74049,[260,261],37.62257,14.74099,{"_":263,"role":72,"ref":264},"Museo Archeologico Regionale di Centuripe","http://sicily.classics.ox.ac.uk/museum/002",{"_":266,"type":76},"KA0858",{"_":78,"mainLang":79,"languages":268},[78],"493945",{"n":83,"url":271,"height":86,"width":85,"desc":272,"surfaceType":88},"ISic000655_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-05-09",[274,276],{"atLeast":275,"atMost":275},80,{"atLeast":277,"atMost":278},30,35,[91,91,280,93,94,96,95],"Libertini, 1926, Centuripe",[99,99,282,101,102,104,103],"VJZRAI26",[284,285,286,210,133,287,288,289,112,113,289,290,115,79],"isic000655","honorific inscription for clodia falconilla",{"_":208},"coarse-grained, banded, white marble, 