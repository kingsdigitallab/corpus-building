/382445/items/B8N2BQ9F",{"_":149,"target":149},"https://biblio.inscriptiones.org/epig10001864","1953364 with fig. 13",{"file":152,"uri":152,"title":153,"status":154,"editionAuthor":13,"type":155,"objectType":159,"material":160,"condition":161,"layoutDesc":162,"handNote":167,"date":181,"places":186,"geo":189,"provenance":70,"provenanceGeo":191,"country":84,"region":85,"settlement":74,"repository":192,"idno":193,"textLang":195,"tmNumber":197,"facsimile":198,"letterHeights":203,"publications":211,"zotero":214,"keywords":217,"html":221,"bibl":222,"citedRangeSort":223,"languageSort":94,"materialSort":23,"typeSort":156},"ISic000656","Honorific inscription for Sextus Pompeius Priscus",{"_":12},{"_":156,"ana":157,"ref":158},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"ana":27},{"layout":163},{"p":164,"rs":165,"damage":166},"Three lines of Latin text in straight alignment. Line 1 has a larger module than Line 2, and Line 2 has a larger module than Line 3. Furthermore, the lack of space in the final line resulted in a greater compression between the letters compared to the other lines.",{"_":32,"ana":33,"ref":34},{"ana":36},{"lettering":168,"dimensions":169},"Elegant square capital letters, slightly verticalized, with serifs. P has an open loop; O and Q are ovoid; A has a vertical crossbar. Spacing in line 2 between the words Quir(ina) and Prisc[o]. A comma-shaped punctuation mark appears in line 1, between Q(uinto) and Pompeio.",[170,175,178],{"type":41,"l":171,"from":43,"to":52,"h":172,"unit":45,"atLeast":173,"atMost":174},"Line 1-3","10-12","10","12",{"type":56,"l":176,"from":43,"to":48,"h":177,"unit":45,"atLeast":177,"atMost":177},"Interlineation line 1 to 2","6",{"type":56,"l":179,"from":48,"to":52,"h":180,"unit":45,"atLeast":180,"atMost":180},"Interlineation line 2 to 3","7",{"_":182,"notBefore":183,"notAfter":184,"evidence":185},"Uncle of cos. of 149 CE (?)",140,160,"prosop