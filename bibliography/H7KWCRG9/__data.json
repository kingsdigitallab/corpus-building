:28,"ana":29,"ref":30},{"dimensions":125},[126,127],{"type":34,"l":35,"from":36,"to":36,"unit":37},{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":129,"notBefore":130,"notAfter":130,"evidence":131},"356 CE (cos. date)",356,"internal-date",[133,134],{"_":48,"type":49,"ref":50},{"_":52,"type":53,"ref":54},[136],[57,58],{"_":62,"role":63,"ref":64},{"_":139,"type":67},"260",{"_":69,"mainLang":70,"languages":141},[69],{"n":73,"url":143,"height":75,"width":76,"desc":77,"surfaceType":78},"ISic000446_tiled.tif",[],[81,83,88,146,89,147],"Ferrua, 1982-1983, Le iscrizioni datate della Sicilia paleocristiana","Rizzone, 2011, Opus Christi edificabit: stati e funzioni dei cristiani di Sicilia attraverso l'apporto dell'epigrafia (secoli IV-VI)",[91,93,98,149,99,150],"Q7DDNWD6","N26B92N4",[152,153,154,13,117,21,104,105,106,107,105,108,109,70],"isic000446","funerary inscription of sporus",{"_":10},{"file":156,"uri":156,"title":157,"status":158,"editionAuthor":11,"type":160,"objectType":161,"material":163,"condition":164,"layoutDesc":166,"handNote":176,"date":181,"places":186,"geo":189,"country":59,"region":60,"settlement":52,"repository":191,"idno":192,"textLang":194,"facsimile":198,"provenance":48,"letterHeights":203,"publications":204,"zotero":208,"keywords":212,"html":217},"ISic000879","Epitaph for Agathe",{"_":159},"edited",{"_":13,"ana":14,"ref":15},{"_":117,"ana":118,"ref":162},"https://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":21,"ana":22,"ref":23},{"ana":165},"#condition.damaged",{"layout":167},{"p":168,"rs":169,"damage":174},"The text appears to observes the shape of the stone, with a fixed left margin and the lines fitting to the line of breakage on the right, and a staurogram centrally filling the space below. The letters retain traces of red paint throughout.",[170,171],{"_":28,"ana":29,"ref":30},{"_":172,"ana":173},"Rubrication, red coloured","#execution.rubrication.red",{"ana":175},"#text_condition.complete",{"lettering":177,"dimensions":178},"Slightly irregular but neatly carved plain letters without serifs. Alpha has straight bar; Epsilon is rectilinear, with mostly equal length bars; Theta is large and voice, with a full width horizontal bar; Kappa generally has short arms; Lamda has a slight extension at the top; Mu (in ligature) has vertical virst and last, with diagonals extending only half-way down;' rho has small head, closed; sigma is lunate but rectilinear; omega is lunate. Interpuncts are used around numerals.",[179,180],{"type":34,"l":35,"from":36,"to":36,"unit":37},{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":182,"notBefore":183,"notAfter":184,"precision":185},"4th-5th century CE",301,500,"low",[187,188],{"_":48,"type":49,"ref":50},{"_":52,"type":53,"ref":54},[190],[57,58],{"_":62,"role":63,"ref":64},{"_":193,"type":67},"28",{"_":195,"mainLang":196,"languages":197},"Ancient Greek","grc",[195],{"n":73,"url":199,"height":200,"width":201,"desc":202,"surfaceType":78},"ISic000879_tiled.tif","4921px","4287px","Photo Museo Arch. Reg. P. Orsi (2012), Aut. Assessorato Beni Culturali Regione Siciliana n.10681 del 06/05/2014",[],[205,88,206,207],"Kaibel, 1890, IG","Orsi, 2018, I Taccuini. I. Riproduzione anastatica e trascrizione dei Taccuini 1-4","IGCVO, 1989",[209,98,210,211],"Q2SBPG9F","RGRSRUHK","9CT5ZWIK",[213,214,215,13,117,21,104,105,106,107,105,108,216,196],"isic000879","epitaph for agathe",{"_":159},"ancient greek","Text encoding: Valentina Mignosa, Jonathan Prag",{"file":219,"uri":219,"title":220,"status":221,"editionAuthor":11,"type":222,"objectType":223,"material":224,"condition":225,"layoutDesc":226,"handNote":231,"date":236,"places":239,"geo":242,"country":59,"region":60,"settlement":52,"repository":244,"idno":245,"textLang":247,"facsimile":249,"provenance":48,"letterHeights":254,"publications":255,"zotero":258,"keywords":261,"html":217},"ISic000934","Epitaph of Zodoros",{"_":159},{"_":13,"ana":14,"ref":15},{"_":117,"ana":118,"ref":162},{"_":21,"ana":22,"ref":23},{"ana":165},{"layout":227},{"p":228,"rs":229,"damage":230},"The text maintains a regular left margin, ignoring the irregularity of the form of the stone, and filling the space to the right; however, the cutter ran out of space at the end of the stone, and inserted the remaining letters of the word Δεκεμβρίῳ and the concluding staurogram, firstly at the end of line 2 (letter β) and then, under a 'paragraphos' line to the left of the main text of line 2, level with lines 3 (letters ριω) and 4 (staurogram)",{"_":28,"ana":29,"ref":30},{"ana":175},{"lettering":232,"dimensions":233},"plainly cut, relatively regular letters, in a curved groove rather than v-cut, without serifs. Alpha has an oblique crossbar, sloping down to left, and a horizontal stroke to left off the top of the letter; beta has closed eyes, the upper is smaller; epsilon is lunate (except for the first in line 5 which is rectilinear); zeta has regular Z form; kappa has near full-legnth arms; mu has cursive form; omicron is full size; rho has closed eye; sigma is lunate; omega is lunate.",[234,235],{"type":34,"l":35,"from":36,"to":36,"unit":37},{"type":39,"l":40,"from":36,"to":41,"unit":37},{"_":237,"notBefore":183,"notAfter":238},"4th - 6th century CE",600,[240,241],{"_":48,"type":49,"ref":50},{"_":52,"type":53,"ref":54},[243],[57,58],{"_":62,"role":63,"ref":64},{"_":246,"type":67},"68",{"_":195,"mainLang":196,"languages":248},[195],{"n":73,"url":250,"height":251,"width":252,"desc":253,"surfaceType":78},"ISic000934_tiled.tif","2448px","3264px","Photo Museo Arch. Reg. P. Orsi (2015), Aut. Assessorato Beni Culturali Regione Siciliana n.10681 del 06/05/2014",[],[205,256,256,88,206,207,257],"Supplementum epigraphicum graecum, 1923-","Feissel, 1982, Remarques de toponymie syrienne d'après des inscriptions grecques chrétiennes trouvées hors de Syrie",[209,259,259,98,210,211,260],"F2GG87EQ","VHTQG3Z8",[262,263,264,13,117,21,104,105,106,107,105,108,216,196],"isic000934","epitaph of zodoros",{"_":159},{"file":266,"uri":266,"title":267,"status":