{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":7,"isBulletin":127},{"title":2,"author":3,"date":4,"citation":5,"uri":6},"Due nuovi saturnii?","Wick","1926","\u003Cspan>F. C. Wick, «Due nuovi saturnii?», \u003Ci>Athenaeum\u003C/i> 4 (1926): 167–71\u003C/span>","https://www.zotero.org/groups/isicily/items/SP2B89MW",[8],{"file":9,"uri":9,"title":10,"status":11,"editionAuthor":13,"type":14,"objectType":18,"material":22,"condition":26,"layoutDesc":27,"handNote":34,"date":48,"places":52,"geo":61,"provenance":54,"provenanceGeo":65,"country":68,"region":69,"settlement":58,"repository":70,"textLang":71,"tmNumber":79,"facsimile":80,"letterHeights":87,"publications":90,"zotero":100,"keywords":110,"html":119,"bibl":120,"citedRangeSort":125,"languageSort":126,"materialSort":23,"typeSort":15},"ISic002753","Fragment of a bilingual dedication to Priapus",{"_":12},"draft",null,{"_":15,"ana":16,"ref":17},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":19,"ana":20,"ref":21},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259.html",{"_":23,"ana":24,"ref":25},"marble","#material.stone.marble","http://www.eagle-network.eu/voc/material/lod/48.html","",{"layout":28},{"_":29,"rs":30,"damage":26},"Five lines of regularly spaced Greek letters followed by three lines of Latin letters. The first two lines of Latin text follow the same spacing as the Greek text; the final line is seemingly centered, more widely spaced (with interpuncts) and separated by a slightly greater interval from the lines above. Although the top of the stone is damaged, the visible space above line 1 is greater than that between the following lines.\n                                    \n                                \t\n\t\t\t",{"_":31,"ana":32,"ref":33},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":35,"dimensions":36},"Regular, well-cut Greek letters with clearly defined serifs at the end of strokes: Omicron, omega and theta all have rhomboid form; in some instances this is actually a pentagonal form, flat across the top; Omega is open at the bottom; Sigma is four bar and regular; Epsilon has equal horizontal strokes; Alpha has broken bar; the diagonal of the Nu starts and finishes well below/above the ends of the vertical strokes. The Latin letters show the beginnings of the move towards cursive forms: M has extended upper strokes and the midpoint reaches to the bottom of the line; A also has extended upper stroke and lacks a cross-bar; O is rounded, in contrast to the Greek text, as is Q with extended tail; P is open; R is closed; E has short upward slanting strokes; L has a long foot, forming almost a C.",[37,44],{"type":38,"l":39,"from":40,"to":41,"h":42,"unit":43,"atLeast":42,"atMost":42},"letterHeight","Lines 1-8","line1","line8","20","mm",{"type":45,"l":46,"from":40,"to":47,"unit":43},"interlinear","Interlineation\n                                ","line2",{"_":49,"notBefore":50,"notAfter":51},"Late 2nd — 4th century CE",180,400,[53,57],{"_":54,"type":55,"ref":56},"Acium","ancient","http://pleiades.stoa.org/places/462067",{"_":58,"type":59,"ref":60},"Aci San Antonio","modern","http://sws.geonames.org/2525383",[62],[63,64],37.57533,15.17411,[66,67],37.598818,15.126647,"Italy","Sicily","unknown",{"_":72,"mainLang":73,"otherLangs":74,"ana":75,"languages":76},"Ancient Greek and Latin","grc","la","#bilingualism.biversion.complementary",[77,78],"Ancient Greek","Latin","175851",{"n":81,"url":82,"height":83,"width":84,"desc":85,"surfaceType":86},"screen","ISic002753_tiled.tif","2790px","3431px","Scan of photo in NSA 1922 p.494 fig.2","front",[88],{"atLeast":89,"atMost":89},20,[91,92,92,92,92,93,94,95,96,97,98,99],"L'année épigraphique: revue des publications épigraphiques relatives a l'antiquité romaine., 1888-","Supplementum epigraphicum graecum, 1923-","Manganaro, 1988, La Sicilia da