oto by students of the Liceo Lazzaro)",[162],{"atLeast":163,"atMost":164},15,20,[81,82,83,166],"Wilson, 1990, Sicily under the Roman Empire: the archaeology of a Roman province, 36 B.C. - A.D. 535",[87,88,89,168],"VF9MMBI9",[170,171,172,15,173,19,96,97,98,99,97,100,174,153],"isic003236","inscribed funerary urn of flavianos",{"_":114},"cinerary urn","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Φλαβιανὸς\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Φλαβιανὸς\">\u003Cspan data-text=\"Φλαβιανὸς\" data-n=\"5\" data-lemma=\"Φλαβιανός\">Φλαβιανὸς\u003C/span>\u003C/span>\u003C/span> · \u003Cspan data-text=\"χρησ\n                    τὸς\" data-n=\"15\" data-lemma=\"χρηστός\">χρησ-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>τὸς\u003C/span> · \u003Cspan data-text=\"καὶ\" data-n=\"25\" data-lemma=\"καί\">καὶ\u003C/span>  \u003Cspan data-text=\"ἄμενπτος\" data-n=\"30\" data-lemma=\"ἄμεμπτος\">ἄμεν(πτος)\u003C/span> · \u003Cspan data-text=\"ἔζησεν\" data-n=\"40\" data-lemma=\"ζάω\">ἔζη(σεν)\u003C/span> · \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἔτη\" data-n=\"50\" data-lemma=\"ἔτος\">ἔτη\u003C/span> · \u003Cspan data-text=\"λζ\" data-n=\"60\" data-lemma=\"λζ\">λζ\u003C/span>´ · \u003Cspan data-text=\"μῆνας\" data-n=\"70\" data-lemma=\"μείς\">μ\u003Cspan class=\"petraeligature\" title=\"Ligature: these characters are joined\">ῆ͡ν\u003C/span>(ας)\u003C/span> · \u003Cspan data-text=\"γ\" data-n=\"80\" data-lemma=\"γ\">γ\u003C/span>´ · \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"ἡμέρας\" data-n=\"90\" data-lemma=\"ἡμέρα\">ἡμέ(ρας)\u003C/span> · \u003Cspan data-text=\"ι\" data-n=\"100