,"region":64,"settlement":55,"repository":138,"idno":141,"textLang":142,"tmNumber":144,"facsimile":145,"letterHeights":147,"publications":148,"zotero":151,"keywords":154,"html":159,"bibl":160},"ISic001550","I.Sicily inscription 001550",{"_":12},{"_":15,"ana":16,"ref":17},{"_":19,"ana":20,"ref":21},{"_":23,"ana":24,"ref":25},{"layout":124},{"rs":125,"damage":26},{"_":30,"ana":31,"ref":32},{"lettering":127,"dimensions":128},"painted letters, simple in style without serifs and not perfectly following a horizontal line. Alpha has straight bar; theta is circular with a central point; M is very broad, all strokes diagonal, the mid-point not fully down to the lower line; sigma is lunate.",[129,130],{"type":37,"l":38,"from":39,"to":39,"unit":40},{"type":42,"l":43,"from":39,"to":44,"unit":40},{"_":46,"notBefore":47,"notAfter":48},[133,134],{"_":51,"type":52,"ref":53},{"_":55,"type":56,"ref":57},[136],[60,61],[],{"_":139,"role":68,"ref":140},"Museo archeologico regionale Lilibeo Marsala - Baglio Anselmi","http://sicily.classics.ox.ac.uk/museum/108",{"type":72},{"_":74,"mainLang":75,"languages":143},[74],"284948",{"n":79,"url":146,"height":81,"width":82,"desc":83,"surfaceType":84},"ISic001550_tiled.tif",[],[149,149,87,150,88,89,90,91],"Supplementum epigraphicum graecum, 1923-","Kretschmer, 1927, Das Femininum von ἥρως",[152,152,93,153,94,95,96,97],"F2GG87EQ","NT9TNH4M",[155,156,157,15,19,23,102,103,104,105,103,158,108,75],"isic001550","i.sicily inscription 001550",{"_":12},"museo archeologico regionale lilibeo marsala - baglio anselmi","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>Μαρία ἥρυς \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>ἀγαθά \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":161,"ptr":162,"ref":163,"title":2,"citation":5,"uri":6},"71-75 tav