e lettering.",-600,-501,[151,152],{"_":59,"type":60,"ref":61,"region":62},{"_":64,"type":65,"ref":66,"region":62},[154],[69,70],[156,157],36.8729563,14.4421611,{"_":77,"role":78,"ref":79},{"_":160,"type":82},"16484",{"_":84,"mainLang":85,"languages":162},[84],[],[92,93,94],[96,97,98],[167,168,169,123,127,131,103,104,105,106,107,108,109,85],"isic001870","inscribed fragment of a marble basin",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΘΟΝΙ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":112,"ptr":172,"ref":173,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":114},{"_":116,"target":116},{"file":175,"uri":175,"title":176,"status":177,"editionAuthor":13,"type":178,"objectType":179,"material":183,"condition":28,"layoutDesc":187,"handNote":191,"date":213,"places":216,"geo":222,"country":62,"provenance":218,"provenanceGeo":226,"region":74,"settlement":75,"repository":229,"idno":230,"textLang":232,"tmNumber":28,"facsimile":234,"letterHeights":241,"publications":251,"zotero":252,"keywords":253,"html":258,"bibl":259,"bulletinDateSort":117,"citedRangeSort":260,"languageSort":84,"materialSort":23,"typeSort":15},"ISic001871","Funerary inscription for Gamike",{"_":12},{"_":15,"ana":16,"ref":17},{"_":180,"ana":181,"ref":182},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":23,"type":184,"resp":185,"ref":27,"subtype":186},"stone.calcarenite","#Coccato",[],{"layout":188},{"p":189,"rs":190,"damage":28},"Text over five lines, carefully following guidelines to the base of each line, with a marginal guideline to the left and right, with the left margin consistently observed. An additional guideline below is unused; the guidelines carefully align with the text to the right of this one. Use of a vacat prior to the age at death.",{"_":33,"ana":34,"ref":35},{"lettering":192,"dimensions":193},"Deep and wide slightly crude v-cut, producing consistent fairly square letters without serifs. Alpha has mostly downward left sloping cross-bar; epsilon is lunate with mostly shorter middle bar; zeta has slight curvature to the strokes; kappa has short arms; mu has four full-length diagonal strokes; lunate sigma, but note final square lunate for digamma / stigma for numeral 6.",[194,198,202,204,209,212],{"type":40,"l":144,"from":42,"to":42,"h":195,"unit":45,"atLeast":196,"atMost":197},"27-30","27","30",{"type":40,"l":199,"from":51,"to":51,"h":200,"unit":45,"atLeast":201,"atMost":197},"Line 2","25-30","25",{"type":40,"l":203,"from":43,"to":43,"h":200,"unit":45,"atLeast":201,"atMost":197},"Line 3",{"type":40,"l":205,"from":206,"to":206,"h":207,"unit":45,"atLeast":208,"atMost":197},"Line 4","line4","21-30","21",{"type":40,"l":210,"from":211,"to":211,"h":200,"unit":45,"atLeast":201,"atMost":197},"Line 5","line5",{"type":49,"l":50,"from":42,"to":51,"unit":45},{"_":214,"notBefore":54,"notAfter":215,"evidence":56},"Roman imperial in date",300,[217,220],{"_":218,"type":60,"ref":219,"region":62},"Syracusae","http://pleiades.stoa.org/places/462503",{"_":75,"type":65,"ref":221,"region":62},"http://sws.geonames.org/2523083",[223],[224,225],37.08415,15.27628,[227,228],37.0784545,15.2786827,{"_":77,"role":78,"ref":79},{"_":231,"type":82},"15083",{"_":84,"mainLang":85,"languages":233},[84],{"n":235,"url":236,"height":237,"width":238,"desc":239,"surfaceType":240},"screen","ISic001871_tiled.tif","3680px","5520px","I.Sicily with the permission of the Parco archeologico e paesaggistico di Siracusa, Eloro, Villa del Tellaro e Akrai, and the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-04-29.","front",[242,245,247,248,250],{"atLeast":243,"atMost":244},27,30,{"atLeast":246,"atMost":244},25,{"atLeast":246,"atMost":244},{"atLeast":249,"atMost":244},21,{"atLeast":246,"atMost":244},[92],[96],[254,255,256,15,180,23,257,107,105,106,107,108,109,85],"isic001871","funerary inscription for gamike",{"_":12},"syracusae","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γαμική\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Γαμική\">Γαμική\u003C/span>\u003C/span>  \u003Cspan data-text=\"χρη\n                    στὰ\">χρη-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>στὰ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"ἄ\n                    μεμπτε\">ἄ-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>μεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> κς´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":260,"ptr":261,"ref":262,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"400",{"target":114},{"_":116,"target":116},{"file":264,"uri":264,"title":265,"status":266,"editionAuthor":13,"type":267,"objectType":268,"material":269,"condition":28,"layoutDesc":271,"handNote":275,"date":296,"places":297,"geo":300,"country":62,"provenance":218,"provenanceGeo":302,"region":74,"settlement":75,"repository":303,"idno":304,"textLang":305,"tmNumber":28,"facsimile":307,"letterHeights":309,"publications":320,"zotero":321,"keywords":322,"html":326,"bibl":327,"bulletinDateSort":117,"citedRangeSort":260,"languageSort":84,"materialSort":23,"typeSort":15},"ISic001872","Funerary inscription for Mousa",{"_":12},{"_":15,"ana":16,"ref":17},{"_":180,"ana":181,"ref":182},{"_":23,"type":184,"resp":185,"ref":27,"subtype":270},[],{"layout":272},{"p":273,"rs":274,"damage":28},"Text over six lines, set in a recessed panel in the style of a temple facade, but without guidelines. Some use of interpuncts and vacats in the text.",{"_":33,"ana":34,"ref":35},{"lettering":276,"dimensions":277},"Text is deeply incised in letters of slightly varying size. Extensive use of serifs, with several letters tending to the cursive. Alpha has straight bar, curving ends; epsilon is lunate with equal length mid-bar; zeta is large and curved; kappa has near full-length arms; mu has slanting strokes that reach the lower line, but often join before the top and have extended upper strokes; pi has overlapping cross bar; rho has closed eye; sigma is lunate. Elegant hedera in line 2; use of vacats in age at death.",[278,281,285,288,289,291,295],{"type":40,"l":144,"from":42,"to":42,"h":279,"unit":45,"atLeast":201,"atMost":280},"25-31","31",{"type":40,"l":199,"from":51,"to":51,"h":282,"unit":45,"atLeast":283,"atMost":284},"20-22","20","22",{"type":40,"l":203,"from":43,"to":43,"h":286,"unit":45,"atLeast":287,"atMost":201},"19-25","19",{"type":40,"l":205,"from":206,"to":206,"h":286,"unit":45,"atLeast":287,"atMost":201},{"type":40,"l":210,"from":211,"to":211,"h":290,"unit":45,"atLeast":287,"atMost":208},"19-21",{"type":40,"l":292,"from":293,"to":293,"h":294,"unit":45,"atLeast":283,"atMost":208},"Line 6","line6","20-21",{"type":49,"l":50,"from":42,"to":51,"unit":45},{"_":214,"notBefore":54,"notAfter":215,"evidence":56},[298,299],{"_":218,"type":60,"ref":219,"region":62},{"_":75,"type":65,"ref":221,"region":62},[301],[224,225],[227,228],{"_":77,"role":78,"ref":79},{"_":231,"type":82},{"_":84,"mainLang":85,"languages":306},[84],{"n":235,"url":308,"height":237,"width":238,"desc":239,"surfaceType":240},"ISic001872_tiled.tif",[310,312,315,317,318,319],{"atLeast":246,"atMost":311},31,{"atLeast":313,"atMost":314},20,22,{"atLeast":316,"atMost":246},19,{"atLeast":316,"atMost":246},{"atLeast":316,"atMost":249},{"atLeast":313,"atMost":249},[92],[96],[323,324,325,15,180,23,257,107,105,106,107,108,109,85],"isic001872","funerary inscription for mousa",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μοῦσα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Μοῦσα\">Μοῦσα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"μῆνες\">μῆνες\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>ι´ ·\u003Cspan dir=\"ltr\">(vac.1)\u003C/span> ἡμέρας \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> κε´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":260,"ptr":328,"ref":329,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":114},{"_":116,"target":116},{"file":331,"uri":331,"title":332,"status":333,"editionAuthor":13,"type":334,"objectType":335,"material":336,"condition":28,"layoutDesc":338,"handNote":346,"date":363,"places":364,"geo":367,"country":62,"provenance":218,"provenanceGeo":369,"region":74,"settlement":75,"repository":370,"idno":371,"textLang":372,"tmNumber":28,"facsimile":374,"letterHeights":376,"publications":386,"zotero":387,"keywords":388,"html":392,"bibl":393,"bulletinDateSort":117,"citedRangeSort":260,"languageSort":84,"materialSort":23,"typeSort":15},"ISic001873","Funerary inscription for Kopria",{"_":12},{"_":15,"ana":16,"ref":17},{"_":180,"ana":181,"ref":182},{"_":23,"type":184,"resp":185,"ref":27,"subtype":337},[],{"layout":339},{"p":340,"rs":341,"damage":28},"Text over five lines, neatly respecting gridlines to the base of each line and with marginal lines to left and right - that on the left is approximately followed, that on the right is ignored; an additional gridline below is unused. Some use of interpuncts and vacats in the text. The first line shows clear traces of red paint in the letters.",[342,343],{"_":33,"ana":34,"ref":35},{"_":344,"ana":345},"rubrication, red colour","#execution.rubrication.red",{"lettering":347,"dimensions":348},"Text is incised in fairly tall, thin, neat and plain letters mostly without serifs. Alpha has downward left sloping cross-bar; epsilon is lunate, with shorter and sometimes detached middle bar; zeta is straight; eta sometimes has detached cross-bar (line 4); kapa has short arms; mu has angled strokes, the mid-strokes only descending half-way, and no upward extension of the apexes; omicron is slightly smaller than other letters; pi does not overlap; rho i slcosed; sigma is lunate. Use of a simple/stylised hedera in lines 2 and 4, and letters are somewhat irregularly spaced especially in the final line.",[349,352,356,357,360,362],{"type":40,"l":144,"from":42,"to":42,"h":350,"unit":45,"atLeast":351,"atMost":197},"29-30 (omicron = 20)","29",{"type":40,"l":199,