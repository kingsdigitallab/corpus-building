{"type":"data","nodes":[{"type":"data","data":[{"debug":1},true],"uses":{}},{"type":"data","data":[{"zotero":1,"inscriptions":7,"isBulletin":566},{"title":2,"author":3,"date":4,"citation":5,"uri":6},"Sicile","Orsi","1896","\u003Cspan>Paolo Orsi, « Sicile », \u003Ci>Bulletin de Correspondance Hellénique\u003C/i> 20 (1896): 399‑400\u003C/span>","https://www.zotero.org/groups/isicily/items/FWX5CWBN",[8,117,172,260,326,391],{"file":9,"uri":9,"title":10,"status":11,"editionAuthor":13,"type":14,"objectType":18,"material":22,"condition":27,"layoutDesc":28,"handNote":35,"date":51,"places":56,"geo":66,"country":61,"provenance":58,"provenanceGeo":70,"region":73,"settlement":74,"repository":75,"idno":79,"textLang":82,"tmNumber":27,"letterHeights":86,"publications":90,"zotero":94,"keywords":98,"html":109,"bibl":110,"bulletinDateSort":116,"citedRangeSort":111,"languageSort":83,"materialSort":23,"typeSort":15},"ISic001869","Funerary inscription for Artemo",{"_":12},"edited",null,{"_":15,"ana":16,"ref":17},"funerary","#function.funerary","http://www.eagle-network.eu/voc/typeins/lod/92.html",{"_":19,"ana":20,"ref":21},"block","#object.block","http://www.eagle-network.eu/voc/objtyp/lod/189.html",{"_":23,"type":24,"subtype":25,"ref":26},"limestone","stone.limestone","unverified","http://www.eagle-network.eu/voc/material/lod/66.html","",{"layout":29},{"p":30,"rs":31,"damage":27},"Three lines of Greek letters, seemingly not centered / regularly laid out.",{"_":32,"ana":33,"ref":34},"chiselled","#execution.chiselled","http://www.eagle-network.eu/voc/writing/lod/1",{"lettering":36,"dimensions":37},"Described by Orsi (1896) as 'scritto a pessimi caratteri', and (1899) as 'lettere cattive, rustiche cosi che a tutta prima sembrano archaiche, e molto sconservate... L'iscrizione negligentemente redatta e scolpita è funebre di tarda età'. Pace states 'lettere del III sec. av. Cr.', but given the presence of lunate epsilon and Orsi's comments, a later date seems much more likely.",[38,47],{"type":39,"l":40,"from":41,"to":42,"h":43,"unit":44,"atLeast":45,"atMost":46},"letterHeight","Line 1-3","line1","line3","55-95","mm","55","95",{"type":48,"l":49,"from":41,"to":50,"unit":44},"interlinear","Interlineation line 1 to 2","line2",{"_":52,"notBefore":53,"notAfter":54,"evidence":55},"Suggested to be of later Roman date by Orsi on the basis of lettering etc.",101,400,"lettering",[57,62],{"_":58,"type":59,"ref":60,"region":61},"Kamarina","ancient","http://pleiades.stoa.org/places/462126","Sicilia",{"_":63,"type":64,"ref":65,"region":61},"Santa Croce Camerina","modern","http://sws.geonames.org/6540853",[67],[68,69],36.8736,14.4507,[71,72],36.8759983,14.4377781,"Sicily","Siracusa",{"_":76,"role":77,"ref":78},"Museo Archeologico Regionale Paolo Orsi","museum","http://sicily.classics.ox.ac.uk/museum/097",{"_":80,"type":81},"16474","inventory",{"_":83,"mainLang":84,"languages":85},"Ancient Greek","grc",[83],[87],{"atLeast":88,"atMost":89},55,95,[91,92,93],"Orsi, 1896, Sicile","Orsi, 1899, Camarina (Campagna archeologica del 1896)","Pace, 1927, Camarina: topografia, storia, archeologia",[95,96,97],"FWX5CWBN","ICW2M9P2","ZJ6KUFMM",[99,100,101,15,19,23,102,103,104,105,106,107,108,84],"isic001869","funerary inscription for artemo",{"_":12},"kamarina","santa croce camerina","sicilia","sicily","siracusa","museo archeologico regionale paolo orsi","ancient greek","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἀρτεμοι\n                    Ἀρτεμιδό\n                    του\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἀρτεμοι\">Ἀρτεμοι̣\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἀρτεμιδό\n                    του\">\u003Cspan 