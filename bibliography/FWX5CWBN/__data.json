span class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΘΟΝΙ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":103,"ptr":160,"ref":161,"title":2,"citation":5},{"target":105},{"_":107,"target":107},{"file":163,"uri":163,"title":164,"status":165,"editionAuthor":12,"type":166,"objectType":167,"material":171,"condition":3,"layoutDesc":172,"handNote":176,"date":194,"places":197,"geo":203,"provenance":199,"provenanceGeo":207,"country":67,"region":68,"settlement":69,"repository":210,"idno":211,"textLang":213,"tmNumber":3,"facsimile":215,"letterHeights":222,"publications":223,"zotero":224,"keywords":225,"html":230,"bibl":231},"ISic001871","Funerary inscription for Gamike",{"_":11},{"_":14,"ana":15,"ref":16},{"_":168,"ana":169,"ref":170},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":22,"ana":23,"ref":24},{"layout":173},{"p":174,"rs":175,"damage":3},"Text over five lines, carefully following guidelines to the base of each line, with a marginal guideline to the left and right, with the left margin consistently observed. An additional guideline below is unused; the guidelines carefully align with the text to the right of this one. Use of a vacat prior to the age at death.",{"_":29,"ana":30,"ref":31},{"lettering":177,"dimensions":178},"Deep and wide slightly crude v-cut, producing consistent fairly square letters without serifs. Alpha has mostly downward left sloping cross-bar; epsilon is lunate with mostly shorter middle bar; zeta has slight curvature to the strokes; kappa has short arms; mu has four full-length diagonal strokes; lunate sigma, but note final square lunate for digamma / stigma for numeral 6.",[179,181,184,186,190,193],{"type":36,"l":132,"from":38,"to":38,"h":180,"unit":41},"27-30",{"type":36,"l":182,"from":45,"to":45,"h":183,"unit":41},"Line 2","25-30",{"type":36,"l":185,"from":39,"to":39,"h":183,"unit":41},"Line 3",{"type":36,"l":187,"from":188,"to":188,"h":189,"unit":41},"Line 4","line4","21-30",{"type":36,"l":191,"from":192,"to":192,"h":183,"unit":41},"Line 5","line5",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":195,"notBefore":48,"notAfter":196,"evidence":50},"Roman imperial in date",300,[198,201],{"_":199,"type":54,"ref":200},"Syracusae","http://pleiades.stoa.org/places/462503",{"_":69,"type":58,"ref":202},"http://sws.geonames.org/2523083",[204],[205,206],37.08415,15.27628,[208,209],37.0784545,15.2786827,{"_":71,"role":72,"ref":73},{"_":212,"type":76},"15083",{"_":78,"mainLang":79,"languages":214},[78],{"n":216,"url":217,"height":218,"width":219,"desc":220,"surfaceType":221},"screen","ISic001871_tiled.tif","3680px","5520px","I.Sicily with the permission of the Parco archeologico e paesaggistico di Siracusa, Eloro, Villa del Tellaro e Akrai, and the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-04-29.","front",[],[83],[87],[226,227,228,14,168,22,229,98,96,97,98,99,100,79],"isic001871","funerary inscription for gamike",{"_":11},"syracusae","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γαμική\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Γαμική\">Γαμική\u003C/span>\u003C/span>  \u003Cspan data-text=\"χρη\n                    στὰ\">χρη-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>στὰ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"ἄ\n                    μεμπτε\">ἄ-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>μεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> κς´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":232,"ptr":233,"ref":234,"title":2,"citation":5},"400",{"target":105},{"_":107,"target":107},{"file":236,"uri":236,"title":237,"status":238,"editionAuthor":12,"type":239,"objectType":240,"material":241,"condition":3,"layoutDesc":242,"handNote":246,"date":263,"places":264,"geo":267,"provenance":199,"provenanceGeo":269,"country":67,"region":68,"settlement":69,"repository":270,"idno":271,"textLang":272,"tmNumber":3,"facsimile":274,"letterHeights":276,"publications":277,"zotero":278,"keywords":279,"html":283,"bibl":284},"ISic001872","Funerary inscription for Mousa",{"_":11},{"_":14,"ana":15,"ref":16},{"_":168,"ana":169,"ref":170},{"_":22,"ana":23,"ref":24},{"layout":243},{"p":244,"rs":245,"damage":3},"Text over six lines, set in a recessed panel in the style of a temple facade, but without guidelines. Some use of interpuncts and vacats in the text.",{"_":29,"ana":30,"ref":31},{"lettering":247,"dimensions":248},"Text is deeply incised in letters of slightly varying size. Extensive use of serifs, with several letters tending to the cursive. Alpha has straight bar, curving ends; epsilon is lunate with equal length mid-bar; zeta is large and curved; kappa has near full-length arms; mu has slanting strokes that reach the lower line, but often join before the top and have extended upper strokes; pi has overlapping cross bar; rho has closed eye; sigma is lunate. Elegant hedera in line 2; use of vacats in age at death.",[249,251,253,255,256,258,262],{"type":36,"l":132,"from":38,"to":38,"h":250,"unit":41},"25-31",{"type":36,"l":182,"from":45,"to":45,"h":252,"unit":41},"20-22",{"type":36,"l":185,"from":39,"to":39,"h":254,"unit":41},"19-25",{"type":36,"l":187,"from":188,"to":188,"h":254,"unit":41},{"type":36,"l":191,"from":192,"to":192,"h":257,"unit":41},"19-21",{"type":36,"l":259,"from":260,"to":260,"h":261,"unit":41},"Line 6","line6","20-21",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":195,"notBefore":48,"notAfter":196,"evidence":50},[265,266],{"_":199,"type":54,"ref":200},{"_":69,"type":58,"ref":202},[268],[205,206],[208,209],{"_":71,"role":72,"ref":73},{"_":212,"type":76},{"_":78,"mainLang":79,"languages":273},[78],{"n":216,"url":275,"height":218,"width":219,"desc":220,"surfaceType":221},"ISic001872_tiled.tif",[],[83],[87],[280,281,282,14,168,22,229,98,96,97,98,99,100,79],"isic001872","funerary inscription for mousa",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μοῦσα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Μοῦσα\">Μοῦσα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"μῆνες\">μῆνες\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>ι´ ·\u003Cspan dir=\"ltr\">(vac.1)\u003C/span> ἡμέρας \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> κε´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":232,"ptr":285,"ref":286,"title":2,"citation":5},{"target":105},{"_":107,"target":107},{"file":288,"uri":288,"title":289,"status":290,"editionAuthor":12,"type":291,"objectType":292,"material":293,"condition":3,"layoutDesc":294,"handNote":302,"date":315,"places":316,"geo":319,"provenance":199,"provenanceGeo":321,"country":67,"region":68,"settlement":69,"repository":322,"idno":323,"textLang":324,"tmNumber":3,"facsimile":326,"letterHeights":328,"publications":329,"zotero":330,"keywords":331,"html":335,"bibl":336},"ISic001873","Funerary inscription for Kopria",{"_":11},{"_":14,"ana":15,"ref":16},{"_":168,"ana":169,"ref":170},{"_":22,"ana":23,"ref":24},{"layout":295},{"p":296,"rs":297,"damage":3},"Text over five lines, neatly respecting gridlines to the base of each line and with marginal lines to left and right - that on the left is approximately followed, that on the right is ignored; an additional gridline below is unused. Some use of interpuncts and vacats in the text. The first line shows clear traces of red paint in the letters.",[298,299],{"_":29,"ana":30,"ref":31},{"_":300,"ana":301},"rubrication, red colour","#execution.rubrication.red",{"lettering":303,"dimensions":304},"Text is incised in fairly tall, thin, neat and plain letters mostly without serifs. Alpha has downward left sloping cross-bar; epsilon is lunate, with shorter and sometimes detached middle bar; zeta is straight; eta sometimes has detached cross-bar (line 4); kapa has short arms; mu has angled strokes, the mid-strokes only descending half-way, and no upward extension of the apexes; omicron is slightly smaller than other letters; pi does not overlap; rho i slcosed; sigma is lunate. Use of a simple/stylised hedera in lines 2 and 4, and letters are somewhat irregularly spaced especially in the final line.",[305,307,309,310,312,314],{"type":36,"l":132,"from":38,"to":38,"h":306,"unit":41},"29-30 (omicron = 20)",{"type":36,"l":182,"from":45,"to":45,"h":308,"unit":41},"26-32",{"type":36,"l":185,"from":39,"to":39,"h":183,"unit":41},{"type":36,"l":187,"from":188,"to":188,"h":311,"unit":41},"24-30",{"type":36,"l":191,"from":192,"to":192,"h":313,"unit":41},"22-32",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":195,"notBefore":48,"notAfter":196,"evidence":50},[317,318],{"_":199,"type":54,"ref":200},{"_":69,"type":58,"ref":202},[320],[205,206],[208,209],{"_":71,"role":72,"ref":73},{"_":212,"type":76},{"_":78,"mainLang":79,"languages":325},[78],{"n":216,"url":327,"height":218,"width":219,"desc":220,"surfaceType":221},"ISic001873_tiled.tif",[],[83],[87],[332,333,334,14,168,22,229,98,96,97,98,99,100,79],"isic001873","funerary inscription for kopria",{"_":11},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κοπρία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κοπρία\">Κοπρία\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span> ❦ \u003Cspan data-text=\"ἔζη\n                    σεν\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σεν\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> λ´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":232,"ptr":337,"ref":338,"titl