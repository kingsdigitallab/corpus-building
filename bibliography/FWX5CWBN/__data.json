s of the lettering.",-600,-501,[149,150],{"_":58,"type":59,"ref":60,"region":61},{"_":63,"type":64,"ref":65,"region":61},[152],[68,69],[154,155],36.8729563,14.4421611,{"_":76,"role":77,"ref":78},{"_":158,"type":81},"16484",{"_":83,"mainLang":84,"languages":160},[83],[],[91,92,93],[95,96,97],[165,166,167,122,126,130,102,103,104,105,106,107,108,84],"isic001870","inscribed fragment of a marble basin",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΘΟΝΙ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":111,"ptr":170,"ref":171,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":113},{"_":115,"target":115},{"file":173,"uri":173,"title":174,"status":175,"editionAuthor":13,"type":176,"objectType":177,"material":181,"condition":27,"layoutDesc":184,"handNote":188,"date":210,"places":213,"geo":219,"country":61,"provenance":215,"provenanceGeo":223,"region":73,"settlement":74,"repository":226,"idno":227,"textLang":229,"tmNumber":27,"facsimile":231,"letterHeights":238,"publications":248,"zotero":249,"keywords":250,"html":255,"bibl":256,"bulletinDateSort":116,"citedRangeSort":257,"languageSort":83,"materialSort":23,"typeSort":15},"ISic001871","Funerary inscription for Gamike",{"_":12},{"_":15,"ana":16,"ref":17},{"_":178,"ana":179,"ref":180},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":23,"type":182,"subtype":27,"resp":183,"ref":26},"stone.calcarenite","#Coccato",{"layout":185},{"p":186,"rs":187,"damage":27},"Text over five lines, carefully following guidelines to the base of each line, with a marginal guideline to the left and right, with the left margin consistently observed. An additional guideline below is unused; the guidelines carefully align with the text to the right of this one. Use of a vacat prior to the age at death.",{"_":32,"ana":33,"ref":34},{"lettering":189,"dimensions":190},"Deep and wide slightly crude v-cut, producing consistent fairly square letters without serifs. Alpha has mostly downward left sloping cross-bar; epsilon is lunate with mostly shorter middle bar; zeta has slight curvature to the strokes; kappa has short arms; mu has four full-length diagonal strokes; lunate sigma, but note final square lunate for digamma / stigma for numeral 6.",[191,195,199,201,206,209],{"type":39,"l":142,"from":41,"to":41,"h":192,"unit":44,"atLeast":193,"atMost":194},"27-30","27","30",{"type":39,"l":196,"from":50,"to":50,"h":197,"unit":44,"atLeast":198,"atMost":194},"Line 2","25-30","25",{"type":39,"l":200,"from":42,"to":42,"h":197,"unit":44,"atLeast":198,"atMost":194},"Line 3",{"type":39,"l":202,"from":203,"to":203,"h":204,"unit":44,"atLeast":205,"atMost":194},"Line 4","line4","21-30","21",{"type":39,"l":207,"from":208,"to":208,"h":197,"unit":44,"atLeast":198,"atMost":194},"Line 5","line5",{"type":48,"l":49,"from":41,"to":50,"unit":44},{"_":211,"notBefore":53,"notAfter":212,"evidence":55},"Roman imperial in date",300,[214,217],{"_":215,"type":59,"ref":216,"region":61},"Syracusae","http://pleiades.stoa.org/places/462503",{"_":74,"type":64,"ref":218,"region":61},"http://sws.geonames.org/2523083",[220],[221,222],37.08415,15.27628,[224,225],37.0784545,15.2786827,{"_":76,"role":77,"ref":78},{"_":228,"type":81},"15083",{"_":83,"mainLang":84,"languages":230},[83],{"n":232,"url":233,"height":234,"width":235,"desc":236,"surfaceType":237},"screen","ISic001871_tiled.tif","3680px","5520px","I.Sicily with the permission of the Parco archeologico e paesaggistico di Siracusa, Eloro, Villa del Tellaro e Akrai, and the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-04-29.","front",[239,242,244,245,247],{"atLeast":240,"atMost":241},27,30,{"atLeast":243,"atMost":241},25,{"atLeast":243,"atMost":241},{"atLeast":246,"atMost":241},21,{"atLeast":243,"atMost":241},[91],[95],[251,252,253,15,178,23,254,106,104,105,106,107,108,84],"isic001871","funerary inscription for gamike",{"_":12},"syracusae","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γαμική\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Γαμική\">Γαμική\u003C/span>\u003C/span>  \u003Cspan data-text=\"χρη\n                    στὰ\">χρη-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>στὰ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"ἄ\n                    μεμπτε\">ἄ-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>μεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> κς´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":257,"ptr":258,"ref":259,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"400",{"target":113},{"_":115,"target":115},{"file":261,"uri":261,"title":262,"status":263,"editionAuthor":13,"type":264,"objectType":265,"material":266,"condition":27,"layoutDesc":267,"handNote":271,"date":292,"places":293,"geo":296,"country":61,"provenance":215,"provenanceGeo":298,"region":73,"settlement":74,"repository":299,"idno":300,"textLang":301,"tmNumber":27,"facsimile":303,"letterHeights":305,"publications":316,"zotero":317,"keywords":318,"html":322,"bibl":323,"bulletinDateSort":116,"citedRangeSort":257,"languageSort":83,"materialSort":23,"typeSort":15},"ISic001872","Funerary inscription for Mousa",{"_":12},{"_":15,"ana":16,"ref":17},{"_":178,"ana":179,"ref":180},{"_":23,"type":182,"subtype":27,"resp":183,"ref":26},{"layout":268},{"p":269,"rs":270,"damage":27},"Text over six lines, set in a recessed panel in the style of a temple facade, but without guidelines. Some use of interpuncts and vacats in the text.",{"_":32,"ana":33,"ref":34},{"lettering":272,"dimensions":273},"Text is deeply incised in letters of slightly varying size. Extensive use of serifs, with several letters tending to the cursive. Alpha has straight bar, curving ends; epsilon is lunate with equal length mid-bar; zeta is large and curved; kappa has near full-length arms; mu has slanting strokes that reach the lower line, but often join before the top and have extended upper strokes; pi has overlapping cross bar; rho has closed eye; sigma is lunate. Elegant hedera in line 2; use of vacats in age at death.",[274,277,281,284,285,287,291],{"type":39,"l":142,"from":41,"to":41,"h":275,"unit":44,"atLeast":198,"atMost":276},"25-31","31",{"type":39,"l":196,"from":50,"to":50,"h":278,"unit":44,"atLeast":279,"atMost":280},"20-22","20","22",{"type":39,"l":200,"from":42,"to":42,"h":282,"unit":44,"atLeast":283,"atMost":198},"19-25","19",{"type":39,"l":202,"from":203,"to":203,"h":282,"unit":44,"atLeast":283,"atMost":198},{"type":39,"l":207,"from":208,"to":208,"h":286,"unit":44,"atLeast":283,"atMost":205},"19-21",{"type":39,"l":288,"from":289,"to":289,"h":290,"unit":44,"atLeast":279,"atMost":205},"Line 6","line6","20-21",{"type":48,"l":49,"from":41,"to":50,"unit":44},{"_":211,"notBefore":53,"notAfter":212,"evidence":55},[294,295],{"_":215,"type":59,"ref":216,"region":61},{"_":74,"type":64,"ref":218,"region":61},[297],[221,222],[224,225],{"_":76,"role":77,"ref":78},{"_":228,"type":81},{"_":83,"mainLang":84,"languages":302},[83],{"n":232,"url":304,"height":234,"width":235,"desc":236,"surfaceType":237},"ISic001872_tiled.tif",[306,308,311,313,314,315],{"atLeast":243,"atMost":307},31,{"atLeast":309,"atMost":310},20,22,{"atLeast":312,"atMost":243},19,{"atLeast":312,"atMost":243},{"atLeast":312,"atMost":246},{"atLeast":309,"atMost":246},[91],[95],[319,320,321,15,178,23,254,106,104,105,106,107,108,84],"isic001872","funerary inscription for mousa",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μοῦσα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Μοῦσα\">Μοῦσα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"μῆνες\">μῆνες\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>ι´ ·\u003Cspan dir=\"ltr\">(vac.1)\u003C/span> ἡμέρας \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> κε´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":257,"ptr":324,"ref":325,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":113},{"_":115,"target":115},{"file":327,"uri":327,"title":328,"status":329,"editionAuthor":13,"type":330,"objectType":331,"material":332,"condition":27,"layoutDesc":333,"handNote":341,"date":358,"places":359,"geo":362,"country":61,"provenance":215,"provenanceGeo":364,"region":73,"settlement":74,"repository":365,"idno":366,"textLang":367,"tmNumber":27,"facsimile":369,"letterHeights":371,"publications":381,"zotero":382,"keywords":383,"html":387,"bibl":388,"bulletinDateSort":116,"citedRangeSort":257,"languageSort":83,"materialSort":23,"typeSort":15},"ISic001873","Funerary inscription for Kopria",{"_":12},{"_":15,"ana":16,"ref":17},{"_":178,"ana":179,"ref":180},{"_":23,"type":182,"subtype":27,"resp":183,"ref":26},{"layout":334},{"p":335,"rs":336,"damage":27},"Text over five lines, neatly respecting gridlines to the base of each line and with marginal lines to left and right - that on the left is approximately followed, that on the right is ignored; an additional gridline below is unused. Some use of interpuncts and vacats in the text. The first line shows clear traces of red paint in the letters.",[337,338],{"_":32,"ana":33,"ref":34},{"_":339,"ana":340},"rubrication, red colour","#execution.rubrication.red",{"lettering":342,"dimensions":343},"Text is incised in fairly tall, thin, neat and plain letters mostly without serifs. Alpha has downward left sloping cross-bar; epsilon is lunate, with shorter and sometimes detached middle bar; zeta is straight; eta sometimes has detached cross-bar (line 4); kapa has short arms; mu has angled strokes, the mid-strokes only descending half-way, and no upward extension of the apexes; omicron is slightly smaller than other letters; pi does not overlap; rho i slcosed; sigma is lunate. Use of a simple/stylised hedera in lines 2 and 4, and letters are somewhat irregularly spaced especially in the final line.",[344,347,351,352,355,357],{"type":39,"l":142,"from":41,"to":41,"h":345,"unit":44,"atLeast":346,"atMost":194},"29-30 (omicron = 20)","29",{"type":39,"l":196,"from":50,"to":50,"h":348,"unit":44,"atLeast":349,"atMost":350},"26-32","26","32",{"type":39,"l":200,"from":42,"to":42,"h":197,"unit":44,"atLeast":198,"atMost":194},{"type":39,"l":202,"from":203,"to":203,"h":353,"unit":44,"atLeast":354,"atMost":194},"24-30","24",{"type":39,"l":207,"from":208,"to":208,"h":356,"unit":44,"atLeast":280,"atMost":350},"22-32",{"type":48,"l":49,"from":41,"to":50,"unit":44},{"_":211,"notBefore":53,"notAfter":212,"evidence":55},[360,361],{"_":215,"type":59,"ref":216,"region":61},{"_":74,"type":64,"ref":218,"region":61},[363],[221,222],[224,225],{"_":76,"role":77,"ref":78},{"_":228,"type":81},{"_":83,"mainLang":84,"languages":368},[83],{"n":232,"url":370,"height":234,"width":235,"desc":236,"surfaceType":237},"ISic001873_tiled.tif",[372,374,377,378,380],{"atLeast":373,"atMost":241},29,{"atLeast":375,"atMost":376},26,32,{"atLeast":243,"atMost":241},{"atLeast":379,"atMost":241},24,{"atLeast":310,"atMost":376},[91],[95],[384,385,386,15,178,23,254,106,104,105,106,107,108,84],"isic001873","funerary inscription for kopria",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κοπρία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κοπρία\">Κοπρία\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span> ❦ \u003Cspan data-text=\"ἔζη\n                    σεν\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σεν\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> λ´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":257,"ptr":389,"ref":390,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":113},{"_":115,"target":115},{"file":392,"uri":392,"title":393,"status":394,"editionAuthor":13,"type":395,"objectType":399,"material":403,"condition":27,"layoutDesc":405,"handNote":409,"date":512,"places":517,"geo":520,"country":61,"provenance":215,"provenanceGeo":522,"region":73,"settlement":74,"repository":525,"idno":526,"textLang":528,"tmNumber":530,"facsimile":531,"letterHeights":534,"publications":542,"zotero":550,"keywords":558,"html":562,"bibl":563,"bulletinDateSort":116,"citedRangeSort":257,"languageSort":83,"materialSort":23,"typeSort":396},"ISic003331","The Syracusans honour King Gelon, son of Hieron II",{"_":12},{"_":396,"ana":397,"ref":398},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html",{"_":400,"ana":401,"ref":402},"base","#object.base","http://www.eagle-network.eu/voc/objtyp/lod/57.html",{"_":23,"type":404,"subtype":27,"resp":183,"ref":26},"stone.calcite_limestone",{"layout":406},{"p":407,"rs":408,"damage":27},"Three lines of finely carved Greek letters, centred on the stone (line one with short vacats at beginning and end, line 2 fully filling the face of the stone, line 3 centred with substantial vacats before and after.",{"_":32,"ana":33,"ref":34},{"lettering":410,"dimensions":499},[411,412],"Elegant wide and very regular letters with thinly carved strokes. Broken bar alpha; beta with equal sized loops; epsilon with short middle bar; kappa with short arms; mu with vertical first and last, middle strokes to half-height; omicron normally full size but small in line 2 (compression a factor); rho with almost fully rounded eye; sigma with approximately horizontal top and bottom strokes or very slightly open; omega full-size rounded and open