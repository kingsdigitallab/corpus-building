e":63,"ref":64,"region":60},[150],[67,68],[152,153],36.8729563,14.4421611,{"_":75,"role":76,"ref":77},{"_":156,"type":80},"16484",{"_":82,"mainLang":83,"languages":158},[82],[],[90,91,92],[94,95,96],[163,164,165,121,125,129,101,102,103,104,105,106,107,83],"isic001870","inscribed fragment of a marble basin",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΘΟΝΙ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":110,"ptr":168,"ref":169,"inscriptionDate":4,"title":2,"citation":5,"uri":6},{"target":112},{"_":114,"target":114},{"file":171,"uri":171,"title":172,"status":173,"editionAuthor":13,"type":174,"objectType":175,"material":179,"condition":26,"layoutDesc":180,"handNote":184,"date":206,"places":209,"geo":215,"country":60,"provenance":211,"provenanceGeo":219,"region":72,"settlement":73,"repository":222,"idno":223,"textLang":225,"tmNumber":26,"facsimile":227,"letterHeights":234,"publications":244,"zotero":245,"keywords":246,"html":251,"bibl":252,"bulletinDateSort":115,"citedRangeSort":253,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001871","Funerary inscription for Gamike",{"_":12},{"_":15,"ana":16,"ref":17},{"_":176,"ana":177,"ref":178},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":23,"ana":24,"ref":25},{"layout":181},{"p":182,"rs":183,"damage":26},"Text over five lines, carefully following guidelines to the base of each line, with a marginal guideline to the left and right, with the left margin consistently observed. An additional guideline below is unused; the guidelines carefully align with the text to the right of this one. Use of a vacat prior to the age at death.",{"_":31,"ana":32,"ref":33},{"lettering":185,"dimensions":186},"Deep and wide slightly crude v-cut, producing consistent fairly square letters without serifs. Alpha has mostly downward left sloping cross-bar; epsilon is lunate with mostly shorter middle bar; zeta has slight curvature to the strokes; kappa has short arms; mu has four full-length diagonal strokes; lunate sigma, but note final square lunate for digamma / stigma for numeral 6.",[187,191,195,197,202,205],{"type":38,"l":140,"from":40,"to":40,"h":188,"unit":43,"atLeast":189,"atMost":190},"27-30","27","30",{"type":38,"l":192,"from":49,"to":49,"h":193,"unit":43,"atLeast":194,"atMost":190},"Line 2","25-30","25",{"type":38,"l":196,"from":41,"to":41,"h":193,"unit":43,"atLeast":194,"atMost":190},"Line 3",{"type":38,"l":198,"from":199,"to":199,"h":200,"unit":43,"atLeast":201,"atMost":190},"Line 4","line4","21-30","21",{"type":38,"l":203,"from":204,"to":204,"h":193,"unit":43,"atLeast":194,"atMost":190},"Line 5","line5",{"type":47,"l":48,"from":40,"to":49,"unit":43},{"_":207,"notBefore":52,"notAfter":208,"evidence":54},"Roman imperial in date",300,[210,213],{"_":211,"type":58,"ref":212,"region":60},"Syracusae","http://pleiades.stoa.org/places/462503",{"_":73,"type":63,"ref":214,"region":60},"http://sws.geonames.org/2523083",[216],[217,218],37.08415,15.27628,[220,221],37.0784545,15.2786827,{"_":75,"role":76,"ref":77},{"_":224,"type":80},"15083",{"_":82,"mainLang":83,"languages":226},[82],{"n":228,"url":229,"height":230,"width":231,"desc":232,"surfaceType":233},"screen","ISic001871_tiled.tif","3680px","5520px","I.Sicily with the permission of the Parco archeologico e paesaggistico di Siracusa, Eloro, Villa del Tellaro e Akrai, and the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-04-29.","front",[235,238,240,241,243],{"atLeast":236,"atMost":237},27,30,{"atLeast":239,"atMost":237},25,{"atLeast":239,"atMost":237},{"atLeast":242,"atMost":237},21,{"atLeast":239,"atMost":237},[90],[94],[247,248,249,15,176,23,250,105,103,104,105,106,107,83],"isic001871","funerary inscription for gamike",{"_":12},"syracusae","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γαμική\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Γαμική\">Γαμική\u003C/span>\u003C/span>  \u003Cspan data-text=\"χρη\n                    στὰ\">χρη-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>στὰ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"ἄ\n                    μεμπτε\">ἄ-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>μεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> κς´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":253,"ptr":254,"ref":255,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"400",{"target":112},{"_":114,"target":114},{"file":257,"uri":257,"title":258,"status":259,"editionAuthor":13,"type":260,"objectType":261,"material":262,"condition":26,"layoutDesc":263,"handNote":267,"date":288,"places":289,"geo":292,"country":60,"provenance":211,"provenanceGeo":294,"region":72,"settlement":73,"repository":295,"idno":296,"textLang":297,"tmNumber":26,"facsimile":299,"letterHeights":301,"publications":312,"zotero":313,"keywords":314,"html":318,"bibl":319,"bulletinDateSort":115,"citedRangeSort":253,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001872","Funerary inscription for Mousa",{"_":12},{"_":15,"ana":16,"ref":17},{"_":176,"ana":177,"ref":178},{"_":23,"ana":24,"ref":25},{"layout":264},{"p":265,"rs":266,"damage":26},"Text over six lines, set in a recessed panel in the style of a temple facade, but without guidelines. Some use of interpuncts and vacats in the text.",{"_":31,"ana":32,"ref":33},{"lettering":268,"dimensions":269},"Text is deeply incised in letters of slightly varying size. Extensive use of serifs, with several letters tending to the cursive. Alpha has straight bar, curving ends; epsilon is lunate with equal length mid-bar; zeta is large and curved; kappa has near full-length arms; mu has slanting strokes that reach the lower line, but often join before the top and have extended upper strokes; pi has overlapping cross bar; rho has closed eye; sigma is lunate. Elegant hedera in line 2; use of vacats in age at death.",[270,273,277,280,281,283,287],{"type":38,"l":140,"from":40,"to":40,"h":271,"unit":43,"atLeast":194,"atMost":272},"25-31","31",{"type":38,"l":192,"from":49,"to":49,"h":274,"unit":43,"atLeast":275,"atMost":276},"20-22","20","22",{"type":38,"l":196,"from":41,"to":41,"h":278,"unit":43,"atLeast":279,"atMost":194},"19-25","19",{"type":38,"l":198,"from":199,"to":199,"h":278,"unit":43,"atLeast":279,"atMost":194},{"type":38,"l":203,"from":204,"to":204,"h":282,"unit":43,"atLeast":279,"atMost":201},"19-21",{"type":38,"l":284,"from":285,"to":285,"h":286,"unit":43,"atLeast":275,"atMost":201},"Line 6","line6","20-21",{"type":47,"l":48,"from":40,"to":49,"unit":43},{"_":207,"notBefore":52,"notAfter":208,"evidence":54},[290,291],{"_":211,"type":58,"ref":212,"region":60},{"_":73,"type":63,"ref":214,"region":60},[293],[217,218],[220,221],{"_":75,"role":76,"ref":77},{"_":224,"type":80},{"_":82,"mainLang":83,"languages":298},[82],{"n":228,"url":300,"height":230,"width":231,"desc":232,"surfaceType":233},"ISic001872_tiled.tif",[302,304,307,309,310,311],{"atLeast":239,"atMost":303},31,{"atLeast":305,"atMost":306},20,22,{"atLeast":308,"atMost":239},19,{"atLeast":308,"atMost":239},{"atLeast":308,"atMost":242},{"atLeast":305,"atMost":242},[90],[94],[315,316,317,15,176,23,250,105,103,104,105,106,107,83],"isic001872","funerary inscription for mousa",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μοῦσα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Μοῦσα\">Μοῦσα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"μῆνες\">μῆνες\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>ι´ ·\u003Cspan dir=\"ltr\">(vac.1)\u003C/span> ἡμέρας \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> κε´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":253,"ptr":320,"ref":321,"inscriptionDate":4,"title":2,"citation":5,"uri":6},{"target":112},{"_":114,"target":114},{"file":323,"uri":323,"title":324,"status":325,"editionAuthor":13,"type":326,"objectType":327,"material":328,"condition":26,"layoutDesc":329,"handNote":337,"date":354,"places":355,"geo":358,"country":60,"provenance":211,"provenanceGeo":360,"region":72,"settlement":73,"repository":361,"idno":362,"textLang":363,"tmNumber":26,"facsimile":365,"letterHeights":367,"publications":377,"zotero":378,"keywords":379,"html":383,"bibl":384,"bulletinDateSort":115,"citedRangeSort":253,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001873","Funerary inscription for Kopria",{"_":12},{"_":15,"ana":16,"ref":17},{"_":176,"ana":177,"ref":178},{"_":23,"ana":24,"ref":25},{"layout":330},{"p":331,"rs":332,"damage":26},"Text over five lines, neatly respecting gridlines to the base of each line and with marginal lines to left and right - that on the left is approximately followed, that on the right is ignored; an additional gridline below is unused. Some use of interpuncts and vacats in the text. The first line shows clear traces of red paint in the letters.",[333,334],{"_":31,"ana":32,"ref":33},{"_":335,"ana":336},"rubrication, red colour","#execution.rubrication.red",{"lettering":338,"dimensions":339},"Text is incised in fairly tall, thin, neat and plain letters mostly without serifs. Alpha has downward left sloping cross-bar; epsilon is lunate, with shorter and sometimes detached middle bar; zeta is straight; eta sometimes has detached cross-bar (line 4); kapa has short arms; mu has angled strokes, the mid-strokes only descending half-way, and no upward extension of the apexes; omicron is slightly smaller than other letters; pi does not overlap; rho i slcosed; sigma is lunate. Use of a simple/stylised hedera in lines 2 and 4, and letters are somewhat irregularly spaced especially in the final line.",[340,343,347,348,351,353],{"type":38,"l":140,"from":40,"to":40,"h":341,"unit":43,"atLeast":342,"atMost":190},"29-30 (omicron = 20)","29",{"type":38,"l":192,"from":49,"to":49,"h":344,"unit":43,"atLeast":345,"atMost":346},"26-32","26","32",{"type":38,"l":196,"from":41,"to":41,"h":193,"unit":43,"atLeast":194,"atMost":190},{"type":38,"l":198,"from":199,"to":199,"h":349,"unit":43,"atLeast":350,"atMost":190},"24-30","24",{"type":38,"l":203,"from":204,"to":204,"h":352,"unit":43,"atLeast":276,"atMost":346},"22-32",{"type":47,"l":48,"from":40,"to":49,"unit":43},{"_":207,"notBefore":52,"notAfter":208,"evidence":54},[356,357],{"_":211,"type":58,"ref":212,"region":60},{"_":73,"type":63,"ref":214,"region":60},[359],[217,218],[220,221],{"_":75,"role":76,"ref":77},{"_":224,"type":80},{"_":82,"mainLang":83,"languages":364},[82],{"n":228,"url":366,"height":230,"width":231,"desc":232,"surfaceType":233},"ISic001873_tiled.tif",[368,370,373,374,376],{"atLeast":369,"atMost":237},29,{"atLeast":371,"atMost":372},26,32,{"atLeast":239,"atMost":237},{"atLeast":375,"atMost":237},24,{"atLeast":306,"atMost":372},[90],[94],[380,381,382,15,176,23,250,105,103,104,105,106,107,83],"isic001873","funerary inscription for kopria",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κοπρία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κοπρία\">Κοπρία\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span> ❦ \u003Cspan data-text=\"ἔζη\n                    σεν\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σεν\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> λ´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":253,"ptr":385,"ref":386,"inscriptionDate":4,