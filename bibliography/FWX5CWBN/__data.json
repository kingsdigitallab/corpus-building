inenumber\">5\u003C/span>σεν\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> λ´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":260,"ptr":394,"ref":395,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},{"target":114},{"_":116,"target":116},{"file":397,"uri":397,"title":398,"status":399,"editionAuthor":13,"type":400,"objectType":404,"material":408,"condition":28,"layoutDesc":411,"handNote":415,"date":518,"places":523,"geo":526,"country":62,"provenance":218,"provenanceGeo":528,"region":74,"settlement":75,"repository":531,"idno":532,"textLang":534,"tmNumber":536,"facsimile":537,"letterHeights":540,"publications":548,"zotero":556,"keywords":564,"html":568,"bibl":569,"bulletinDateSort":117,"citedRangeSort":260,"languageSort":84,"materialSort":23,"typeSort":401},"ISic003331","The Syracusans honour King Gelon, son of Hieron II",{"_":12},{"_":401,"ana":402,"ref":403},"honorific","#function.honorific","http://www.eagle-network.eu/voc/typeins/lod/69.html",{"_":405,"ana":406,"ref":407},"base","#object.base","http://www.eagle-network.eu/voc/objtyp/lod/57.html",{"_":23,"type":409,"resp":185,"ref":27,"subtype":410},"stone.calcite_limestone",[],{"layout":412},{"p":413,"rs":414,"damage":28},"Three lines of finely carved Greek letters, centred on the stone (line one with short vacats at beginning and end, line 2 fully filling the face of the stone, line 3 centred with substantial vacats before and after.",{"_":33,"ana":34,"ref":35},{"lettering":416,"dimensions":505},[417,418],"Elegant wide and very regular letters with thinly carved strokes. Broken bar alpha; beta with equal sized loops; epsilon with short middle bar; kappa with short arms; mu with vertical first and last, middle strokes to half-height; omicron normally full size but small in line 2 (compression a factor); rho with almost fully rounded eye; sigma with approximately horizontal top and bottom strokes or very slightly open; omega full-size rounded