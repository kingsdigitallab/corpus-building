=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":100,"date":3,"citedRange":101,"ptr":155,"ref":156,"title":2,"citation":4},{"target":103},{"_":105,"target":105},{"file":158,"uri":158,"title":159,"status":160,"editionAuthor":11,"type":161,"objectType":162,"material":166,"condition":24,"layoutDesc":167,"handNote":171,"date":189,"places":192,"geo":198,"country":64,"region":65,"settlement":66,"repository":202,"idno":203,"textLang":205,"facsimile":207,"provenance":194,"letterHeights":214,"publications":215,"zotero":216,"keywords":217,"html":222,"bibl":223},"ISic001871","Funerary inscription for Gamike",{"_":10},{"_":13,"ana":14,"ref":15},{"_":163,"ana":164,"ref":165},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":21,"ana":22,"ref":23},{"layout":168},{"p":169,"rs":170,"damage":24},"Text over five lines, carefully following guidelines to the base of each line, with a marginal guideline to the left and right, with the left margin consistently observed. An additional guideline below is unused; the guidelines carefully align with the text to the right of this one. Use of a vacat prior to the age at death.",{"_":29,"ana":30,"ref":31},{"lettering":172,"dimensions":173},"Deep and wide slightly crude v-cut, producing consistent fairly square letters without serifs. Alpha has mostly downward left sloping cross-bar; epsilon is lunate with mostly shorter middle bar; zeta has slight curvature to the strokes; kappa has short arms; mu has four full-length diagonal strokes; lunate sigma, but note final square lunate for digamma / stigma for numeral 6.",[174,176,179,181,185,188],{"type":36,"l":130,"from":38,"to":38,"h":175,"unit":41},"27-30",{"type":36,"l":177,"from":45,"to":45,"h":178,"unit":41},"Line 2","25-30",{"type":36,"l":180,"from":39,"to":39,"h":178,"unit":41},"Line 3",{"type":36,"l":182,"from":183,"to":183,"h":184,"unit":41},"Line 4","line4","21-30",{"type":36,"l":186,"from":187,"to":187,"h":178,"unit":41},"Line 5","line5",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":190,"notBefore":48,"notAfter":191,"evidence":50},"Roman imperial in date",300,[193,196],{"_":194,"type":54,"ref":195},"Syracusae","http://pleiades.stoa.org/places/462503",{"_":66,"type":58,"ref":197},"http://sws.geonames.org/2523083",[199],[200,201],37.08415,15.27628,{"_":68,"role":69,"ref":70},{"_":204,"type":73},"15083",{"_":75,"mainLang":76,"languages":206},[75],{"n":208,"url":209,"height":210,"width":211,"desc":212,"surfaceType":213},"screen","ISic001871_tiled.tif","3680px","5520px","I.Sicily with the permission of the Parco archeologico e paesaggistico di Siracusa, Eloro, Villa del Tellaro e Akrai, and the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-04-29.","front",[],[80],[84],[218,219,220,13,163,21,221,95,93,94,95,96,97,76],"isic001871","funerary inscription for gamike",{"_":10},"syracusae","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γαμική\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Γαμική\">Γαμική\u003C/span>\u003C/span>  \u003Cspan data-text=\"χρη\n                    στὰ\">χρη-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>στὰ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"ἄ\n                    μεμπτε\">ἄ-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>μεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> κς´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":100,"date":3,"citedRange":224,"ptr":225,"ref":226,"title":2,"citation":4},"400",{"target":103},{"_":105,"target":105},{"file":228,"uri":228,"title":229,"status":230,"editionAuthor":11,"type":231,"objectType":232,"material":233,"condition":24,"layoutDesc":234,"handNote":238,"date":255,"places":256,"geo":259,"country":64,"region":65,"settlement":66,"repository":261,"idno":262,"textLang":263,"facsimile":265,"provenance":194,"letterHeights":267,"publications":268,"zotero":269,"keywords":270,"html":274,"bibl":275},"ISic001872","Funerary inscription for Mousa",{"_":10},{"_":13,"ana":14,"ref":15},{"_":163,"ana":164,"ref":165},{"_":21,"ana":22,"ref":23},{"layout":235},{"p":236,"rs":237,"damage":24},"Text over six lines, set in a recessed panel in the style of a temple facade, but without guidelines. Some use of interpuncts and vacats in the text.",{"_":29,"ana":30,"ref":31},{"lettering":239,"dimensions":240},"Text is deeply incised in letters of slightly varying size. Extensive use of serifs, with several letters tending to the cursive. Alpha has straight bar, curving ends; epsilon is lunate with equal length mid-bar; zeta is large and curved; kappa has near full-length arms; mu has slanting strokes that reach the lower line, but often join before the top and have extended upper strokes; pi has overlapping cross bar; rho has closed eye; sigma is lunate. Elegant hedera in line 2; use of vacats in age at death.",[241,243,245,247,248,250,254],{"type":36,"l":130,"from":38,"to":38,"h":242,"unit":41},"25-31",{"type":36,"l":177,"from":45,"to":45,"h":244,"unit":41},"20-22",{"type":36,"l":180,"from":39,"to":39,"h":246,"unit":41},"19-25",{"type":36,"l":182,"from":183,"to":183,"h":246,"unit":41},{"type":36,"l":186,"from":187,"to":187,"h":249,"unit":41},"19-21",{"type":36,"l":251,"from":252,"to":252,"h":253,"unit":41},"Line 6","line6","20-21",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":190,"notBefore":48,"notAfter":191,"evidence":50},[257,258],{"_":194,"type":54,"ref":195},{"_":66,"type":58,"ref":197},[260],[200,201],{"_":68,"role":69,"ref":70},{"_":204,"type":73},{"_":75,"mainLang":76,"languages":264},[75],{"n":208,"url":266,"height":210,"width":211,"desc":212,"surfaceType":213},"ISic001872_tiled.tif",[],[80],[84],[271,272,273,13,163,21,221,95,93,94,95,96,97,76],"isic001872","funerary inscription for mousa",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μοῦσα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Μοῦσα\">Μοῦσα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"μῆνες\">μῆνες\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>ι´ ·\u003Cspan dir=\"ltr\">(vac.1)\u003C/span> ἡμέρας \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> κε´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":100,"date":3,"citedRange":224,"ptr":276,"ref":277,"title":2,"citation":4},{"target":103},{"_":105,"target":105},{"file":279,"uri":279,"title":280,"status":281,"editionAuthor":11,"type":282,"objectType":283,"material":284,"condition":24,"layoutDesc":285,"handNote":293,"date":306,"places":307,"geo":310,"country":64,"region":65,"settlement":66,"repository":312,"idno":313,"textLang":314,"facsimile":316,"provenance":194,"letterHeights":318,"publications":319,"zotero":320,"keywords":321,"html":325,"bibl":326},"ISic001873","Funerary inscription for Kopria",{"_":10},{"_":13,"ana":14,"ref":15},{"_":163,"ana":164,"ref":165},{"_":21,"ana":22,"ref":23},{"layout":286},{"p":287,"rs":288,"damage":24},"Text over five lines, neatly respecting gridlines to the base of each line and with marginal lines to left and right - that on the left is approximately followed, that on the right is ignored; an additional gridline below is unused. Some use of interpuncts and vacats in the text. The first line shows clear traces of red paint in the letters.",[289,290],{"_":29,"ana":30,"ref":31},{"_":291,"ana":292},"rubrication, red colour","#execution.rubrication.red",{"lettering":294,"dimensions":295},"Text is incised in fairly tall, thin, neat and plain letters mostly without serifs. Alpha has downward left sloping cross-bar; epsilon is lunate, with shorter and sometimes detached middle bar; zeta is straight; eta sometimes has detached cross-bar (line 4); kapa has short arms; mu has angled strokes, the mid-strokes only descending half-way, and no upward extension of the apexes; omicron is slightly smaller than other letters; pi does not overlap; rho i slcosed; sigma is lunate. Use of a simple/stylised hedera in lines 2 and 4, and letters are somewhat irregularly spaced especially in the final line.",[296,298,300,301,303,305],{"type":36,"l":130,"from":38,"to":38,"h":297,"unit":41},"29-30 (omicron = 20)",{"type":36,"l":177,"from":45,"to":45,"h":299,"unit":41},"26-32",{"type":36,"l":180,"from":39,"to":39,"h":178,"unit":41},{"type":36,"l":182,"from":183,"to":183,"h":302,"unit":41},"24-30",{"type":36,"l":186,"from":187,"to":187,"h":304,"unit":41},"22-32",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":190,"notBefore":48,"notAfter":191,"evidence":50},[308,309],{"_":194,"type":54,"ref":195},{"_":66,"type":58,"ref":197},[311],[200,201],{"_":68,"role":69,"ref":70},{"_":204,"type":73},{"_":75,"mainLang":76,"languages":315},[75],{"n":208,"url":317,"height":210,"width":211,"desc":212,"surfaceType":213},"ISic001873_tiled.tif",[],[80],[84],[322,323,324,13,163,21,221,95,93,94,95,96,97,76],"isic001873","funerary inscription for kopria",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κοπρία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κοπρία\">Κοπρία\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span> ❦ \u003Cspan data-text=\"ἔζη\n                    σεν\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σεν\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> λ´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":100,"date":3,"citedRange":224,"ptr":327,"ref":328,"title":2,"citation":4},{"target":103},{"_":105,"target":105},{"file":330,"uri":330,"title":331,"status":332,"editionAuthor":11,"type":333,"objectType":337,"material":341,"condition":24,"layoutDesc":342,"handNote":346,"date":447,"places":452,"geo":455,"coun