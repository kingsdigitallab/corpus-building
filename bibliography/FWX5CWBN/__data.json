--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΘΟΝΙ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":103,"date":3,"citedRange":104,"ptr":161,"ref":162,"title":2,"citation":4},{"target":106},{"_":108,"target":108},{"file":164,"uri":164,"title":165,"status":166,"editionAuthor":11,"type":167,"objectType":168,"material":172,"condition":24,"layoutDesc":173,"handNote":177,"date":195,"places":198,"geo":204,"provenance":200,"provenanceGeo":208,"country":67,"region":68,"settlement":69,"repository":211,"idno":212,"textLang":214,"tmNumber":24,"facsimile":216,"letterHeights":223,"publications":224,"zotero":225,"keywords":226,"html":231,"bibl":232},"ISic001871","Funerary inscription for Gamike",{"_":10},{"_":13,"ana":14,"ref":15},{"_":169,"ana":170,"ref":171},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":21,"ana":22,"ref":23},{"layout":174},{"p":175,"rs":176,"damage":24},"Text over five lines, carefully following guidelines to the base of each line, with a marginal guideline to the left and right, with the left margin consistently observed. An additional guideline below is unused; the guidelines carefully align with the text to the right of this one. Use of a vacat prior to the age at death.",{"_":29,"ana":30,"ref":31},{"lettering":178,"dimensions":179},"Deep and wide slightly crude v-cut, producing consistent fairly square letters without serifs. Alpha has mostly downward left sloping cross-bar; epsilon is lunate with mostly shorter middle bar; zeta has slight curvature to the strokes; kappa has short arms; mu has four full-length diagonal strokes; lunate sigma, but note final square lunate for digamma / stigma for numeral 6.",[180,182,185,187,191,194],{"type":36,"l":133,"from":38,"to":38,"h":181,"unit":41},"27-30",{"type":36,"l":183,"from":45,"to":45,"h":184,"unit":41},"Line 2","25-30",{"type":36,"l":186,"from":39,"to":39,"h":184,"unit":41},"Line 3",{"type":36,"l":188,"from":189,"to":189,"h":190,"unit":41},"Line 4","line4","21-30",{"type":36,"l":192,"from":193,"to":193,"h":184,"unit":41},"Line 5","line5",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":196,"notBefore":48,"notAfter":197,"evidence":50},"Roman imperial in date",300,[199,202],{"_":200,"type":54,"ref":201},"Syracusae","http://pleiades.stoa.org/places/462503",{"_":69,"type":58,"ref":203},"http://sws.geonames.org/2523083",[205],[206,207],37.08415,15.27628,[209,210],37.0784545,15.2786827,{"_":71,"role":72,"ref":73},{"_":213,"type":76},"15083",{"_":78,"mainLang":79,"languages":215},[78],{"n":217,"url":218,"height":219,"width":220,"desc":221,"surfaceType":222},"screen","ISic001871_tiled.tif","3680px","5520px","I.Sicily with the permission of the Parco archeologico e paesaggistico di Siracusa, Eloro, Villa del Tellaro e Akrai, and the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-04-29.","front",[],[83],[87],[227,228,229,13,169,21,230,98,96,97,98,99,100,79],"isic001871","funerary inscription for gamike",{"_":10},"syracusae","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γαμική\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Γαμική\">Γαμική\u003C/span>\u003C/span>  \u003Cspan data-text=\"χρη\n                    στὰ\">χρη-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>στὰ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"ἄ\n                    μεμπτε\">ἄ-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>μεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> κς´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":103,"date":3,"citedRange":233,"ptr":234,"ref":235,"title":2,"citation":4},"400",{"target":106},{"_":108,"target":108},{"file":237,"uri":237,"title":238,"status":239,"editionAuthor":11,"type":240,"objectType":241,"material":242,"condition":24,"layoutDesc":243,"handNote":247,"date":264,"places":265,"geo":268,"provenance":200,"provenanceGeo":270,"country":67,"region":68,"settlement":69,"repository":271,"idno":272,"textLang":273,"tmNumber":24,"facsimile":275,"letterHeights":277,"publications":278,"zotero":279,"keywords":280,"html":284,"bibl":285},"ISic001872","Funerary inscription for Mousa",{"_":10},{"_":13,"ana":14,"ref":15},{"_":169,"ana":170,"ref":171},{"_":21,"ana":22,"ref":23},{"layout":244},{"p":245,"rs":246,"damage":24},"Text over six lines, set in a recessed panel in the style of a temple facade, but without guidelines. Some use of interpuncts and vacats in the text.",{"_":29,"ana":30,"ref":31},{"lettering":248,"dimensions":249},"Text is deeply incised in letters of slightly varying size. Extensive use of serifs, with several letters tending to the cursive. Alpha has straight bar, curving ends; epsilon is lunate with equal length mid-bar; zeta is large and curved; kappa has near full-length arms; mu has slanting strokes that reach the lower line, but often join before the top and have extended upper strokes; pi has overlapping cross bar; rho has closed eye; sigma is lunate. Elegant hedera in line 2; use of vacats in age at death.",[250,252,254,256,257,259,263],{"type":36,"l":133,"from":38,"to":38,"h":251,"unit":41},"25-31",{"type":36,"l":183,"from":45,"to":45,"h":253,"unit":41},"20-22",{"type":36,"l":186,"from":39,"to":39,"h":255,"unit":41},"19-25",{"type":36,"l":188,"from":189,"to":189,"h":255,"unit":41},{"type":36,"l":192,"from":193,"to":193,"h":258,"unit":41},"19-21",{"type":36,"l":260,"from":261,"to":261,"h":262,"unit":41},"Line 6","line6","20-21",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":196,"notBefore":48,"notAfter":197,"evidence":50},[266,267],{"_":200,"type":54,"ref":201},{"_":69,"type":58,"ref":203},[269],[206,207],[209,210],{"_":71,"role":72,"ref":73},{"_":213,"type":76},{"_":78,"mainLang":79,"languages":274},[78],{"n":217,"url":276,"height":219,"width":220,"desc":221,"surfaceType":222},"ISic001872_tiled.tif",[],[83],[87],[281,282,283,13,169,21,230,98,96,97,98,99,100,79],"isic001872","funerary inscription for mousa",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μοῦσα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Μοῦσα\">Μοῦσα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"μῆνες\">μῆνες\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>ι´ ·\u003Cspan dir=\"ltr\">(vac.1)\u003C/span> ἡμέρας \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> κε´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":103,"date":3,"citedRange":233,"ptr":286,"ref":287,"title":2,"citation":4},{"target":106},{"_":108,"target":108},{"file":289,"uri":289,"title":290,"status":291,"editionAuthor":11,"type":292,"objectType":293,"material":294,"condition":24,"layoutDesc":295,"handNote":303,"date":316,"places":317,"geo":320,"provenance":200,"provenanceGeo":322,"country":67,"region":68,"settlement":69,"repository":323,"idno":324,"textLang":325,"tmNumber":24,"facsimile":327,"letterHeights":329,"publications":330,"zotero":331,"keywords":332,"html":336,"bibl":337},"ISic001873","Funerary inscription for Kopria",{"_":10},{"_":13,"ana":14,"ref":15},{"_":169,"ana":170,"ref":171},{"_":21,"ana":22,"ref":23},{"layout":296},{"p":297,"rs":298,"damage":24},"Text over five lines, neatly respecting gridlines to the base of each line and with marginal lines to left and right - that on the left is approximately followed, that on the right is ignored; an additional gridline below is unused. Some use of interpuncts and vacats in the text. The first line shows clear traces of red paint in the letters.",[299,300],{"_":29,"ana":30,"ref":31},{"_":301,"ana":302},"rubrication, red colour","#execution.rubrication.red",{"lettering":304,"dimensions":305},"Text is incised in fairly tall, thin, neat and plain letters mostly without serifs. Alpha has downward left sloping cross-bar; epsilon is lunate, with shorter and sometimes detached middle bar; zeta is straight; eta sometimes has detached cross-bar (line 4); kapa has short arms; mu has angled strokes, the mid-strokes only descending half-way, and no upward extension of the apexes; omicron is slightly smaller than other letters; pi does not overlap; rho i slcosed; sigma is lunate. Use of a simple/stylised hedera in lines 2 and 4, and letters are somewhat irregularly spaced especially in the final line.",[306,308,310,311,313,315],{"type":36,"l":133,"from":38,"to":38,"h":307,"unit":41},"29-30 (omicron = 20)",{"type":36,"l":183,"from":45,"to":45,"h":309,"unit":41},"26-32",{"type":36,"l":186,"from":39,"to":39,"h":184,"unit":41},{"type":36,"l":188,"from":189,"to":189,"h":312,"unit":41},"24-30",{"type":36,"l":192,"from":193,"to":193,"h":314,"unit":41},"22-32",{"type":43,"l":44,"from":38,"to":45,"unit":41},{"_":196,"notBefore":48,"notAfter":197,"evidence":50},[318,319],{"_":200,"type":54,"ref":201},{"_":69,"type":58,"ref":203},[321],[206,207],[209,210],{"_":71,"role":72,"ref":73},{"_":213,"type":76},{"_":78,"mainLang":79,"languages":326},[78],{"n":217,"url":328,"height":219,"width":220,"desc":221,"surfaceType":222},"ISic001873_tiled.tif",[],[83],[87],[333,334,335,13,169,21,230,98,96,97,98,99,100,79],"isic001873","funerary inscription for kopria",{"_":10},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κοπρία\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Κοπρία\">Κοπρία\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span> ❦ \u003Cspan data-text=\"ἔζη\n                    σεν\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σεν\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> λ´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":103,"date":3,"cit