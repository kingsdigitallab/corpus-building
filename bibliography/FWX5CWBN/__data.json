16484",{"_":82,"mainLang":83,"languages":157},[82],[],[90,91,92],[94,95,96],[162,163,164,120,124,128,101,102,103,104,105,106,107,83],"isic001870","inscribed fragment of a marble basin",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>]ΘΟΝΙ[\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":110,"ptr":167,"ref":168,"title":2,"citation":5,"uri":6},{"target":112},{"_":114,"target":114},{"file":170,"uri":170,"title":171,"status":172,"editionAuthor":13,"type":173,"objectType":174,"material":178,"condition":26,"layoutDesc":179,"handNote":183,"date":205,"places":208,"geo":214,"provenance":210,"provenanceGeo":218,"country":71,"region":72,"settlement":73,"repository":221,"idno":222,"textLang":224,"tmNumber":26,"facsimile":226,"letterHeights":233,"publications":243,"zotero":244,"keywords":245,"html":250,"bibl":251,"citedRangeSort":252,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001871","Funerary inscription for Gamike",{"_":12},{"_":15,"ana":16,"ref":17},{"_":175,"ana":176,"ref":177},"plaque","#object.plaque","http://www.eagle-network.eu/voc/objtyp/lod/259",{"_":23,"ana":24,"ref":25},{"layout":180},{"p":181,"rs":182,"damage":26},"Text over five lines, carefully following guidelines to the base of each line, with a marginal guideline to the left and right, with the left margin consistently observed. An additional guideline below is unused; the guidelines carefully align with the text to the right of this one. Use of a vacat prior to the age at death.",{"_":31,"ana":32,"ref":33},{"lettering":184,"dimensions":185},"Deep and wide slightly crude v-cut, producing consistent fairly square letters without serifs. Alpha has mostly downward left sloping cross-bar; epsilon is lunate with mostly shorter middle bar; zeta has slight curvature to the strokes; kappa has short arms; mu has four full-length diagonal strokes; lunate sigma, but note final square lunate for digamma / stigma for numeral 6.",[186,190,194,196,201,204],{"type":38,"l":139,"from":40,"to":40,"h":187,"unit":43,"atLeast":188,"atMost":189},"27-30","27","30",{"type":38,"l":191,"from":49,"to":49,"h":192,"unit":43,"atLeast":193,"atMost":189},"Line 2","25-30","25",{"type":38,"l":195,"from":41,"to":41,"h":192,"unit":43,"atLeast":193,"atMost":189},"Line 3",{"type":38,"l":197,"from":198,"to":198,"h":199,"unit":43,"atLeast":200,"atMost":189},"Line 4","line4","21-30","21",{"type":38,"l":202,"from":203,"to":203,"h":192,"unit":43,"atLeast":193,"atMost":189},"Line 5","line5",{"type":47,"l":48,"from":40,"to":49,"unit":43},{"_":206,"notBefore":52,"notAfter":207,"evidence":54},"Roman imperial in date",300,[209,212],{"_":210,"type":58,"ref":211},"Syracusae","http://pleiades.stoa.org/places/462503",{"_":73,"type":62,"ref":213},"http://sws.geonames.org/2523083",[215],[216,217],37.08415,15.27628,[219,220],37.0784545,15.2786827,{"_":75,"role":76,"ref":77},{"_":223,"type":80},"15083",{"_":82,"mainLang":83,"languages":225},[82],{"n":227,"url":228,"height":229,"width":230,"desc":231,"surfaceType":232},"screen","ISic001871_tiled.tif","3680px","5520px","I.Sicily with the permission of the Parco archeologico e paesaggistico di Siracusa, Eloro, Villa del Tellaro e Akrai, and the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2022-04-29.","front",[234,237,239,240,242],{"atLeast":235,"atMost":236},27,30,{"atLeast":238,"atMost":236},25,{"atLeast":238,"atMost":236},{"atLeast":241,"atMost":236},21,{"atLeast":238,"atMost":236},[90],[94],[246,247,248,15,175,23,249,105,103,104,105,106,107,83],"isic001871","funerary inscription for gamike",{"_":12},"syracusae","\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γαμική\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Γαμική\">Γαμική\u003C/span>\u003C/span>  \u003Cspan data-text=\"χρη\n                    στὰ\">χρη-\u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>στὰ\u003C/span>  \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cspan data-text=\"ἄ\n                    μεμπτε\">ἄ-\u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>μεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔτη\">ἔτη\u003C/span> κς´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":252,"ptr":253,"ref":254,"title":2,"citation":5,"uri":6},"400",{"target":112},{"_":114,"target":114},{"file":256,"uri":256,"title":257,"status":258,"editionAuthor":13,"type":259,"objectType":260,"material":261,"condition":26,"layoutDesc":262,"handNote":266,"date":287,"places":288,"geo":291,"provenance":210,"provenanceGeo":293,"country":71,"region":72,"settlement":73,"repository":294,"idno":295,"textLang":296,"tmNumber":26,"facsimile":298,"letterHeights":300,"publications":311,"zotero":312,"keywords":313,"html":317,"bibl":318,"citedRangeSort":252,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001872","Funerary inscription for Mousa",{"_":12},{"_":15,"ana":16,"ref":17},{"_":175,"ana":176,"ref":177},{"_":23,"ana":24,"ref":25},{"layout":263},{"p":264,"rs":265,"damage":26},"Text over six lines, set in a recessed panel in the style of a temple facade, but without guidelines. Some use of interpuncts and vacats in the text.",{"_":31,"ana":32,"ref":33},{"lettering":267,"dimensions":268},"Text is deeply incised in letters of slightly varying size. Extensive use of serifs, with several letters tending to the cursive. Alpha has straight bar, curving ends; epsilon is lunate with equal length mid-bar; zeta is large and curved; kappa has near full-length arms; mu has slanting strokes that reach the lower line, but often join before the top and have extended upper strokes; pi has overlapping cross bar; rho has closed eye; sigma is lunate. Elegant hedera in line 2; use of vacats in age at death.",[269,272,276,279,280,282,286],{"type":38,"l":139,"from":40,"to":40,"h":270,"unit":43,"atLeast":193,"atMost":271},"25-31","31",{"type":38,"l":191,"from":49,"to":49,"h":273,"unit":43,"atLeast":274,"atMost":275},"20-22","20","22",{"type":38,"l":195,"from":41,"to":41,"h":277,"unit":43,"atLeast":278,"atMost":193},"19-25","19",{"type":38,"l":197,"from":198,"to":198,"h":277,"unit":43,"atLeast":278,"atMost":193},{"type":38,"l":202,"from":203,"to":203,"h":281,"unit":43,"atLeast":278,"atMost":200},"19-21",{"type":38,"l":283,"from":284,"to":284,"h":285,"unit":43,"atLeast":274,"atMost":200},"Line 6","line6","20-21",{"type":47,"l":48,"from":40,"to":49,"unit":43},{"_":206,"notBefore":52,"notAfter":207,"evidence":54},[289,290],{"_":210,"type":58,"ref":211},{"_":73,"type":62,"ref":213},[292],[216,217],[219,220],{"_":75,"role":76,"ref":77},{"_":223,"type":80},{"_":82,"mainLang":83,"languages":297},[82],{"n":227,"url":299,"height":229,"width":230,"desc":231,"surfaceType":232},"ISic001872_tiled.tif",[301,303,306,308,309,310],{"atLeast":238,"atMost":302},31,{"atLeast":304,"atMost":305},20,22,{"atLeast":307,"atMost":238},19,{"atLeast":307,"atMost":238},{"atLeast":307,"atMost":241},{"atLeast":304,"atMost":241},[90],[94],[314,315,316,15,175,23,249,105,103,104,105,106,107,83],"isic001872","funerary inscription for mousa",{"_":12},"\u003Cdiv class=\"textpart\" lang=\"grc\">\u003Cspan class=\"ab\" id=\"div-interpretive\">  \u003Ca id=\"al1-interpretive\">\u003C!--0-->\u003C/a>\u003Cspan class=\"linenumber\">1\u003C/span>\u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μοῦσα\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Μοῦσα\">Μοῦσα\u003C/span>\u003C/span>  \u003Cbr id=\"al2-interpretive\">\u003Cspan class=\"linenumber\">2\u003C/span>\u003Cspan data-text=\"χρηστὰ\">χρηστὰ\u003C/span> ❦ \u003Cspan data-text=\"καὶ\">καὶ\u003C/span>  \u003Cbr id=\"al3-interpretive\">\u003Cspan class=\"linenumber\">3\u003C/span>\u003Cspan data-text=\"ἄμεμπτε\">ἄμεμπτε\u003C/span>  \u003Cbr id=\"al4-interpretive\">\u003Cspan class=\"linenumber\">4\u003C/span>\u003Cspan data-text=\"χαῖρε\">χαῖρε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"ἔζη\n                    σε\">ἔζη-\u003Cbr id=\"al5-interpretive\">\u003Cspan class=\"linenumber\">5\u003C/span>σε\u003C/span>  \u003Cspan dir=\"ltr\">(vac.1)\u003C/span>  \u003Cspan data-text=\"μῆνες\">μῆνες\u003C/span>  \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>ι´ ·\u003Cspan dir=\"ltr\">(vac.1)\u003C/span> ἡμέρας \u003Cspan dir=\"ltr\">(vac.1)\u003C/span> κε´ \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":252,"ptr":319,"ref":320,"title":2,"citation":5,"uri":6},{"target":112},{"_":114,"target":114},{"file":322,"uri":322,"title":323,"status":324,"editionAuthor":13,"type":325,"objectType":326,"material":327,"condition":26,"layoutDesc":328,"handNote":336,"date":353,"places":354,"geo":357,"provenance":210,"provenanceGeo":359,"country":71,"region":72,"settlement":73,"repository":360,"idno":361,"textLang":362,"tmNumber":26,"facsimile":364,"letterHeights":366,"publications":376,"zotero":377,"keywords":378,"html":382,"bibl":383,"citedRangeSort":252,"languageSort":82,"materialSort":23,"typeSort":15},"ISic001873","Funerary inscription for Kopria",{"_":12},{"_":15,"ana":16,"ref":17},{"_":175,"ana":176,"ref":177},{"_":23,"ana":24,"ref":25},{"layout":329},{"p":330,"rs":331,"damage":26},"Text over five lines, neatly respecting gridlines to the base of each line and with marginal lines to left and right - that on the left is approximately followed, that on the right is ignored; an additional gridline below is unused. Some use of interpuncts and vacats in the text. The first line shows clear traces of red paint in the letters.",[332,333],{"_":31,"ana":32,"ref":33},{"_":334,"ana":335},"rubrication, red colour","#execution.rubrication.red",{"lettering":337,"dimensions":338},"Text is incised in fairly tall, thin, neat and plain letters mostly without serifs. Alpha has downward left sloping cross-bar; epsilon is lunate, with shorter and sometimes detached middle bar; zeta is straight; eta sometimes has detached cross-bar (line 4); kapa has short arms; mu has angled strokes, the mid-strokes only descending half-way, and no upward extension of the apexes; omicron is slightly smaller than other letters; pi does not overlap; rho i slcosed; sigma is lunate. Use of a simple/stylised hedera in lines 2 and 4, and letters are somewhat irregularly spaced especially in the final line.",[339,342,346,347,350,352],{"type":38,"l":139,"from":40,"to":40,"h":340,"unit":43,"atLeast":341,"atMost":189},"29-30 (omicron = 20)","29",{"type":38,"l":191,"from":49,"to":49,"h":343,"unit":43,"atLeast":344,"atMost":345},"26-32","26","32",{"type":38,"l":195,"from":41,"to":41,"h":192,"unit":43,"atLeast":193,"atMost":189},{"type":38,"l":197,"from":198,"to":198,"h":348,"unit":43,"atLeast":349,"atMost":189},"24-30","24",{"type":38,"l":202,"from":203,"to":203,"h":351,"unit":43,"atLeast":275,"atMost":345},"22-32",{"type":47,"l":48,"from":40,"to":49,"unit":43},{"_":206,"notBefore":52,"notAfter":207,"evidence":54},[355,356],{"_":210,"type":58,"ref":211},{"_":73,"type":62,"ref":213},[358],[2