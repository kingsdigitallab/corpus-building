],{"_":60,"type":61,"ref":62},{"_":64,"type":65,"ref":66},[465],[69,70],{"_":74,"role":75,"ref":76},{"_":468,"type":79},"67",{"_":81,"mainLang":82,"languages":470},[81],{"n":85,"url":472,"height":88,"width":87,"desc":473,"surfaceType":90},"ISic000131_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J.Prag 04.07.23",[],[96,476,97,98],"Romano, 1838, Antichità termitane",[100,478,101,102],"25ZN5T5X",[480,481,482,252,442,204,107,108,109,110,108,111,112,82],"isic000131","funerary inscription for m. antonius natalis",{"_":10},"Text encoding: Tuuli Ahlholm; Alex Antoniou, edition source:",{"file":485,"uri":485,"title":486,"status":487,"editionAuthor":11,"type":488,"objectType":489,"material":490,"condition":129,"layoutDesc":491,"handNote":495,"date":517,"places":518,"geo":521,"country":71,"region":72,"settlement":64,"repository":523,"idno":524,"textLang":526,"facsimile":528,"provenance":60,"letterHeights":531,"publications":532,"zotero":533,"keywords":534,"html":192},"ISic000133","Funerary plot for Marcus Arruntius Brocchus",{"_":118},{"_":252,"ana":253,"ref":254},{"_":442,"ana":443,"ref":444},{"_":204,"ana":205,"ref":206},{"layout":492},{"p":493,"rs":494,"damage":129},"Five lines of Latin letters, seemingly centred on the stone.",{"_":31,"ana":32,"ref":33},{"lettering":496,"dimensions":497},"Rather worn, partially v-cut letters with simple terminal serifs and triangular comma-shaped interpuncts.",[498,500,502,504,505,507,509,511,514],{"type":40,"l":41,"from":42,"to":42,"h":499,"unit":44},"34-39 (T is taller)",{"type":40,"l":48,"from":49,"to":49,"h":501,"unit":44},"38-41",{"type":40,"l":142,"from":143,"to":143,"h":503,"unit":44},"30-35",{"type":40,"l":146,"from":147,"to":147,"h":503,"unit":44},{"type":40,"l":150,"from":151,"to":151,"h":506,"unit":44},"27-34",{"type":51,"l":52,"from":42,"to":49,"h":508,"unit":44},"24-25",{"type":51,"l":370,"from":49,"to":143,"h":510,"unit":44},"9-12",{"type":51,"l":512,"from":143,"to":147,"h":513,"unit":44},"Interlineation line 3 to 4","12-18",{"type":51,"l":515,"from":147,"to":151,"h":516,"unit":44},"Interlineation line 4 to 5","20-26",{"_":219,"notBefore":55,"notAfter":220},[519,520],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[522],[69,70],{"_":74,"role":75,"ref":76},{"_":525,"type":79},"51",{"_":81,"mainLang":82,"languages":527},[81],{"n":85,"url":529,"height":88,"width":87,"desc":530,"surfaceType":90},"ISic000133_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J.Prag 05.07.2023",[],[96,476,97,98],[100,478,101,102],[535,536,537,252,442,204,107,108,109,110,108,111,112,82],"isic000133","funerary plot for marcus arruntius brocchus",{"_":118},{"file":539,"uri":539,"title":540,"status":541,"editionAuthor":11,"type":542,"objectType":543,"material":544,"condition":129,"layoutDesc":545,"handNote":549,"date":562,"places":563,"geo":566,"country":71,"region":72,"settlement":64,"repository":568,"idno":569,"textLang":571,"facsimile":573,"provenance":60,"letterHeights":576,"publications":577,"zotero":578,"keywords":579,"html":192},"ISic000144","Funerary inscription for Publius Cestius",{"_":10},{"_":252,"ana":253,"ref":254},{"_":18,"ana":19,"ref":124},{"_":204,"ana":205,"ref":206},{"layout":546},{"p":547,"rs":548,"damage":129},"Parts of three lines of Latin letters, possibly centred on the stone.",{"_":31,"ana":32,"ref":33},{"lettering":550,"dimensions":551},"Neat, thinly incised (not a true v-cut) letters with simple terminal serifs. A triangular serif in line 2, and a comma shaped 'interpunct' at the end of line 2.",[552,554,556,558,560],{"type":40,"l":41,"from":42,"to":42,"h":553,"unit":44},"24",{"type":40,"l":48,"from":49,"to":49,"h":555,"unit":44},"30-32",{"type":40,"l":142,"from":143,"to":143,"h":557,"unit":44},"incomplete",{"type":51,"l":52,"from":42,"to":49,"h":559,"unit":44},"12",{"type":51,"l":370,"from":49,"to":143,"h":561,"unit":44},"10",{"_":219,"notBefore":55,"notAfter":220},[564,565],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[567],[69,70],{"_":74,"role":75,"ref":76},{"_":570,"type":79},"38",{"_":81,"mainLang":82,"languages":572},[81],{"n":85,"url":574,"height":87,"width":88,"desc":575,"surfaceType":90},"ISic000144_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J.Prag 2023-07-07.",[],[96,97,98],[100,101,102],[580,581,582,252,18,204,107,108,109,110,108,111,112,82],"isic000144","funerary inscription for publius cestius",{"_":10},{"file":584,"uri":584,"title":585,"status":586,"editionAuthor":11,"type":587,"objectType":588,"material":589,"condition":129,"layoutDesc":590,"handNote":594,"date":604,"places":606,"geo":609,"country":71,"region":72,"settlement":64,"repository":611,"idno":612,"textLang":614,"facsimile":616,"provenance":60,"letterHeights":619,"publications":620,"zotero":621,"keywords":622,"html":483},"ISic000147","Funerary inscription for P. Cestius Catullus",{"_":10},{"_":252,"ana":253,"ref":254},{"_":442,"ana":443,"ref":444},{"_":204,"ana":205,"ref":206},{"layout":591},{"p":592,"rs":593,"damage":129},"Three lines of Latin text. While line 1 is relatively square and centred on stone, lines 2-3 are off centre. Line 3 drifts upwards. Use of triangular interpuncts between every word, and at the beginning of each line. Beneath these are two upside-down 'V's of different sizes, perhaps stone-carver marks? The first is roughly halfway down the stone, the other is around 4/5 towards the base, and is followed by a more lightly carved E (also upside down); a faint 'C' shape is visible below. ",{"_":31,"ana":32,"ref":33},{"lettering":595,"dimensions":596},"Letters are deeply chiselled with simple serifs. Letters are evenly spaced. Strokes on Xs are a little lopsided, some curvature to V and L. The upside down Vs below are 24mm (upper) and 63mm (lower).",[597,599,601,603],{"type":40,"l":41,"from":42,"to":42,"h":598,"unit":44},"50-53",{"type":40,"l":48,"from":49,"to":49,"h":600,"unit":44},"45-47",{"type":40,"l":142,"from":143,"to":143,"h":602,"unit":44},"39-44",{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":605,"notBefore":55,"notAfter":56,"evidence":57},"1st-2nd century CE",[607,608],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[610],[69,70],{"_":74,"role":75,"ref":76},{"_":613,"type":79},"111",{"_":81,"mainLang":82,"languages":615},[81],{"n":85,"url":617,"height":87,"width":88,"desc":618,"surfaceType":90},"ISic000147_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J.Prag 2022-07-08.",[],[96,97,98],[100,101,102],[623,624,625,252,442,204,107,108,109,110,108,111,112,82],"isic000147","funerary inscription for p. cestius catullus",{"_":10},{"file":627,"uri":627,"title":628,"status":629,"editionAuthor":11,"type":630,"objectType":631,"material":632,"condition":129,"layoutDesc":633,"handNote":637,"date":648,"places":652,"geo":655,"country":71,"region":72,"settlement":64,"repository":657,"idno":658,"textLang":660,"facsimile":662,"provenance":60,"letterHeights":664,"publications":665,"zotero":666,"keywords":667,"html":192},"ISic000148","Funerary inscription for Cestia Catulla",{"_":10},{"_":252,"ana":253,"ref":254},{"_":18,"ana":19,"ref":124},{"_":22,"ana":23,"ref":24},{"layout":634},{"p":635,"rs":636,"damage":129},"The text is carefully laid out with a bounding guideline around all four sides, and faint traces of guielines to the top and bottom of each line of text. Ligature in line 2 maintains the spacing, with interpuncts between wrods.",{"_":31,"ana":32,"ref":33},{"lettering":638,"dimensions":639},"Large wide letters in a thin v-cut, reducing in height to line 4, with elegant serifs, comma-shaped interpuncts, and use of ligature.",[640,642,644,646,647],{"type":40,"l":41,"from":42,"to":42,"h":641,"unit":44},"75",{"type":40,"l":48,"from":49,"to":49,"h":643,"unit":44},"70",{"type":40,"l":142,"from":143,"to":143,"h":645,"unit":44},"62-65 (I = 70)",{"type":40,"l":146,"from":147,"to":147,"h":598,"unit":44},{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":649,"notBefore":55,"notAfter":650,"evidence":651},"first half of the C1 CE",50,"letter",[653,654],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[656],[69,70],{"_":74,"role":75,"ref":76},{"_":659,"type":79},"64ab",{"_":81,"mainLang":82,"languages":661},[81],{"n":85,"url":663,"height":87,"width":88,"desc":428,"surfaceType":90},"ISic000148_tiled.tif",[],[96,97,98],[100,101,102],[668,669,670,252,18,22,107,108,109,110,108,111,112,82],"isic000148","funerary inscription for cestia catulla",{"_":10},{"file":672,"uri":672,"title":673,"status":674,"editionAuthor":11,"type":675,"objectType":676,"material":677,"condition":129,"layoutDesc":678,"handNote":682,"date":690,"places":691,"geo":694,"country":71,"region":72,"settlement":64,"repository":696,"idno":697,"textLang":699,"facsimile":701,"provenance":60,"letterHeights":704,"publications":705,"zotero":706,"keywords":707,"html":483},"ISic000151","Funerary epitaph for Titus Cispius Eros",{"_":10},{"_":252,"ana":253,"ref":254},{"_":18,"ana":19,"ref":124},{"_":22,"ana":23,"ref":24},{"layout":679},{"p":680,"rs":681,"damage":129},"Two lines of Latin inscription. Despite the break to the right, no text appears to have been lost. Use of comma-shaped interpuncts in line 1, although the very first interpunct in that line is extremely worn but appears to be shaped differently. Long hederae used in line 2 (and below line 2).",{"_":31,"ana":32,"ref":33},{"lettering":683,"dimensions":684},"Letters are tall, well-spaced, regular and keep mostly to the line. The letters have serifs. Extended top-bar to the second 'T' in line 1.",[685,687,689],{"type":40,"l":41,"from":42,"to":42,"h":686,"unit":44},"52-58 (T=62)",{"type":40,"l":48,"from":49,"to":49,"h":688,"unit":44},"47-51",{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":219,"notBefore":55,"notAfter":324},[692,693],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[695],[69,70],{"_":74,"role":75,"ref":76},{"_":698,"type":79},"40ac",{"_":81,"mainLang":82,"languages":700},[81],{"n":85,"url":702,"height":87,"width":88,"desc":703,"surfaceType":90},"ISic000151_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-07.",[],[96,97,98],[100,101,102],[708,709,710,252,18,22,107,108,109,110,108,111,112,82],"isic000151","funerary epitaph for titus cispius eros",{"_":10},{"file":712,"uri":712,"title":713,"status":714,"editionAuthor":11,"type":715,"objectType":716,"material":717,"condition":129,"layoutDesc":718,"handNote":722,"date":731,"places":732,"geo":735,"country":71,"region":72,"settlement":64,"repository":737,"idno":738,"textLang":740,"facsimile":742,"provenance":60,"letterHeights":745,"publications":746,"zotero":747,"keywords":748,"html":752},"ISic000181","Epitaph for L. Herennius Certus",{"_":10},{"_":252,"ana":253,"ref":254},{"_":18,"ana":19,"ref":20},{"_":22,"ana":23,"ref":24},{"layout":719},{"p":720,"rs":721,"damage":129},"Three lines of Latin text, line 3 is almost entirely missing. Ill-defined interpuncts used, some triangular. Large vacat at the end of line 3. Abrasions at the beginning of line 2 frustrate precision of comprehension.",{"_":31,"ana":32,"ref":33},{"lettering":723,"dimensions":724},"Slightly haphazard letters, but otherwise tall and well-spaced. Serifs used on most letters.",[725,727,728,730],{"type":40,"l":41,"from":42,"to":42,"h":726,"unit":44},"39-42",{"type":40,"l":48,"from":49,"to":49,"h":454,"unit":44},{"type":40,"l":142,"from":143,"to":143,"h":729,"unit":44},"irrecoverable",{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":219,"notBefore":55,"notAfter":220},[733,734],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[736],[69,70],{"_":74,"role":75,"ref":76},{"_":739,"type":79},"65 A/B",{"_":81,"mainLang":82,"languages":741},[81],{"n":85,"url":743,"height":87,"width":88,"desc":744,"surfaceType":90},"ISic000181_tiled.tif","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; photo J. Prag 2023-07-07",[],[96,476,97,98],[100,478,101,102],[749,750,751,252,18,22,107,108,109,110,108,111,112,82],"isic000181","epitaph for l. herennius certus",{"_":10},"Text encoding: Jonathan Prag; Alex Antoniou, edition source:",{"file":754,"uri":754,"title":755,"status":756,"editionAuthor":11,"type":757,"objectType":758,"material":759,"condition":760,"layoutDesc":762,"handNote":768,"date":773,"places":775,"geo":778,"country":71,"region":72,"settlement":64,"repository":780,"textLang":781,"facsimile":783,"provenance":60,"letterHeights":788,"publications":789,"zotero":790,"keywords":791,"html":795},"ISic000193","Epitaph for Lucia",{"_":10},{"_":252,"ana":253,"ref":254},{"_":18,"ana":19,"ref":20},{"_":22,"ana":23,"ref":24},{"ana":761},"#condition.damaged",{"layout":763},{"p":764,"rs":765,"damage":766},"It seems highly likely that the text was centered over two lines, and that elements are missing from the right.",{"_":31,"ana":32,"ref":33},{"ana":767},"#text_condition.complete",{"lettering":769,"dimensions":770},"Large simple letters, lacking serifs and with a broad module.",[771,772],{"type":40,"l":41,"from":42,"to":42,"unit":44},{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":774,"notBefore":55,"notAfter":56,"evidence":57},"Earlier Roman Imperial",[776,777],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[779],[69,70],{"_":74,"role":75,"ref":76},{"_":81,"mainLang":82,"languages":782},[81],{"n":85,"url":784,"height":785,"width":786,"desc":787,"surfaceType":90},"ISic000193_tiled.tif","1371px","2090px","I.Sicily with the permission of the Assessorato Regionale dei Beni Culturali e dell’Identità Siciliana - Dipartimento dei Beni Culturali e dell’Identità Siciliana; image from ILTermini",[],[96,476,97,98],[100,478,101,102],[792,793,794,252,18,22,107,108,109,110,108,111,112,82],"isic000193","epitaph for lucia",{"_":10},"Text encoding: Valentina Mignosa, edition source:",{"file":797,"uri":797,"title":798,"status":799,"editionAuthor":11,"type":800,"material":801,"condition":129,"layoutDesc":802,"handNote":805,"date":809,"places":810,"geo":813,"country":71,"region":72,"settlement":64,"repository":815,"idno":816,"textLang":818,"facsimile":820,"provenance":60,"letterHeights":822,"publications":823,"zotero":824,"keywords":825,"html":795},"ISic000207","I.Sicily inscription 000207",{"_":118},{"_":252,"ana":253,"ref":254},{"_":22,"ana":23,"ref":24},{"layout":803},{"rs":804,"damage":129},{"_":31,"ana":32,"ref":33},{"dimensions":806},[807,808],{"type":40,"l":41,"from":42,"to":42,"unit":44},{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":219,"notBefore":55,"notAfter":220},[811,812],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[814],[69,70],{"_":74,"role":75,"ref":76},{"_":817,"type":79},"42",{"_":81,"mainLang":82,"languages":819},[81],{"n":85,"url":821,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic000207_tiled.tif",[],[96,97,98],[100,101,102],[826,827,828,252,22,107,108,109,110,108,111,112,82],"isic000207","i.sicily inscription 000207",{"_":118},{"file":830,"uri":830,"title":831,"status":832,"editionAuthor":11,"type":833,"material":834,"condition":129,"layoutDesc":835,"handNote":839,"date":852,"places":853,"geo":856,"country":71,"region":72,"settlement":64,"repository":858,"textLang":859,"facsimile":861,"provenance":60,"letterHeights":863,"publications":864,"zotero":865,"keywords":866,"html":870},"ISic000225","Funerary epitaph for a certain Dionysius and Cn. Terentius Rufus, by the wife of the latter, Vibia Ammia",{"_":10},{"_":252,"ana":253,"ref":254},{"_":204,"ana":205,"ref":206},{"layout":836},{"p":837,"rs":838,"damage":129},"Five lines of Latin text, although first line is completely obscured. Likely only 1-2 letters are missing on the left side. Use of comma-shaped interpuncts in line 1 and the beginning of line 2, becoming more irregular after the deeply incised, perfectly rounded, dot-shaped interpunct before 'Rufo' at the end of line 2.",{"_":31,"ana":32,"ref":33},{"lettering":840,"dimensions":841},"Letters are deeply carved, with small serifs. The letters are incredibly regular, in shape and spacing, although 'T's are rendered tall, but not consistently. The end of line 3 has a small 'o', presumably to fit the final word 'Rufo' onto the stone. Use of incised guidelines is visible at both the top and bottom of each line. Guidelines are largely followed, except for the tall 'T's and the occasional seriffed foot.",[842,844,846,848,849,851],{"type":40,"l":41,"from":42,"to":42,"h":843,"unit":44},"irrecoverable, as only the bottom of two letters survive.",{"type":40,"l":48,"from":49,"to":49,"h":845,"unit":44},"27-29",{"type":40,"l":142,"from":143,"to":143,"h":847,"unit":44},"36-38 (first T=45 mm, last O=20mm)",{"type":40,"l":146,"from":147,"to":147,"h":269,"unit":44},{"type":40,"l":150,"from":151,"to":151,"h":850,"unit":44},"24-29 (Ts 29-31mm)",{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":219,"notBefore":55,"notAfter":220},[854,855],{"_":60,"type":61,"ref":62},{"_":64,"type":65,"ref":66},[857],[69,70],{"_":74,"role":75,"ref":76},{"_":81,"mainLang":82,"languages":860},[81],{"n":85,"url":862,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic000225_tiled.tif",[],[96,97,98],[100,101,102],[867,868,869,252,204,107,108,109,110,108,111,112,82],"isic000225","funerary epitaph for a certain dionysius and cn. terentius rufus, by the wife of the latter, vibia ammia",{"_":10},"Text encoding: Valentina Mignosa; Alex Antoniou, edition source:",{"file":872,"uri":872,"title":873,"status":874,"editionAuthor":11,"type":875,"objectType":876,"material":877,"condition":129,"layoutDesc":878,"handNote":882,"date":890,"places":891,"geo":894,"country":71,"region":72,"settlement":64,"repository":896,"idno":897,"textLang":899,"facsimile":901,"provenance":60,"letterHeights":903,"publications":904,"zotero":905,"keywords":906,"html":870},"ISic000226","Funerary epitaph for Tertia",{"_":10},{"_":252,"ana":253,"ref":254},{"_":18,"ana":19,"ref":124},{"_":22,"ana":23,"ref":24},{"layout":879},{"p":880,"rs":881,"damage":129},"Two lines of complete Latin. Use of triangular interpuncts.",{"_":31,"ana":32,"ref":33},{"lettering":883,"dimensions":884},"Small, well-formed letters, a little hapharzardly positioned on each line.",[885,887,889],{"type":40,"l":41,"from":42,"to":42,"h":886,"unit":44},"22-25",{"type":40,"l":48,"from":49,"to":49,"h":888,"unit":44},"17-19",{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":219,"notBefore":55,"notAfter":220},[892,893],{"_":60,"type":61,"ref":62},{"_":64,"type":65,"ref":66},[895],[69,70],{"_":74,"role":75,"ref":76},{"_":898,"type":79},"37",{"_":81,"mainLang":82,"languages":900},[81],{"n":85,"url":902,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic000226_tiled.tif",[],[96,97,98],[100,101,102],[907,908,909,252,18,22,107,108,109,110,108,111,112,82],"isic000226","funerary epitaph for tertia",{"_":10},{"file":911,"uri":911,"title":912,"status":913,"editionAuthor":11,"type":914,"material":915,"condition":129,"layoutDesc":916,"handNote":919,"date":923,"places":924,"geo":927,"country":71,"region":72,"settlement":64,"repository":929,"idno":930,"textLang":932,"facsimile":934,"provenance":60,"letterHeights":936,"publications":937,"zotero":938,"keywords":939,"html":795},"ISic000229","I.Sicily inscription 000229",{"_":118},{"_":252,"ana":253,"ref":254},{"_":22,"ana":23,"ref":24},{"layout":917},{"rs":918,"damage":129},{"_":31,"ana":32,"ref":33},{"dimensions":920},[921,922],{"type":40,"l":41,"from":42,"to":42,"unit":44},{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":219,"notBefore":55,"notAfter":220},[925,926],{"_":60,"type":61,"ref":62},{"_":64,"type":65,"ref":66},[928],[69,70],{"_":74,"role":75,"ref":76},{"_":931,"type":79},"81ab",{"_":81,"mainLang":82,"languages":933},[81],{"n":85,"url":935,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic000229_tiled.tif",[],[181,96,97,98],[185,100,101,102],[940,941,942,252,22,107,108,109,110,108,111,112,82],"isic000229","i.sicily inscription 000229",{"_":118},{"file":944,"uri":944,"title":945,"status":946,"editionAuthor":11,"type":947,"objectType":948,"material":949,"condition":129,"layoutDesc":950,"handNote":954,"date":961,"places":963,"geo":966,"country":71,"region":72,"settlement":64,"repository":968,"idno":969,"textLang":971,"facsimile":973,"provenance":60,"letterHeights":975,"publications":976,"zotero":977,"keywords":978,"html":870},"ISic000230","Funerary inscription for Vecilia",{"_":10},{"_":252,"ana":253,"ref":254},{"_":442,"ana":443,"ref":444},{"_":204,"ana":205,"ref":206},{"layout":951},{"p":952,"rs":953,"damage":129},"Two lines of Latin text, roughly centred on stone, but all contained within top half of the stone. Small dash interpunct is evident in line 1, but possible traces elsewhere. Graffiti squeezed into stone between left edge of stone and start of text, and roughly follows lines of inscription (but far from faithfully).",{"_":31,"ana":32,"ref":33},{"lettering":955,"dimensions":956},"Text is only lightly inscribed on stone. Letters even spaced and well-formed. Light serifs. Graffiti very rough, grey scratches on surface. Letters are imitative of main text, but thickness of lines, size of letters and orientation of letters are inconsistent.",[957,958,960],{"type":40,"l":41,"from":42,"to":42,"h":456,"unit":44},{"type":40,"l":48,"from":49,"to":49,"h":959,"unit":44},"35-42",{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":962,"notBefore":55,"notAfter":650},"Bivona (1994, 239) dates to the first half of the 1st century CE based on the missing cognomen.",[964,965],{"_":60,"type":61,"ref":62},{"_":64,"type":65,"ref":66},[967],[69,70],{"_":74,"role":75,"ref":76},{"_":970,"type":79},"124",{"_":81,"mainLang":82,"languages":972},[81],{"n":85,"url":974,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic000230_tiled.tif",[],[181,96,97,98],[185,100,101,102],[979,980,981,252,442,204,107,108,109,110,108,111,112,82],"isic000230","funerary inscription for vecilia",{"_":10},{"file":983,"uri":983,"title":984,"status":985,"editionAuthor":11,"type":986,"objectType":987,"material":988,"condition":129,"layoutDesc":989,"handNote":993,"date":1001,"places":1002,"geo":1005,"country":71,"region":72,"settlement":64,"repository":1007,"textLang":1008,"facsimile":1010,"provenance":60,"letterHeights":1012,"publications":1013,"zotero":1014,"keywords":1015,"html":870},"ISic000236","Funerary inscription for Marcus Voluscius Felix",{"_":10},{"_":252,"ana":253,"ref":254},{"_":18,"ana":19,"ref":124},{"_":22,"ana":23,"ref":24},{"layout":990},{"p":991,"rs":992,"damage":129},"Two lines of Latin text, not centred on stone. Three different interpuncts used: L1 triangular, L2 comma and dash.",{"_":31,"ana":32,"ref":33},{"lettering":994,"dimensions":995},"Text is straight and well-carved. Serifs used on most letters, pronounced tails on most letters. Letters are not evenly spaced. Cs are distinctive in shape, with a high rounded bulge. Whilst Bivona (1994) attested that the text is included within guidelines, no traces of these were apparent on the stone in autopsy.",[996,998,1000],{"type":40,"l":41,"from":42,"to":42,"h":997,"unit":44},"59-63",{"type":40,"l":48,"from":49,"to":49,"h":999,"unit":44},"48-52",{"type":51,"l":52,"from":42,"to":49,"unit":44},{"_":219,"notBefore":55,"notAfter":220},[1003,1004],{"_":60,"type":61,"ref":62,"cert":16},{"_":64,"type":65,"ref":66},[1006],[69,70],{"_":74,"role":75,"ref":76},{"_":81,"mainLang":82,"languages":1009},[81],{"n":85,"url":1011,"height":87,"width":88,"desc":89,"surfaceType":90},"ISic000236_tiled.tif",[],[96,97,98],[100,101,102],[1016,1017,1018,252,18,22,107,108,109,110,108,111,112,82],"isic000236","funerary inscription for marcus voluscius felix",{"_":10}],"uses":{"params":["slug"]}}]}
