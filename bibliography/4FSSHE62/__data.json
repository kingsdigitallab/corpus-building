/lod/1",{"ana":39},"#text_condition.complete",{"lettering":41,"dimensions":42},"The letters are incised somewhat crudely, more in the style of scratched than formally engraved letters, but of roughly equal size throughout. Lunate epsilon and sigma, uncial omega, mu tending towards cursive.",[43,50],{"type":44,"l":45,"from":46,"to":47,"h":48,"unit":49},"letterHeight","Line 1-3","line1","line3","17-22","mm",{"type":51,"l":52,"from":46,"to":53,"unit":49},"interlinear","Interlineation line 1 to 2 ","line2",{"_":55,"notBefore":56,"notAfter":57,"evidence":58},"1st century BCE",-100,-1,"lettering",[60,64],{"_":61,"type":62,"ref":63},"Segesta","ancient","https://pleiades.stoa.org/places/462487",{"_":61,"type":65,"ref":66},"modern","http://sws.geonames.org/2523171",[68],[69,70],37.94171,12.83649,"Italy","Sicily",{"_":74,"role":75,"ref":76},"Parco archeologico di Segesta","site","http://sicily.classics.ox.ac.uk/museum/196",{"_":78,"type":79},"SG6496","inventory",{"_":81,"mainLang":82,"languages":83},"Ancient Greek","grc",[81],[],[86,87,88,89,90,91,92],"Supplementum epigraphicum graecum, 1923-","Dubois, 2008, IGDS2","Nenci, 1995, Iscrizioni greche e latine","Nenci, 1997, Novità epigrafiche dall'area elima","Giustolisi, 1999, Petra: atlante delle antiche strutture rupestri dell'alta valle del Platani (Castronovo)","De Vido, 2003, Genealogie Segestane","Ampolo and Erdas, 2019, Inscriptiones Segestanae. Le iscrizioni greche e latine di Segesta",[94,95,96,97,98,99,100],"F2GG87EQ","SM2KDHZC","WHBJDH75","4FSSHE62","GGJ4H43M","33HPA43I","3PK3JKXR",[102,103,104,105,22,26,106,106,107,108,106,109,110,82],"isic002727","inscription recording works undertaken by the agoranomos herakleios",{"_":10},"building; honorific","segesta","italy","sicily","parco archeologico di segesta","ancient greek","Text encoding: Jonathan Prag, edition source: \u003Ca href=\"http://zotero.org/groups/382445/items/3PK3JKXR\">http://zotero.org/groups/382445/items/3PK3JKXR\u003C/a>",{"file":113,"uri":113,"title":11