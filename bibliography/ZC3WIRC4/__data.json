[ἄλλο τι ἀγ]ά̣γῃ δυσαγείτω καὶ αὐτὸς καὶ γέ[νος αὐτοῦ καθάπερ] \u003Cbr id=\"al6-interpretive\">\u003Cspan class=\"linenumber\">6\u003C/span>[καὶ ἐπὶ ἱε]ροῦ χρήματος καταβλαβέος γ̣[έγραπται \u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al7-interpretive\">\u003Cspan class=\"linenumber\">7\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 8.\u003C/span>] καὶ τῶν νεανίσκων τῶν ἀλε[ιφομένων\u003Cspan dir=\"ltr\" class=\"gap\">---\u003C/span>] \u003Cbr id=\"al8-interpretive\">\u003Cspan class=\"linenumber\">8\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 9.\u003C/span>] ὀφιλόντωι τῶι \u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"Ἑρμᾶι\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἑρμᾶι\">Ἑρμᾶι\u003C/span>\u003C/span> καὶ τῶι \u003Cspan data-type=\"persname\" data-name-type=\"divine\" data-text=\"Ἡρακλεῖ\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Ἡρακλεῖ\">Ἡρα[κλεῖ\u003C/span>\u003C/span> καὶ τοῖς νεανί-]\u003Cbr id=\"al9-interpretive\">\u003Cspan class=\"linenumber\">9\u003C/span>[σκοις τοῖς ἀ]λειφομένοις δικασάσθω δὲ [αὐτοῖς ὥσπερ ἐπὶ ἱε-]\u003Cbr id=\"al10-interpretive\">\u003Cspan class=\"linenumber\">10\u003C/span>[ροῦ χρήματο]ς̣ καταβλαβέος ἄνις ἐπιδε[κάτου ὁ βουλόμενος] \u003Cbr id=\"al11-interpretive\">\u003Cspan class=\"linenumber\">11\u003C/span>[\u003Cspan dir=\"ltr\" class=\"gap\">. 10.\u003C/span>]ι νεανίσκοι μὴ δόγμα τι π̣[αρβαινόντω ἀλλὰ φυλασσόν-]\u003Cbr id=\"al12-interpretive\">\u003Cspan class=\"linenumber\">12\u003C/span>[τω τὸ γεγ]ραμμένον ἐς [τὸν ἅπαντα χρόνον] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":105,"ptr":106,"ref":108,"inscriptionDate":4,"title":2,"citation":5,"uri":6,"year":4},"9-10=171-172",{"target":107},"https://www.zotero.org/groups/382445/items/ZC3WIRC4",{"_":109,"target":109},"https://biblio.inscriptiones.org/epig10001722",1923,false],"uses":{"params":["slug"]}}]}
