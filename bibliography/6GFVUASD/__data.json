":236},"marble",{"layout":603},{"p":604,"rs":605,"damage":24},"Parts of three lines of Latin letters are preserved",{"_":29,"ana":30,"ref":31},{"lettering":607,"dimensions":608},"The letters are neatly V-cut and well-proportioned, with modest serifs. Neither lines 1 nor 3 are completely preserved, but line 1 is taller than line 2, and line 3 is shorter",[609,611],{"type":130,"l":305,"from":137,"to":137,"h":610,"unit":134},"70",{"type":141,"l":142,"from":132,"to":137,"h":143,"unit":134},{"_":613,"notBefore":570,"notAfter":571,"evidence":148,"precision":149},"1st century CE",[615,616],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[618],[162,163],{"_":167,"role":168,"ref":169},{"_":621,"type":172},"ME 20225",{"_":262,"mainLang":263,"languages":623},[262],{"n":178,"url":625,"height":585,"width":626,"desc":586,"surfaceType":183},"ISic000802_tiled.tif","5982px",[],[186,188,272,192,194],[198,200,276,204,206],[631,632,633,13,290,601,214,215,216,217,214,218,283,263],"isic000802","latin fragment mentioning a basilica",{"_":10},{"file":635,"uri":635,"title":636,"status":637,"editionAuthor":11,"type":638,"objectType":639,"material":640,"condition":24,"layoutDesc":642,"handNote":645,"date":652,"places":656,"geo":659,"country":164,"region":165,"settlement":152,"repository":661,"idno":662,"textLang":664,"facsimile":666,"provenance":152,"letterHeights":669,"publications":670,"zotero":671,"keywords":672,"html":220},"ISic000805","Fragmentary latin inscription mentioning a proconsul",{"_":10},{"_":13,"ana":14,"ref":15},{"_":290,"ana":291,"ref":292},{"_":641,"ana":235,"ref":236},"marble (pink)",{"layout":643},{"rs":644,"damage":24},{"_":29,"ana":30,"ref":31},{"lettering":646,"dimensions":647},"Letters are 50mm high, tall, thin, serifed. P and R are open; the hastae of M join early and extend upwards; a hedera like interpunct (tail top and bottom to a hollow element) appears once between C and V of line 2.",[648,651],{"type":130,"l":649,"from":132,"to":309,"h":650,"unit":134},"Line 1-3","50",{"type":141,"l":247,"from":132,"to":137,"unit":134},{"_":653,"notBefore":654,"notAfter":655,"precision":149},"3rd century CE",201,300,[657,658],{"_":152,"type":153,"ref":154},{"_":156,"type":157,"ref":158,"offset":159},[660],[162,163],{"_":167,"role":168,"ref":169},{"_":663,"type":172},"ME 20228",{"_":262,"mainLang":263,"languages":665},[262],{"n":178,"url":667,"height":668,"width":585,"desc":586,"surfaceType":183},"ISic000805_tiled.tif","5256px",[],[186,188,272,191,192,194,196],[198,200,276,203,204,206,208],[673,674,675,13,290,641,214,215,216,217,214,218,283,263],"isic000805","fragmentary latin inscription mentioning a proconsul",{"_":10},{"file":677,"uri":677,"title":678,"status":679,"editionAuthor":11,"type":680,"objectType":681,"material":685,"condition":24,"layoutDesc":686,"handNote":690,"date":717,"places":719,"geo":722,"country":164,"region":165,"settlement":152,"repository":724,"idno":725,"textLang":727,"facsimile":729,"provenance":152,"letterHeights":734,"publications":735,"zotero":747,"keywords":759,"html":220},"ISic001176","A koinon of priests honours [-?-] Lapiron, son of Diogenes",{"_":10},{"_":13,"ana":14,"ref":15},{"_":682,"ana":683,"ref":684},"block","#object.block","http://www.eagle-network.eu/voc/objtyp/lod/189.html",{"_":358,"ana":359,"ref":360},{"layout":687},{"p":688,"rs":689,"damage":24},"Three lines of Greek text are preserved: the state of the stone means that the beginning and end of all three lines is lost, and at least one further line could have been lost below. If there were any lines above these, they would have been on a separate block of stone.",{"_":29,"ana":30,"ref":31},{"lettering":691,"dimensions":712},[692,693],"The letters are regularly cut, with deep terminations to the strokes rather than extended serifs. Epsilon has a shorter middle bar, detached from the main vertical; omicron is very slightly smaller than the other letters; omega is almost, or completely closed, with a slightly elliptical 