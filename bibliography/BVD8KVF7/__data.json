 class=\"linenumber\">4\u003C/span> τοῦ ἀρχιτέκτονος· μετὰ τὴν ὑπ[ατείαν τοῦ δεσπότου ἡμῶν \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Θεοδοσίου\n                    αἰωνίου Αὐγούστου\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Θεοδοσίου\n                    αἰωνίου\">Θεοδο]σίου αἰωνίου\u003C/span>  \u003Cspan data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Αὐγούστου\">Αὐγούστου\u003C/span>\u003C/span> τὸ διʹ κ\u003Cspan class=\"underline\">α\u003C/span>ὶ \u003Cspan data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μαξίμου\">\u003Cspan data-type=\"name\" data-name-type=\"\" data-text=\"Μαξίμου\">Μαξίμου\u003C/span>\u003C/span> τοῦ λαμπ [ροτάτου] \u003C/span>\u003C/div>  \u003Cp class=\"miniapp\">\u003C/p>",{"author":3,"date":4,"citedRange":488,"ptr":489,"ref":490,"inscriptionDate":4,"title":2,"citation":5,"uri":6},"24-30 no.5 fig.7",{"target":311},{"_":136,"target":136},{"file":492,"uri":492,"title":493,"status":494,"editionAuthor":13,"type":496,"objectType":500,"material":501,"condition":26,"layoutDesc":503,"handNote":507,"date":525,"places":529,"geo":532,"country":60,"provenance":57,"provenanceGeo":534,"region":183,"settlement":62,"repository":537,"idno":538,"textLang":540,"tmNumber":542,"facsimile":543,"letterHeights":547,"publications":555,"zotero":558,"keywords":561,"html":565,"bibl":566,"bulletinDateSort":137,"citedRangeSort":567,"languageSort":81,"materialSort":502,"typeSort":497},"ISic000298","Dedication to the Genius of the city of Catania",{"_":495},"edited",{"_":497,"ana":498,"ref":499},"dedication","#function.dedication","http://www.eagle-network.eu/voc/typeins/lod/88.html",{"_":19,"ana":20,"ref":21},{"_":502,"ana":24,"ref":25},"marble (white)",{"layout":504},{"p":505,"rs":506,"damage":26},"The text is preserved intact, over seven lines, although the edge\n                                        of the surviving stone clips the tops of the letters of the first line. The\n                                        letters diminish in size over the first four lines, with a vacat in the second\n                                        half of line four; the final three lines are larger again. The left margin of\n                                        the text is maintained regularly, the right margin varies from line to line.",{"_":31,"ana":32,"ref":33},{"lettering":508,"dimensions":509},"The letters are deeply but somewhat irregularly cut, with some\n                                    internal variation (e.g. A appears with both broken and straight bar; E appears both\n                                    as a tall narrow standard E and as a vertical stroke with a single horizontal bar\n                                    across the middle; V appears both as V and as Y). Interpuncts are mostly absent,\n                                    except after VC and CONS in the final two lines.",[510,514,517,524],{"type":38,"l":263,"from":40,"to":40,"h":511,"unit":43,"atLeast":512,"atMost":513},"60-80","60","80",{"type":38,"l":515,"from":49,"to":442,"h":516,"unit":43,"atLeast":166,"atMost":512},"Line 2-4","40-60",{"type":38,"l":518,"from":519,"to":520,"h":521,"unit":43,"atLeast":522,"atMost":523},"Line 5-7","line5","line7","50-70","50","70",{"type":47,"from":40,"to":49,"unit":43},{"_":526,"notBefore":527,"notAfter":528},"Munatidius is not otherwise known; the mention of three Domini\n                                    requires one of the periods 337—340, 367—378, 379—383, 388—395, 402—408, and 421. A\n                                    precise choice is not possible, but the consensus amongst scholars is for a date in\n                                    the 4th century rather than later.",337,421,[530,531],{"_":57,"type":58,"ref":59,"region":60},{"_":62,"type":63,"ref":64,"region":60},[533],[67,68],[535,536],37.502748,15.083639,{"_":185,"role":75,"ref":186},{"_":539,"type":79},"2",{"_":81,"mainLang":82,"languages":541},[81],"175826",{"n":86,"url":544,"h