/www.zotero.org/groups/382445/items/Q2SBPG9F</a></div><div id=\"edition-diplomatic\"><span class=\"textpartnumber\" id=\"abA\">section A</span><div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"divA--diplomatic\"><a id=\"aA-l1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span>ΟΙΔΕΚΟΡΙΩΝΕΣ<br id=\"aA-l2-diplomatic\"><span class=\"linenumber\">2</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μάρκον Οὐαλέριον Διογνήτου\n                    Μῆγα υἱὸν Χόρτωνα\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Μάρκον\">Μ</span><span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Οὐαλέριον\">ΟΥΑΛΕΡΙΟΝ</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Διογνήτου\n                    Μῆγα\"><span data-type=\"name\" data-name-type=\"patronymic\" data-text=\"Διογνήτου\">ΔΙΟΓΝΗΤΟΥ</span><br id=\"aA-l3-diplomatic\"><span class=\"linenumber\">3</span><span data-type=\"name\" data-name-type=\"patronymic\" data-text=\"Μῆγα\">ΜΗΓΑ</span></span><span data-text=\"υἱὸν\">ΥΙΟΝ</span><span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Χόρτωνα\">ΧΟΡΤΩΝΑ</span></span><br id=\"aA-l4-diplomatic\"><span class=\"linenumber\">4</span>ΕΥΕΡΓΕΤΑΝ</span></div><span class=\"textpartnumber\" id=\"abB\">section B</span><div class=\"textpart\" lang=\"la\"><span class=\"ab\" id=\"divB--diplomatic\"><a id=\"aB-l1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span>ORDOETPOPULUSCIVITLILYBIT<br id=\"aB-l2-diplomatic\"><span class=\"linenumber\">2</span>PATRONOPERPETUO</span></div><p class=\"miniapp\"></p></div>"
