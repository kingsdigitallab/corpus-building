      "html": "<div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"div-diplomatic\"><a id=\"al1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span data-text=\"ὁ\" data-n=\"10\" data-lemma=\"\">Ο</span><span data-text=\"δᾶμος\" data-n=\"15\" data-lemma=\"\">ΔΑΜΟΣ</span> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <br id=\"al2-diplomatic\"><span class=\"linenumber\">2</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Βίωτον Τιμάνδρου\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Βίωτον\"><span data-text=\"Βίωτον\" data-n=\"25\" data-lemma=\"\">.ΙΩΤΟΝ</span></span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Τιμάνδρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Τιμάνδρου\"><span data-text=\"Τιμάνδρου\" data-n=\"30\" data-lemma=\"\">ΤΙΜΑΝΔΡΟ[.]</span></span></span></span><br id=\"al3-diplomatic\"><span class=\"linenumber\">3</span><span data-text=\"εὐνοίας\" data-n=\"35\" data-lemma=\"\">ΕΥΝΟΙΑΣ</span><span data-text=\"ἕνεκεν\" data-n=\"40\" data-lemma=\"\">ΕΝΕΚΕ.</span></span></div><p class=\"miniapp\"></p>"
