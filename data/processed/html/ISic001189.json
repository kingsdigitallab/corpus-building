"Βίωτον\"><span data-text=\"Βίωτον\" data-n=\"25\" data-lemma=\"\">.ΙΩΤΟΝ</span></span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Τιμάνδρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Τιμάνδρου\"><span data-text=\"Τιμάνδρου\" data-n=\"30\" data-lemma=\"\">ΤΙΜΑΝΔΡΟ[.]</span></span></span></span><br id=\"al3-diplomatic\"><span class=\"linenumber\">3</span><span data-text=\"εὐνοίας\" data-n=\"35\" data-lemma=\"\">ΕΥΝΟΙΑΣ</span><span data-text=\"ἕνεκεν\" data-n=\"40\" data-lemma=\"\">ΕΝΕΚΕ.</span></span></div><p class=\"miniapp\"></p></div>"
