{
  "title": "ISic002999. I.Sicily inscription 002999",
  "body": "<div id=\"editions\"><div class=\"attribution\">Text encoding: Valentina Mignosa</div><div id=\"edition-interpretive\" lang=\"grc\">  <div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"div-interpretive\">  <a id=\"al1-interpretive\"><!--0--></a><span class=\"linenumber\">1</span>Χαριστήρια <span data-type=\"persname\" data-name-type=\"divine\" data-text=\"Παίδεσσι\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Παίδεσσι\">Παίδεσσι</span></span> καὶ <br id=\"al2-interpretive\"><span class=\"linenumber\">2</span><span data-type=\"persname\" data-name-type=\"divine\" data-text=\"Ἄννᾳ\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Ἄννᾳ\">Ἄννᾳ</span></span> κ̣[αὶ <span data-type=\"persname\" data-name-type=\"divine\" data-text=\"ἈπόλλωνιἈπόλωνι\"><span data-type=\"name\" data-name-type=\"\" data-text=\"ἈπόλλωνιἈπόλωνι\">Ἀπ]όλωνι</span></span>  <br id=\"al3-interpretive\"><span class=\"linenumber\">3</span>ἐπὶ ἀμφιπόλου ἐ[ν Συρακούσ]αις [<span dir=\"ltr\" class=\"gap\">.</span>] <br id=\"al4-interpretive\"><span class=\"linenumber\">4</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Αὖλου Ματίου Σέστου\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Αὖλου\">Α(ὖλου)</span>  <span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Ματίου\">Ματίου</span>  <span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Σέστου\">Σέστου</span></span> ἱερείας δὲ <br id=\"al5-interpretive\"><span class=\"linenumber\">5</span>τᾶν <span data-type=\"persname\" data-name-type=\"divine\" data-text=\"Παίδων\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Παίδων\">Παίδων</span></span>  <span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Καικιλίας\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Καικιλίας\">Καικιλίας</span></span>  <br id=\"al6-interpretive\"><span class=\"linenumber\">6</span>οἱ παραγενόμενοι ποτὶ <span data-type=\"persname\" data-name-type=\"divine\" data-text=\"Νύμφας\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Νύμφας\">Νύ&lt;μ&gt;φας</span></span>  <br id=\"al7-interpretive\"><span class=\"linenumber\">7</span>καὶ εὐχαριστήσαντες μηνὸς <br id=\"al8-interpretive\"><span class=\"linenumber\">8</span>Ἀπελλαίου τρίτᾳ <span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σέξτος\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Σέξτος\">Σέξτος</span></span>  <br id=\"al9-interpretive\"><span class=\"linenumber\">9</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Αὖλος · Μάρκις Λόνγος\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Αὖλος\">Α(ὖλος)</span> · <span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Μάρκις\">Μάρκις</span>  <span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Λόνγος\">Λόν[γος]</span></span>  <br id=\"al10-interpretive\"><span class=\"linenumber\">10</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κόϊντος · Ὄππις Κάνακις\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Κόϊντος\">Κ(όϊντος)</span> · <span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Ὄππις\">Ὄππις</span>  <span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Κάνακις\">Κάνακις</span></span>  <br id=\"al11-interpretive\"><span class=\"linenumber\">11</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κόϊντος · Ἄμπιους Κρήσκης\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Κόϊντος\">Κ(όϊντος)</span> · <span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Ἄμπιους\">Ἄμπιους</span>  <span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Κρήσκης\">Κρήσκη[ς]</span></span>  <br id=\"al12-interpretive\"><span class=\"linenumber\">12</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\" Αἴλις Σελλά\">[<span dir=\"ltr\" class=\"gap\">.</span>] <span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Αἴλις\">Αἴλις</span>  <span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Σελλά\">Σελλά[<span dir=\"ltr\" class=\"gap\">---</span>]</span></span>  <br id=\"al13-interpretive\"><span class=\"linenumber\">13</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κόϊντος ήσις ωτιανός\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Κόϊντος\">Κ(όϊντος?)</span>  <span data-type=\"name\" data-name-type=\"nomen\" data-text=\"ήσις\">[<span dir=\"ltr\" class=\"gap\">.</span>]ήσις</span>  <span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"ωτιανός\">[<span dir=\"ltr\" class=\"gap\">---</span>]ω̣τιανός</span></span>  <br id=\"al14-interpretive\"><span class=\"linenumber\">14</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γάϊος ιφκρατος\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Γάϊος\">Γ(άϊος)</span> [<span dir=\"ltr\" class=\"gap\">---</span>]ιφ̣[<span dir=\"ltr\" class=\"gap\">---</span>]κ̣ρατος</span>  <br id=\"al15-interpretive\"><span class=\"linenumber\">15</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Γάϊος μητος\"><span data-type=\"name\" data-name-type=\"praenoman\" data-text=\"Γάϊος\">Γ(άϊος)</span> [<span dir=\"ltr\" class=\"gap\">---</span>]μητος</span>  </span></div>  <p class=\"miniapp\">l.2 reg., orig. ..ΟΛΩΝΙἈπόλωνι</p></div><div class=\"attribution\">Text encoding: Valentina Mignosa</div><div id=\"edition-diplomatic\" lang=\"grc\"><div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"div-diplomatic\"><a id=\"al1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span>ΧΑΡΙΣΤΗΡΙΑ<span data-type=\"persname\" data-name-type=\"divine\" data-text=\"Παίδεσσι\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Παίδεσσι\">ΠΑΙΔΕΣΣΙ</span></span>ΚΑΙ<br id=\"al2-diplomatic\"><span class=\"linenumber\">2</span><span data-type=\"persname\" data-name-type=\"divine\" data-text=\"Ἄννᾳ\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Ἄννᾳ\">ΑΝΝΑ</span></span>.[..<span data-type=\"persname\" data-name-type=\"divine\" data-text=\"ἈπόλλωνιἈπόλωνι\"><span data-type=\"name\" data-name-type=\"\" data-text=\"ἈπόλλωνιἈπόλωνι\">..]ΟΛΩΝΙ</span></span><br id=\"al3-diplomatic\"><span class=\"linenumber\">3</span>ΕΠΙΑΜΦΙΠΟΛΟΥΕ[.........]ΑΙΣ[<span dir=\"ltr\" class=\"gap\">·</span>]<br id=\"al4-diplomatic\"><span class=\"linenumber\">4</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Αὖλου Ματίου Σέστου\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Αὖλου\">Α</span><span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Ματίου\">ΜΑΤΙΟΥ</span><span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Σέστου\">ΣΕΣΤΟΥ</span></span>ΙΕΡΕΙΑΣΔΕ<br id=\"al5-diplomatic\"><span class=\"linenumber\">5</span>ΤΑΝ<span data-type=\"persname\" data-name-type=\"divine\" data-text=\"Παίδων\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Παίδων\">ΠΑΙΔΩΝ</span></span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Καικιλίας\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Καικιλίας\">ΚΑΙΚΙΛΙΑΣ</span></span><br id=\"al6-diplomatic\"><span class=\"linenumber\">6</span>ΟΙΠΑΡΑΓΕΝΟΜΕΝΟΙΠΟΤΙ<span data-type=\"persname\" data-name-type=\"divine\" data-text=\"Νύμφας\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Νύμφας\">ΝΥΦΑΣ</span></span><br id=\"al7-diplomatic\"><span class=\"linenumber\">7</span>ΚΑΙΕΥΧΑΡΙΣΤΗΣΑΝΤΕΣΜΗΝΟΣ<br id=\"al8-diplomatic\"><span class=\"linenumber\">8</span>ΑΠΕΛΛΑΙΟΥΤΡΙΤΑ<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Σέξτος\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Σέξτος\">ΣΕΞΤΟΣ</span></span><br id=\"al9-diplomatic\"><span class=\"linenumber\">9</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Αὖλος · Μάρκις Λόνγος\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Αὖλος\">Α</span>·<span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Μάρκις\">ΜΑΡΚΙΣ</span><span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Λόνγος\">ΛΟΝ[...]</span></span><br id=\"al10-diplomatic\"><span class=\"linenumber\">10</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κόϊντος · Ὄππις Κάνακις\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Κόϊντος\">Κ</span>·<span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Ὄππις\">ΟΠΠΙΣ</span><span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Κάνακις\">ΚΑΝΑΚΙΣ</span></span><br id=\"al11-diplomatic\"><span class=\"linenumber\">11</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κόϊντος · Ἄμπιους Κρήσκης\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Κόϊντος\">Κ</span>·<span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Ἄμπιους\">ΑΜΠΙΟΥΣ</span><span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Κρήσκης\">ΚΡΗΣΚΗ[.]</span></span><br id=\"al12-diplomatic\"><span class=\"linenumber\">12</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\" Αἴλις Σελλά\">[<span dir=\"ltr\" class=\"gap\">·</span>]<span data-type=\"name\" data-name-type=\"nomen\" data-text=\"Αἴλις\">ΑΙΛΙΣ</span><span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"Σελλά\">ΣΕΛΛΑ[<span dir=\"ltr\" class=\"gap\">---</span>]</span></span><br id=\"al13-diplomatic\"><span class=\"linenumber\">13</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Κόϊντος ήσις ωτιανός\"><span data-type=\"name\" data-name-type=\"praenomen\" data-text=\"Κόϊντος\">Κ</span><span data-type=\"name\" data-name-type=\"nomen\" data-text=\"ήσις\">[<span dir=\"ltr\" class=\"gap\">·</span>]ΗΣΙΣ</span><span data-type=\"name\" data-name-type=\"cognomen\" data-text=\"ωτιανός\">[<span dir=\"ltr\" class=\"gap\">---</span>].ΤΙΑΝΟΣ</span></span><br id=\"al14-diplomatic\"><span class=