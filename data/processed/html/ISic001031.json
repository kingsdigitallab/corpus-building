      "html": "<div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"div-diplomatic\"><a id=\"al1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span><span data-text=\"ἐπὶ\" data-n=\"5\" data-lemma=\"\">[...</span><span data-text=\"Φιλοκράτεος\" data-n=\"10\" data-lemma=\"\">.]Ι.ΟΚ[.]Α.[..].</span><span data-text=\"Ἀφροδίται\" data-n=\"15\" data-lemma=\"\">ΑΦΡΟ....[.]</span><span class=\"textpartnumber\" style=\"left: -4em;\">Col. 1<br></span><br id=\"al2-diplomatic\"><span class=\"linenumber\">2</span><span data-text=\"ἀγορανόμοι\" data-n=\"20\" data-lemma=\"\">ΑΓΟΡΑΝΟΜΟΙ</span><br id=\"al3-diplomatic\"><span class=\"linenumber\">3</span><span data-text=\"Διονυσόδωρος\" data-n=\"25\" data-lemma=\"\">ΔΙΟΝΥΣΟΔΩΡΟΣ</span><span data-text=\"Ζωπύρου\" data-n=\"30\" data-lemma=\"\">ΖΩΠΥΡΟΥ</span><br id=\"al4-diplomatic\"><span class=\"linenumber\">4</span><span data-text=\"Εὐφραῖος\" data-n=\"35\" data-lemma=\"\">ΕΥΦΡΑΙΟΣ</span><span data-text=\"Καλλικράτεος\" data-n=\"40\" data-lemma=\"\">ΚΑΛΛΙΚΡΑΤΕΟΣ</span><br id=\"al5-diplomatic\"><span class=\"linenumber\">5</span><span data-text=\"τριακάδαρχοι\" data-n=\"45\" data-lemma=\"\">ΤΡΙΑΚΑΔΑΡΧΟΙ</span><br id=\"al6-diplomatic\"><span class=\"linenumber\">6</span><span data-text=\"Δαμοκράτης\" data-n=\"50\" data-lemma=\"\">ΔΑΜΟΚΡΑΤΗΣ</span><span data-text=\"Ἀριστοκράτεος\" data-n=\"55\" data-lemma=\"\">ΑΡΙΣΤΟΚΡΑΤΕΟΣ</span><br id=\"al7-diplomatic\"><span class=\"linenumber\">7</span><span data-text=\"Ἀγέας\" data-n=\"60\" data-lemma=\"\">ΑΓΕΑΣ</span><span data-text=\"Ἀγέα\" data-n=\"65\" data-lemma=\"\">ΑΓΕΑ</span><br id=\"al8-diplomatic\"><span class=\"linenumber\">8</span><span data-text=\"Ἀπολλώνιος\" data-n=\"70\" data-lemma=\"\">ΑΠΟΛΛΩΝΙΟΣ</span><span data-text=\"Ἀγάθωνος\" data-n=\"75\" data-lemma=\"\">ΑΓΑΘΩΝΟΣ</span><br id=\"al9-diplomatic\"><span class=\"linenumber\">9</span><span data-text=\"Ἕλωρις\" data-n=\"80\" data-lemma=\"\">ΕΛΩΡΙΣ</span><span data-text=\"Ἀπολλωνίου\" data-n=\"85\" data-lemma=\"\">Α