e-type=\"demotic\" data-text=\"Περ\"><span data-text=\"Περ\">Περ(- - -)</span></span></span>  <br id=\"al6-interpretive\"><span class=\"linenumber\">6</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"κράτεος\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"κράτεος\"><span data-text=\"κράτεος\">κράτεος</span></span></span>  <br id=\"al7-interpretive\"><span class=\"linenumber\">7</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"ώρου Σαλ\"><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"ώρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"ώρου\"><span data-text=\"ώρου\">ώρου</span></span></span>  <span data-type=\"name\" data-name-type=\"demotic\" data-text=\"Σαλ\"><span data-text=\"Σαλ\">Σαλ(- - -)</span></span></span>  <br id=\"al8-interpretive\"><span class=\"linenumber\">8</span>[<span dir=\"ltr\" class=\"gap\">---</span>] <span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μάμου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Μάμου\">Μ̣άμου</span></span>  </span></div>  <p class=\"miniapp\"></p></div><div class=\"attribution\">Text encoding: Jonathan Prag, edition source: <a href=\"https://www.zotero.org/groups/382445/items/9RD2X88G\">https://www.zotero.org/groups/382445/items/9RD2X88G</a></div><div id=\"edition-diplomatic\" lang=\"grc\"><div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"div-diplomatic\"><a id=\"al1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span>[<span dir=\"ltr\" class=\"gap\">---</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Νυμφοδώρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Νυμφοδώρου\">..]ΜΦΟΔΩΡΟΥ</span></span><br id=\"al2-diplomatic\"><span class=\"linenumber\">2</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"οδώρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"οδώρου\"><span data-text=\"οδώρου\">ΟΔΩΡΟΥ</span></span></span><br id=\"al3-diplomatic\"><span class=\"linenumber\">3</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"α\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"α\"><span data-text=\"α\">Α</span></span></span><br id=\"al4-diplomatic\"><span class=\"linenumber\">4</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"κλείου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"κλείου\"><span data-text=\"κλείου\">ΚΛΕΙΟΥ</span></span></span><br id=\"al5-diplomatic\"><span class=\"linenumber\">5</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"οτίου Περ\"><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"οτίου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"οτίου\"><span data-text=\"οτίου\">Ο.ΙΟΥ</span></span></span><span data-type=\"name\" data-name-type=\"demotic\" data-text=\"Περ\"><span data-text=\"Περ\">ΠΕΡ</span></span></span><br id=\"al6-diplomatic\"><span class=\"linenumber\">6</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"κράτεος\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"κράτεος\"><span data-text=\"κράτεος\">ΚΡΑΤΕΟΣ</span></span></span><br id=\"al7-diplomatic\"><span class=\"linenumber\">7</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"ώρου Σαλ\"><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"ώρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"ώρου\"><span data-text=\"ώρου\">ΩΡΟΥ</span></span></span><span data-type=\"name\" data-name-type=\"demotic\" data-text=\"Σαλ\"><span data-text=\"Σαλ\">ΣΑΛ</span></span></span><br id=\"al8-diplomatic\"><span class=\"linenumber\">8</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Μάμου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Μάμου\">.ΑΜΟΥ</span></span></span></div><p class=\"miniapp\"></p></div>"
