      "html": "<div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"div-diplomatic\"><a id=\"al1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Χαρικλέος\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Χαρικλέος\">ΧΑΡΙΚΛΕΟΣ</span></span><br id=\"al2-diplomatic\"><span class=\"linenumber\">2</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"ς  Τελεσάρχου\"><span data-text=\"ς\">Σ</span> &nbsp;&nbsp; <span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Τελεσάρχου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Τελεσάρχου\">ΤΕΛΕΣΑΡΧΟΥ</span></span></span><br id=\"al3-diplomatic\"><span class=\"linenumber\">3</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἡρακλείου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Ἡρακλείου\">ΗΡΑΚΛΕΙΟΥ</span></span><br id=\"al4-diplomatic\"><span class=\"linenumber\">4</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"ς  Ἀπολλοδώρου\"><span data-text=\"ς\">Σ</span> &nbsp;&nbsp; <span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἀπολλοδώρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Ἀπολλοδώρου\">ΑΠΟΛΛΟΔΩΡΟΥ</span></span></span><br id=\"al5-diplomatic\"><span class=\"linenumber\">5</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Θεοδώρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Θεοδώρου\">ΘΕΟΔΩΡΟΥ</span></span><br id=\"al6-diplomatic\"><span class=\"linenumber\">6</span>[<span dir=\"ltr\" class=\"gap\">---</span>]<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"ος Εὐφράνορος