ext=\"Ἀριστέα\"><span data-text=\"Ἀριστέα\" data-n=\"10\" data-lemma=\"Ἀριστέας\">ΑΡΙΣΤΕΑ</span></span></span></span></span></div><p class=\"miniapp\"></p></div><div class=\"attribution\">Text encoding: Dmitry Dundua, Robert Crellin</div><div id=\"edition-diplomatic-simple-lemmatized\"><div class=\"textpart\"><span class=\"ab\" id=\"div-diplomatic\"><span data-text=\"Ὀλτίσκος\" data-n=\"5\" data-lemma=\"Ὀλτίσκος\">ΟΛΤΙΣΚΟΣ</span><span data-text=\"Ἀριστέα\" data-n=\"10\" data-lemma=\"Ἀριστέας\">ΑΡΙΣΤΕΑ</span></span></div><p class=\"miniapp\"></p></div>"
