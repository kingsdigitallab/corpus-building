rag; edition source: <a href=\"http://zotero.org/groups/382445/items/3PK3JKXR\">http://zotero.org/groups/382445/items/3PK3JKXR</a></div><div id=\"edition-diplomatic\" lang=\"grc\"><div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"div-diplomatic\"><a id=\"al1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span>ΙΕΡ<span class=\"underline\">ΟΘ</span>ΥΤΕΟΝΤΟΣ<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Φάωνος\n                    Νύμφωνος Σωπολιανοῦ\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Φάωνος\">ΦΑΩΝΟΣ</span><br id=\"al2-diplomatic\"><span class=\"linenumber\">2</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Νύμφωνος\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Νύμφωνος\">ΝΥ[.]<span class=\"underline\">Φ</span>ΩΝΟΣ</span></span><span data-type=\"name\" data-name-type=\"\" data-text=\"Σωπολιανοῦ\">ΣΩΠΟΛΙΑΝΟΥ</span></span><br id=\"al3-diplomatic\"><span class=\"linenumber\">3</span>ΑΓΟΡ.ΝΟΜΕΟΝΤΟΣ<span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ξενάρχου\n                    Ἀπολλοδώρου\"><span data-type=\"name\" data-name-type=\"\" data-text=\"Ξενάρχου\">ΞΕΝΑΡΧΟΥ</span><br id=\"al4-diplomatic\"><span class=\"linenumber\">4</span><span data-type=\"persname\" data-name-type=\"attested\" data-text=\"Ἀπολλοδώρου\"><span data-type=\"name\" data-name-type=\"patronym\" data-text=\"Ἀπολλοδώρου\">ΑΠΟΛΛ<span class=\"underline\">ΟΔΩ</span>ΡΟΥ</span></span></span>ΚΑΙΤΑΝΕΠΙΜΕΛΕΙΑΝ<br id=\"al5-diplomatic\"><span class=\"linenumber\">5</span>ΠΟ<span class=\"underline\">ΙΣΑΜ</span>ΕΝΟΥΤΩΝΕΡΓΩΝVACAT<br id=\"al6-diplomatic\"><span class=\"linenumber\">6</span>Α.[.]<span class=\"underline\">Ο</span>[.]<span class=\"underline\">Α</span>ΚΑΤΕΣΚΕΥΑΣΘΗ</span></div><p class=\"miniapp\"></p></div>"
