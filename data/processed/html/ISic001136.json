      "html": "<div class=\"textpart\" lang=\"grc\"><span class=\"ab\" id=\"div-diplomatic\"><a id=\"al1-diplomatic\"><!--0--></a><span class=\"linenumber\">1</span>[<span dir=\"ltr\" class=\"gap\">⁦ - - - - - - - - - - ⁩</span>]<br id=\"al2-diplomatic\"><span class=\"linenumber\">2</span><span data-text=\"ἐπὶ τὸ\" data-n=\"10\" data-lemma=\"\">[.]....Ο</span><span data-text=\"άλειπτήριον\" data-n=\"15\" data-lemma=\"\">ΑΛΕΙ.[......</span><span data-text=\"ἐκ\" data-n=\"20\" data-lemma=\"\">..</span><span data-text=\"τοῦ\" data-n=\"25\" data-lemma=\"\">...]</span><br id=\"al3-diplomatic\"><span class=\"linenumber\">3</span><span data-text=\"ἰδίου\" data-n=\"30\" data-lemma=\"\">[.]ΔΙΟΥ</span><span data-text=\"ποιήσαντα\" data-n=\"35\" data-lemma=\"\">ΠΟΙΗ.....</span><br id=\"al4-diplomatic\"><span class=\"linenumber\">4</span><span data-text=\"καὶ\" data-n=\"40\" data-lemma=\"\">[.]ΑΙ</span><span data-text=\"τὰς\" data-n=\"45\" data-lemma=\"\">ΤΑΣ</span><span data-text=\"διώρυγας\" data-n=\"50\" data-lemma=\"\">ΔΙΩΡΥΓΑΣ</span><span data-text=\"καὶ τὰν\" data-n=\"55\" data-lemma=\"\">.....[..]</span><br id=\"al5-diplomatic\"><span class=\"linenumber\">5</span><span data-text=\"στρῶσιν\" data-n=\"60\" data-lemma=\"\">[.]ΤΡΩΣΙΝ</span><span data-text=\"τᾶς\" data-n=\"65\" data-lemma=\"\">ΤΑΣ</span><span data-text=\"πλατείας\" data-n=\"70\" data-lemma=\"\">ΠΛΑΤΕΙΑΣ</span><span data-text=\"τὰν\" data-n=\"75\" data-lemma=\"\">ΤΑ[.]</span><br id=\"al6-diplomatic\"><span class=\"linenumber\">6</span><span data-text=\"ἀπὸ\" data-n=\"80\" data-lemma=\"\">[.]ΠΟ</span><span data-text=\"τοῦ\" data-n=\"85\" data-lemma=\"\">ΤΟΥ</span><span data-text=\"λίθου\" data-n=\"90\" data-lemma=\"\">ΛΙΘΟΥ</span><span data-text=\"τοῦ\" data-n=\"95\" data-lemma=\"\">ΤΟΥ</span><br id=\"al7-diplomatic\"><span class=\"linenumber\">7</span><span data-text=\"θηγανείτα\" data-n=\"100\" data-lemma=\"\">ΘΗΓΑΝΕΙΤΑ</span><span data-text=\"ἀπὸ\" data-n=\"105\" data-lemma=\"\">ΑΠΟ</span><span data-text=\"τ